@model IEnumerable<GaziHastane.Models.AdminLog>
@{
    ViewData["Title"] = "Sistem Hareketleri";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="px-4 sm:px-6 lg:px-8 py-8 w-full max-w-9xl mx-auto">
    <div class="mb-8">
        <h1 class="text-2xl md:text-3xl text-white font-bold">Sistem <span class="text-slate-400 font-medium">Hareketleri</span></h1>
        <p class="text-slate-400 text-sm mt-1">Admin panelindeki son 500 iţlem kaydý</p>
    </div>

    <div class="bg-white/5 backdrop-blur-xl shadow-lg rounded-2xl border border-white/10 relative overflow-hidden">
        <header class="px-5 py-4 border-b border-white/10">
            <h2 class="font-semibold text-slate-100">Log Kayýtlarý <span class="text-slate-400 font-medium">(@Model.Count())</span></h2>
        </header>

        <div class="px-5 py-4 border-b border-white/10">
            <form method="get" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-6 gap-3">
                <input type="text" name="kullanici" value="@ViewBag.Kullanici" placeholder="Kullanýcý" class="w-full rounded-lg border border-white/10 bg-white/10 text-slate-100 placeholder:text-slate-400 px-3 py-2" />

                <select name="islemTipi" class="w-full rounded-lg border border-white/10 bg-slate-900 text-slate-100 px-3 py-2">
                    <option value="">Tüm Ýţlem Tipleri</option>
                    @foreach (var tip in (IEnumerable<string>)ViewBag.IslemTipleri)
                    {
                        if ((string?)ViewBag.IslemTipi == tip)
                        {
                            <option value="@tip" selected>@tip</option>
                        }
                        else
                        {
                            <option value="@tip">@tip</option>
                        }
                    }
                </select>

                <select name="modul" class="w-full rounded-lg border border-white/10 bg-slate-900 text-slate-100 px-3 py-2">
                    <option value="">Tüm Modüller</option>
                    @foreach (var m in (IEnumerable<string>)ViewBag.Moduller)
                    {
                        if ((string?)ViewBag.Modul == m)
                        {
                            <option value="@m" selected>@m</option>
                        }
                        else
                        {
                            <option value="@m">@m</option>
                        }
                    }
                </select>

                <input type="date" name="baslangicTarih" value="@ViewBag.BaslangicTarih" class="w-full rounded-lg border border-white/10 bg-slate-900 text-slate-100 px-3 py-2" />
                <input type="date" name="bitisTarih" value="@ViewBag.BitisTarih" class="w-full rounded-lg border border-white/10 bg-slate-900 text-slate-100 px-3 py-2" />

                <div class="flex flex-wrap gap-2">
                    <button type="submit" class="flex-1 min-w-[110px] rounded-lg bg-cyan-500 hover:bg-cyan-600 text-white font-semibold px-3 py-2">Filtrele</button>
                    <button type="submit" formaction="/Admin/SistemLog/ExportExcel" class="flex-1 min-w-[140px] rounded-lg bg-emerald-600 hover:bg-emerald-700 text-white font-semibold px-3 py-2 flex items-center justify-center gap-2">
                        <i class="fa-solid fa-file-excel"></i>
                        Excel'e Aktar
                    </button>
                    <a asp-action="Index" class="flex-1 min-w-[110px] rounded-lg border border-white/20 text-slate-200 text-center px-3 py-2">Temizle</a>
                </div>
            </form>
        </div>

        <div class="p-3">
            <div class="overflow-x-auto">
                <table class="table-auto w-full">
                    <thead class="text-xs font-semibold uppercase text-slate-300 bg-white/5 border-t border-b border-white/10">
                        <tr>
                            <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Tarih</th>
                            <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Kullanýcý</th>
                            <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Ýţlem</th>
                            <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Modül</th>
                            <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Açýklama</th>
                            <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">IP Adresi</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm divide-y divide-white/10 text-slate-200">
                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                var badgeClass = item.IslemTipi switch
                                {
                                    "SÝL" => "bg-rose-500/20 text-rose-300 border border-rose-500/30",
                                    "EKLE" => "bg-emerald-500/20 text-emerald-300 border border-emerald-500/30",
                                    "GÝRÝŢ" => "bg-indigo-500/20 text-indigo-300 border border-indigo-500/30",
                                    _ => "bg-cyan-500/20 text-cyan-200 border border-cyan-500/30"
                                };

                                <tr>
                                    <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-slate-300">@item.Tarih.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap font-medium text-white">@(item.KullaniciAdi ?? "-")</td>
                                    <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap">
                                        <span class="text-xs inline-flex font-semibold rounded-full px-2.5 py-0.5 @badgeClass">@item.IslemTipi</span>
                                    </td>
                                    <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-slate-300">@item.Modul</td>
                                    <td class="px-2 first:pl-5 last:pr-5 py-3 text-slate-200">@item.Aciklama</td>
                                    <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-slate-400">@(item.IpAdresi ?? "-")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="px-2 first:pl-5 last:pr-5 py-6 whitespace-nowrap text-center text-slate-400 font-medium">
                                    Henüz log kaydý bulunmuyor.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

