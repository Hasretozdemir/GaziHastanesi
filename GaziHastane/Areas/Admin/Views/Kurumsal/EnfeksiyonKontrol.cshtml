@model List<GaziHastane.Models.KurumsalIcerik>
@{
    ViewData["Title"] = "Enfeksiyon Kontrol Yönetimi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var Sekmeler = ViewBag.Sekmeler as List<GaziHastane.Models.KurumsalSekme> ?? new List<GaziHastane.Models.KurumsalSekme>();
}

<div class="max-w-6xl mx-auto mt-8 relative space-y-6">

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-teal-500 to-cyan-600 flex items-center justify-center shadow-[0_0_20px_rgba(20,184,166,0.4)]">
                <i class="fa-solid fa-bacterium text-white text-2xl"></i>
            </div>
            <div>
                <h2 class="text-2xl font-black text-transparent bg-clip-text bg-gradient-to-r from-white to-teal-200">Enfeksiyon Kontrol</h2>
                <p class="text-sm text-teal-200/60 mt-1">Sekme ekle ve sekme içeriğine kod/HTML ekleyin.</p>
            </div>
        </div>

        <div class="flex gap-2 bg-slate-800/50 p-1.5 rounded-xl border border-teal-500/20">
            <button onclick="switchTab('tab-icerik', this)" class="tab-btn active px-5 py-2.5 rounded-lg text-sm font-bold bg-teal-500/20 text-teal-300 transition-all">İçerik Listesi</button>
            <button onclick="switchTab('tab-Sekmeler', this)" class="tab-btn px-5 py-2.5 rounded-lg text-sm font-bold text-slate-400 hover:text-white transition-all">Sekmeler</button>
        </div>
    </div>

    <div id="tab-Sekmeler" class="tab-content hidden">
        <div class="glass-card bg-slate-900/60 backdrop-blur-2xl border border-teal-500/20 rounded-3xl p-6 shadow-2xl relative overflow-hidden">
            <div class="flex justify-between items-center mb-6 border-b border-teal-500/10 pb-4">
                <h3 class="text-lg font-bold text-white"><i class="fa-solid fa-folder-tree text-teal-400 mr-2"></i>Sekmeler</h3>
                <button type="button" onclick="openSekmeModal()" class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-gradient-to-r from-teal-600 to-cyan-600 hover:from-teal-500 hover:to-cyan-500 text-white font-bold shadow-lg transition-all">
                    <i class="fa-solid fa-plus"></i> Yeni Sekme
                </button>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="text-slate-400 border-b border-teal-500/20">
                            <th class="text-left py-3 px-3 font-semibold">Başlık</th>
                            <th class="text-left py-3 px-3 font-semibold">Sekme ID</th>
                            <th class="text-left py-3 px-3 font-semibold">İkon</th>
                            <th class="text-center py-3 px-3 font-semibold">Sıra</th>
                            <th class="text-center py-3 px-3 font-semibold">Durum</th>
                            <th class="text-right py-3 px-3 font-semibold">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Sekmeler)
                        {
                            <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
                                <td class="py-3 px-3 text-white font-semibold">@item.Baslik</td>
                                <td class="py-3 px-3 text-slate-300">@item.SekmeId</td>
                                <td class="py-3 px-3 text-slate-300">@item.IconClass</td>
                                <td class="py-3 px-3 text-center"><span class="bg-slate-800 border border-slate-700 rounded-md px-2 py-1 text-slate-300 text-xs">@item.Sira</span></td>
                                <td class="py-3 px-3 text-center">
                                    @if (item.AktifMi)
                                    {
                                        <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 inline-block"></span>
                                    }
                                    else
                                    {
                                        <span class="w-2.5 h-2.5 rounded-full bg-rose-500 inline-block opacity-50"></span>
                                    }
                                </td>
                                <td class="py-3 px-3 text-right">
                                    <div class="inline-flex gap-2">
                                        <button type="button"
                                                data-id="@item.Id" data-baslik="@item.Baslik" data-sekmeid="@item.SekmeId"
                                                data-icon="@item.IconClass" data-sira="@item.Sira" data-aktif="@(item.AktifMi ? "true" : "false")"
                                                onclick="openSekmeModal(this)"
                                                class="inline-flex items-center text-xs px-3 py-1.5 rounded-lg bg-blue-500/10 border border-blue-500/20 text-blue-400 hover:bg-blue-500/30 transition-all">
                                            <i class="fa-solid fa-pen-to-square mr-1.5"></i> Düzenle
                                        </button>
                                        <form asp-action="KurumsalSekmeSil" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="button" onclick="confirmDelete(this.closest('form'))" class="inline-flex items-center text-xs px-3 py-1.5 rounded-lg bg-rose-500/10 border border-rose-500/20 text-rose-400 hover:bg-rose-500/30 transition-all">
                                                <i class="fa-solid fa-trash-can mr-1.5"></i> Sil
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="flex items-center gap-4 rounded-2xl border border-emerald-500/30 bg-emerald-500/10 px-6 py-4 backdrop-blur-xl relative overflow-hidden">
            <div class="absolute top-0 left-0 w-1.5 h-full bg-emerald-500"></div>
            <i class="fa-solid fa-check-circle text-emerald-400 text-xl"></i>
            <div><h4 class="text-emerald-400 text-sm font-bold">Başarılı</h4><p class="text-emerald-100/90 text-sm">@TempData["Success"]</p></div>
        </div>
    }

    <div id="sekmeModal" class="fixed inset-0 z-[105] hidden items-center justify-center bg-black/60 backdrop-blur-sm transition-opacity opacity-0 duration-300">
        <div id="sekmeModalContent" class="glass-card bg-slate-900/95 border border-teal-500/30 rounded-3xl p-8 max-w-xl w-full shadow-[0_0_50px_rgba(20,184,166,0.15)] transform scale-90 transition-transform duration-300 max-h-[90vh] overflow-y-auto custom-scroll">

            <div class="flex justify-between items-center mb-6 border-b border-teal-500/10 pb-4">
                <h3 id="sekmeModalTitle" class="text-2xl font-black text-white">Yeni Sekme Ekle</h3>
                <button type="button" onclick="closeSekmeModal()" class="text-slate-400 hover:text-white"><i class="fa-solid fa-xmark text-xl"></i></button>
            </div>

            <form asp-action="KurumsalSekmeKaydet" method="post" class="space-y-5">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="sekmeId" value="0" />

                <div>
                    <label class="block text-sm font-semibold text-teal-100 mb-2">Başlık *</label>
                    <input type="text" name="Baslik" id="sekmeBaslik" class="w-full rounded-xl bg-slate-800/50 border border-teal-500/20 p-3 text-white focus:ring-2 focus:ring-teal-500/50" required />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-teal-100 mb-2">Sekme ID (Örn: misyon-vizyon) *</label>
                    <input type="text" name="SekmeId" id="sekmeKey" class="w-full rounded-xl bg-slate-800/50 border border-teal-500/20 p-3 text-white focus:ring-2 focus:ring-teal-500/50" required />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-teal-100 mb-2">İkon Sınıfı</label>
                    <input type="text" name="IconClass" id="sekmeIcon" class="w-full rounded-xl bg-slate-800/50 border border-teal-500/20 p-3 text-white focus:ring-2 focus:ring-teal-500/50" placeholder="fa-solid fa-bullseye" />
                </div>
                <div class="grid md:grid-cols-2 gap-5">
                    <div>
                        <label class="block text-sm font-semibold text-teal-100 mb-2">Sıralama</label>
                        <input type="number" name="Sira" id="sekmeSira" value="99" class="w-full rounded-xl bg-slate-800/50 border border-teal-500/20 p-3 text-white focus:ring-2 focus:ring-teal-500/50" />
                    </div>
                    <div class="flex items-center gap-3 bg-slate-800/30 border border-emerald-500/20 rounded-xl p-3 mt-7">
                        <input type="checkbox" name="AktifMi" id="sekmeAktif" value="true" checked class="w-5 h-5 accent-emerald-500 cursor-pointer" />
                        <label class="text-sm font-bold text-emerald-400 cursor-pointer" for="sekmeAktif">Sitede Yayınla</label>
                    </div>
                </div>

                <input type="hidden" name="SayfaKey" value="EnfeksiyonKontrol" />

                <div class="flex gap-3 pt-6 border-t border-teal-500/10">
                    <button type="button" onclick="closeSekmeModal()" class="flex-1 py-3 rounded-xl bg-slate-800 hover:bg-slate-700 text-slate-300 font-bold transition-all">İptal</button>
                    <button type="submit" class="flex-1 py-3 rounded-xl bg-gradient-to-r from-teal-600 to-cyan-600 text-white font-bold shadow-lg transition-all">Kaydet</button>
                </div>
            </form>
        </div>
    </div>

    <div id="tab-icerik" class="tab-content block">
        <div class="glass-card bg-slate-900/60 backdrop-blur-2xl border border-teal-500/20 rounded-3xl p-6 shadow-2xl relative overflow-hidden">

            <div class="flex justify-between items-center mb-6 border-b border-teal-500/10 pb-4">
                <h3 class="text-lg font-bold text-white"><i class="fa-solid fa-list text-teal-400 mr-2"></i>Eklenen İçerikler</h3>
                <button type="button" onclick="openIcerikModal()" class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-gradient-to-r from-teal-600 to-cyan-600 hover:from-teal-500 hover:to-cyan-500 text-white font-bold shadow-lg transition-all">
                    <i class="fa-solid fa-plus"></i> Yeni Ekle
                </button>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="text-slate-400 border-b border-teal-500/20">
                            <th class="text-left py-3 px-3 font-semibold">Kategori</th>
                            <th class="text-left py-3 px-3 font-semibold">İçerik Kimliği</th>
                            <th class="text-center py-3 px-3 font-semibold">Sıra</th>
                            <th class="text-center py-3 px-3 font-semibold">Durum</th>
                            <th class="text-right py-3 px-3 font-semibold">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
                                <td class="py-3 px-3"><span class="bg-teal-500/20 text-teal-400 border border-teal-500/30 px-3 py-1 rounded-lg text-xs font-bold">@item.Kategori</span></td>
                                <td class="py-3 px-3"><p class="text-white font-bold">İçerik #@item.Id</p></td>
                                <td class="py-3 px-3 text-center"><span class="bg-slate-800 border border-slate-700 rounded-md px-2 py-1 text-slate-300 text-xs">@item.Sira</span></td>
                                <td class="py-3 px-3 text-center">
                                    @if (item.AktifMi)
                                    {
                                        <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 inline-block"></span>
                                    }
                                    else
                                    {
                                        <span class="w-2.5 h-2.5 rounded-full bg-rose-500 inline-block opacity-50"></span>
                                    }
                                </td>
                                <td class="py-3 px-3 text-right">
                                    <div class="inline-flex gap-2">
                                        <button type="button"
                                                data-id="@item.Id" data-kategori="@item.Kategori" data-baslik="@item.Baslik"
                                                data-altbaslik="@item.AltBaslik" data-aciklama="@item.Aciklama" data-medya="@item.MedyaYolu"
                                                data-sira="@item.Sira" data-aktif="@(item.AktifMi ? "true" : "false")"
                                                onclick="openIcerikModal(this)"
                                                class="inline-flex items-center text-xs px-3 py-1.5 rounded-lg bg-blue-500/10 border border-blue-500/20 text-blue-400 hover:bg-blue-500/30 transition-all">
                                            <i class="fa-solid fa-pen-to-square mr-1.5"></i> Düzenle
                                        </button>

                                        <form asp-action="KurumsalIcerikSil" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="button" onclick="confirmDelete(this.closest('form'))" class="inline-flex items-center text-xs px-3 py-1.5 rounded-lg bg-rose-500/10 border border-rose-500/20 text-rose-400 hover:bg-rose-500/30 transition-all">
                                                <i class="fa-solid fa-trash-can mr-1.5"></i> Sil
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

<!-- Modal: İçerik -->
<div id="icerikModal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/60 backdrop-blur-sm transition-opacity opacity-0 duration-300">
    <div id="icerikModalContent" class="glass-card bg-slate-900/95 border border-teal-500/30 rounded-3xl p-8 max-w-6xl w-full shadow-[0_0_50px_rgba(20,184,166,0.15)] transform scale-90 transition-transform duration-300 max-h-[90vh] overflow-y-auto custom-scroll">

        <div class="flex justify-between items-center mb-6 border-b border-teal-500/10 pb-4">
            <h3 id="modalTitle" class="text-2xl font-black text-white">Yeni İçerik Ekle</h3>
            <button type="button" onclick="closeIcerikModal()" class="text-slate-400 hover:text-white"><i class="fa-solid fa-xmark text-xl"></i></button>
        </div>

        <form asp-action="KurumsalIcerikKaydet" method="post" enctype="multipart/form-data" class="space-y-5">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="modId" value="0" />
            <input type="hidden" name="SayfaKey" value="EnfeksiyonKontrol" />

            <div class="grid gap-6 xl:grid-cols-[minmax(0,1.1fr)_minmax(320px,0.9fr)] items-start">
                <div class="space-y-5">
                    <div>
                        <label class="block text-sm font-bold text-teal-300 mb-2">Hangi Sekmede Gösterilsin? *</label>
                        <select name="Kategori" id="modKat" class="w-full rounded-xl bg-slate-800 border border-teal-500/40 p-3 text-white focus:ring-2 focus:ring-teal-500/50" required>
                            <option value="">-- Seçiniz --</option>
                            @foreach (var sekme in Sekmeler)
                            {
                                <option value="@sekme.SekmeId">@sekme.Baslik</option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-teal-100 mb-2">Sayfa İçeriği (Kod / HTML)</label>
                        <textarea name="Aciklama" id="modAciklama" rows="18" class="w-full rounded-xl bg-slate-800/50 border border-teal-500/20 p-3 text-white focus:ring-2 focus:ring-teal-500/50 tiny-editor"></textarea>
                    </div>

                    <div class="grid md:grid-cols-2 gap-5">
                        <div>
                            <label class="block text-sm font-semibold text-teal-100 mb-2">Sıralama</label>
                            <input type="number" name="Sira" id="modSira" value="99" class="w-full rounded-xl bg-slate-800/50 border border-teal-500/20 p-3 text-white focus:ring-2 focus:ring-teal-500/50" />
                        </div>
                        <div class="flex items-center gap-3 bg-slate-800/30 border border-emerald-500/20 rounded-xl p-3 mt-7">
                            <input type="checkbox" name="AktifMi" id="modAktif" value="true" checked class="w-5 h-5 accent-emerald-500 cursor-pointer" />
                            <label class="text-sm font-bold text-emerald-400 cursor-pointer" for="modAktif">Sitede Yayınla</label>
                        </div>
                    </div>
                </div>

                <div class="md:col-span-2">
                    <label class="block text-sm font-semibold text-teal-100 mb-2">Dosya Yükle (Opsiyonel)</label>
                    <input type="file" name="FormDosyasi" id="formFile" accept=".pdf,.doc,.docx,.png,.jpg,.jpeg,.webp" class="block w-full text-sm text-slate-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-emerald-600 file:text-white hover:file:bg-emerald-700 file:cursor-pointer" />
                    <p id="formFileInfo" class="text-xs text-emerald-300 mt-1"></p>
                </div>
            </div>

            <div class="flex gap-3 pt-6 border-t border-teal-500/10">
                <button type="button" onclick="closeIcerikModal()" class="flex-1 py-3 rounded-xl bg-slate-800 hover:bg-slate-700 text-slate-300 font-bold transition-all">İptal</button>
                <button type="submit" class="flex-1 py-3 rounded-xl bg-gradient-to-r from-teal-600 to-cyan-600 text-white font-bold shadow-lg transition-all">Kaydet</button>
            </div>
        </form>
    </div>
</div>

<div id="deleteModal" class="fixed inset-0 z-[110] hidden items-center justify-center bg-black/60 backdrop-blur-sm transition-opacity opacity-0 duration-300">
    <div id="deleteModalContent" class="glass-card bg-slate-900/90 border border-rose-500/30 rounded-3xl p-8 max-w-sm w-full shadow-[0_0_50px_rgba(225,29,72,0.15)] transform scale-90 transition-transform duration-300 text-center">
        <div class="w-20 h-20 rounded-full bg-rose-500/10 flex items-center justify-center mx-auto mb-5 border-[4px] border-rose-500/20"><i class="fa-solid fa-triangle-exclamation text-4xl text-rose-500"></i></div>
        <h3 class="text-xl font-black text-white mb-2">Emin misiniz?</h3>
        <p class="text-slate-300 text-sm mb-6">Bu işlem geri alınamaz.</p>
        <div class="flex gap-3">
            <button type="button" onclick="closeDeleteModal()" class="flex-1 py-3 rounded-xl bg-slate-800 hover:bg-slate-700 text-slate-300 font-bold">Vazgeç</button>
            <button id="confirmDelBtn" type="button" class="flex-1 py-3 rounded-xl bg-gradient-to-r from-rose-600 to-red-600 text-white font-bold">Sil</button>
        </div>
    </div>
</div>

<script>
    // Tab and modal scripts (adapted from HemsirelikHizmetleri)
    function switchTab(tabId, btn) {
        document.querySelectorAll('.tab-content').forEach(tc => { tc.classList.remove('block'); tc.classList.add('hidden'); });
        document.querySelectorAll('.tab-btn').forEach(tb => { tb.classList.remove('bg-teal-500/20','text-teal-300'); tb.classList.add('text-slate-400'); });
        document.getElementById(tabId).classList.remove('hidden');
        document.getElementById(tabId).classList.add('block');
        btn.classList.add('bg-teal-500/20','text-teal-300'); btn.classList.remove('text-slate-400');
    }

    // Modal helper functions
    const mod = document.getElementById('icerikModal');
    const modContent = document.getElementById('icerikModalContent');
    function openIcerikModal(btnData = null) {
        if(btnData) {
            document.getElementById('modalTitle').innerText = "İçeriği Güncelle";
            document.getElementById('modId').value = btnData.getAttribute('data-id');
            document.getElementById('modKat').value = btnData.getAttribute('data-kategori');
            document.getElementById('modAciklama').value = btnData.getAttribute('data-aciklama');
            document.getElementById('modSira').value = btnData.getAttribute('data-sira');
            document.getElementById('modAktif').checked = btnData.getAttribute('data-aktif') === 'true';
        } else {
            document.getElementById('modalTitle').innerText = "Yeni İçerik Ekle";
            document.getElementById('modId').value = "0";
            document.getElementById('modKat').value = "";
            document.getElementById('modAciklama').value = '';
            document.getElementById('modSira').value = "99";
            document.getElementById('modAktif').checked = true;
        }
        mod.classList.remove('hidden'); mod.classList.add('flex');
        setTimeout(() => { mod.classList.remove('opacity-0'); modContent.classList.remove('scale-90'); modContent.classList.add('scale-100'); }, 10);
    }
    function closeIcerikModal() { mod.classList.add('opacity-0'); modContent.classList.remove('scale-100'); modContent.classList.add('scale-90'); setTimeout(() => { mod.classList.add('hidden'); mod.classList.remove('flex'); }, 300); }

    const sekmeModal = document.getElementById('sekmeModal');
    const sekmeModalContent = document.getElementById('sekmeModalContent');
    function openSekmeModal(btnData = null) {
        if (btnData) {
            document.getElementById('sekmeModalTitle').innerText = "Sekmeyi Güncelle";
            document.getElementById('sekmeId').value = btnData.getAttribute('data-id');
            document.getElementById('sekmeBaslik').value = btnData.getAttribute('data-baslik');
            document.getElementById('sekmeKey').value = btnData.getAttribute('data-sekmeid');
            document.getElementById('sekmeIcon').value = btnData.getAttribute('data-icon');
            document.getElementById('sekmeSira').value = btnData.getAttribute('data-sira');
            document.getElementById('sekmeAktif').checked = btnData.getAttribute('data-aktif') === 'true';
        } else {
            document.getElementById('sekmeModalTitle').innerText = "Yeni Sekme Ekle";
            document.getElementById('sekmeId').value = "0";
            document.getElementById('sekmeBaslik').value = "";
            document.getElementById('sekmeKey').value = "";
            document.getElementById('sekmeIcon').value = "";
            document.getElementById('sekmeSira').value = "99";
            document.getElementById('sekmeAktif').checked = true;
        }
        sekmeModal.classList.remove('hidden'); sekmeModal.classList.add('flex');
        setTimeout(() => { sekmeModal.classList.remove('opacity-0'); sekmeModalContent.classList.remove('scale-90'); sekmeModalContent.classList.add('scale-100'); }, 10);
    }
    function closeSekmeModal() { sekmeModal.classList.add('opacity-0'); sekmeModalContent.classList.remove('scale-100'); sekmeModalContent.classList.add('scale-90'); setTimeout(() => { sekmeModal.classList.add('hidden'); sekmeModal.classList.remove('flex'); }, 300); }

    // Delete modal
    let formToSubmit = null;
    const delMod = document.getElementById('deleteModal');
    const delModContent = document.getElementById('deleteModalContent');
    function confirmDelete(form) { formToSubmit = form; delMod.classList.remove('hidden'); delMod.classList.add('flex'); setTimeout(() => { delMod.classList.remove('opacity-0'); delModContent.classList.remove('scale-90'); delModContent.classList.add('scale-100'); }, 10); }
    function closeDeleteModal() { delMod.classList.add('opacity-0'); delModContent.classList.remove('scale-100'); delModContent.classList.add('scale-90'); setTimeout(() => { delMod.classList.add('hidden'); delMod.classList.remove('flex'); }, 300); }
    document.getElementById('confirmDelBtn').addEventListener('click', function() { if(formToSubmit) formToSubmit.submit(); });

    // File input info
    const fileInput = document.getElementById('formFile');
    if (fileInput) {
        fileInput.addEventListener('change', function(e) {
            const fileInfo = document.getElementById('formFileInfo');
            if (e.target.files.length > 0) {
                const file = e.target.files[0];
                const maxSize = 50 * 1024 * 1024;
                if (file.size > maxSize) { fileInfo.textContent = '❌ Dosya çok büyük (Max 50MB)'; fileInfo.style.color = '#ef4444'; e.target.value = ''; }
                else { fileInfo.textContent = `✓ ${file.name} (${(file.size/1024/1024).toFixed(2)} MB)`; fileInfo.style.color = '#10b981'; }
            } else { fileInfo.textContent = ''; }
        });
    }
</script>

