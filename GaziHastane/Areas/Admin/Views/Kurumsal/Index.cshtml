@model List<GaziHastane.Models.KurumsalMenu>
@using GaziHastane.Models
@{
    ViewData["Title"] = "Kurumsal Menü Yönetimi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var gruplar = ViewBag.Gruplar as List<KurumsalMenuGrup> ?? new List<KurumsalMenuGrup>();
}

<div class="space-y-6 relative">
    <div class="flex items-center justify-between">
        <h2 class="text-2xl font-black text-white">Kurumsal Sidebar Yönetimi</h2>
        <div class="flex gap-2">
            <a href="/Admin/Kurumsal/GrupForm" class="px-4 py-2 rounded-xl bg-indigo-500/20 border border-indigo-500/40 text-indigo-300 hover:bg-indigo-500/30 transition-colors text-sm font-bold">+ Grup Ekle</a>
            <a href="/Admin/Kurumsal/MenuForm" class="px-4 py-2 rounded-xl bg-cyan-500/20 border border-cyan-500/40 text-cyan-300 hover:bg-cyan-500/30 transition-colors text-sm font-bold">+ Menü Ekle</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="flex items-center gap-4 rounded-2xl border border-emerald-500/30 bg-gradient-to-r from-emerald-900/40 to-slate-900/40 px-6 py-4 shadow-[0_0_20px_rgba(16,185,129,0.15)] backdrop-blur-xl relative overflow-hidden">
            <div class="absolute top-0 left-0 w-1.5 h-full bg-emerald-500 shadow-[0_0_10px_rgba(16,185,129,0.8)]"></div>
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-emerald-500/20 flex items-center justify-center border border-emerald-500/30 shadow-inner">
                <i class="fa-solid fa-check text-emerald-400 text-lg"></i>
            </div>
            <div>
                <h4 class="text-emerald-400 text-sm font-bold tracking-wide mb-0.5">Baţarýlý Ýţlem</h4>
                <p class="text-emerald-100/90 text-sm">@TempData["Success"]</p>
            </div>
        </div>
    }

    <div class="grid md:grid-cols-3 gap-4">
        <div class="glass-card rounded-2xl p-5">
            <h3 class="font-bold text-indigo-300 mb-3">Gruplar</h3>
            <div class="space-y-2 max-h-96 overflow-auto pr-2">
                @foreach (var item in gruplar)
                {
                    <div class="bg-slate-900/40 rounded-xl p-3 border border-white/5 transition-colors hover:border-white/10">
                        <p class="font-bold text-white text-sm">@item.GrupAdi</p>
                        <p class="text-xs text-slate-400 mb-2">Sýra: @item.Sira · @(item.AktifMi ? "Aktif" : "Pasif")</p>
                        <div class="flex gap-2 mt-2 pt-2 border-t border-white/5">
                            <a href="/Admin/Kurumsal/GrupForm/@item.Id" class="text-xs px-3 py-1.5 rounded-lg bg-white/10 text-slate-300 hover:bg-white/20 hover:text-white transition-colors">Düzenle</a>
                            <form method="post" asp-action="GrupSil" class="inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="button" onclick="confirmDelete(this.closest('form'))" class="text-xs px-3 py-1.5 rounded-lg bg-rose-500/20 text-rose-300 hover:bg-rose-500/40 hover:text-rose-100 transition-colors">
                                    <i class="fa-solid fa-trash-can mr-1"></i> Sil
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="md:col-span-2 glass-card rounded-2xl p-5">
            <h3 class="font-bold text-cyan-300 mb-3">Menüler</h3>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="text-slate-400 border-b border-white/10">
                            <th class="text-left py-3 px-2">Baţlýk</th>
                            <th class="text-left py-3 px-2">URL</th>
                            <th class="text-left py-3 px-2">Grup</th>
                            <th class="text-left py-3 px-2">Sýra</th>
                            <th class="text-right py-3 px-2">Ýţlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="border-b border-white/5 hover:bg-white/5 transition-colors group">
                                <td class="py-3 px-2 text-white font-semibold">@item.Baslik</td>
                                <td class="py-3 px-2 text-slate-300">@item.Url</td>
                                <td class="py-3 px-2 text-slate-300">@item.Grup?.GrupAdi</td>
                                <td class="py-3 px-2 text-slate-300">
                                    <span class="bg-slate-800 border border-slate-700 rounded px-2 py-1 text-xs">@item.Sira</span>
                                </td>
                                <td class="py-3 px-2 text-right">
                                    <div class="inline-flex gap-2">
                                        <a href="/Admin/Kurumsal/MenuForm/@item.Id" class="text-xs px-3 py-1.5 rounded-lg bg-white/10 text-slate-300 hover:bg-white/20 hover:text-white transition-colors">Düzenle</a>
                                        <form method="post" asp-action="MenuSil" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="button" onclick="confirmDelete(this.closest('form'))" class="text-xs px-3 py-1.5 rounded-lg bg-rose-500/20 text-rose-300 hover:bg-rose-500/40 hover:text-rose-100 transition-colors">
                                                <i class="fa-solid fa-trash-can mr-1"></i> Sil
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div id="customDeleteModal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/60 backdrop-blur-sm transition-opacity opacity-0 duration-300">
    <div id="customDeleteModalContent" class="glass-card bg-slate-900/90 border border-rose-500/30 rounded-3xl p-8 max-w-sm w-full shadow-[0_0_50px_rgba(225,29,72,0.15)] transform scale-90 transition-transform duration-300">
        <div class="flex flex-col items-center text-center">

            <div class="w-20 h-20 rounded-full bg-rose-500/10 flex items-center justify-center mb-5 border-[4px] border-rose-500/20 relative">
                <i class="fa-solid fa-triangle-exclamation text-4xl text-rose-500 relative z-10"></i>
                <div class="absolute inset-0 bg-rose-500/20 blur-xl rounded-full"></div>
            </div>

            <h3 class="text-2xl font-black text-white mb-2">Emin misiniz?</h3>
            <p class="text-slate-300 text-sm mb-8 leading-relaxed">
                Bu kaydý tamamen silmek üzeresiniz. Bu iţlem <b>geri alýnamaz</b> ve iliţkili sayfalar hastane web sitesinden kaldýrýlýr.
            </p>

            <div class="flex gap-3 w-full">
                <button type="button" onclick="closeDeleteModal()" class="flex-1 py-3 rounded-xl bg-slate-800 hover:bg-slate-700 border border-slate-600 text-slate-300 hover:text-white font-semibold transition-colors">
                    Vazgeç
                </button>
                <button id="confirmBtn" type="button" class="flex-1 py-3 rounded-xl bg-gradient-to-r from-rose-600 to-red-600 hover:from-rose-500 hover:to-red-500 text-white font-bold shadow-lg shadow-rose-500/30 hover:shadow-rose-500/50 hover:-translate-y-0.5 transition-all flex items-center justify-center gap-2">
                    <i class="fa-solid fa-trash-can"></i> Evet, Sil
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    let formToSubmit = null;
    const modal = document.getElementById('customDeleteModal');
    const modalContent = document.getElementById('customDeleteModalContent');

    // Modalý Açan Fonksiyon
    function confirmDelete(form) {
        formToSubmit = form;

        // Önce display:flex yapýp görünür kýlýyoruz
        modal.classList.remove('hidden');
        modal.classList.add('flex');

        // Küçük bir gecikme ile animasyonlarý (opacity ve scale) tetikliyoruz
        setTimeout(() => {
            modal.classList.remove('opacity-0');
            modalContent.classList.remove('scale-90');
            modalContent.classList.add('scale-100');
        }, 10);
    }

    // Modalý Kapatan Fonksiyon
    function closeDeleteModal() {
        // Önce animasyonlarý geri alýyoruz
        modal.classList.add('opacity-0');
        modalContent.classList.remove('scale-100');
        modalContent.classList.add('scale-90');

        // Animasyon bittikten sonra display:none yapýyoruz
        setTimeout(() => {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            formToSubmit = null;
        }, 300); // 300ms tailwind transition süresi
    }

    // Evet Sil butonuna týklandýđýnda
    document.getElementById('confirmBtn').addEventListener('click', function() {
        if(formToSubmit) {
            // Ýsteđe bađlý: Butonun içine loading ikonu koyabiliriz
            this.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Siliniyor...';
            this.classList.add('opacity-80', 'cursor-not-allowed');
            formToSubmit.submit(); // Formu gönder (Veritabanýndan silme iţlemi)
        }
    });
</script>