@model List<GaziHastane.Models.KurumsalSekme>
@{
    var sayfaKey = ViewBag.SayfaKey as string ?? "genel";
    var sayfaBaslik = ViewBag.SayfaBaslik as string ?? "Kurumsal Ä°Ă§erik";
}

<div class="max-w-2xl mx-auto mt-8 relative space-y-6">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div class="flex items-center gap-4">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-teal-500 to-cyan-600 flex items-center justify-center shadow-[0_0_20px_rgba(20,184,166,0.4)]">
                <i class="fa-solid fa-building-columns text-white text-3xl"></i>
            </div>
            <div>
                <h2 class="text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-white to-teal-200">@sayfaBaslik</h2>
                <p class="text-slate-400 font-medium">Sayfa sekmelerini ve iĂ§eriklerini buradan yĂ¶netebilirsiniz.</p>
            </div>
        </div>
    </div>

    <!-- Main Content Card -->
    <div class="glass-card bg-slate-900/40 border border-white/10 rounded-[2.5rem] p-8 backdrop-blur-xl shadow-2xl relative overflow-hidden min-h-[500px]">
        <div class="absolute top-0 right-0 w-64 h-64 bg-teal-500/5 blur-[100px] -z-10"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-cyan-500/5 blur-[100px] -z-10"></div>

        <div class="flex justify-between items-center mb-8">
            <div class="flex items-center gap-3">
                <i class="fa-solid fa-layer-group text-teal-400 text-xl"></i>
                <h3 class="text-xl font-bold text-white">Mevcut Sekmeler</h3>
            </div>
            <button type="button" onclick="openSekmeModal()" class="group relative px-6 py-3 bg-gradient-to-r from-teal-600 to-cyan-600 rounded-2xl font-bold text-white shadow-lg hover:shadow-teal-500/20 transition-all active:scale-95">
                <span class="flex items-center gap-2"><i class="fa-solid fa-plus text-lg"></i> Yeni Sekme Ekle</span>
            </button>
        </div>

        <div class="overflow-x-auto custom-scroll">
            <table class="w-full text-left border-separate border-spacing-y-3">
                <thead>
                    <tr class="text-slate-400 text-xs uppercase tracking-widest font-black">
                        <th class="pb-2 px-4">BaĹźlÄ±k</th>
                        <th class="pb-2 px-4">Sekme ID</th>
                        <th class="pb-2 px-4 text-center">Icon</th>
                        <th class="pb-2 px-4 text-center">SÄ±ra</th>
                        <th class="pb-2 px-4 text-center">Durum</th>
                        <th class="pb-2 px-4 text-right">Ä°Ĺźlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr class="group bg-white/5 hover:bg-white/10 border border-white/5 rounded-2xl transition-all duration-300">
                                <td class="py-4 px-4 rounded-l-2xl font-bold text-white">@item.Baslik</td>
                                <td class="py-4 px-4 text-slate-400 font-mono text-sm">@item.SekmeId</td>
                                <td class="py-4 px-4 text-center">
                                    <i class="@(item.IconClass ?? "fa-solid fa-circle") text-teal-400 text-lg"></i>
                                </td>
                                <td class="py-4 px-4 text-center">
                                    <span class="bg-slate-800 text-slate-400 text-xs px-2 py-1 rounded-lg border border-slate-700">@item.Sira</span>
                                </td>
                                <td class="py-4 px-4 text-center">
                                    <div class="flex justify-center">
                                        @if (item.AktifMi) { <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 shadow-[0_0_10px_rgba(16,185,129,0.5)]"></span> }
                                        else { <span class="w-2.5 h-2.5 rounded-full bg-rose-500 opacity-50"></span> }
                                    </div>
                                </td>
                                <td class="py-4 px-4 text-right rounded-r-2xl">
                                    <div class="flex justify-end gap-2">
                                        <button type="button" onclick="openSekmeModal(this)"
                                                data-id="@item.Id" data-baslik="@item.Baslik" data-sekmeid="@item.SekmeId"
                                                data-icon="@item.IconClass" data-sira="@item.Sira" data-aktif="@(item.AktifMi ? "true" : "false")"
                                                data-icerik="@item.Icerik"
                                                class="p-2.5 rounded-xl bg-blue-500/10 border border-blue-500/20 text-blue-400 hover:bg-blue-50 hover:text-white transition-all shadow-sm">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </button>
                                        <form asp-action="KurumsalSekmeSil" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="button" onclick="confirmDelete(this.closest('form'))"
                                                    class="p-2.5 rounded-xl bg-rose-500/10 border border-rose-500/20 text-rose-400 hover:bg-rose-500 hover:text-white transition-all shadow-sm">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-12 text-slate-500 italic">HenĂĽz sekme eklenmemiĹź.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Sekme ModalÄ± -->
<div id="sekmeModal" class="fixed inset-0 z-[105] hidden items-center justify-center bg-black/60 backdrop-blur-sm transition-opacity opacity-0 duration-300 p-4">
    <div id="sekmeModalContent" class="glass-card bg-slate-900/95 border border-teal-500/30 rounded-[2rem] p-8 max-w-4xl w-full shadow-[0_0_50px_rgba(20,184,166,0.15)] transform scale-90 transition-transform duration-300 max-h-[95vh] overflow-y-auto custom-scroll">
        <div class="flex justify-between items-center mb-6 border-b border-teal-500/10 pb-4">
            <h3 id="modalTitle" class="text-2xl font-black text-white">Yeni Sekme Ekle</h3>
            <button type="button" onclick="closeSekmeModal()" class="text-slate-400 hover:text-white transition-colors"><i class="fa-solid fa-xmark text-2xl"></i></button>
        </div>

        <form asp-action="KurumsalSekmeKaydet" method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="modId" value="0" />
            <input type="hidden" name="SayfaKey" value="@sayfaKey" />
            <input type="hidden" name="SekmeId" id="modSekmeId" />

            <div class="grid md:grid-cols-2 gap-5">
                            <div class="space-y-1.5">
                <label class="block text-sm font-bold text-teal-100/70 ml-1">Sekme Ýçeriđi (HTML)</label>
                <textarea name="Icerik" id="modIcerik" rows="10" class="w-full rounded-2xl bg-slate-800/50 border border-teal-500/20 p-4 text-white focus:ring-2 focus:ring-teal-500/50 outline-none transition-all tiny-editor"></textarea>
            </div>

            <div class="flex items-center justify-between">
                <label class="flex items-center gap-3 bg-slate-800/50 border border-teal-500/20 rounded-2xl px-6 py-4 cursor-pointer hover:bg-slate-800 transition-all">
                    <input type="checkbox" name="AktifMi" id="modAktif" value="true" checked class="w-5 h-5 accent-teal-500" />
                    <span class="text-sm font-bold text-teal-400">Bu Sekme Aktif</span>
                </label>

                <div class="flex gap-4">
                    <button type="button" onclick="closeSekmeModal()" class="px-8 py-4 rounded-2xl bg-slate-800 text-slate-400 font-bold hover:bg-slate-700 transition-all">Ä°ptal</button>
                    <button type="submit" class="px-12 py-4 rounded-2xl bg-gradient-to-r from-teal-600 to-cyan-600 text-white font-black shadow-lg hover:shadow-teal-500/20 transition-all active:scale-95">KAYDET</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Silme ModalÄ± -->
<div id="deleteModal" class="fixed inset-0 z-[110] hidden items-center justify-center bg-black/60 backdrop-blur-sm transition-opacity opacity-0 duration-300 p-4">
    <div id="deleteModalContent" class="glass-card bg-slate-900/95 border border-rose-500/30 rounded-[2.5rem] p-10 max-w-sm w-full shadow-[0_0_50px_rgba(225,29,72,0.2)] transform scale-90 transition-transform duration-300 text-center">
        <div class="w-24 h-24 rounded-full bg-rose-500/10 flex items-center justify-center mx-auto mb-6 border-[4px] border-rose-500/20">
            <i class="fa-solid fa-triangle-exclamation text-5xl text-rose-500"></i>
        </div>
        <h3 class="text-2xl font-black text-white mb-3">Emin misiniz?</h3>
        <p class="text-slate-400 font-medium mb-8">Bu sekme ve tĂĽm iĂ§eriÄźi silinecektir.</p>
        <div class="flex gap-4">
            <button type="button" onclick="closeDeleteModal()" class="flex-1 py-4 rounded-2xl bg-slate-800 text-slate-400 font-bold hover:bg-slate-700 transition-all">VazgeĂ§</button>
            <button id="confirmDelBtn" type="button" class="flex-1 py-4 rounded-2xl bg-gradient-to-r from-rose-600 to-red-600 text-white font-black shadow-lg hover:shadow-rose-500/20 transition-all active:scale-95">SÄ°L</button>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/codemirror.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/theme/dracula.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/codemirror.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/mode/xml/xml.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/mode/javascript/javascript.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/mode/css/css.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/mode/htmlmixed/htmlmixed.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/addon/edit/closetag.min.js"></script>
<script>
    function updateSlug(val) {
        const slug = val.toLowerCase()
            .replace(/ /g, '-')
            .replace(/[^\w-]+/g, '')
            .replace(/-+/g, '-');
        document.getElementById('modSekmeId').value = slug;
        document.getElementById('slug-preview').innerText = slug;
    }

    function openSekmeModal(btn = null) {
        const mod = document.getElementById('sekmeModal');
        const modContent = document.getElementById('sekmeModalContent');

        if(btn) {
            document.getElementById('modalTitle').innerText = "Sekmeyi DĂĽzenle";
            document.getElementById('modId').value = btn.getAttribute('data-id');
            document.getElementById('modBaslik').value = btn.getAttribute('data-baslik');
            document.getElementById('modSekmeId').value = btn.getAttribute('data-sekmeid');
            document.getElementById('slug-preview').innerText = btn.getAttribute('data-sekmeid');
            document.getElementById('modIcon').value = btn.getAttribute('data-icon');
            document.getElementById('modSira').value = btn.getAttribute('data-sira');
            document.getElementById('modAktif').checked = btn.getAttribute('data-aktif') === 'true';
            
            const icerik = btn.getAttribute('data-icerik') || '';
            if(window.codeEditor) window.codeEditor.setValue(icerik);
            else document.getElementById('modIcerik').value = icerik;
        } else {
            document.getElementById('modalTitle').innerText = "Yeni Sekme Ekle";
            document.getElementById('modId').value = "0";
            document.getElementById('modBaslik').value = "";
            document.getElementById('modSekmeId').value = "";
            document.getElementById('slug-preview').innerText = "";
            document.getElementById('modIcon').value = "fa-solid fa-info";
            document.getElementById('modSira').value = "99";
            document.getElementById('modAktif').checked = true;
            if(window.codeEditor) window.codeEditor.setValue('');
        }

        mod.classList.remove('hidden'); mod.classList.add('flex');
        setTimeout(() => { 
            mod.classList.remove('opacity-0'); 
            modContent.classList.remove('scale-90'); 
            modContent.classList.add('scale-100'); 
            if(window.codeEditor) window.codeEditor.refresh();
        }, 10);
    }

    function closeSekmeModal() {
        const mod = document.getElementById('sekmeModal');
        const modContent = document.getElementById('sekmeModalContent');
        mod.classList.add('opacity-0'); modContent.classList.remove('scale-100'); modContent.classList.add('scale-90');
        setTimeout(() => { mod.classList.add('hidden'); mod.classList.remove('flex'); }, 300);
    }

    let formToSubmit = null;
    function confirmDelete(form) {
        formToSubmit = form;
        const mod = document.getElementById('deleteModal');
        const modContent = document.getElementById('deleteModalContent');
        mod.classList.remove('hidden'); mod.classList.add('flex');
        setTimeout(() => { mod.classList.remove('opacity-0'); modContent.classList.remove('scale-90'); modContent.classList.add('scale-100'); }, 10);
    }
    function closeDeleteModal() {
        const mod = document.getElementById('deleteModal');
        const modContent = document.getElementById('deleteModalContent');
        mod.classList.add('opacity-0'); modContent.classList.remove('scale-100'); modContent.classList.add('scale-90');
        setTimeout(() => { mod.classList.add('hidden'); mod.classList.remove('flex'); }, 300);
    }
    document.getElementById('confirmDelBtn').addEventListener('click', () => { if(formToSubmit) formToSubmit.submit(); });

    document.addEventListener("DOMContentLoaded", function() {
        const textareas = document.querySelectorAll('.tiny-editor');
        textareas.forEach(ta => {
            window.codeEditor = CodeMirror.fromTextArea(ta, {
                mode: "htmlmixed",
                theme: "dracula",
                lineNumbers: true,
                autoCloseTags: true,
                lineWrapping: true
            });
                        window.codeEditor.on('change', editor => {
                editor.save();
            });
        });
    });
</script>

<style>
    .glass-card { background: rgba(15, 23, 42, 0.7); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); }
    .animate-fadeIn { animation: fadeIn 0.4s ease-out forwards; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .custom-scroll::-webkit-scrollbar { width: 6px; height: 6px; }
    .custom-scroll::-webkit-scrollbar-track { background: rgba(255,255,255,0.02); }
    .custom-scroll::-webkit-scrollbar-thumb { background: rgba(20,184,166,0.2); border-radius: 10px; }
    
    .CodeMirror {
        border-radius: 1rem;
        height: 400px;
        font-family: 'Fira Code', monospace;
        font-size: 14px;
        padding: 10px;
        background: rgba(15, 23, 42, 0.5) !important;
    }
</style>



