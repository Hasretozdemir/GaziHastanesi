@model GaziHastane.Models.BashekimlikPersonel
@{
    ViewData["Title"] = Model?.Id > 0 ? "Personel Düzenle" : "Yeni Personel Ekle";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="max-w-4xl mx-auto mt-8">

    <div class="mb-6 flex items-center gap-4 px-2">
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center shadow-[0_0_20px_rgba(59,130,246,0.4)] relative overflow-hidden">
            <div class="absolute inset-0 bg-white/20 blur-md rounded-full transform -translate-x-4 -translate-y-4"></div>
            <i class="fa-solid fa-user-tie text-white text-2xl relative z-10"></i>
        </div>
        <div>
            <h2 class="text-2xl font-black text-transparent bg-clip-text bg-gradient-to-r from-white to-blue-200">@(Model?.Id > 0 ? "Personeli Güncelle" : "Yeni Personel Ekle")</h2>
            <p class="text-sm text-blue-200/60 mt-1">Hastane yönetimine eklenecek kişinin bilgilerini doldurun.</p>
        </div>
    </div>

    <div class="glass-card bg-slate-900/60 backdrop-blur-2xl border border-blue-500/20 rounded-3xl p-8 shadow-2xl relative overflow-hidden group">

        <div class="absolute -top-24 -right-24 w-64 h-64 bg-blue-500/10 rounded-full blur-[80px] pointer-events-none transition-colors duration-700"></div>

        <form asp-action="PersonelForm" method="post" enctype="multipart/form-data" class="space-y-6 relative z-10">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <input asp-for="FotografYolu" type="hidden" />
            <input asp-for="CvYolu" type="hidden" />

            <div class="grid md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="AdSoyad" class="block text-sm font-semibold text-blue-100 mb-2">Ad Soyad <span class="text-rose-400">*</span></label>
                    <input asp-for="AdSoyad" class="w-full rounded-xl bg-slate-800/50 border border-blue-500/20 px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-all hover:border-blue-500/40" placeholder="Örn: Hakan ATALAR" required />
                </div>
                <div>
                    <label asp-for="Unvan" class="block text-sm font-semibold text-blue-100 mb-2">Unvan <span class="text-rose-400">*</span></label>
                    <input asp-for="Unvan" class="w-full rounded-xl bg-slate-800/50 border border-blue-500/20 px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-all hover:border-blue-500/40" placeholder="Örn: Prof. Dr." required />
                </div>
            </div>

            <div class="grid md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="UzmanlikAlani" class="block text-sm font-semibold text-blue-100 mb-2">Uzmanlık Alanı</label>
                    <input asp-for="UzmanlikAlani" class="w-full rounded-xl bg-slate-800/50 border border-blue-500/20 px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-all hover:border-blue-500/40" placeholder="Örn: Ortopedi ve Travmatoloji Uzmanı" />
                </div>
                <div>
                    <label asp-for="Email" class="block text-sm font-semibold text-blue-100 mb-2">E-Posta Adresi</label>
                    <input asp-for="Email" type="email" class="w-full rounded-xl bg-slate-800/50 border border-blue-500/20 px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-all hover:border-blue-500/40" placeholder="Örn: hakan.atalar@gazi.edu.tr" />
                </div>
            </div>

            <div class="grid md:grid-cols-3 gap-6">
                <div class="md:col-span-2">
                    <label asp-for="KurumBilgisi" class="block text-sm font-semibold text-blue-100 mb-2">Kurum Bilgisi</label>
                    <input asp-for="KurumBilgisi" class="w-full rounded-xl bg-slate-800/50 border border-blue-500/20 px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-all hover:border-blue-500/40" placeholder="Örn: Gazi Üniversitesi Tıp Fakültesi" />
                </div>
                <div>
                    <label asp-for="Sira" class="block text-sm font-semibold text-blue-100 mb-2">Sıralama</label>
                    <input asp-for="Sira" type="number" class="w-full rounded-xl bg-slate-800/50 border border-blue-500/20 px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-all hover:border-blue-500/40" value="@(Model?.Sira ?? 99)" />
                </div>
            </div>

            <hr class="border-blue-500/10 my-6" />

            <div class="grid md:grid-cols-2 gap-6 bg-slate-800/30 p-5 rounded-2xl border border-blue-500/10">
                <div>
                    <label class="block text-sm font-semibold text-blue-100 mb-2"><i class="fa-solid fa-image text-blue-400 mr-1"></i> Profil Fotoğrafı Yükle</label>
                    <input type="file" name="fotografDosyasi" accept="image/*" class="w-full text-sm text-slate-400 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-blue-500/20 file:text-blue-300 hover:file:bg-blue-500/30 cursor-pointer transition-all" />
                    @if (!string.IsNullOrEmpty(Model?.FotografYolu))
                    {
                        <p class="text-xs text-emerald-400 mt-2"><i class="fa-solid fa-check"></i> Mevcut fotoğraf yüklü. Değiştirmek isterseniz yeni seçin.</p>
                    }
                </div>
                <div>
                    <label class="block text-sm font-semibold text-blue-100 mb-2"><i class="fa-solid fa-file-pdf text-rose-400 mr-1"></i> CV (Özgeçmiş) Yükle</label>
                    <input type="file" name="cvDosyasi" accept=".pdf,.doc,.docx" class="w-full text-sm text-slate-400 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-blue-500/20 file:text-blue-300 hover:file:bg-blue-500/30 cursor-pointer transition-all" />
                    @if (!string.IsNullOrEmpty(Model?.CvYolu))
                    {
                        <p class="text-xs text-emerald-400 mt-2"><i class="fa-solid fa-check"></i> Mevcut CV yüklü. Değiştirmek isterseniz yeni seçin.</p>
                    }
                </div>
            </div>

            <hr class="border-blue-500/10 my-6" />

            <div class="grid md:grid-cols-2 gap-4">

                <label class="relative flex items-center gap-4 p-4 rounded-xl border border-amber-500/20 bg-slate-800/40 hover:bg-slate-800/70 cursor-pointer transition-all group">
                    <div class="flex items-center justify-center w-6 h-6">
                        <input asp-for="IsBashekim" class="w-5 h-5 rounded border-amber-500/50 bg-slate-700 text-amber-500 focus:ring-amber-500 focus:ring-offset-slate-900 cursor-pointer transition-transform group-hover:scale-110" />
                    </div>
                    <div class="flex flex-col">
                        <span class="text-sm font-bold text-amber-400">Bu Kişi Başhekim Mi?</span>
                        <span class="text-xs text-slate-400 mt-0.5">İşaretlerseniz, en üstteki altın yıldızlı alanda çıkar.</span>
                    </div>
                </label>

                <label class="relative flex items-center gap-4 p-4 rounded-xl border border-blue-500/20 bg-slate-800/40 hover:bg-slate-800/70 cursor-pointer transition-all group">
                    <div class="flex items-center justify-center w-6 h-6">
                        <input asp-for="AktifMi" class="w-5 h-5 rounded border-blue-500/50 bg-slate-700 text-blue-500 focus:ring-blue-500 focus:ring-offset-slate-900 cursor-pointer transition-transform group-hover:scale-110" />
                    </div>
                    <div class="flex flex-col">
                        <span class="text-sm font-bold text-white group-hover:text-blue-300">Sitede Aktif (Görünür) Mi?</span>
                        <span class="text-xs text-slate-400 mt-0.5">Kapalıysa hastane sitesinde gösterilmez.</span>
                    </div>
                </label>

            </div>

            <div class="flex items-center justify-end gap-3 pt-6">
                <a href="/Admin/Bashekimlik/Index" class="flex items-center gap-2 px-6 py-3 rounded-xl bg-slate-800 hover:bg-slate-700 border border-slate-600 text-slate-300 hover:text-white transition-all font-medium">
                    <i class="fa-solid fa-xmark"></i> İptal
                </a>

                <button type="submit" class="flex items-center gap-2 px-8 py-3 rounded-xl bg-gradient-to-r from-blue-600 to-cyan-500 hover:from-blue-500 hover:to-cyan-400 text-white font-bold shadow-[0_0_20px_rgba(59,130,246,0.4)] hover:shadow-[0_0_30px_rgba(6,182,212,0.6)] hover:-translate-y-1 transition-all">
                    <i class="fa-solid fa-floppy-disk"></i> Kaydet
                </button>
            </div>
        </form>
    </div>
</div>