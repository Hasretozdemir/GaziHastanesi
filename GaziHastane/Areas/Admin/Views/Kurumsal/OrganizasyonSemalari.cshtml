@model List<GaziHastane.Models.KurumsalIcerik>
@using System.IO
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = ViewBag.SayfaBaslik;
    var sayfaKey = ViewBag.SayfaKey as string;
}

<div class="max-w-6xl mx-auto mt-8 relative space-y-6">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center shadow-[0_0_20px_rgba(37,99,235,0.4)]">
                <i class="fa-solid fa-diagram-project text-white text-2xl"></i>
            </div>
            <div>
                <h2 class="text-2xl font-black text-transparent bg-clip-text bg-gradient-to-r from-white to-blue-200">@ViewBag.SayfaBaslik</h2>
                <p class="text-sm text-blue-200/60 mt-1">Başlık ve şema dosyası ekleyin, anasayfada kenar menüden açılır.</p>
            </div>
        </div>
        <button type="button" onclick="openSchemaModal()" class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white font-bold shadow-lg transition-all">
            <i class="fa-solid fa-plus"></i> Yeni Şema Ekle
        </button>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="flex items-center gap-4 rounded-2xl border border-emerald-500/30 bg-emerald-500/10 px-6 py-4 backdrop-blur-xl relative overflow-hidden">
            <div class="absolute top-0 left-0 w-1.5 h-full bg-emerald-500"></div>
            <i class="fa-solid fa-check-circle text-emerald-400 text-xl"></i>
            <div><h4 class="text-emerald-400 text-sm font-bold">Başarılı</h4><p class="text-emerald-100/90 text-sm">@TempData["Success"]</p></div>
        </div>
    }

    <div class="glass-card bg-slate-900/60 backdrop-blur-2xl border border-blue-500/20 rounded-3xl p-6 shadow-2xl relative overflow-hidden">
        <div class="flex justify-between items-center mb-6 border-b border-blue-500/10 pb-4">
            <h3 class="text-lg font-bold text-white"><i class="fa-solid fa-list text-blue-400 mr-2"></i>Şemalar</h3>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="text-slate-400 border-b border-blue-500/20">
                            <th class="text-left py-3 px-3 font-semibold">Başlık</th>
                            <th class="text-left py-3 px-3 font-semibold">Dosya</th>
                            <th class="text-center py-3 px-3 font-semibold">Sıra</th>
                            <th class="text-center py-3 px-3 font-semibold">Durum</th>
                            <th class="text-right py-3 px-3 font-semibold">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderBy(x => x.Sira))
                        {
                            <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
                                <td class="py-3 px-3 text-white font-semibold">@item.Baslik</td>
                                <td class="py-3 px-3 text-slate-300 text-xs">
                                    @if (!string.IsNullOrWhiteSpace(item.MedyaYolu))
                                    {
                                        <div class="flex items-center gap-2">
                                            <i class="fa-solid fa-file-image text-rose-400"></i>
                                            <span>@System.IO.Path.GetFileName(item.MedyaYolu)</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-slate-500">-</span>
                                    }
                                </td>
                                <td class="py-3 px-3 text-center"><span class="bg-slate-800 border border-slate-700 rounded-md px-2 py-1 text-slate-300 text-xs">@item.Sira</span></td>
                                <td class="py-3 px-3 text-center">
                                    @if (item.AktifMi)
                                    {
                                        <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 inline-block"></span>
                                    }
                                    else
                                    {
                                        <span class="w-2.5 h-2.5 rounded-full bg-rose-500 inline-block opacity-50"></span>
                                    }
                                </td>
                                <td class="py-3 px-3 text-right">
                                    <div class="inline-flex gap-2">
                                        <button type="button"
                                                data-id="@item.Id" data-baslik="@item.Baslik" data-aciklama="@(item.Aciklama ?? "")"
                                                data-medya="@(item.MedyaYolu ?? "")" data-sira="@item.Sira" data-aktif="@(item.AktifMi ? "true" : "false")"
                                                onclick="openSchemaModal(this)"
                                                class="inline-flex items-center text-xs px-3 py-1.5 rounded-lg bg-blue-500/10 border border-blue-500/20 text-blue-400 hover:bg-blue-500/30 transition-all">
                                            <i class="fa-solid fa-pen-to-square mr-1.5"></i> Düzenle
                                        </button>
                                        <form asp-action="KurumsalIcerikSil" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="button" onclick="confirmDelete(this.closest('form'))" class="inline-flex items-center text-xs px-3 py-1.5 rounded-lg bg-rose-500/10 border border-rose-500/20 text-rose-400 hover:bg-rose-500/30 transition-all">
                                                <i class="fa-solid fa-trash-can mr-1.5"></i> Sil
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-12">
                <i class="fa-solid fa-inbox text-slate-400 text-4xl mb-4"></i>
                <p class="text-slate-400 font-medium">Henüz şema eklenmemiştir.</p>
            </div>
        }
    </div>

    <div id="schemaModal" class="fixed inset-0 z-[105] hidden items-center justify-center bg-black/60 backdrop-blur-sm transition-opacity opacity-0 duration-300">
        <div id="schemaModalContent" class="glass-card bg-slate-900/95 border border-emerald-500/30 rounded-3xl p-8 max-w-2xl w-full shadow-[0_0_50px_rgba(16,185,129,0.15)] transform scale-90 transition-transform duration-300 max-h-[90vh] overflow-y-auto custom-scroll">
            <div class="flex justify-between items-center mb-6 border-b border-emerald-500/10 pb-4">
                <h3 id="schemaModalTitle" class="text-2xl font-black text-white">Yeni Şema Ekle</h3>
                <button type="button" onclick="closeSchemaModal()" class="text-slate-400 hover:text-white"><i class="fa-solid fa-xmark text-xl"></i></button>
            </div>

            <form asp-action="KurumsalIcerikKaydet" method="post" enctype="multipart/form-data" class="space-y-5">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="schemaId" value="0" />
                <input type="hidden" name="SayfaKey" value="@sayfaKey" />
                <input type="hidden" name="ExistingMedya" id="schemaExistingMedya" value="" />
                <input type="hidden" name="Kategori" value="" />

                <div>
                    <label class="block text-sm font-semibold text-emerald-100 mb-2">Şema Başlığı *</label>
                    <input type="text" name="Baslik" id="schemaBaslik" class="w-full rounded-xl bg-slate-800/50 border border-emerald-500/20 p-3 text-white focus:ring-2 focus:ring-emerald-500/50" placeholder="Örn: Başhekimlik Organizasyon Şeması" required />
                </div>

                <div>
                    <label class="block text-sm font-semibold text-emerald-100 mb-2">Açıklama</label>
                    <textarea name="Aciklama" id="schemaAciklama" class="w-full rounded-xl bg-slate-800/50 border border-emerald-500/20 p-3 text-white focus:ring-2 focus:ring-emerald-500/50 h-32" placeholder="Şema ile ilgili kısa açıklama..."></textarea>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-emerald-100 mb-2">
                        <i class="fa-solid fa-cloud-arrow-up mr-2"></i>Şema Dosyası Yükle
                    </label>
                    <input type="file" name="FormDosyasi" id="schemaFile" accept=".pdf,.png,.jpg,.jpeg,.webp,.doc,.docx" class="block w-full text-sm text-slate-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-emerald-600 file:text-white hover:file:bg-emerald-700 file:cursor-pointer" />
                    <p id="schemaFileInfo" class="text-xs text-emerald-300 mt-1"></p>
                </div>

                <div class="grid md:grid-cols-2 gap-5">
                    <div>
                        <label class="block text-sm font-semibold text-emerald-100 mb-2">Sıralama</label>
                        <input type="number" name="Sira" id="schemaSira" value="99" class="w-full rounded-xl bg-slate-800/50 border border-emerald-500/20 p-3 text-white focus:ring-2 focus:ring-emerald-500/50" />
                    </div>
                    <div class="flex items-center gap-3 bg-slate-800/30 border border-emerald-500/20 rounded-xl p-3 mt-7">
                        <input type="checkbox" name="AktifMi" id="schemaAktif" value="true" checked class="w-5 h-5 accent-emerald-500 cursor-pointer" />
                        <label class="text-sm font-bold text-emerald-400 cursor-pointer" for="schemaAktif">Sitede Yayınla</label>
                    </div>
                </div>

                <div class="flex gap-3 pt-6 border-t border-emerald-500/10">
                    <button type="button" onclick="closeSchemaModal()" class="flex-1 py-3 rounded-xl bg-slate-800 hover:bg-slate-700 text-slate-300 font-bold transition-all">İptal</button>
                    <button type="submit" class="flex-1 py-3 rounded-xl bg-gradient-to-r from-emerald-600 to-teal-600 text-white font-bold shadow-lg transition-all">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .glass-card {
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
    }

    .custom-scroll::-webkit-scrollbar {
        width: 6px;
    }

    .custom-scroll::-webkit-scrollbar-track {
        background: transparent;
    }

    .custom-scroll::-webkit-scrollbar-thumb {
        background: rgba(148, 163, 184, 0.3);
        border-radius: 10px;
    }
</style>

<script>
    function openSchemaModal(btn = null) {
        const modal = document.getElementById('schemaModal');
        const title = document.getElementById('schemaModalTitle');
        const form = modal.querySelector('form');

        if (btn && btn.dataset.id) {
            title.textContent = 'Şemayı Düzenle';
            document.getElementById('schemaId').value = btn.dataset.id;
            document.getElementById('schemaBaslik').value = btn.dataset.baslik;
            document.getElementById('schemaAciklama').value = btn.dataset.aciklama || '';
            document.getElementById('schemaExistingMedya').value = btn.dataset.medya || '';
            document.getElementById('schemaSira').value = btn.dataset.sira;
            document.getElementById('schemaAktif').checked = btn.dataset.aktif === 'true';
            document.getElementById('schemaFileInfo').textContent = btn.dataset.medya ? `Mevcut dosya: ${btn.dataset.medya.split('/').pop()}` : '';
            document.getElementById('schemaFile').value = '';
        } else {
            title.textContent = 'Yeni Şema Ekle';
            document.getElementById('schemaId').value = '0';
            form.reset();
            document.getElementById('schemaSira').value = '99';
            document.getElementById('schemaAktif').checked = true;
            document.getElementById('schemaExistingMedya').value = '';
            document.getElementById('schemaFileInfo').textContent = '';
        }

        modal.classList.remove('hidden');
        modal.classList.add('flex');
        setTimeout(() => modal.classList.add('opacity-100'), 10);
        document.getElementById('schemaModalContent').classList.remove('scale-90');
        document.getElementById('schemaModalContent').classList.add('scale-100');
    }

    function closeSchemaModal() {
        const modal = document.getElementById('schemaModal');
        modal.classList.remove('opacity-100');
        setTimeout(() => {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }, 300);
    }

    function confirmDelete(form) {
        if (confirm('Silmek istediğinizden emin misiniz?')) {
            form.submit();
        }
    }

    document.addEventListener('click', function (e) {
        const modal = document.getElementById('schemaModal');
        if (e.target === modal) closeSchemaModal();
    });

    const schemaFileInput = document.getElementById('schemaFile');
    if (schemaFileInput) {
        schemaFileInput.addEventListener('change', function (e) {
            const fileInfo = document.getElementById('schemaFileInfo');
            if (e.target.files.length > 0) {
                const file = e.target.files[0];
                fileInfo.textContent = `Seçilen dosya: ${file.name}`;
            } else {
                fileInfo.textContent = '';
            }
        });
    }
</script>
