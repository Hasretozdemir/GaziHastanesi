@model GaziHastane.Models.BasinKurumsalIletisim
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Basın ve Kurumsal İletişim Yönetimi";
}

<style>
    :root {
        --glass-bg: rgba(255, 255, 255, 0.03);
        --glass-border: rgba(255, 255, 255, 0.08);
        --accent-primary: #8b5cf6;
        --accent-secondary: #6366f1;
        --text-muted: #94a3b8;
    }

    .glass-card {
        background: var(--glass-bg);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 2rem;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .hero-banner {
        background: linear-gradient(135deg, rgba(139, 92, 246, 0.2) 0%, rgba(99, 102, 241, 0.2) 100%);
        padding: 4rem 3rem;
        border-bottom: 1px solid var(--glass-border);
        position: relative;
        overflow: hidden;
    }

    .hero-banner::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(139, 92, 246, 0.1) 0%, transparent 70%);
        animation: rotate 20s linear infinite;
    }

    @@keyframes rotate {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .content-area { padding: 3rem; }

    .form-section {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--glass-border);
        border-radius: 1.5rem;
        padding: 2rem;
        margin-bottom: 2.5rem;
        transition: transform 0.3s ease, background 0.3s ease;
    }

    .form-section:hover {
        background: rgba(255, 255, 255, 0.04);
        transform: translateY(-5px);
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2rem;
        border-bottom: 1px solid var(--glass-border);
        padding-bottom: 1rem;
    }

    .section-header h3 {
        font-size: 1.25rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: #fff;
    }

    .form-label {
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text-muted);
        margin-bottom: 0.75rem;
        display: block;
    }

    .form-control {
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid var(--glass-border);
        border-radius: 1rem;
        padding: 1rem 1.25rem;
        color: #fff;
        font-size: 1rem;
        transition: all 0.3s ease;
        width: 100%;
    }

    .form-control:focus {
        background: rgba(0, 0, 0, 0.3);
        border-color: var(--accent-primary);
        box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.15);
        outline: none;
    }

    textarea.form-control { min-height: 200px; line-height: 1.6; }

    .btn-premium {
        background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-secondary) 100%);
        color: #fff;
        padding: 1.25rem 2.5rem;
        border-radius: 1.25rem;
        font-weight: 800;
        font-size: 1.1rem;
        border: none;
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        box-shadow: 0 10px 25px rgba(139, 92, 246, 0.3);
    }

    .btn-premium:hover {
        transform: translateY(-3px) scale(1.02);
        box-shadow: 0 20px 40px rgba(139, 92, 246, 0.4);
    }

    .btn-outline {
        background: transparent;
        color: var(--text-muted);
        padding: 1.25rem 2.5rem;
        border-radius: 1.25rem;
        font-weight: 700;
        border: 1px solid var(--glass-border);
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
    }

    .btn-outline:hover {
        background: rgba(255, 255, 255, 0.05);
        color: #fff;
        border-color: #fff;
    }

    .info-pill {
        background: rgba(59, 130, 246, 0.1);
        border: 1px solid rgba(59, 130, 246, 0.2);
        color: #60a5fa;
        padding: 1rem 1.5rem;
        border-radius: 1rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .required::after { content: " *"; color: #ef4444; }

    .custom-switch {
        display: flex;
        align-items: center;
        gap: 1rem;
        cursor: pointer;
    }

    .switch-bg {
        width: 3.5rem;
        height: 2rem;
        background: rgba(255,255,255,0.1);
        border-radius: 2rem;
        position: relative;
        transition: all 0.3s ease;
    }

    input:checked + .switch-bg { background: var(--accent-primary); }

    .switch-circle {
        width: 1.5rem;
        height: 1.5rem;
        background: #fff;
        border-radius: 50%;
        position: absolute;
        top: 0.25rem;
        left: 0.25rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    input:checked + .switch-bg .switch-circle { left: 1.75rem; }
</style>

<div class="max-w-5xl mx-auto py-12 px-4">
    @if (TempData["Success"] != null)
    {
        <div class="mb-8 animate-bounce bg-emerald-500/20 border border-emerald-500/30 text-emerald-400 p-6 rounded-3xl flex items-center gap-4">
            <i class="fa-solid fa-circle-check text-2xl"></i>
            <span class="font-bold text-lg">@TempData["Success"]</span>
        </div>
    }

    <div class="glass-card">
        <div class="hero-banner">
            <div class="relative z-10">
                <div class="w-20 h-20 bg-white/10 rounded-3xl flex items-center justify-center mb-6 backdrop-blur-md border border-white/20">
                    <i class="fa-solid fa-bullhorn text-4xl text-white"></i>
                </div>
                <h1 class="text-5xl font-black text-white tracking-tighter mb-2">Basın ve İletişim</h1>
                <p class="text-xl text-white/60 font-medium">Birim kurumsal bilgilerini buradan yönetebilirsiniz.</p>
            </div>
        </div>

        <div class="content-area">
            <div class="info-pill">
                <i class="fa-solid fa-circle-info text-xl"></i>
                <p class="text-sm font-semibold">Bu bilgiler ziyaretçilere "Hastanemizde" menüsü altında sunulacaktır.</p>
            </div>

            <form asp-action="BasinVeKurumsalIletisimKaydet" method="post" class="needs-validation">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="form-section">
                    <div class="section-header">
                        <i class="fa-solid fa-file-lines text-accent-primary"></i>
                        <h3>Genel İçerik</h3>
                    </div>

                    <div class="mb-8">
                        <label asp-for="Baslik" class="form-label required">Birim Başlığı</label>
                        <input type="text" asp-for="Baslik" class="form-control" placeholder="Örn: Basın ve Kurumsal İletişim Birimi">
                        <span asp-validation-for="Baslik" class="text-red-400 text-xs mt-2 block"></span>
                    </div>

                    <div>
                        <label asp-for="Aciklama" class="form-label required">Hakkımızda / Tanıtım Metni</label>
                        <textarea asp-for="Aciklama" class="form-control" placeholder="Birimin görevleri ve tanıtımı..."></textarea>
                        <span asp-validation-for="Aciklama" class="text-red-400 text-xs mt-2 block"></span>
                    </div>
                </div>

                <div class="form-section">
                    <div class="section-header">
                        <i class="fa-solid fa-phone-volume text-accent-primary"></i>
                        <h3>İletişim Detayları</h3>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
                        <div>
                            <label asp-for="Telefon" class="form-label">Telefon</label>
                            <input type="tel" asp-for="Telefon" class="form-control" placeholder="0312 XXX XX XX">
                        </div>
                        <div>
                            <label asp-for="Email" class="form-label">E-Posta</label>
                            <input type="email" asp-for="Email" class="form-control" placeholder="birim@gazi.edu.tr">
                        </div>
                    </div>

                    <div>
                        <label asp-for="Lokasyon" class="form-label">Konum / Ofis</label>
                        <input type="text" asp-for="Lokasyon" class="form-control" placeholder="E Blok, Kat: 11">
                    </div>
                </div>

                <div class="form-section">
                    <div class="flex items-center justify-between">
                        <div>
                            <h3 class="text-white font-bold text-lg">Yayın Durumu</h3>
                            <p class="text-sm text-text-muted mt-1">Son Güncelleme: @Model?.SonGuncelleme.ToString("f")</p>
                        </div>
                        <label class="custom-switch">
                            <input type="checkbox" asp-for="IsActive" class="hidden" />
                            <div class="switch-bg">
                                <div class="switch-circle"></div>
                            </div>
                        </label>
                    </div>
                </div>

                <div class="flex items-center justify-center gap-6 mt-12">
                    <button type="submit" class="btn-premium">
                        <i class="fa-solid fa-sparkles"></i>
                        Güncelle ve Kaydet
                    </button>
                    <a href="@Url.Action("Index", "Kurumsal")" class="btn-outline">
                        Vazgeç
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        // Form animasyonları ve validasyonlar
        document.querySelectorAll('.form-control').forEach(el => {
            el.addEventListener('focus', () => {
                el.closest('.form-section').style.borderColor = 'rgba(139, 92, 246, 0.3)';
            });
            el.addEventListener('blur', () => {
                el.closest('.form-section').style.borderColor = 'rgba(255, 255, 255, 0.08)';
            });
        });
    </script>
}
