@model GaziHastane.Models.KurumsalSayfa
@{
    var pageTitle = ViewData["PageTitle"]?.ToString() ?? "Kurumsal Sayfa";
    var pageKey = ViewData["PageKey"]?.ToString() ?? string.Empty;
}

<div class="max-w-5xl mx-auto mt-8">
    <div class="mb-6 flex items-center gap-3 px-2">
        <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-cyan-500 to-blue-600 flex items-center justify-center shadow-lg shadow-cyan-500/30">
            <i class="fa-solid fa-file-pen text-white text-xl"></i>
        </div>
        <div>
            <h2 class="text-2xl font-black text-white tracking-wide">@pageTitle</h2>
            <p class="text-sm text-slate-400 mt-1">Kod/HTML tabanlı içerik düzenleme ekranı</p>
        </div>
    </div>

    <div class="glass-card bg-slate-900/60 backdrop-blur-xl border border-white/10 rounded-3xl p-8 shadow-2xl">
        <form asp-action="EditDynamicPage" asp-route-pageKey="@pageKey" method="post" class="space-y-6">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <input asp-for="Slug" type="hidden" />

            <div>
                <label asp-for="Baslik" class="block text-sm font-semibold text-slate-300 mb-2">Sayfa Başlığı</label>
                <input asp-for="Baslik" class="w-full rounded-xl bg-slate-800/50 border border-slate-600/50 px-4 py-3 text-white" />
            </div>

            <div>
                <label asp-for="Icerik" class="block text-sm font-semibold text-slate-300 mb-2">Sayfa İçeriği (HTML/Kod)</label>
                <textarea asp-for="Icerik" id="editor" rows="16" class="w-full rounded-xl bg-slate-800/50 border border-slate-600/50 px-4 py-3 text-white"></textarea>
            </div>

            <div class="grid md:grid-cols-3 gap-4">
                <div>
                    <label asp-for="FotografUrl" class="block text-sm font-semibold text-slate-300 mb-2">Fotoğraf URL</label>
                    <input asp-for="FotografUrl" class="w-full rounded-xl bg-slate-800/50 border border-slate-600/50 px-4 py-3 text-white" />
                </div>
                <div>
                    <label asp-for="Unvan" class="block text-sm font-semibold text-slate-300 mb-2">Unvan</label>
                    <input asp-for="Unvan" class="w-full rounded-xl bg-slate-800/50 border border-slate-600/50 px-4 py-3 text-white" />
                </div>
                <div>
                    <label asp-for="Telefon" class="block text-sm font-semibold text-slate-300 mb-2">Telefon</label>
                    <input asp-for="Telefon" class="w-full rounded-xl bg-slate-800/50 border border-slate-600/50 px-4 py-3 text-white" />
                </div>
            </div>

            <label class="relative flex items-center gap-3 p-4 rounded-xl border border-slate-600/50 bg-slate-800/30 cursor-pointer">
                <input asp-for="AktifMi" class="w-5 h-5 rounded border-slate-500 bg-slate-700 text-cyan-500 focus:ring-cyan-500 focus:ring-offset-slate-900 cursor-pointer" />
                <span class="text-sm font-semibold text-white">Sayfa aktif</span>
            </label>

            <div class="flex items-center justify-end gap-3 pt-2">
                <button type="submit" class="flex items-center gap-2 px-8 py-3 rounded-xl bg-gradient-to-r from-cyan-600 to-blue-600 text-white font-bold shadow-lg shadow-cyan-500/30">
                    <i class="fa-solid fa-floppy-disk"></i>
                    Sayfayı Kaydet
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/4.22.1/full/ckeditor.js"></script>
    <script>
        CKEDITOR.replace('editor', {
            height: 420,
            allowedContent: true,
            extraAllowedContent: '*[*]{*}(*);',
            toolbar: [
                { name: 'document', items: ['Source', '-', 'Preview'] },
                { name: 'clipboard', items: ['Undo', 'Redo'] },
                { name: 'basicstyles', items: ['Bold', 'Italic', 'Underline', 'Strike', '-', 'RemoveFormat'] },
                { name: 'paragraph', items: ['NumberedList', 'BulletedList', '-', 'JustifyLeft', 'JustifyCenter', 'JustifyRight'] },
                { name: 'insert', items: ['Link', 'Unlink', 'Image', 'Table', 'HorizontalRule'] }
            ]
        });
    </script>
}
