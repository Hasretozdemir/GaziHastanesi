@model GaziHastane.Models.KurumsalMenuGrup
@{
    ViewData["Title"] = "Menü Grubu Yönetimi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="max-w-2xl mx-auto mt-8">

    <div class="mb-6 flex items-center gap-4 px-2">
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center shadow-[0_0_20px_rgba(99,102,241,0.4)] relative overflow-hidden">
            <div class="absolute inset-0 bg-white/20 blur-md rounded-full transform -translate-x-4 -translate-y-4"></div>
            <i class="fa-solid fa-layer-group text-white text-2xl relative z-10"></i>
        </div>
        <div>
            <h2 class="text-2xl font-black text-transparent bg-clip-text bg-gradient-to-r from-white to-indigo-200 tracking-wide">Menü Grubu Formu</h2>
            <p class="text-sm text-indigo-200/60 mt-1">Sol menüde yer alacak ana baþlýk gruplarýný buradan yönetin.</p>
        </div>
    </div>

    <div class="glass-card bg-slate-900/60 backdrop-blur-2xl border border-indigo-500/20 rounded-3xl p-8 shadow-[0_0_40px_rgba(99,102,241,0.1)] relative overflow-hidden group">

        <div class="absolute -top-24 -right-24 w-48 h-48 bg-indigo-500/20 rounded-full blur-[60px] pointer-events-none group-hover:bg-purple-500/20 transition-colors duration-700"></div>

        <form asp-action="GrupForm" method="post" class="space-y-6 relative z-10">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />

            <div>
                <label asp-for="GrupAdi" class="block text-sm font-semibold text-indigo-100 mb-2">Grup Adý <span class="text-purple-400">*</span></label>
                <div class="relative">
                    <input asp-for="GrupAdi" class="w-full rounded-xl bg-slate-800/50 border border-indigo-500/20 px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-400 transition-all duration-300 hover:border-indigo-500/40 shadow-inner" placeholder="Örn: Kurumsal, Týbbi Birimler..." />
                </div>
            </div>

            <div>
                <label asp-for="Sira" class="block text-sm font-semibold text-indigo-100 mb-2">Grup Sýralamasý</label>
                <input asp-for="Sira" type="number" class="w-full rounded-xl bg-slate-800/50 border border-indigo-500/20 px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-400 transition-all duration-300 hover:border-indigo-500/40 shadow-inner" placeholder="1" />
            </div>

            <div class="pt-2">
                <label class="relative flex items-center gap-4 p-4 rounded-xl border border-indigo-500/20 bg-slate-800/40 hover:bg-slate-800/70 hover:border-indigo-500/40 cursor-pointer transition-all duration-300 group/check">
                    <div class="flex items-center justify-center w-6 h-6">
                        <input asp-for="AktifMi" class="w-5 h-5 rounded border-indigo-500/50 bg-slate-700 text-indigo-500 focus:ring-indigo-500 focus:ring-offset-slate-900 cursor-pointer transition-transform duration-200 group-hover/check:scale-110" />
                    </div>
                    <div class="flex flex-col">
                        <span class="text-sm font-bold text-white group-hover/check:text-indigo-300 transition-colors">Grup Aktif Mi?</span>
                        <span class="text-xs text-slate-400 mt-0.5">Kapalýysa, bu gruba ait hiįbir menü sitede görünmez.</span>
                    </div>
                </label>
            </div>

            <hr class="border-indigo-500/10 my-6" />

            <div class="flex items-center justify-end gap-3 pt-2">
                <a href="/Admin/Kurumsal/Index" class="flex items-center gap-2 px-6 py-3 rounded-xl bg-slate-800/80 hover:bg-slate-700 border border-slate-600/50 text-slate-300 hover:text-white transition-all duration-300 font-medium">
                    <i class="fa-solid fa-xmark"></i>
                    Vazgeį
                </a>

                <button type="submit" class="flex items-center gap-2 px-8 py-3 rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 text-white font-bold shadow-[0_0_20px_rgba(99,102,241,0.4)] hover:shadow-[0_0_30px_rgba(168,85,247,0.6)] hover:-translate-y-1 transition-all duration-300">
                    <i class="fa-solid fa-check-double"></i>
                    Kaydet
                </button>
            </div>
        </form>
    </div>
</div>