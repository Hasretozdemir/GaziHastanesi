@model IEnumerable<GaziHastane.Models.Yetkili>
@{
    ViewData["Title"] = "Yetkili Yönetimi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div x-data="{
    isModalOpen: false,
    isEdit: false,
    editData: { id: '', adSoyad: '', email: '', rol: 'Yönetici', isActive: true }
}">

    <div class="glass-card rounded-[2rem] p-6 md:p-8">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-2xl bg-gradient-to-tr from-rose-500/20 to-red-600/20 border border-rose-500/30 flex items-center justify-center text-rose-400 shadow-[0_0_15px_rgba(244,63,94,0.2)]">
                    <i class="fa-solid fa-user-shield text-xl"></i>
                </div>
                <div>
                    <h2 class="text-xl font-black text-white tracking-wide">Yetkili Listesi</h2>
                    <p class="text-xs text-slate-400 font-medium mt-1">Sistem yöneticileri ve editörleri yönetin</p>
                </div>
            </div>

            <a href="/Admin/Yetkililer/Create" class="bg-gradient-to-r from-rose-500 to-red-600 text-white px-6 py-3 rounded-xl font-bold text-sm shadow-[0_0_20px_rgba(244,63,94,0.3)] hover:scale-105 transition flex items-center gap-2 border-0 cursor-pointer">
                <i class="fa-solid fa-user-plus"></i>
                <span>Yeni Yetkili Ekle</span>
            </a>
        </div>

        <div class="overflow-x-auto custom-scroll -mx-6 px-6 md:mx-0 md:px-0">
            <table class="w-full min-w-[800px] text-left border-collapse">
                <thead>
                    <tr class="text-[11px] font-black tracking-widest text-slate-500 uppercase border-b border-white/10 bg-white/5">
                        <th class="px-4 py-4 first:rounded-tl-2xl">Profil</th>
                        <th class="px-4 py-4">E-Posta</th>
                        <th class="px-4 py-4">Rol</th>
                        <th class="px-4 py-4">Durum</th>
                        <th class="px-4 py-4 text-right last:rounded-tr-2xl">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-white/5 transition duration-200 group">
                            <td class="px-4 py-3 align-middle">
                                <div class="flex items-center gap-3">
                                    <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(item.AdSoyad)&background=random&color=fff&rounded=true" class="w-10 h-10 rounded-xl shadow-lg" alt="@item.AdSoyad">
                                    <div class="flex flex-col">
                                        <span class="text-sm font-bold text-white">@item.AdSoyad</span>
                                        <span class="text-[10px] text-slate-400 font-medium">@item.KayitTarihi.ToString("dd.MM.yyyy") katıldı</span>
                                    </div>
                                </div>
                            </td>
                            <td class="px-4 py-3 align-middle">
                                <span class="text-sm font-medium text-slate-300">@item.Email</span>
                            </td>
                            <td class="px-4 py-3 align-middle">
                                @if (item.Rol == "Süper Admin")
                                {
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-[11px] font-bold bg-amber-500/10 text-amber-300 border border-amber-500/20"><i class="fa-solid fa-crown mr-1 text-[8px]"></i> @item.Rol</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-[11px] font-bold bg-blue-500/10 text-blue-300 border border-blue-500/20">@item.Rol</span>
                                }
                            </td>
                            <td class="px-4 py-3 align-middle">
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-xs font-bold @(item.IsActive ? "bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 shadow-[0_0_10px_rgba(16,185,129,0.1)]" : "bg-slate-500/10 text-slate-400 border border-white/5")">
                                    <span class="w-1.5 h-1.5 rounded-full @(item.IsActive ? "bg-emerald-400 animate-pulse" : "bg-slate-500")"></span>
                                    @(item.IsActive ? "Aktif" : "Pasif")
                                </span>
                            </td>
                            <td class="px-4 py-3 align-middle text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="/Admin/Yetkililer/Edit/@item.Id" class="w-8 h-8 rounded-xl bg-amber-500/10 text-amber-400 border border-amber-500/20 flex items-center justify-center hover:bg-amber-500 hover:text-white transition duration-300 cursor-pointer border-0">
                                        <i class="fa-solid fa-pen-to-square text-xs"></i>
                                    </a>
                                    <button onclick="deleteConfirm('@item.Id')" class="w-8 h-8 rounded-xl bg-rose-500/10 text-rose-400 border border-rose-500/20 flex items-center justify-center hover:bg-rose-500 hover:text-white transition duration-300 cursor-pointer border-0">
                                        <i class="fa-solid fa-trash text-xs"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Modal kept for inline creation/editing if needed, still usable via Alpine triggers elsewhere -->
    <template x-if="isModalOpen">
        <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-950/80 backdrop-blur-md" x-transition.opacity>

            <div @@click.outside="isModalOpen = false"
                 class="relative w-full max-w-lg bg-slate-900 border border-white/10 rounded-[2.5rem] shadow-2xl overflow-hidden"
                 x-transition:enter="transition ease-out duration-300"
                 x-transition:enter-start="opacity-0 scale-90 translate-y-8"
                 x-transition:enter-end="opacity-100 scale-100 translate-y-0">

                <button @@click="isModalOpen = false" class="absolute top-6 right-6 w-10 h-10 rounded-full bg-white/5 text-slate-400 flex items-center justify-center hover:bg-white/10 hover:text-white transition cursor-pointer border-0 z-10">
                    <i class="fa-solid fa-xmark text-lg"></i>
                </button>

                <div class="p-8 pb-4 text-center">
                    <h3 class="text-2xl font-black text-white" x-text="isEdit ? 'Yetkili Bilgilerini Güncelle' : 'Yeni Yetkili Oluştur'"></h3>
                    <p class="text-sm text-slate-500 mt-1">Lütfen tüm alanları eksiksiz doldurun.</p>
                </div>

                <div class="mx-8 p-4 rounded-2xl bg-rose-500/10 border border-rose-500/20 flex items-start gap-4">
                    <div class="w-10 h-10 rounded-xl bg-rose-500/20 flex items-center justify-center text-rose-400 shrink-0">
                        <i class="fa-solid fa-shield-halved"></i>
                    </div>
                    <p class="text-[11px] text-rose-200/70 leading-relaxed font-medium">
                        Güvenlik için şifrelerin karmaşık olması önerilir. Düzenleme sırasında şifre alanını boş bırakırsanız mevcut şifre korunur.
                    </p>
                </div>

                <form :action="isEdit ? '/Admin/Yetkililer/Edit' : '/Admin/Yetkililer/Create'" method="post" class="p-8 pt-6 space-y-5">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" :value="editData.id" />

                    <div class="space-y-1.5">
                        <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest ml-1">Ad Soyad *</label>
                        <div class="relative">
                            <i class="fa-solid fa-signature absolute left-5 top-1/2 -translate-y-1/2 text-slate-500 text-sm"></i>
                            <input type="text" name="AdSoyad" :value="editData.adSoyad" required
                                   class="w-full bg-white/5 border border-white/10 rounded-2xl pl-12 pr-5 py-4 text-white outline-none focus:border-rose-500/50 transition font-semibold" placeholder="Ad Soyad giriniz">
                        </div>
                    </div>

                    <div class="space-y-1.5">
                        <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest ml-1">E-Posta Adresi *</label>
                        <div class="relative">
                            <i class="fa-solid fa-envelope absolute left-5 top-1/2 -translate-y-1/2 text-slate-500 text-sm"></i>
                            <input type="email" name="Email" :value="editData.email" required
                                   class="w-full bg-white/5 border border-white/10 rounded-2xl pl-12 pr-5 py-4 text-white outline-none focus:border-rose-500/50 transition font-semibold" placeholder="ornek@gazi.edu.tr">
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div class="space-y-1.5">
                            <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest ml-1">Yetki Rolü *</label>
                            <select name="Rol" class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-white outline-none focus:border-rose-500/50 transition font-semibold appearance-none cursor-pointer">
                                <option value="Yönetici" :selected="editData.rol == 'Yönetici'" class="bg-slate-900">Yönetici</option>
                                <option value="Editör" :selected="editData.rol == 'Editör'" class="bg-slate-900">Editör</option>
                                <option value="Süper Admin" :selected="editData.rol == 'Süper Admin'" class="bg-slate-900">Süper Admin</option>
                            </select>
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest ml-1" x-text="isEdit ? 'Yeni Şifre' : 'Şifre *'"></label>
                            <div class="relative">
                                <i class="fa-solid fa-lock absolute left-5 top-1/2 -translate-y-1/2 text-slate-500 text-sm"></i>
                                <input type="password" name="SifreHash" :required="!isEdit"
                                       class="w-full bg-white/5 border border-white/10 rounded-2xl pl-12 pr-5 py-4 text-white outline-none focus:border-rose-500/50 transition font-semibold" placeholder="••••••••">
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center justify-between p-5 bg-white/5 rounded-[1.5rem] border border-white/5">
                        <div>
                            <p class="text-xs font-black text-white">Hesap Aktif mi?</p>
                            <p class="text-[10px] text-slate-500 font-medium mt-0.5">İşaretli ise sisteme girebilir.</p>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" name="IsActive" value="true" :checked="editData.isActive" class="sr-only peer">
                            <div class="w-12 h-6 bg-slate-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-rose-500 shadow-inner"></div>
                        </label>
                    </div>

                    <div class="pt-4 flex flex-col gap-3">
                        <button type="submit" class="w-full bg-gradient-to-r from-rose-500 to-red-600 text-white py-4 rounded-[1.5rem] font-black text-sm shadow-xl hover:scale-[1.02] active:scale-95 transition-all cursor-pointer border-0">
                            İŞLEMİ KAYDET
                        </button>
                        <button type="button" @@click="isModalOpen = false" class="w-full bg-transparent text-slate-500 py-2 rounded-xl font-bold text-xs hover:text-white transition cursor-pointer border-0">
                            Vazgeç ve Kapat
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </template>

</div>

<script>
    // Silme Onay Penceresi (SweetAlert2)
    function deleteConfirm(id) {
        Swal.fire({
            title: 'Emin misiniz?',
            text: "Seçilen yetkili hesabı kalıcı olarak silinecektir!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#f43f5e',
            cancelButtonColor: '#64748b',
            confirmButtonText: '<i class="fa-solid fa-trash mr-2"></i> Evet, Sil!',
            cancelButtonText: 'Hayır, Vazgeç',
            background: '#0f172a',
            color: '#fff',
            customClass: {
                popup: 'rounded-[2.5rem] border border-white/10 shadow-2xl',
                confirmButton: 'rounded-xl px-6 py-3 font-bold',
                cancelButton: 'rounded-xl px-6 py-3 font-bold'
            }
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/Admin/Yetkililer/Delete/' + id;
            }
        })
    }
</script>

<style>
    /* Select iconu ve scrollbar için özel dokunuşlar */
    select {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%2364748b' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
        background-position: right 1.25rem center;
        background-repeat: no-repeat;
        background-size: 1.2em 1.2em;
    }
</style>