@using System.Linq
@{
    ViewData["Title"] = "Gösterge Paneli";
    // Şablonun tam yolunu buraya veriyoruz ki başka yeri okumasın!
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";

    var toplamDoktor = (int?)ViewBag.ToplamDoktor ?? 0;
    var bugunkuRandevu = (int?)ViewBag.BugunkuRandevu ?? 0;
    var bugunkuRandevuDagilim = ViewBag.BugunkuRandevuDagilim as List<KeyValuePair<string, int>> ?? new List<KeyValuePair<string, int>>();
    var aktifBolum = (int?)ViewBag.AktifBolum ?? 0;
    var sistemYuku = (int?)ViewBag.SistemYuku ?? 0;
    var aktifKisiler = ViewBag.AktifKisiler as List<GaziHastane.Models.Doktor> ?? new List<GaziHastane.Models.Doktor>();
}

<div class="mb-8 pl-2">
    <h2 class="text-4xl md:text-5xl font-black mb-2 tracking-tight">Sisteme Hoş Geldin</h2>
    <p class="text-slate-400 font-medium">Gazi Hastanesi sistem altyapısı sorunsuz çalışıyor. İşte bugünün özet verileri.</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">

    <div class="glass-card p-6 rounded-[2rem] relative overflow-hidden group">
        <div class="absolute -right-6 -top-6 w-32 h-32 bg-cyan-500/10 rounded-full blur-2xl group-hover:bg-cyan-500/20 transition duration-500"></div>
        <div class="flex justify-between items-start mb-4 relative z-10">
            <div>
                <p class="text-[10px] font-black text-cyan-400 uppercase tracking-widest mb-1">Toplam Doktor</p>
                <h3 class="text-4xl font-black text-white">@toplamDoktor</h3>
            </div>
            <div class="w-12 h-12 rounded-xl bg-cyan-500/20 border border-cyan-500/30 flex items-center justify-center text-cyan-400 text-xl shadow-[0_0_15px_rgba(6,182,212,0.2)]">
                <i class="fa-solid fa-user-md neon-icon"></i>
            </div>
        </div>
        <div class="w-full h-1.5 bg-black/40 rounded-full mt-6 overflow-hidden relative z-10">
            <div class="h-full bg-gradient-to-r from-cyan-400 to-blue-500 shadow-[0_0_10px_#38bdf8]" style="width:@Math.Min(100, toplamDoktor)%"></div>
        </div>
        <p class="text-xs text-slate-400 mt-2 font-medium relative z-10"><span class="text-cyan-400 font-bold"><i class="fa-solid fa-circle-check"></i> @toplamDoktor</span> kayıtlı doktor</p>
    </div>

    <div class="glass-card p-6 rounded-[2rem] relative overflow-hidden group">
        <div class="absolute -right-6 -top-6 w-32 h-32 bg-purple-500/10 rounded-full blur-2xl group-hover:bg-purple-500/20 transition duration-500"></div>
        <div class="flex justify-between items-start mb-4 relative z-10">
            <div>
                <p class="text-[10px] font-black text-purple-400 uppercase tracking-widest mb-1">Bugünkü Randevu</p>
                <h3 class="text-4xl font-black text-white">@bugunkuRandevu</h3>
            </div>
            <div class="w-12 h-12 rounded-xl bg-purple-500/20 border border-purple-500/30 flex items-center justify-center text-purple-400 text-xl shadow-[0_0_15px_rgba(168,85,247,0.2)]">
                <i class="fa-solid fa-calendar-check neon-icon"></i>
            </div>
        </div>
        <div class="w-full h-1.5 bg-black/40 rounded-full mt-6 overflow-hidden relative z-10">
            <div class="h-full bg-gradient-to-r from-purple-400 to-pink-500 shadow-[0_0_10px_#c084fc]" style="width:@Math.Min(100, bugunkuRandevu)%"></div>
        </div>
        <p class="text-xs text-slate-400 mt-2 font-medium relative z-10"><span class="text-purple-400 font-bold"><i class="fa-solid fa-calendar-day"></i> @bugunkuRandevu</span> bugünkü randevu</p>
        @if (bugunkuRandevuDagilim.Any())
        {
            <p class="text-[11px] text-slate-500 mt-1 truncate" title="@string.Join(", ", bugunkuRandevuDagilim.Select(x => $"{x.Key}: {x.Value}"))">
                En yoğun: @string.Join(" • ", bugunkuRandevuDagilim.Select(x => $"{x.Key} ({x.Value})"))
            </p>
        }
    </div>

    <div class="glass-card p-6 rounded-[2rem] relative overflow-hidden group">
        <div class="absolute -right-6 -top-6 w-32 h-32 bg-emerald-500/10 rounded-full blur-2xl group-hover:bg-emerald-500/20 transition duration-500"></div>
        <div class="flex justify-between items-start mb-4 relative z-10">
            <div>
                <p class="text-[10px] font-black text-emerald-400 uppercase tracking-widest mb-1">Aktif Bölümler</p>
                <h3 class="text-4xl font-black text-white">@aktifBolum</h3>
            </div>
            <div class="w-12 h-12 rounded-xl bg-emerald-500/20 border border-emerald-500/30 flex items-center justify-center text-emerald-400 text-xl shadow-[0_0_15px_rgba(16,185,129,0.2)]">
                <i class="fa-solid fa-house-medical neon-icon"></i>
            </div>
        </div>
        <div class="w-full h-1.5 bg-black/40 rounded-full mt-6 overflow-hidden relative z-10">
            <div class="h-full bg-emerald-500 shadow-[0_0_10px_#34d399]" style="width:@Math.Min(100, aktifBolum)%"></div>
        </div>
        <p class="text-xs text-slate-400 mt-2 font-medium relative z-10"><span class="text-emerald-400 font-bold"><i class="fa-solid fa-check"></i> @aktifBolum bölüm</span> aktif durumda</p>
    </div>

    <div class="glass-card p-6 rounded-[2rem] relative overflow-hidden group">
        <div class="absolute -right-6 -top-6 w-32 h-32 bg-pink-500/10 rounded-full blur-2xl group-hover:bg-pink-500/20 transition duration-500"></div>
        <div class="flex justify-between items-start mb-4 relative z-10">
            <div>
                <p class="text-[10px] font-black text-pink-400 uppercase tracking-widest mb-1">Sistem Yükü</p>
                <h3 class="text-4xl font-black text-white">%@sistemYuku</h3>
            </div>
            <div class="w-12 h-12 rounded-xl bg-pink-500/20 border border-pink-500/30 flex items-center justify-center text-pink-400 text-xl shadow-[0_0_15px_rgba(236,72,153,0.2)]">
                <i class="fa-solid fa-server neon-icon"></i>
            </div>
        </div>
        <div class="w-full flex items-end gap-1 h-8 mt-4 relative z-10">
            <div class="w-1/6 bg-pink-500/40 rounded-t-sm h-[30%]"></div>
            <div class="w-1/6 bg-pink-500/60 rounded-t-sm h-[50%]"></div>
            <div class="w-1/6 bg-pink-500/80 rounded-t-sm h-[80%]"></div>
            <div class="w-1/6 bg-pink-400 rounded-t-sm h-[60%]"></div>
            <div class="w-1/6 bg-pink-500/40 rounded-t-sm h-[40%]"></div>
            <div class="w-1/6 bg-pink-500/90 rounded-t-sm h-[100%] shadow-[0_0_10px_#ec4899]"></div>
        </div>
    </div>

</div>

<div class="glass-card rounded-[2rem] overflow-hidden mb-8">
    <div class="p-8 border-b border-white/5 flex justify-between items-center bg-white/[0.02]">
        <h3 class="text-xl font-black tracking-wide text-white"><i class="fa-solid fa-bolt text-cyan-400 mr-2"></i> Sistemdeki Aktif Kişiler</h3>
        <a href="/Admin/Doktorlar/Index" class="text-sm font-bold text-cyan-400 hover:text-cyan-300 transition">Tümünü Gör <i class="fa-solid fa-arrow-right text-xs ml-1"></i></a>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left whitespace-nowrap">
            <thead class="bg-black/20">
                <tr>
                    <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-white/5">Hekim Adı</th>
                    <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-white/5">Birim</th>
                    <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-white/5">Durum</th>
                    <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-white/5 text-right">İşlem</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
                @if (aktifKisiler.Any())
                {
                    foreach (var item in aktifKisiler)
                    {
                        var adIlk = string.IsNullOrWhiteSpace(item.Ad) ? string.Empty : item.Ad.Substring(0, 1);
                        var soyadIlk = string.IsNullOrWhiteSpace(item.Soyad) ? string.Empty : item.Soyad.Substring(0, 1);
                        var kisaltma = (adIlk + soyadIlk).ToUpper();
                        if (string.IsNullOrWhiteSpace(kisaltma))
                        {
                            kisaltma = "--";
                        }
                        <tr class="hover:bg-white/5 transition duration-200">
                            <td class="px-8 py-5">
                                <div class="flex items-center gap-4">
                                    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center font-black text-white shadow-[0_0_15px_rgba(99,102,241,0.4)]">@kisaltma</div>
                                    <div>
                                        <p class="font-bold text-white text-sm">@item.Ad @item.Soyad</p>
                                        <p class="text-xs text-slate-400 font-medium">@(string.IsNullOrWhiteSpace(item.Unvan) ? "Uzman" : item.Unvan)</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-8 py-5"><span class="text-sm font-bold text-cyan-300 bg-cyan-500/10 border border-cyan-500/20 px-3 py-1.5 rounded-lg">@(item.Bolum?.Ad ?? "Birim atanmadı")</span></td>
                            <td class="px-8 py-5">
                                <span class="flex items-center gap-2 text-xs font-bold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-3 py-1.5 rounded-lg w-max">
                                    <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse shadow-[0_0_5px_#34d399]"></span> Aktif
                                </span>
                            </td>
                            <td class="px-8 py-5 text-right">
                                <a href="/Admin/Doktorlar/Edit/@item.Id" class="w-8 h-8 rounded-lg bg-white/5 hover:bg-white/20 text-white transition flex items-center justify-center ml-auto border border-white/10"><i class="fa-solid fa-ellipsis"></i></a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="px-8 py-8 text-center text-slate-500 italic">Aktif kişi kaydı bulunamadı.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>