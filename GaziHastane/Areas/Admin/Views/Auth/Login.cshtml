@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GaziMed | Yönetim Paneli Girişi</title>

    <!-- Scripts & Fonts -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Plus Jakarta Sans', 'sans-serif'] },
                    animation: {
                        'pulse-slow': 'pulse 8s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        'blob': 'blob 7s infinite',
                    },
                    keyframes: {
                        blob: {
                            "0%": { transform: "translate(0px, 0px) scale(1)" },
                            "33%": { transform: "translate(30px, -50px) scale(1.1)" },
                            "66%": { transform: "translate(-20px, 20px) scale(0.9)" },
                            "100%": { transform: "translate(0px, 0px) scale(1)" },
                        }
                    }
                }
            }
        }
    </script>

    <style>
        body {
            background-color: #020617;
            overflow: hidden;
        }

        /* Arkaplan Işık Sızıntıları */
        .light-glow {
            position: absolute;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(56, 189, 248, 0.15) 0%, rgba(56, 189, 248, 0) 70%);
            filter: blur(60px);
            z-index: -1;
        }

        .glass-panel {
            background: rgba(15, 23, 42, 0.7);
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.8);
        }

        .input-focus-ring:focus {
            box-shadow: 0 0 0 2px rgba(15, 23, 42, 1), 0 0 0 4px rgba(56, 189, 248, 0.4);
        }

        /* Parıltı Efekti */
        .shimmer {
            position: relative;
            overflow: hidden;
        }

            .shimmer::after {
                content: '';
                position: absolute;
                top: -50%;
                left: -50%;
                width: 200%;
                height: 200%;
                background: linear-gradient(45deg, transparent, rgba(255,255,255,0.03), transparent);
                transform: rotate(45deg);
                animation: shimmer-effect 6s infinite;
            }

        @@keyframes shimmer-effect {
            0% {
                transform: translateX(-100%) rotate(45deg);
            }

            100% {
                transform: translateX(100%) rotate(45deg);
            }
        }
    </style>
</head>
<body class="flex items-center justify-center min-h-screen text-slate-200 antialiased">

    <!-- Dinamik Arkaplan -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="light-glow top-[-10%] left-[-5%] animate-pulse-slow"></div>
        <div class="light-glow bottom-[-10%] right-[-5%] animate-pulse-slow" style="background: radial-gradient(circle, rgba(139, 92, 246, 0.12) 0%, rgba(139, 92, 246, 0) 70%); transition-delay: 2s;"></div>

        <div class="absolute top-1/4 left-1/3 w-72 h-72 bg-purple-500/10 rounded-full mix-blend-screen filter blur-[80px] animate-blob"></div>
        <div class="absolute top-1/2 right-1/4 w-96 h-96 bg-cyan-500/10 rounded-full mix-blend-screen filter blur-[80px] animate-blob" style="animation-delay: 2s;"></div>
    </div>

    <!-- Login Kartı -->
    <div class="glass-panel w-full max-w-[440px] rounded-[2.5rem] p-10 relative z-10 mx-4 shimmer">

        <!-- Logo -->
        <div class="text-center mb-10">
            <div class="relative inline-block group">
                <div class="absolute -inset-1 bg-gradient-to-r from-cyan-500 to-purple-600 rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000"></div>
                <div class="relative w-16 h-16 bg-slate-900 rounded-2xl flex items-center justify-center border border-white/10 mb-4 mx-auto">
                    <i class="fa-solid fa-staff-snake text-3xl bg-gradient-to-tr from-cyan-400 to-purple-400 bg-clip-text text-transparent"></i>
                </div>
            </div>
            <h1 class="text-3xl font-extrabold tracking-tighter text-white">
                GAZİ<span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">MED</span>
            </h1>
            <p class="text-[10px] text-slate-500 uppercase tracking-[0.3em] font-bold mt-2">Güvenli Yönetim Üssü</p>
        </div>

        <!-- Hata Mesajı -->
        @if (ViewBag.ErrorMessage != null)
        {
            <div class="bg-red-500/10 border border-red-500/20 text-red-400 text-xs font-semibold px-4 py-3 rounded-xl mb-6 flex items-center gap-3 animate-pulse">
                <i class="fa-solid fa-circle-exclamation"></i>
                @ViewBag.ErrorMessage
            </div>
        }

        <!-- FORM BAŞLANGICI -->
        <form method="post" asp-action="Login" class="space-y-6">
            @Html.AntiForgeryToken()

            <!-- E-Posta -->
            <div class="space-y-2">
                <label class="text-[11px] font-bold text-slate-500 uppercase tracking-widest ml-1">Kurumsal E-Posta</label>
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <i class="fa-solid fa-envelope text-slate-600 group-focus-within:text-cyan-500 transition-colors"></i>
                    </div>
                    <input type="email" name="email" required placeholder="admin@gazihastanesi.com"
                           class="w-full bg-slate-950/50 border border-white/5 rounded-xl py-3.5 pl-11 pr-4 text-white placeholder-slate-600 transition-all focus:bg-slate-900 focus:border-cyan-500/50 outline-none input-focus-ring">
                </div>
            </div>

            <!-- Şifre -->
            <div class="space-y-2">
                <label class="text-[11px] font-bold text-slate-500 uppercase tracking-widest ml-1">Güvenli Şifre</label>
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <i class="fa-solid fa-shield-halved text-slate-600 group-focus-within:text-cyan-500 transition-colors"></i>
                    </div>
                    <input type="password" name="sifre" required placeholder="••••••••"
                           class="w-full bg-slate-950/50 border border-white/5 rounded-xl py-3.5 pl-11 pr-4 text-white placeholder-slate-600 transition-all focus:bg-slate-900 focus:border-cyan-500/50 outline-none input-focus-ring tracking-[0.3em]">
                </div>
            </div>

            <!-- Submit -->
            <button type="submit" class="group relative w-full flex items-center justify-center p-0.5 overflow-hidden text-sm font-bold text-white rounded-xl bg-gradient-to-br from-cyan-500 to-blue-600 hover:shadow-[0_0_20px_rgba(6,182,212,0.3)] transition-all duration-300 transform hover:scale-[1.01] active:scale-95">
                <span class="relative w-full px-5 py-4 transition-all ease-in duration-75 bg-slate-900 rounded-[10px] group-hover:bg-opacity-0 flex items-center justify-center gap-3">
                    SİSTEME GİRİŞ YAP
                    <i class="fa-solid fa-arrow-right-to-bracket opacity-70 group-hover:translate-x-1 transition-transform"></i>
                </span>
            </button>
        </form>
        <!-- FORM BİTİŞİ -->
        <!-- Footer -->
        <div class="mt-10 pt-6 border-t border-white/5 text-center">
            <div class="flex items-center justify-center gap-4 mb-4 opacity-30">
                <i class="fa-solid fa-fingerprint text-white text-lg"></i>
                <i class="fa-solid fa-microchip text-white text-lg"></i>
                <i class="fa-solid fa-key text-white text-lg"></i>
            </div>
            <p class="text-[9px] text-slate-600 font-medium uppercase tracking-[0.2em] leading-relaxed">
                İzinsiz giriş denemeleri kayıt altına alınır.<br>
                &copy; @DateTime.Now.Year GAZİ HASTANESİ BİLİŞİM
            </p>
        </div>
    </div>

</body>
</html>