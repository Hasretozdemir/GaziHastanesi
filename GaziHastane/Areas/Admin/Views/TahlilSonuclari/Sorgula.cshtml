@model GaziHastane.Models.TahlilSonucSorguViewModel
@{
    ViewData["Title"] = "T.C. ile Tahlil Sorgula";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="max-w-5xl mx-auto pt-8 pb-12 px-4">
    <div class="mb-8 flex justify-between items-end">
        <div>
            <h2 class="text-3xl md:text-4xl font-black mb-2 tracking-tight">T.C. ile <span class="text-gradient">Tahlil Sorgula</span></h2>
            <p class="text-slate-400 font-medium">Hastanın T.C. kimlik numarası ile kayıtlı tüm tahlilleri görüntüleyin.</p>
        </div>
        <a href="/Admin/TahlilSonuclari/Giris" class="text-cyan-400 hover:text-cyan-300 text-sm font-bold">Yeni Sonuç Girişi</a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="mb-4 rounded-xl border border-rose-500/30 bg-rose-500/10 px-4 py-3 text-rose-300 text-sm font-bold">@TempData["Error"]</div>
    }

    <div class="glass-card p-6 rounded-[2rem] mb-6">
        <form method="get" asp-action="Sorgula" class="flex flex-col md:flex-row gap-3">
            <input name="tcKimlikNo" value="@Model.TCKimlikNo" maxlength="11" placeholder="11 haneli T.C. Kimlik No" class="flex-1 bg-black/20 border border-white/10 rounded-xl py-3 px-4 text-sm text-white focus:outline-none focus:border-cyan-500/50" />
            <button type="submit" class="bg-gradient-to-r from-cyan-500 to-blue-600 text-white px-6 py-3 rounded-xl font-bold text-sm">Sorgula</button>
        </form>
    </div>

    @if (Model.Hasta != null)
    {
        <div class="mb-4 text-slate-300 text-sm font-semibold">Hasta: <span class="text-white font-black">@Model.Hasta.Ad @Model.Hasta.Soyad</span> · TC: @Model.Hasta.TCKimlikNo</div>

        @if (Model.Sonuclar.Any())
        {
            <div class="glass-card rounded-[2rem] overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left whitespace-nowrap">
                        <thead class="bg-black/20">
                            <tr>
                                <th class="px-6 py-3 text-[11px] font-black text-slate-400 uppercase tracking-widest">Tarih</th>
                                <th class="px-6 py-3 text-[11px] font-black text-slate-400 uppercase tracking-widest">Kategori</th>
                                <th class="px-6 py-3 text-[11px] font-black text-slate-400 uppercase tracking-widest">Test</th>
                                <th class="px-6 py-3 text-[11px] font-black text-slate-400 uppercase tracking-widest">Sonuç</th>
                                <th class="px-6 py-3 text-[11px] font-black text-slate-400 uppercase tracking-widest">Referans</th>
                                <th class="px-6 py-3 text-[11px] font-black text-slate-400 uppercase tracking-widest">Doktor</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/5">
                            @foreach (var item in Model.Sonuclar)
                            {
                                <tr class="hover:bg-white/5">
                                    <td class="px-6 py-4 text-slate-300 text-sm">@item.Tarih.ToString("dd.MM.yyyy")</td>
                                    <td class="px-6 py-4 text-slate-300 text-sm">@(item.TestKategorisi ?? "Laboratuvar")</td>
                                    <td class="px-6 py-4 text-white text-sm font-bold">@item.TestAdi</td>
                                    <td class="px-6 py-4 text-slate-300 text-sm">@(string.IsNullOrWhiteSpace(item.SonucDegeri) ? "-" : item.SonucDegeri)</td>
                                    <td class="px-6 py-4 text-slate-400 text-sm">@(string.IsNullOrWhiteSpace(item.ReferansAraligi) ? "-" : item.ReferansAraligi)</td>
                                    <td class="px-6 py-4 text-slate-400 text-sm">@(item.Doktor != null ? $"{item.Doktor.Ad} {item.Doktor.Soyad}" : "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="rounded-xl border border-slate-700 bg-slate-800/40 px-4 py-4 text-slate-300 text-sm">Bu hastaya ait tahlil kaydı bulunamadı.</div>
        }
    }
</div>
