@model GaziHastane.Models.Bolum
@{
    ViewData["Title"] = "Poliklinik Sil";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="flex items-center justify-center min-h-[70vh]">
    <div class="glass-card p-10 rounded-[2rem] relative overflow-hidden max-w-lg w-full text-center">
        <div class="absolute inset-0 bg-gradient-to-b from-rose-500/5 to-transparent pointer-events-none"></div>
        <div class="absolute -top-20 -right-20 w-40 h-40 bg-rose-500/20 rounded-full blur-3xl pointer-events-none"></div>

        <div class="w-20 h-20 rounded-full bg-rose-500/20 border border-rose-500/30 flex items-center justify-center text-rose-400 text-3xl mx-auto mb-6 shadow-[0_0_20px_rgba(244,63,94,0.3)]">
            <i class="fa-solid fa-triangle-exclamation animate-pulse"></i>
        </div>

        <h2 class="text-3xl font-black text-white mb-2 tracking-tight">Emin misiniz?</h2>
        <p class="text-slate-400 text-sm font-medium mb-8">Aşağıdaki poliklinik/bölüm sistemden kalıcı olarak silinecektir. Eğer bu bölüme bağlı doktorlar varsa, silme işlemi hata verebilir!</p>

        <div class="bg-black/30 border border-white/5 rounded-2xl p-6 flex items-center gap-5 text-left mb-8">
            @if (!string.IsNullOrEmpty(Model.FotografUrl))
            {
                <img src="@Model.FotografUrl" class="w-16 h-16 rounded-2xl object-cover shadow-[0_0_15px_rgba(0,0,0,0.5)]" alt="@Model.Ad">
            }
            else
            {
                <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-pink-500 to-purple-600 flex items-center justify-center font-black text-xl text-white shadow-[0_0_15px_rgba(236,72,153,0.4)]">
                    <i class="fa-solid fa-stethoscope"></i>
                </div>
            }
            <div>
                <p class="font-bold text-white text-lg">@Model.Ad</p>
                <p class="text-sm text-pink-400 font-bold mt-1"><i class="fa-solid fa-layer-group text-xs mr-1"></i> @(string.IsNullOrEmpty(Model.Kategori) ? "Genel Kategori" : Model.Kategori)</p>
            </div>
        </div>

        <form asp-action="Delete" method="post" class="flex flex-col sm:flex-row gap-4 justify-center relative z-10">
            <input type="hidden" asp-for="Id" />
            <a href="/Admin/Bolumler/Index" class="px-6 py-3 rounded-xl font-bold text-sm text-slate-300 bg-white/5 hover:bg-white/10 hover:text-white transition w-full sm:w-auto">
                Vazgeç
            </a>
            <button type="submit" class="bg-gradient-to-r from-rose-500 to-pink-600 text-white px-8 py-3 rounded-xl font-bold text-sm shadow-[0_0_20px_rgba(244,63,94,0.3)] hover:scale-105 transition flex items-center justify-center gap-2 w-full sm:w-auto">
                <i class="fa-solid fa-trash"></i> Evet, Kalıcı Olarak Sil
            </button>
        </form>
    </div>
</div>