@model GaziHastane.Models.Bolum
@{
    ViewData["Title"] = "Yeni Poliklinik Ekle";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="max-w-4xl mx-auto pt-8 pb-12 px-4">

    <div class="mb-8 flex flex-col items-center text-center">
        <a href="/Admin/Bolumler/Index" class="text-pink-400 hover:text-pink-300 text-sm font-bold flex items-center gap-2 mb-4 transition">
            <i class="fa-solid fa-arrow-left"></i> Listeye Dön
        </a>
        <h2 class="text-3xl md:text-4xl font-black mb-2 tracking-tight">Yeni <span class="text-gradient">Bölüm Ekle</span> 🏥</h2>
        <p class="text-slate-400 font-medium">Hastaneye yeni bir poliklinik veya tıbbi birim ekleyin.</p>
    </div>

    <div class="glass-card p-8 md:p-10 rounded-[2rem] relative overflow-hidden mb-10 shadow-2xl">
        <div class="absolute -right-20 -top-20 w-64 h-64 bg-pink-500/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute -left-20 -bottom-20 w-64 h-64 bg-purple-500/10 rounded-full blur-3xl pointer-events-none"></div>

        <form asp-action="Create" method="post" enctype="multipart/form-data" class="relative z-10">
            <div asp-validation-summary="ModelOnly" class="text-rose-400 mb-4 text-sm font-bold bg-rose-500/10 p-3 rounded-lg border border-rose-500/20 hidden"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div class="md:col-span-2">
                    <label asp-for="Ad" class="block text-[11px] font-black text-slate-400 uppercase tracking-widest mb-2">Poliklinik / Birim Adı *</label>
                    <div class="relative">
                        <i class="fa-solid fa-house-medical absolute left-4 top-1/2 -translate-y-1/2 text-slate-500"></i>
                        <input asp-for="Ad" required class="w-full bg-black/20 border border-white/10 rounded-xl py-3 pl-11 pr-4 text-sm font-medium text-white placeholder-slate-600 focus:outline-none focus:border-pink-500/50 focus:ring-1 focus:ring-pink-500/50 transition" placeholder="Örn: Kardiyoloji, Göz Hastalıkları vb.">
                    </div>
                </div>

                <div>
                    <label asp-for="Kategori" class="block text-[11px] font-black text-slate-400 uppercase tracking-widest mb-2">Kategori</label>
                    <div class="relative">
                        <i class="fa-solid fa-layer-group absolute left-4 top-1/2 -translate-y-1/2 text-slate-500"></i>
                        <input asp-for="Kategori" class="w-full bg-black/20 border border-white/10 rounded-xl py-3 pl-11 pr-4 text-sm font-medium text-white placeholder-slate-600 focus:outline-none focus:border-pink-500/50 focus:ring-1 focus:ring-pink-500/50 transition" placeholder="Örn: Cerrahi Bilimler, Dahiliye vb.">
                    </div>
                </div>

                <div>
                    <label class="block text-[11px] font-black text-slate-400 uppercase tracking-widest mb-2">Bölüm Fotoğrafı</label>
                    <div class="flex items-center gap-4 bg-black/20 border border-white/10 rounded-xl p-2 pr-4 transition hover:border-pink-500/30">
                        <div class="w-12 h-12 bg-white/5 rounded-lg flex items-center justify-center border border-white/10 shrink-0">
                            <i class="fa-solid fa-image text-slate-500"></i>
                        </div>

                        <div class="flex-1 overflow-hidden">
                            <input type="file" name="GorselDosya" accept="image/*" class="block w-full text-sm text-slate-400
                                file:mr-4 file:py-2 file:px-4
                                file:rounded-lg file:border-0
                                file:text-xs file:font-bold
                                file:bg-pink-500/10 file:text-pink-400
                                hover:file:bg-pink-500/20
                                file:transition file:cursor-pointer cursor-pointer outline-none" />
                        </div>
                    </div>
                </div>

                <div class="md:col-span-2">
                    <label asp-for="Aciklama" class="block text-[11px] font-black text-slate-400 uppercase tracking-widest mb-2">Bölüm Açıklaması / Detaylar</label>
                    <textarea asp-for="Aciklama" rows="4" class="w-full bg-black/20 border border-white/10 rounded-xl p-4 text-sm font-medium text-white placeholder-slate-600 focus:outline-none focus:border-pink-500/50 focus:ring-1 focus:ring-pink-500/50 transition custom-scroll" placeholder="Bu poliklinikte verilen hizmetler hakkında kısa bilgi..."></textarea>
                </div>

                <div class="md:col-span-2 flex items-center gap-4 bg-black/20 p-5 rounded-xl border border-white/5">
                    <div class="relative flex items-center cursor-pointer">
                        <input asp-for="IsActive" type="checkbox" class="sr-only peer" checked>
                        <div class="w-11 h-6 bg-slate-600 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-pink-500 shadow-[0_0_10px_rgba(236,72,153,0.2)]"></div>
                    </div>
                    <div>
                        <p class="text-sm font-bold text-white mb-0.5">Poliklinik Hizmet Veriyor Mu?</p>
                        <p class="text-[10px] text-slate-400">Pasif yaparsanız, randevu sisteminde seçilemez hale gelir.</p>
                    </div>
                </div>
            </div>

            <div class="flex justify-end gap-4 mt-8 pt-6 border-t border-white/10">
                <a href="/Admin/Bolumler/Index" class="px-6 py-2.5 rounded-xl font-bold text-sm text-slate-300 hover:text-white hover:bg-white/5 transition flex items-center">
                    İptal Et
                </a>
                <button type="submit" class="bg-gradient-to-r from-pink-500 to-rose-600 text-white px-8 py-2.5 rounded-xl font-bold text-sm shadow-[0_0_20px_rgba(244,63,94,0.3)] hover:scale-105 transition flex items-center gap-2">
                    <i class="fa-solid fa-check"></i> Bölümü Kaydet
                </button>
            </div>
        </form>
    </div>
</div>