@model IEnumerable<GaziHastane.Models.Iletisim>
@{
    ViewData["Title"] = "İletişim Yönetimi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<style>
    .glass-card {
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(12px);
        border: 1px border-white/10;
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
    }

    .text-gradient {
        background: linear-gradient(135deg, #f97316 0%, #fbbf24 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .table-hover-row:hover {
        background: rgba(255, 255, 255, 0.03) !important;
        transition: all 0.3s ease;
    }
</style>

<div class="p-6 space-y-10">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h2 class="text-3xl md:text-4xl font-extrabold text-white tracking-tight">
                İletişim <span class="text-gradient">Bilgileri</span> 📞
            </h2>
            <p class="text-slate-400 mt-1 font-medium">Hastanenin lokasyon, santral ve ulaşım rehberini buradan yönetin.</p>
        </div>
    </div>

    <section>
        <div class="flex items-center justify-between mb-5 px-2">
            <div>
                <h3 class="text-xl font-bold text-white flex items-center gap-2">
                    <i class="fa-solid fa-map-location-dot text-amber-500"></i>
                    Ulaşım Rehberi Kartları
                </h3>
                <p class="text-slate-500 text-sm">İletişim sayfasındaki ulaşım kartlarını yönetin.</p>
            </div>
            <a href="/Admin/Iletisim/UlasimCreate" class="group bg-amber-500 hover:bg-amber-600 text-white px-5 py-2.5 rounded-xl font-bold text-sm shadow-lg shadow-amber-500/20 transition-all flex items-center gap-2">
                <i class="fa-solid fa-plus group-hover:rotate-90 transition-transform"></i>
                Ulaşım Kartı Ekle
            </a>
        </div>

        <div class="glass-card rounded-[1.5rem] border border-white/5 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-white/5 border-b border-white/10">
                        <tr>
                            <th class="px-6 py-4 text-[11px] font-bold text-slate-400 uppercase tracking-widest">Başlık</th>
                            <th class="px-6 py-4 text-[11px] font-bold text-slate-400 uppercase tracking-widest text-center">İkon</th>
                            <th class="px-6 py-4 text-[11px] font-bold text-slate-400 uppercase tracking-widest">Tema</th>
                            <th class="px-6 py-4 text-[11px] font-bold text-slate-400 uppercase tracking-widest">Durum</th>
                            <th class="px-6 py-4 text-[11px] font-bold text-slate-400 uppercase tracking-widest text-right">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5 text-sm">
                        @if (ViewBag.UlasimRehberleri != null)
                        {
                            foreach (var item in ViewBag.UlasimRehberleri)
                            {
                                <tr class="table-hover-row">
                                    <td class="px-6 py-4 text-white font-semibold">@item.UlasimTipi</td>
                                    <td class="px-6 py-4 text-center">
                                        <div class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-white/5 text-amber-400 border border-white/10">
                                            <i class="@item.Ikon"></i>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="flex items-center gap-2 text-slate-300">
                                            <span class="w-3 h-3 rounded-full" style="background-color:@item.TemaRengi"></span>
                                            @item.TemaRengi
                                        </span>
                                    </td>
                                    <td class="px-6 py-4">
                                        @if (item.IsActive)
                                        {
                                            <span class="px-3 py-1 rounded-full bg-emerald-500/10 text-emerald-400 text-[10px] font-bold border border-emerald-500/20">Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="px-3 py-1 rounded-full bg-rose-500/10 text-rose-400 text-[10px] font-bold border border-rose-500/20">Pasif</span>
                                        }
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <div class="flex justify-end gap-2">
                                            <a href="/Admin/Iletisim/UlasimEdit/@item.Id" class="p-2 rounded-lg bg-blue-500/10 text-blue-400 hover:bg-blue-500 hover:text-white transition-all"><i class="fa-solid fa-pen-to-square"></i></a>
                                            <a href="/Admin/Iletisim/UlasimDelete/@item.Id" class="p-2 rounded-lg bg-rose-500/10 text-rose-400 hover:bg-rose-500 hover:text-white transition-all"><i class="fa-solid fa-trash"></i></a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <section>
        <div class="flex items-center justify-between mb-5 px-2">
            <div>
                <h3 class="text-xl font-bold text-white flex items-center gap-2">
                    <i class="fa-solid fa-hospital text-orange-500"></i>
                    Şube ve Adres Bilgileri
                </h3>
                <p class="text-slate-500 text-sm">Hastane şubelerini ve santral numaralarını yönetin.</p>
            </div>
            <a href="/Admin/Iletisim/Create" class="group bg-orange-500 hover:bg-orange-600 text-white px-5 py-2.5 rounded-xl font-bold text-sm shadow-lg shadow-orange-500/20 transition-all flex items-center gap-2">
                <i class="fa-solid fa-location-plus group-hover:scale-110 transition-transform"></i>
                Yeni Adres Ekle
            </a>
        </div>

        <div class="glass-card rounded-[1.5rem] border border-white/5 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-white/5 border-b border-white/10">
                        <tr>
                            <th class="px-6 py-4 text-[11px] font-bold text-slate-400 uppercase tracking-widest">Şube / Adres</th>
                            <th class="px-6 py-4 text-[11px] font-bold text-slate-400 uppercase tracking-widest">Santral</th>
                            <th class="px-6 py-4 text-[11px] font-bold text-slate-400 uppercase tracking-widest">Durum</th>
                            <th class="px-6 py-4 text-[11px] font-bold text-slate-400 uppercase tracking-widest text-right">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5 text-sm">
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr class="table-hover-row">
                                    <td class="px-6 py-5">
                                        <div class="flex items-center gap-4">
                                            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-orange-500 to-amber-500 flex items-center justify-center text-white shadow-lg">
                                                <i class="fa-solid fa-building"></i>
                                            </div>
                                            <div>
                                                <p class="font-bold text-white">@item.Baslik</p>
                                                <p class="text-[11px] text-slate-400 max-w-[250px] truncate">@item.KisaAdres</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-5">
                                        <span class="text-slate-300 font-medium">
                                            <i class="fa-solid fa-phone text-orange-400 mr-2 opacity-70"></i>
                                            @(string.IsNullOrEmpty(item.Santral) ? "-" : item.Santral)
                                        </span>
                                    </td>
                                    <td class="px-6 py-5">
                                        @if (item.IsActive)
                                        {
                                            <span class="px-3 py-1 rounded-full bg-emerald-500/10 text-emerald-400 text-[10px] font-bold border border-emerald-500/20">Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="px-3 py-1 rounded-full bg-rose-500/10 text-rose-400 text-[10px] font-bold border border-rose-500/20">Pasif</span>
                                        }
                                    </td>
                                    <td class="px-6 py-5 text-right">
                                        <div class="flex justify-end gap-2">
                                            <a href="/Admin/Iletisim/Edit/@item.Id" class="p-2 rounded-lg bg-blue-500/10 text-blue-400 hover:bg-blue-500 hover:text-white transition-all"><i class="fa-solid fa-pen-to-square"></i></a>
                                            <a href="/Admin/Iletisim/Delete/@item.Id" class="p-2 rounded-lg bg-rose-500/10 text-rose-400 hover:bg-rose-500 hover:text-white transition-all"><i class="fa-solid fa-trash"></i></a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="px-6 py-10 text-center text-slate-500 italic">Kayıtlı adres bulunamadı.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</div>
