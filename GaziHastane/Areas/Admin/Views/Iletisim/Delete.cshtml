@model GaziHastane.Models.Iletisim
@{
    ViewData["Title"] = "Adres Sil"; Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
<div class="flex justify-center min-h-[70vh] items-center">
    <div class="glass-card p-10 rounded-[2rem] text-center max-w-lg w-full">
        <div class="w-20 h-20 rounded-full bg-rose-500/20 flex items-center justify-center text-rose-400 text-3xl mx-auto mb-6">
            <i class="fa-solid fa-triangle-exclamation"></i>
        </div>
        <h2 class="text-3xl font-black text-white mb-2">Emin misiniz?</h2>
        <p class="text-slate-400 mb-8"><strong>@Model.Baslik</strong> kalıcı olarak silinecektir.</p>
        <form asp-action="Delete" method="post" class="flex justify-center gap-4">
            <input type="hidden" asp-for="Id" />
            <a href="/Admin/Iletisim/Index" class="px-6 py-3 rounded-xl font-bold text-slate-300 bg-white/5 hover:text-white transition">Vazgeç</a>
            <button type="submit" class="bg-rose-500 text-white px-8 py-3 rounded-xl font-bold shadow-lg hover:scale-105">Kalıcı Olarak Sil</button>
        </form>
    </div>
</div>