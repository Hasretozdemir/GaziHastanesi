@model GaziHastane.Models.UlasimRehberi
@{
    ViewData["Title"] = "Ulaţým Kartý Sil";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="max-w-xl mx-auto pt-10">
    <div class="glass-card p-8 rounded-3xl text-center">
        <h3 class="text-2xl font-black text-white mb-3">Kart silinsin mi?</h3>
        <p class="text-slate-300 mb-1">@Model.UlasimTipi</p>
        <p class="text-slate-500 text-sm mb-6">Bu iţlem geri alýnamaz.</p>

        <form asp-action="UlasimDelete" method="post" class="flex justify-center gap-3">
            <input type="hidden" asp-for="Id" />
            <a href="/Admin/Iletisim/Index" class="px-5 py-2.5 rounded-xl font-bold text-slate-300">Vazgeç</a>
            <button type="submit" class="bg-gradient-to-r from-rose-500 to-red-600 text-white px-6 py-2.5 rounded-xl font-bold">Sil</button>
        </form>
    </div>
</div>
