@model IEnumerable<GaziHastane.Models.HastaRehberi>
@{
    ViewData["Title"] = "Hasta Rehberi Yönetimi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="mb-8 pl-2 flex justify-between items-end">
    <div>
        <h2 class="text-3xl md:text-4xl font-black mb-2 tracking-tight">Hasta <span class="text-gradient">Rehberi</span> 📖</h2>
        <p class="text-slate-400 font-medium">Ziyaret kuralları, yatış-çıkış işlemleri ve hasta bilgilendirme yazılarını yönetin.</p>
    </div>
    <a href="/Admin/HastaRehberi/Create" class="bg-gradient-to-r from-emerald-500 to-teal-600 text-white px-6 py-2.5 rounded-xl font-bold text-sm shadow-[0_0_20px_rgba(16,185,129,0.3)] hover:scale-105 transition">
        <i class="fa-solid fa-plus mr-2"></i>Yeni Başlık Ekle
    </a>
</div>

<div class="glass-card rounded-[2rem] overflow-hidden mb-8">
    <div class="overflow-x-auto">
        <table class="w-full text-left whitespace-nowrap">
            <thead class="bg-black/20">
                <tr>
                    <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-white/5 w-16">Sıra</th>
                    <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-white/5">Rehber Başlığı</th>
                    <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-white/5">Durum</th>
                    <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-white/5 text-right">İşlemler</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr class="hover:bg-white/5 transition duration-200">
                            <td class="px-8 py-5">
                                <span class="w-8 h-8 rounded-lg bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 font-bold flex items-center justify-center text-sm">
                                    @item.SiraNo
                                </span>
                            </td>
                            <td class="px-8 py-5">
                                <div class="flex items-center gap-4">
                                    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center font-black text-white shadow-[0_0_15px_rgba(16,185,129,0.4)]">
                                        <i class="@(string.IsNullOrEmpty(item.Ikon) ? "fa-solid fa-file-lines" : item.Ikon) text-sm"></i>
                                    </div>
                                    <div>
                                        <p class="font-bold text-white text-sm">@item.Baslik</p>
                                        <p class="text-xs text-slate-400 w-64 truncate">@item.Icerik</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-8 py-5">
                                @if (item.IsActive)
                                {
                                    <span class="flex items-center gap-2 text-xs font-bold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-3 py-1.5 rounded-lg w-max">
                                        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse shadow-[0_0_5px_#34d399]"></span> Yayında
                                    </span>
                                }
                                else
                                {
                                    <span class="flex items-center gap-2 text-xs font-bold text-rose-400 bg-rose-500/10 border border-rose-500/20 px-3 py-1.5 rounded-lg w-max">
                                        <span class="w-2 h-2 rounded-full bg-rose-400 shadow-[0_0_5px_#f43f5e]"></span> Gizli
                                    </span>
                                }
                            </td>
                            <td class="px-8 py-5 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="/Admin/HastaRehberi/Edit/@item.Id" class="w-8 h-8 rounded-lg bg-blue-500/10 hover:bg-blue-500/30 text-blue-400 transition flex items-center justify-center border border-blue-500/20">
                                        <i class="fa-solid fa-pen text-xs"></i>
                                    </a>
                                    <a href="/Admin/HastaRehberi/Delete/@item.Id" class="w-8 h-8 rounded-lg bg-rose-500/10 hover:bg-rose-500/30 text-rose-400 transition flex items-center justify-center border border-rose-500/20">
                                        <i class="fa-solid fa-trash text-xs"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="px-8 py-12 text-center text-slate-400">
                            <i class="fa-solid fa-book-medical text-4xl mb-4 opacity-50 block"></i>
                            <p>Sistemde henüz bir rehber içeriği bulunmamaktadır.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>