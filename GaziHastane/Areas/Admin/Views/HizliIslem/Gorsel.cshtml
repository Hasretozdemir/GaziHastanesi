@model List<GaziHastane.Models.Medya>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Kurumsal Slider Yönetimi";
}

<div class="space-y-6">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h2 class="text-3xl font-black text-white tracking-tight">Kurumsal Slider Yönetimi</h2>
            <p class="text-slate-400 text-sm">Kurumsal slider görsellerini ekleyin, hedef sayfayı belirleyin ve sıralamayı yönetin.</p>
        </div>

        <button onclick="toggleModal('imageModal')" class="bg-gradient-to-r from-pink-600 to-purple-600 hover:from-pink-500 hover:to-purple-500 text-white px-6 py-3 rounded-2xl font-bold shadow-lg shadow-pink-500/20 transition-all flex items-center gap-2 group">
            <i class="fa-solid fa-camera-retro group-hover:rotate-12 transition-transform"></i>
            Yeni Görsel Ekle
        </button>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="rounded-xl border border-emerald-500/30 bg-emerald-500/10 text-emerald-300 px-4 py-3 text-sm font-semibold">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="rounded-xl border border-rose-500/30 bg-rose-500/10 text-rose-300 px-4 py-3 text-sm font-semibold">@TempData["Error"]</div>
    }

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="glass-card rounded-[2.5rem] overflow-hidden group relative border border-white/5 hover:border-white/20 transition-all duration-500">
                    <div class="aspect-[16/9] overflow-hidden relative">
                        <img src="@item.GorselYolu" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt="@item.Baslik" />

                        <div class="absolute top-4 left-4">
                            @if (item.IsSlider)
                            {
                                <span class="bg-cyan-500/20 backdrop-blur-md border border-cyan-500/30 text-cyan-400 text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest shadow-xl">Slider Aktif</span>
                            }
                            else
                            {
                                <span class="bg-slate-500/20 backdrop-blur-md border border-slate-500/30 text-slate-300 text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest shadow-xl">Slider Pasif</span>
                            }
                        </div>
                    </div>

                    <div class="p-6">
                        <h4 class="font-bold text-slate-200 truncate mb-2">@item.Baslik</h4>
                        <p class="text-[11px] text-slate-400 truncate mb-4">@(string.IsNullOrWhiteSpace(item.HedefUrl) ? "Hedef sayfa yok" : item.HedefUrl)</p>

                        <div class="flex items-center justify-between border-t border-white/5 pt-4">
                            <label class="flex items-center cursor-pointer group/toggle">
                                <div class="relative">
                                    <input type="checkbox" class="sr-only peer" @(item.IsSlider ? "checked" : "") onchange="updateSliderStatus(@item.Id, this.checked)">
                                    <div class="w-11 h-6 bg-slate-800 rounded-full peer peer-checked:after:translate-x-full peer-checked:bg-gradient-to-r peer-checked:from-cyan-500 peer-checked:to-blue-600 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all shadow-inner"></div>
                                </div>
                                <span class="ml-3 text-xs font-bold text-slate-500 group-hover/toggle:text-slate-300 transition-colors uppercase tracking-tighter">Slider</span>
                            </label>

                            <div class="flex gap-2">
                                <button onclick="openEditModal(@item.Id, '@(item.Baslik?.Replace("'", "\\'") ?? "")', '@(item.HedefUrl?.Replace("'", "\\'") ?? "")', @item.SiraNo, @(item.IsSlider.ToString().ToLower()), @(item.IsActive.ToString().ToLower()))" class="w-9 h-9 flex items-center justify-center rounded-xl bg-white/5 text-slate-400 hover:bg-white/10 hover:text-white transition-all" title="Düzenle">
                                    <i class="fa-solid fa-pen-to-square text-sm"></i>
                                </button>
                                <form asp-action="GorselSil" method="post" onsubmit="return confirm('Bu görseli silmek istediğinize emin misiniz?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="w-9 h-9 flex items-center justify-center rounded-xl bg-rose-500/10 text-rose-500 hover:bg-rose-500 hover:text-white transition-all" title="Sil">
                                        <i class="fa-solid fa-trash-can text-sm"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<div id="imageModal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4 bg-black/80 backdrop-blur-md">
    <div class="glass-card w-full max-w-xl rounded-[3rem] p-10 shadow-2xl border border-white/10 relative overflow-hidden">
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-purple-600/20 rounded-full blur-3xl"></div>

        <div class="flex justify-between items-center mb-8 relative z-10">
            <div>
                <h3 class="text-2xl font-black text-white italic">KURUMSAL <span class="text-pink-500 underline decoration-2 underline-offset-4">SLIDER</span></h3>
                <p class="text-slate-400 text-xs mt-1 uppercase tracking-widest font-bold">Önerilen Boyut: 1920x1080px</p>
            </div>
            <button type="button" onclick="toggleModal('imageModal')" class="w-10 h-10 flex items-center justify-center rounded-full bg-white/5 text-slate-400 hover:text-white transition">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
        </div>

        <form asp-action="GorselYukle" asp-controller="HizliIslem" method="post" enctype="multipart/form-data" class="space-y-6 relative z-10">
            @Html.AntiForgeryToken()
            <div>
                <label class="block text-sm font-bold text-slate-400 mb-2 ml-1 uppercase tracking-wide">Görsel Başlığı</label>
                <input type="text" name="title" class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 px-5 text-white focus:outline-none focus:border-pink-500/50 focus:ring-4 focus:ring-pink-500/10 transition-all" required />
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-400 mb-2 ml-1 uppercase tracking-wide">Tıklama Hedefi (URL)</label>
                <input type="text" name="hedefUrl" placeholder="/Kurumsal/Index" class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 px-5 text-white focus:outline-none focus:border-pink-500/50 focus:ring-4 focus:ring-pink-500/10 transition-all" />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-bold text-slate-400 mb-2 ml-1 uppercase tracking-wide">Dosya Seçimi</label>
                    <input type="file" name="imageFile" accept="image/*" class="w-full bg-white/5 border border-white/10 rounded-2xl py-3 px-4 text-slate-400 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-black file:uppercase file:bg-pink-600 file:text-white hover:file:bg-pink-500 cursor-pointer" required />
                </div>

                <div>
                    <label class="block text-sm font-bold text-slate-400 mb-2 ml-1 uppercase tracking-wide">Sıra No</label>
                    <input type="number" name="siraNo" value="0" class="w-full bg-white/5 border border-white/10 rounded-2xl py-3 px-4 text-white focus:outline-none focus:border-pink-500/50" />
                </div>
            </div>

            <div class="flex items-end pb-2">
                <label class="flex items-center gap-4 bg-white/5 border border-white/10 p-4 rounded-2xl w-full cursor-pointer hover:bg-white/10 transition">
                    <input type="checkbox" name="isSlider" value="true" checked class="w-5 h-5 rounded-lg border-white/10 bg-black/20 text-pink-500 focus:ring-pink-500/20">
                    <span class="text-sm font-bold text-slate-300">Slider'da Göster</span>
                </label>
            </div>

            <button type="submit" class="w-full bg-gradient-to-r from-pink-600 to-purple-600 hover:scale-[1.02] active:scale-95 text-white font-black py-5 rounded-2xl shadow-xl shadow-pink-600/20 transition-all uppercase tracking-widest mt-4">
                Kaydet
            </button>
        </form>
    </div>
</div>

<div id="editModal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4 bg-black/80 backdrop-blur-md">
    <div class="glass-card w-full max-w-xl rounded-[3rem] p-10 shadow-2xl border border-white/10 relative overflow-hidden">
        <div class="flex justify-between items-center mb-8 relative z-10">
            <h3 class="text-2xl font-black text-white italic">SLIDER <span class="text-cyan-400">DÜZENLE</span></h3>
            <button type="button" onclick="toggleModal('editModal')" class="w-10 h-10 flex items-center justify-center rounded-full bg-white/5 text-slate-400 hover:text-white transition">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
        </div>

        <form asp-action="GorselDuzenle" asp-controller="HizliIslem" method="post" enctype="multipart/form-data" class="space-y-6">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="edit-id" />

            <div>
                <label class="block text-sm font-bold text-slate-400 mb-2 ml-1 uppercase tracking-wide">Görsel Başlığı</label>
                <input type="text" name="title" id="edit-title" class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 px-5 text-white" required />
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-400 mb-2 ml-1 uppercase tracking-wide">Tıklama Hedefi (URL)</label>
                <input type="text" name="hedefUrl" id="edit-hedef" class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 px-5 text-white" />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-bold text-slate-400 mb-2 ml-1 uppercase tracking-wide">Yeni Dosya (Opsiyonel)</label>
                    <input type="file" name="imageFile" accept="image/*" class="w-full bg-white/5 border border-white/10 rounded-2xl py-3 px-4 text-slate-400 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-black file:uppercase file:bg-cyan-600 file:text-white" />
                </div>

                <div>
                    <label class="block text-sm font-bold text-slate-400 mb-2 ml-1 uppercase tracking-wide">Sıra No</label>
                    <input type="number" name="siraNo" id="edit-sira" class="w-full bg-white/5 border border-white/10 rounded-2xl py-3 px-4 text-white" />
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <label class="flex items-center gap-3 bg-white/5 border border-white/10 p-4 rounded-2xl cursor-pointer">
                    <input type="checkbox" name="isSlider" id="edit-slider" value="true" class="w-5 h-5 rounded-lg">
                    <span class="text-sm font-bold text-slate-300">Slider Aktif</span>
                </label>
                <label class="flex items-center gap-3 bg-white/5 border border-white/10 p-4 rounded-2xl cursor-pointer">
                    <input type="checkbox" name="isActive" id="edit-active" value="true" class="w-5 h-5 rounded-lg">
                    <span class="text-sm font-bold text-slate-300">Yayında</span>
                </label>
            </div>

            <button type="submit" class="w-full bg-gradient-to-r from-cyan-600 to-blue-600 text-white font-black py-4 rounded-2xl uppercase tracking-widest">Güncelle</button>
        </form>
    </div>
</div>

<script>
    function toggleModal(id) {
        const modal = document.getElementById(id);
        modal.classList.toggle('hidden');
    }

    function openEditModal(id, baslik, hedefUrl, siraNo, isSlider, isActive) {
        document.getElementById('edit-id').value = id;
        document.getElementById('edit-title').value = baslik;
        document.getElementById('edit-hedef').value = hedefUrl;
        document.getElementById('edit-sira').value = siraNo;
        document.getElementById('edit-slider').checked = isSlider;
        document.getElementById('edit-active').checked = isActive;
        toggleModal('editModal');
    }

    function updateSliderStatus(id, status) {
        fetch('/Admin/HizliIslem/SliderDurumGuncelle', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
            },
            body: `id=${id}&status=${status}`
        });
    }
</script>