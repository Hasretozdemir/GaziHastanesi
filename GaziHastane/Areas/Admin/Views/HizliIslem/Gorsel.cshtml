@model List<GaziHastane.Models.Medya>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Görsel Yönetimi";
}

<div class="space-y-6">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h2 class="text-3xl font-black text-white tracking-tight">Görsel Yönetimi</h2>
            <p class="text-slate-400 text-sm">Veritabanındaki tüm görseller burada listelenir. URL bilgisini kopyalayıp sitede kullanabilirsiniz.</p>
        </div>

        <button onclick="toggleModal('imageModal')" class="bg-gradient-to-r from-pink-600 to-purple-600 hover:from-pink-500 hover:to-purple-500 text-white px-6 py-3 rounded-2xl font-bold shadow-lg shadow-pink-500/20 transition-all flex items-center gap-2 group">
            <i class="fa-solid fa-image group-hover:rotate-12 transition-transform"></i>
            Yeni Görsel Ekle
        </button>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="rounded-xl border border-emerald-500/30 bg-emerald-500/10 text-emerald-300 px-4 py-3 text-sm font-semibold">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="rounded-xl border border-rose-500/30 bg-rose-500/10 text-rose-300 px-4 py-3 text-sm font-semibold">@TempData["Error"]</div>
    }

    <div class="glass-card rounded-[2rem] overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left whitespace-nowrap">
                <thead class="bg-black/20 text-[11px] uppercase text-slate-400 tracking-widest">
                    <tr>
                        <th class="px-6 py-4">Görsel</th>
                        <th class="px-6 py-4">Başlık</th>
                        <th class="px-6 py-4">Alan</th>
                        <th class="px-6 py-4">URL</th>
                        <th class="px-6 py-4 text-right">İşlem</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="hover:bg-white/5 transition-colors">
                                <td class="px-6 py-4">
                                    <img src="@item.GorselYolu" alt="@item.Baslik" class="w-20 h-12 object-cover rounded-lg border border-white/10" />
                                </td>
                                <td class="px-6 py-4 text-slate-200 font-semibold">@item.Baslik</td>
                                <td class="px-6 py-4 text-indigo-300 text-sm">@item.Alan</td>
                                <td class="px-6 py-4 text-cyan-300 text-xs max-w-[360px] truncate" title="@item.GorselYolu">@item.GorselYolu</td>
                                <td class="px-6 py-4 text-right">
                                    <a href="@item.GorselYolu" target="_blank" class="px-3 py-1.5 rounded-lg bg-cyan-500/10 text-cyan-300 text-xs font-bold mr-2">Aç</a>
                                    <form asp-action="GorselSil" method="post" class="inline" onsubmit="return confirm('Bu görseli silmek istediğinize emin misiniz?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="px-3 py-1.5 rounded-lg bg-rose-500/10 text-rose-300 text-xs font-bold">Sil</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-6 text-slate-400 italic">Henüz kayıtlı görsel yok.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="imageModal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4 bg-black/80 backdrop-blur-md">
    <div class="glass-card w-full max-w-xl rounded-[3rem] p-10 shadow-2xl border border-white/10 relative overflow-hidden">
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-purple-600/20 rounded-full blur-3xl"></div>

        <div class="flex justify-between items-center mb-8 relative z-10">
            <div>
                <h3 class="text-2xl font-black text-white italic">YENİ <span class="text-pink-500 underline decoration-2 underline-offset-4">GÖRSEL</span></h3>
                <p class="text-slate-400 text-xs mt-1 uppercase tracking-widest font-bold">Yükleme sonrası URL tabloya düşer.</p>
            </div>
            <button type="button" onclick="toggleModal('imageModal')" class="w-10 h-10 flex items-center justify-center rounded-full bg-white/5 text-slate-400 hover:text-white transition">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
        </div>

        <form asp-action="GorselYukle" asp-controller="HizliIslem" method="post" enctype="multipart/form-data" class="space-y-6 relative z-10">
            @Html.AntiForgeryToken()
            <div>
                <label class="block text-sm font-bold text-slate-400 mb-2 ml-1 uppercase tracking-wide">Görsel Başlığı</label>
                <input type="text" name="title" class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 px-5 text-white focus:outline-none focus:border-pink-500/50 focus:ring-4 focus:ring-pink-500/10 transition-all" required />
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-400 mb-2 ml-1 uppercase tracking-wide">Alan</label>
                <select name="alan" class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 px-5 text-white">
                    <option class="bg-slate-800 text-white" value="Kurumsal">Kurumsal</option>
                    <option class="bg-slate-800 text-white" value="AnaSayfa">Ana Sayfa</option>
                    <option class="bg-slate-800 text-white" value="Genel">Genel</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-400 mb-2 ml-1 uppercase tracking-wide">Dosya Seçimi</label>
                <input type="file" name="imageFile" accept="image/*" class="w-full bg-white/5 border border-white/10 rounded-2xl py-3 px-4 text-slate-400 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-black file:uppercase file:bg-pink-600 file:text-white hover:file:bg-pink-500 cursor-pointer" required />
            </div>

            <button type="submit" class="w-full bg-gradient-to-r from-pink-600 to-purple-600 hover:scale-[1.02] active:scale-95 text-white font-black py-5 rounded-2xl shadow-xl shadow-pink-600/20 transition-all uppercase tracking-widest mt-4">
                Kaydet
            </button>
        </form>
    </div>
</div>

<script>
    function toggleModal(id) {
        const modal = document.getElementById(id);
        modal.classList.toggle('hidden');
    }
</script>