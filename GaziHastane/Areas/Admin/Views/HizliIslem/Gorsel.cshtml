@{
    Layout = "_Layout";
    ViewData["Title"] = "Medya & Slider Yönetimi";
}

<div class="space-y-6">
    <!-- Üst Başlık ve Aksiyon Butonu -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h2 class="text-3xl font-black text-white tracking-tight">Medya Kütüphanesi</h2>
            <p class="text-slate-400 text-sm">Görselleri yükleyin ve anasayfa slider içeriğini belirleyin.</p>
        </div>

        <button onclick="toggleModal('imageModal')" class="bg-gradient-to-r from-pink-600 to-purple-600 hover:from-pink-500 hover:to-purple-500 text-white px-6 py-3 rounded-2xl font-bold shadow-lg shadow-pink-500/20 transition-all flex items-center gap-2 group">
            <i class="fa-solid fa-camera-retro group-hover:rotate-12 transition-transform"></i>
            Yeni Görsel Ekle
        </button>
    </div>

    <!-- Görsel Kartları Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">

        <!-- Örnek Kart (Bu kısım döngü ile veritabanından gelecek) -->
        <div class="glass-card rounded-[2.5rem] overflow-hidden group relative border border-white/5 hover:border-white/20 transition-all duration-500">
            <!-- Görsel Alanı -->
            <div class="aspect-[16/9] overflow-hidden relative">
                <img src="https://picsum.photos/800/450?random=1" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt="Örnek" />

                <!-- Slider Rozeti -->
                <div class="absolute top-4 left-4">
                    <span class="bg-cyan-500/20 backdrop-blur-md border border-cyan-500/30 text-cyan-400 text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest shadow-xl">
                        Slider Aktif
                    </span>
                </div>
            </div>

            <!-- İçerik Alanı -->
            <div class="p-6">
                <h4 class="font-bold text-slate-200 truncate mb-4">Anasayfa Karşılama Görseli</h4>

                <div class="flex items-center justify-between border-t border-white/5 pt-4">
                    <!-- Slider Toggle (Hızlı Güncelleme) -->
                    <label class="flex items-center cursor-pointer group/toggle">
                        <div class="relative">
                            <input type="checkbox" class="sr-only peer" checked onchange="updateSliderStatus(1, this.checked)">
                            <div class="w-11 h-6 bg-slate-800 rounded-full peer peer-checked:after:translate-x-full peer-checked:bg-gradient-to-r peer-checked:from-cyan-500 peer-checked:to-blue-600 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all shadow-inner"></div>
                        </div>
                        <span class="ml-3 text-xs font-bold text-slate-500 group-hover/toggle:text-slate-300 transition-colors uppercase tracking-tighter">Slider</span>
                    </label>

                    <!-- Aksiyonlar -->
                    <div class="flex gap-2">
                        <button class="w-9 h-9 flex items-center justify-center rounded-xl bg-white/5 text-slate-400 hover:bg-white/10 hover:text-white transition-all" title="Düzenle">
                            <i class="fa-solid fa-pen-to-square text-sm"></i>
                        </button>
                        <form asp-action="Sil" asp-route-id="1" asp-route-type="gorsel" method="post" onsubmit="return confirm('Bu görseli silmek istediğinize emin misiniz?')">
                            <button type="submit" class="w-9 h-9 flex items-center justify-center rounded-xl bg-rose-500/10 text-rose-500 hover:bg-rose-500 hover:text-white transition-all" title="Sil">
                                <i class="fa-solid fa-trash-can text-sm"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <!-- Örnek Kart Bitiş -->

    </div>
</div>

<!-- GÖRSEL YÜKLEME MODAL -->
<div id="imageModal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4 bg-black/80 backdrop-blur-md">
    <div class="glass-card w-full max-w-xl rounded-[3rem] p-10 shadow-2xl border border-white/10 relative overflow-hidden">
        <!-- Arkaplan Süsleme -->
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-purple-600/20 rounded-full blur-3xl"></div>

        <div class="flex justify-between items-center mb-8 relative z-10">
            <div>
                <h3 class="text-2xl font-black text-white italic">MEDYA <span class="text-pink-500 underline decoration-2 underline-offset-4">YÜKLE</span></h3>
                <p class="text-slate-400 text-xs mt-1 uppercase tracking-widest font-bold">Görsel Standartı: 1920x1080px</p>
            </div>
            <button onclick="toggleModal('imageModal')" class="w-10 h-10 flex items-center justify-center rounded-full bg-white/5 text-slate-400 hover:text-white transition">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
        </div>

        <form asp-action="GorselYukle" asp-controller="HizliIslem" method="post" enctype="multipart/form-data" class="space-y-6 relative z-10">
            <div>
                <label class="block text-sm font-bold text-slate-400 mb-2 ml-1 uppercase tracking-wide">Görsel Başlığı</label>
                <input type="text" name="title" placeholder="Görsel için bir isim verin..."
                       class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 px-5 text-white focus:outline-none focus:border-pink-500/50 focus:ring-4 focus:ring-pink-500/10 transition-all" required />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-bold text-slate-400 mb-2 ml-1 uppercase tracking-wide">Dosya Seçimi</label>
                    <input type="file" name="imageFile" accept="image/*"
                           class="w-full bg-white/5 border border-white/10 rounded-2xl py-3 px-4 text-slate-400 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-black file:uppercase file:bg-pink-600 file:text-white hover:file:bg-pink-500 cursor-pointer" required />
                </div>

                <div class="flex items-end pb-2">
                    <label class="flex items-center gap-4 bg-white/5 border border-white/10 p-4 rounded-2xl w-full cursor-pointer hover:bg-white/10 transition">
                        <input type="checkbox" name="isSlider" value="true" class="w-5 h-5 rounded-lg border-white/10 bg-black/20 text-pink-500 focus:ring-pink-500/20">
                        <span class="text-sm font-bold text-slate-300">Slider'da Göster</span>
                    </label>
                </div>
            </div>

            <button type="submit" class="w-full bg-gradient-to-r from-pink-600 to-purple-600 hover:scale-[1.02] active:scale-95 text-white font-black py-5 rounded-2xl shadow-xl shadow-pink-600/20 transition-all uppercase tracking-widest mt-4">
                Galeriye Kaydet
            </button>
        </form>
    </div>
</div>

<script>
    function toggleModal(id) {
        const modal = document.getElementById(id);
        modal.classList.toggle('hidden');
    }

    // Slider durumunu anlık güncellemek için (AJAX kullanılabilir)
    function updateSliderStatus(id, status) {
        console.log("ID:", id, "Yeni Durum:", status);
        // Burada fetch() kullanarak Controller'daki SliderDurumGuncelle metoduna istek atabilirsin.
    }
</script>