@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Belge Yönetimi";
}

<div class="space-y-6">
    <!-- Üst Başlık ve Yükleme Alanı -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h2 class="text-3xl font-black text-white tracking-tight">Belge Yönetimi</h2>
            <p class="text-slate-400 text-sm">Sistemdeki dokümanları ve formları buradan yönetebilirsiniz.</p>
        </div>

        <!-- Yükleme Butonu (Modal'ı tetikler) -->
        <button onclick="toggleModal('uploadModal')" class="bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white px-6 py-3 rounded-2xl font-bold shadow-lg shadow-blue-500/20 transition-all flex items-center gap-2 group">
            <i class="fa-solid fa-cloud-arrow-up group-hover:-translate-y-1 transition-transform"></i>
            Yeni Belge Yükle
        </button>
    </div>

    <!-- Belge Listesi Tablosu -->
    <div class="glass-card rounded-[2rem] overflow-hidden">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-white/5 border-b border-white/10 text-slate-400 text-xs uppercase tracking-widest">
                    <th class="px-8 py-5 font-bold">Belge Adı</th>
                    <th class="px-6 py-5 font-bold text-right">İşlemler</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
                <!-- Burası veritabanından dönecek (Örnek satır) -->
                <tr class="hover:bg-white/[0.02] transition-colors group">
                    <td class="px-8 py-5 text-slate-200 font-medium italic">Henüz belge yüklenmedi veya listeleniyor...</td>
                    <td class="px-8 py-5 text-right text-slate-500 text-sm">--</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- YÜKLEME MODAL (Gizli Form) -->
<div id="uploadModal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
    <div class="glass-card w-full max-w-lg rounded-[2.5rem] p-8 shadow-2xl border border-white/10">
        <div class="flex justify-between items-center mb-6">
            <h3 class="text-xl font-bold text-white">Yeni Belge Yükle</h3>
            <button onclick="toggleModal('uploadModal')" class="text-slate-400 hover:text-white"><i class="fa-solid fa-xmark text-xl"></i></button>
        </div>

        <!-- SENİN FORMUN BURADA -->
        <form asp-action="BelgeYukle" asp-controller="HizliIslem" method="post" enctype="multipart/form-data" class="space-y-5">
            <div>
                <label class="block text-sm font-medium text-slate-400 mb-2 ml-1">Belge Başlığı</label>
                <input type="text" name="title" placeholder="Örn: 2024 Yılı Faaliyet Raporu"
                       class="w-full bg-black/20 border border-white/10 rounded-xl py-3 px-4 text-white focus:outline-none focus:border-blue-500 transition" required />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-400 mb-2 ml-1">Dosya Seçin</label>
                <input type="file" name="file"
                       class="w-full bg-black/20 border border-white/10 rounded-xl py-2 px-3 text-slate-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-bold file:bg-blue-600 file:text-white hover:file:bg-blue-500 cursor-pointer" required />
            </div>

            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-4 rounded-xl shadow-lg transition-all mt-4">
                Sisteme Yükle
            </button>
        </form>
    </div>
</div>

<script>
    function toggleModal(id) {
        const modal = document.getElementById(id);
        modal.classList.toggle('hidden');
    }
</script>