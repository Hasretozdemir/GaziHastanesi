@{
    ViewData["Title"] = "Gazi Mail Tasarım Ayarları";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="h-full flex items-start justify-center p-2 md:p-6">

    <div class="glass-card w-full max-w-5xl rounded-[2rem] p-8 md:p-10 relative overflow-hidden animate__animated animate__fadeIn">

        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-cyan-500/10 rounded-full blur-[120px] -z-10 pointer-events-none"></div>

        <div class="flex flex-col md:flex-row md:items-center gap-5 mb-10 border-b border-white/5 pb-8">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-tr from-cyan-500 to-blue-600 flex items-center justify-center shadow-[0_0_25px_rgba(6,182,212,0.4)] shrink-0">
                <i class="fa-solid fa-wand-magic-sparkles text-2xl text-white"></i>
            </div>
            <div>
                <h2 class="text-2xl font-black text-white tracking-wide">Mail Sayfası Tasarım Yönetimi</h2>
                <p class="text-[14px] text-slate-400 mt-1">
                    Giriş ekranının görsel kimliğini buradan düzenleyin. <span class="text-cyan-400">Cam efekti (Glassmorphism)</span> mimarisi sistem tarafından otomatik korunur.
                </p>
            </div>
        </div>

        <form action="/Admin/HizliIslem/GaziMailKaydet" method="post" enctype="multipart/form-data" class="space-y-10">

            <div>
                <h3 class="text-xs font-black text-cyan-400 uppercase tracking-widest mb-5 flex items-center gap-2">
                    <i class="fa-solid fa-image"></i> Medya & Görseller
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                    <div class="bg-black/20 border border-white/5 rounded-2xl p-6 hover:border-cyan-500/30 hover:bg-black/40 transition group">
                        <label class="block text-[11px] font-bold text-slate-400 mb-3 tracking-widest">ARKA PLAN FOTOĞRAFI</label>
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-xl bg-white/5 flex items-center justify-center border border-white/10 group-hover:text-cyan-400 transition">
                                <i class="fa-solid fa-panorama text-lg"></i>
                            </div>
                            <input type="file" class="block w-full text-sm text-slate-300 file:mr-4 file:py-2.5 file:px-5 file:rounded-xl file:border-0 file:text-xs file:font-bold file:bg-cyan-500/10 file:text-cyan-400 hover:file:bg-cyan-500/20 hover:file:text-white transition cursor-pointer">
                        </div>
                    </div>

                    <div class="bg-black/20 border border-white/5 rounded-2xl p-6 hover:border-cyan-500/30 hover:bg-black/40 transition group">
                        <label class="block text-[11px] font-bold text-slate-400 mb-3 tracking-widest">KURUM LOGOSU</label>
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-xl bg-white/5 flex items-center justify-center border border-white/10 group-hover:text-cyan-400 transition">
                                <i class="fa-solid fa-leaf text-lg"></i>
                            </div>
                            <input type="file" class="block w-full text-sm text-slate-300 file:mr-4 file:py-2.5 file:px-5 file:rounded-xl file:border-0 file:text-xs file:font-bold file:bg-cyan-500/10 file:text-cyan-400 hover:file:bg-cyan-500/20 hover:file:text-white transition cursor-pointer">
                        </div>
                    </div>
                </div>
            </div>

            <div>
                <h3 class="text-xs font-black text-cyan-400 uppercase tracking-widest mb-5 flex items-center gap-2">
                    <i class="fa-solid fa-fill-drip"></i> Dinamik Renk Paleti
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                    <div class="bg-black/20 border border-white/5 rounded-2xl p-5 hover:border-cyan-500/30 transition">
                        <label class="block text-[11px] font-bold text-slate-400 mb-2 tracking-widest">KART ZEMİNİ (RGBA TAVSİYE EDİLİR)</label>
                        <div class="relative">
                            <input type="text" value="rgba(15, 23, 42, 0.85)" class="w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-sm font-medium text-white focus:outline-none focus:border-cyan-500/50 focus:ring-1 focus:ring-cyan-500/50 transition">
                        </div>
                    </div>

                    <div class="bg-black/20 border border-white/5 rounded-2xl p-5 hover:border-cyan-500/30 transition flex gap-3 items-end">
                        <div class="flex-1">
                            <label class="block text-[11px] font-bold text-slate-400 mb-2 tracking-widest">VURGU & HOVER (Örn: #c5a059)</label>
                            <input type="text" value="#c5a059" class="w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-sm font-medium text-white focus:outline-none focus:border-cyan-500/50 transition">
                        </div>
                        <input type="color" value="#c5a059" class="w-12 h-12 rounded-xl cursor-pointer bg-transparent border-0 p-0 shrink-0">
                    </div>

                    <div class="bg-black/20 border border-white/5 rounded-2xl p-5 hover:border-cyan-500/30 transition flex gap-3 items-end">
                        <div class="flex-1">
                            <label class="block text-[11px] font-bold text-slate-400 mb-2 tracking-widest">BUTON RENGİ 1 (SOL)</label>
                            <input type="text" value="#1e40af" class="w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-sm font-medium text-white focus:outline-none focus:border-cyan-500/50 transition">
                        </div>
                        <input type="color" value="#1e40af" class="w-12 h-12 rounded-xl cursor-pointer bg-transparent border-0 p-0 shrink-0">
                    </div>

                    <div class="bg-black/20 border border-white/5 rounded-2xl p-5 hover:border-cyan-500/30 transition flex gap-3 items-end">
                        <div class="flex-1">
                            <label class="block text-[11px] font-bold text-slate-400 mb-2 tracking-widest">BUTON RENGİ 2 (SAĞ)</label>
                            <input type="text" value="#0f172a" class="w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-sm font-medium text-white focus:outline-none focus:border-cyan-500/50 transition">
                        </div>
                        <input type="color" value="#0f172a" class="w-12 h-12 rounded-xl cursor-pointer bg-transparent border-0 p-0 shrink-0">
                    </div>

                </div>
            </div>

            <div class="flex items-center justify-between pt-6 border-t border-white/5 mt-8">
                <button type="button" class="text-sm font-bold text-slate-400 hover:text-rose-400 transition flex items-center gap-2">
                    <i class="fa-solid fa-rotate-left"></i> Orijinal Tasarıma Dön
                </button>

                <button type="submit" class="bg-gradient-to-r from-cyan-500 to-blue-600 text-white px-8 py-3.5 rounded-xl font-bold text-sm shadow-[0_0_20px_rgba(6,182,212,0.3)] hover:scale-105 transition flex items-center gap-2">
                    <i class="fa-solid fa-check-double"></i> Ayarları Sisteme Uygula
                </button>
            </div>

        </form>
    </div>
</div>