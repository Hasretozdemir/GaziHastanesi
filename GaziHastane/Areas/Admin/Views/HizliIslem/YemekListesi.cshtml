@model IEnumerable<GaziHastane.Models.YemekListesi>
@{
    ViewData["Title"] = "Yemek Listesi Yönetimi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="h-full flex items-start justify-center p-2 md:p-6 overflow-y-auto custom-scroll">

    <div class="glass-card w-full max-w-5xl rounded-[2rem] p-8 md:p-10 relative overflow-hidden animate__animated animate__fadeIn">

        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-orange-500/10 rounded-full blur-[120px] -z-10 pointer-events-none"></div>

        <div class="flex flex-col md:flex-row md:items-center gap-5 mb-8 border-b border-white/5 pb-8">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-tr from-orange-500 to-red-600 flex items-center justify-center shadow-[0_0_25px_rgba(249,115,22,0.4)] shrink-0">
                <i class="fa-solid fa-utensils text-2xl text-white"></i>
            </div>
            <div>
                <h2 class="text-2xl font-black text-white tracking-wide">Yemek Listesi Yönetimi</h2>
                <p class="text-[14px] text-slate-400 mt-1">
                    Hastanenin aylık öğün planlamasını buradan yapabilirsiniz. Sistemdeki tüm menüler otomatik olarak hastane ön yüzünde yayınlanır.
                </p>
            </div>
        </div>

        <div class="bg-black/20 border border-white/5 rounded-2xl p-6 md:p-8 mb-8 relative">
            <h3 class="text-xs font-black text-orange-400 uppercase tracking-widest mb-6 flex items-center gap-2">
                <i class="fa-solid fa-plus"></i> Yeni Öğün Kaydı
            </h3>

            <form action="/Admin/HizliIslem/YemekEkle" method="post" class="space-y-6">

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-[11px] font-bold text-slate-400 mb-2 tracking-widest">TARİH SEÇİMİ</label>
                        <input type="date" name="Tarih" required class="w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-sm font-medium text-white focus:outline-none focus:border-orange-500/50 transition [color-scheme:dark]">
                    </div>
                    <div>
                        <label class="block text-[11px] font-bold text-slate-400 mb-2 tracking-widest">ÖĞÜN TİPİ</label>
                        <select name="Ogun" id="ogunSecici" required class="w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-sm font-medium text-white focus:outline-none focus:border-orange-500/50 transition">
                            <option value="1" class="bg-slate-900">Kahvaltı</option>
                            <option value="2" class="bg-slate-900" selected>Öğle Yemeği</option>
                            <option value="3" class="bg-slate-900">Akşam Yemeği</option>
                        </select>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div id="corbaAlani">
                        <label class="block text-[11px] font-bold text-slate-400 mb-2 tracking-widest">ÇORBA</label>
                        <input type="text" name="Corba" placeholder="Örn: Mercimek Çorbası" class="w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-sm font-medium text-white focus:outline-none focus:border-orange-500/50 transition">
                    </div>

                    <div>
                        <label class="block text-[11px] font-bold text-slate-400 mb-2 tracking-widest">ANA YEMEK</label>
                        <input type="text" name="AnaYemek" required placeholder="Örn: Orman Kebabı" class="w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-sm font-medium text-white focus:outline-none focus:border-orange-500/50 transition">
                    </div>

                    <div>
                        <label class="block text-[11px] font-bold text-slate-400 mb-2 tracking-widest">YARDIMCI YEMEK</label>
                        <input type="text" name="YardimciYemek" placeholder="Örn: Pirinç Pilavı" class="w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-sm font-medium text-white focus:outline-none focus:border-orange-500/50 transition">
                    </div>

                    <div id="tatliAlani">
                        <label class="block text-[11px] font-bold text-slate-400 mb-2 tracking-widest">TATLI / MEYVE</label>
                        <input type="text" name="TatliMeyve" placeholder="Örn: Mevsim Salata" class="w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-sm font-medium text-white focus:outline-none focus:border-orange-500/50 transition">
                    </div>
                </div>

                <div class="flex flex-col md:flex-row items-end gap-6 pt-2">
                    <div class="w-full md:w-1/3">
                        <label class="block text-[11px] font-bold text-slate-400 mb-2 tracking-widest">TOPLAM KALORİ (Kcal)</label>
                        <input type="number" name="ToplamKalori" placeholder="Örn: 850" class="w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-sm font-medium text-white focus:outline-none focus:border-orange-500/50 transition">
                    </div>
                    <div class="w-full md:w-2/3">
                        <button type="submit" class="w-full bg-gradient-to-r from-orange-500 to-red-600 text-white py-3.5 rounded-xl font-bold text-sm shadow-[0_0_20px_rgba(249,115,22,0.3)] hover:scale-[1.02] transition flex items-center justify-center gap-2">
                            <i class="fa-solid fa-floppy-disk"></i> Sistemi Güncelle ve Kaydet
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <div class="bg-black/20 border border-white/5 rounded-2xl p-6 md:p-8">
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-xs font-black text-slate-300 uppercase tracking-widest flex items-center gap-2">
                    <i class="fa-solid fa-list text-orange-400"></i> Sistemdeki Kayıtlı Öğünler
                </h3>
                <a href="/Admin/HizliIslem/YemekListesiExcel" class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 px-4 py-2 rounded-xl text-[11px] font-black uppercase tracking-widest hover:bg-emerald-500 hover:text-white transition flex items-center gap-2">
                    <i class="fa-solid fa-file-excel"></i> Excel Rapor Al
                </a>
            </div>

            <div class="max-h-[350px] overflow-y-auto custom-scroll pr-2">
                <table class="w-full text-left text-sm text-slate-300 border-collapse">
                    <thead class="text-[10px] text-slate-500 uppercase font-black bg-black/40 sticky top-0 backdrop-blur-md z-10">
                        <tr>
                            <th class="px-4 py-4 rounded-l-xl">Tarih</th>
                            <th class="px-4 py-4">Öğün</th>
                            <th class="px-4 py-4">Ana Yemek</th>
                            <th class="px-4 py-4">Kalori</th>
                            <th class="px-4 py-4 text-right rounded-r-xl">İşlem</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">

                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model.OrderByDescending(x => x.Tarih))
                            {
                                <tr class="hover:bg-white/5 transition group">
                                    <td class="px-4 py-4 whitespace-nowrap">
                                        <div class="font-bold text-white">@item.Tarih.ToString("dd MMM yyyy")</div>
                                        <div class="text-[10px] text-slate-500 mt-0.5">@item.Tarih.ToString("dddd")</div>
                                    </td>
                                    <td class="px-4 py-4">
                                        @if (item.Ogun == 1)
                                        {
                                            <span class="bg-yellow-500/10 border border-yellow-500/20 text-yellow-400 px-2.5 py-1.5 rounded-lg text-[10px] font-bold"><i class="fa-solid fa-coffee mr-1"></i>KAHVALTI</span>
                                        }
                                        else if (item.Ogun == 2)
                                        {

                                            <span class="bg-green-500/10 border border-green-500/20 text-green-400 px-2.5 py-1.5 rounded-lg text-[10px] font-bold"><i class="fa-solid fa-sun mr-1"></i>ÖĞLE</span>
                                        }
                                        else
                                        {

                                            <span class="bg-blue-500/10 border border-blue-500/20 text-blue-400 px-2.5 py-1.5 rounded-lg text-[10px] font-bold"><i class="fa-solid fa-moon mr-1"></i>AKŞAM</span>
                                        }
                                    </td>
                                    <td class="px-4 py-4">
                                        <span class="font-semibold text-white">@item.AnaYemek</span>
                                    </td>
                                    <td class="px-4 py-4">
                                        <span class="text-orange-400 font-bold bg-orange-400/10 px-2 py-1 rounded">@item.ToplamKalori kcal</span>
                                    </td>
                                    <td class="px-4 py-4 text-right">
                                        <a href="/Admin/HizliIslem/YemekSil/@item.Id" class="w-9 h-9 inline-flex items-center justify-center rounded-xl bg-rose-500/10 text-rose-400 border border-rose-500/20 hover:bg-rose-500 hover:text-white transition" title="Kaydı Sil" onclick="return confirm('Bu öğünü silmek istediğinize emin misiniz?');">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="px-4 py-12 text-center text-slate-500">
                                    <i class="fa-solid fa-inbox text-4xl mb-4 opacity-30 block"></i>
                                    Sistemde henüz kayıtlı yemek menüsü bulunmamaktadır.
                                </td>
                            </tr>
                        }

                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        // Kahvaltı seçildiğinde Çorba ve Tatlı alanlarını gizleyen yapı
        document.getElementById('ogunSecici').addEventListener('change', function() {
            const corbaAlani = document.getElementById('corbaAlani');
            const tatliAlani = document.getElementById('tatliAlani');

            if(this.value === '1') {
                corbaAlani.style.display = 'none';
                tatliAlani.style.display = 'none';
            } else {
                corbaAlani.style.display = 'block';
                tatliAlani.style.display = 'block';
            }
        });

        document.getElementById('ogunSecici').dispatchEvent(new Event('change'));
    </script>
}