@model GaziHastane.Models.Haber
@{
    ViewData["Title"] = "Haber Düzenle";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="glass-card rounded-[2rem] p-6 md:p-8">

    <div class="flex items-center gap-4 mb-8 border-b border-slate-700/50 pb-6">
        <div class="w-12 h-12 rounded-2xl bg-gradient-to-tr from-amber-500/20 to-orange-600/20 border border-amber-500/30 flex items-center justify-center text-amber-400 shadow-[0_0_15px_rgba(245,158,11,0.2)]">
            <i class="fa-solid fa-pen-to-square text-xl"></i>
        </div>
        <div>
            <h2 class="text-xl font-black text-white tracking-wide">Haber Düzenle</h2>
            <p class="text-xs text-slate-400 font-medium mt-1">Mevcut haberin bilgilerini güncelliyorsunuz</p>
        </div>
    </div>

    <form asp-action="Edit" asp-controller="Haberler" asp-area="Admin" method="post">

        <div asp-validation-summary="All" class="bg-rose-500/10 border border-rose-500/20 text-rose-400 p-4 rounded-xl mb-6 text-sm font-medium"></div>

        <input type="hidden" asp-for="Id" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

            <div class="md:col-span-2">
                <label asp-for="Baslik" class="block text-xs font-bold text-slate-400 mb-2 uppercase tracking-wider">Başlık <span class="text-rose-500">*</span></label>
                <input asp-for="Baslik" class="w-full bg-slate-900/50 border border-slate-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition duration-200" required />
                <span asp-validation-for="Baslik" class="text-rose-400 text-[11px] font-medium mt-1 block"></span>
            </div>

            <div>
                <label asp-for="Kategori" class="block text-xs font-bold text-slate-400 mb-2 uppercase tracking-wider">Kategori <span class="text-rose-500">*</span></label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none">
                        <i class="fa-solid fa-tags text-slate-500"></i>
                    </div>
                    <input asp-for="Kategori" class="w-full bg-slate-900/50 border border-slate-700 rounded-xl pl-11 pr-4 py-3 text-white focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition duration-200" required />
                </div>
                <span asp-validation-for="Kategori" class="text-rose-400 text-[11px] font-medium mt-1 block"></span>
            </div>

            <div>
                <label asp-for="YayinTarihi" class="block text-xs font-bold text-slate-400 mb-2 uppercase tracking-wider">Yayın Tarihi <span class="text-rose-500">*</span></label>
                <input asp-for="YayinTarihi" type="datetime-local" class="w-full bg-slate-900/50 border border-slate-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition duration-200" required />
                <span asp-validation-for="YayinTarihi" class="text-rose-400 text-[11px] font-medium mt-1 block"></span>
            </div>

            <div class="md:col-span-2">
                <label asp-for="GorselUrl" class="block text-xs font-bold text-slate-400 mb-2 uppercase tracking-wider">Görsel URL <span class="text-rose-500">*</span></label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none">
                        <i class="fa-solid fa-link text-slate-500"></i>
                    </div>
                    <input asp-for="GorselUrl" class="w-full bg-slate-900/50 border border-slate-700 rounded-xl pl-11 pr-4 py-3 text-white focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition duration-200" required />
                </div>
                <span asp-validation-for="GorselUrl" class="text-rose-400 text-[11px] font-medium mt-1 block"></span>
            </div>

            <div class="md:col-span-2">
                <label asp-for="Ozet" class="block text-xs font-bold text-slate-400 mb-2 uppercase tracking-wider">Özet (Ana Sayfada Görünür) <span class="text-rose-500">*</span></label>
                <textarea asp-for="Ozet" rows="2" class="w-full bg-slate-900/50 border border-slate-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition duration-200 resize-none" required></textarea>
                <span asp-validation-for="Ozet" class="text-rose-400 text-[11px] font-medium mt-1 block"></span>
            </div>

            <div class="md:col-span-2">
                <label asp-for="Icerik" class="block text-xs font-bold text-slate-400 mb-2 uppercase tracking-wider">Detaylı İçerik</label>
                <textarea asp-for="Icerik" rows="6" class="w-full bg-slate-900/50 border border-slate-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition duration-200"></textarea>
                <span asp-validation-for="Icerik" class="text-rose-400 text-[11px] font-medium mt-1 block"></span>
            </div>

            <div class="md:col-span-2 flex items-center p-4 rounded-xl border border-slate-700/50 bg-slate-800/30 transition hover:bg-slate-800/50">
                <div class="flex items-center h-5">
                    <input asp-for="IsActive" type="checkbox" class="w-5 h-5 rounded bg-slate-900 border-slate-600 text-cyan-500 focus:ring-cyan-500 focus:ring-offset-slate-800 cursor-pointer" />
                </div>
                <div class="ml-3 text-sm cursor-pointer">
                    <label asp-for="IsActive" class="font-bold text-white cursor-pointer">Sitede Göster (Aktif Mi?)</label>
                    <p class="text-[11px] text-slate-400 mt-0.5">Bu seçenek işaretli ise haber ziyaretçiler tarafından görülebilir.</p>
                </div>
            </div>

        </div>

        <div class="mt-8 flex items-center justify-end gap-4 border-t border-slate-700/50 pt-6">
            <a asp-action="Index" class="px-6 py-2.5 rounded-xl font-bold text-sm text-slate-400 hover:text-white hover:bg-slate-800 transition duration-300">
                İptal Et
            </a>
            <button type="submit" class="bg-gradient-to-r from-amber-500 to-orange-600 text-white px-8 py-2.5 rounded-xl font-bold text-sm shadow-[0_0_20px_rgba(245,158,11,0.3)] hover:scale-105 transition duration-300 flex items-center gap-2">
                <i class="fa-solid fa-save"></i>
                <span>Değişiklikleri Kaydet</span>
            </button>
        </div>

    </form>
</div>