@model IEnumerable<GaziHastane.Models.BorcOdeme>
@{
    ViewData["Title"] = "Borç Yönetimi - Tüm Borçlar";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">

<style>
    /* Eğer global CSS'inizde yoksa cam efekti ve gradient metin için gerekli sınıflar */
    .glass-card {
        background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .text-gradient {
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-image: linear-gradient(to right, #818cf8, #2dd4bf); /* Indigo - Teal */
    }
</style>

<div class="px-4 sm:px-6 lg:px-8 py-8 w-full max-w-9xl mx-auto">

    <div class="mb-8 pl-2 flex flex-col sm:flex-row sm:justify-between sm:items-end gap-4">
        <div>
            <h2 class="text-3xl md:text-4xl font-black mb-2 tracking-tight text-white">Borç <span class="text-gradient">Yönetimi</span> 💳</h2>
            <p class="text-slate-400 font-medium">Hastaların sisteme girilmiş borç, ödeme ve finansal durumlarını yönetin.</p>
        </div>
        <a href="@Url.Action("BorcEkle", "BorcYonetim")" class="bg-gradient-to-r from-indigo-500 to-cyan-600 text-white px-6 py-2.5 rounded-xl font-bold text-sm shadow-[0_0_20px_rgba(99,102,241,0.3)] hover:scale-105 transition flex items-center w-max">
            <i class="fa-solid fa-plus mr-2"></i>Yeni Borç Ekle
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 px-4 py-3 rounded-xl relative mb-6 font-medium flex items-center shadow-[0_0_15px_rgba(16,185,129,0.1)]" role="alert">
            <i class="fa-solid fa-circle-check mr-3 text-lg"></i>
            <span class="block sm:inline">@TempData["Success"]</span>
        </div>
    }

    <div class="glass-card rounded-[2rem] overflow-hidden mb-8">
        <div class="overflow-x-auto">
            <table class="w-full text-left whitespace-nowrap">
                <thead class="bg-black/20">
                    <tr>
                        <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-white/5">T.C. & Hasta Adı</th>
                        <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-white/5">Protokol No</th>
                        <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-white/5">İşlem Tipi</th>
                        <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-white/5 text-right">Tutar</th>
                        <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-white/5 text-center">Tarihler</th>
                        <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-white/5 text-center">Durum</th>
                        <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-white/5 text-right">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="hover:bg-white/5 transition duration-200">

                                <td class="px-8 py-5">
                                    <div class="flex items-center gap-4">
                                        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center font-black text-white shadow-[0_0_15px_rgba(99,102,241,0.4)]">
                                            @(item.Hasta?.Ad?.Substring(0, 1))@(item.Hasta?.Soyad?.Substring(0, 1))
                                        </div>
                                        <div>
                                            <p class="font-bold text-white text-sm">@(item.Hasta?.Ad) @(item.Hasta?.Soyad)</p>
                                            <p class="text-xs text-slate-400 flex items-center gap-1 mt-0.5">
                                                <i class="fa-regular fa-id-card text-[10px]"></i> @item.Hasta?.TCKimlikNo
                                            </p>
                                        </div>
                                    </div>
                                </td>

                                <td class="px-8 py-5">
                                    <span class="px-3 py-1.5 rounded-lg bg-white/5 border border-white/10 text-slate-300 text-xs font-mono tracking-wider">
                                        @item.ProtakolNo
                                    </span>
                                </td>

                                <td class="px-8 py-5">
                                    <span class="text-slate-300 text-sm">@item.IslemTipi</span>
                                </td>

                                <td class="px-8 py-5 text-right">
                                    <span class="font-black text-white text-base">@item.Tutar.ToString("N2") <span class="text-slate-500 font-normal text-sm">₺</span></span>
                                </td>

                                <td class="px-8 py-5 text-center">
                                    <div class="flex flex-col gap-1 items-center">
                                        <p class="text-[11px] text-slate-400">Eklenme: <span class="text-slate-200 font-medium">@(item.EklenmeTarihi?.ToString("dd.MM.yyyy") ?? "-")</span></p>
                                        <p class="text-[11px] text-slate-400">Son Ödeme: <span class="text-rose-400 font-medium">@(item.SonOdemeTarihi?.ToString("dd.MM.yyyy") ?? "-")</span></p>
                                    </div>
                                </td>

                                <td class="px-8 py-5">
                                    <div class="flex justify-center">
                                        @if (item.OdendiMi)
                                        {
                                            <span class="flex items-center gap-2 text-xs font-bold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-3 py-1.5 rounded-lg w-max">
                                                <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse shadow-[0_0_5px_#34d399]"></span> Ödendi
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="flex items-center gap-2 text-xs font-bold text-rose-400 bg-rose-500/10 border border-rose-500/20 px-3 py-1.5 rounded-lg w-max">
                                                <span class="w-2 h-2 rounded-full bg-rose-400 shadow-[0_0_5px_#f43f5e]"></span> Ödenmedi
                                            </span>
                                        }
                                    </div>
                                </td>

                                <td class="px-8 py-5 text-right">
                                    @if (!item.OdendiMi)
                                    {
                                        <div class="flex items-center justify-end gap-2">
                                            <form asp-action="BorcSil" asp-route-id="@item.Id" method="post">
                                                <button type="button" onclick="confirmDelete(this.form)" class="w-8 h-8 rounded-lg bg-rose-500/10 hover:bg-rose-500/30 text-rose-400 transition flex items-center justify-center border border-rose-500/20 shadow-sm" title="Borcu Sil">
                                                    <i class="fa-solid fa-trash text-xs"></i>
                                                </button>
                                            </form>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="px-8 py-16 text-center text-slate-400 border-t border-white/5">
                                <div class="w-16 h-16 rounded-full bg-white/5 flex items-center justify-center mx-auto mb-4 border border-white/10">
                                    <i class="fa-solid fa-file-invoice-dollar text-2xl text-slate-500"></i>
                                </div>
                                <h3 class="text-white font-bold text-lg mb-1">Kayıt Bulunamadı</h3>
                                <p class="text-sm">Sistemde henüz girilmiş bir hasta borç kaydı bulunmamaktadır.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function confirmDelete(form) {
            Swal.fire({
                title: 'Emin misiniz?',
                text: "Bu borç kaydını silmek üzeresiniz. Bu işlem geri alınamaz!",
                icon: 'warning',
                background: '#1e293b', /* Koyu tema arkaplanı */
                color: '#fff',
                showCancelButton: true,
                confirmButtonColor: '#f43f5e',
                cancelButtonColor: '#475569',
                confirmButtonText: 'Evet, Sil',
                cancelButtonText: 'İptal',
                customClass: {
                    popup: 'border border-white/10 rounded-2xl shadow-2xl',
                    confirmButton: 'rounded-xl font-bold',
                    cancelButton: 'rounded-xl font-bold'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            })
        }
    </script>
}