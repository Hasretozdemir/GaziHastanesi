@model IEnumerable<GaziHastane.Models.Etkinlik>
@{
    ViewData["Title"] = "Etkinlik Yönetimi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="glass-card rounded-[2rem] p-6 md:p-8">

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-2xl bg-gradient-to-tr from-fuchsia-500/20 to-purple-600/20 border border-fuchsia-500/30 flex items-center justify-center text-fuchsia-400 shadow-[0_0_15px_rgba(217,70,239,0.2)]">
                <i class="fa-solid fa-calendar-days text-xl"></i>
            </div>
            <div>
                <h2 class="text-xl font-black text-white tracking-wide">Etkinlik Listesi</h2>
                <p class="text-xs text-slate-400 font-medium mt-1">Kongre, sempozyum ve eğitimleri yönetin</p>
            </div>
        </div>

        <a asp-action="Create" asp-controller="Etkinlikler" asp-area="Admin" class="bg-gradient-to-r from-fuchsia-500 to-purple-600 text-white px-5 py-2.5 rounded-xl font-bold text-sm shadow-[0_0_20px_rgba(217,70,239,0.3)] hover:scale-105 transition flex items-center gap-2">
            <i class="fa-solid fa-plus"></i>
            <span>Yeni Etkinlik Ekle</span>
        </a>
    </div>

    <div class="overflow-x-auto custom-scroll -mx-6 px-6 md:mx-0 md:px-0">
        <table class="w-full min-w-[850px] text-left border-collapse">
            <thead>
                <tr>
                    <th class="px-4 py-4 text-[11px] font-black tracking-widest text-slate-500 uppercase border-b border-white/10 bg-white/5 first:rounded-tl-2xl">Tarih & Saat</th>
                    <th class="px-4 py-4 text-[11px] font-black tracking-widest text-slate-500 uppercase border-b border-white/10 bg-white/5 w-1/3">Başlık</th>
                    <th class="px-4 py-4 text-[11px] font-black tracking-widest text-slate-500 uppercase border-b border-white/10 bg-white/5">Tip</th>
                    <th class="px-4 py-4 text-[11px] font-black tracking-widest text-slate-500 uppercase border-b border-white/10 bg-white/5">Konum</th>
                    <th class="px-4 py-4 text-[11px] font-black tracking-widest text-slate-500 uppercase border-b border-white/10 bg-white/5">Durum</th>
                    <th class="px-4 py-4 text-[11px] font-black tracking-widest text-slate-500 uppercase border-b border-white/10 bg-white/5 text-right last:rounded-tr-2xl">İşlemler</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-white/5 transition duration-200 group">

                        <td class="px-4 py-3 align-middle">
                            <div class="flex flex-col">
                                <span class="text-sm font-bold text-fuchsia-100">@item.Tarih.ToString("dd.MM.yyyy")</span>
                                <span class="text-[11px] text-slate-400 font-medium flex items-center gap-1.5 mt-1">
                                    <i class="fa-regular fa-clock text-fuchsia-400/70"></i> @item.SaatAraligi
                                </span>
                            </div>
                        </td>

                        <td class="px-4 py-3 align-middle">
                            <span class="text-sm font-semibold text-slate-200 line-clamp-2">@item.Baslik</span>
                        </td>

                        <td class="px-4 py-3 align-middle">
                            <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-[11px] font-bold bg-fuchsia-500/10 text-fuchsia-300 border border-fuchsia-500/20 shadow-[0_0_10px_rgba(217,70,239,0.05)]">
                                @item.EtkinlikTipi
                            </span>
                        </td>

                        <td class="px-4 py-3 align-middle">
                            <span class="text-xs text-slate-300 flex items-center gap-1.5 line-clamp-1">
                                <i class="fa-solid fa-location-dot text-slate-500"></i> @item.Konum
                            </span>
                        </td>

                        <td class="px-4 py-3 align-middle">
                            @if (item.IsActive)
                            {
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 shadow-[0_0_10px_rgba(16,185,129,0.1)]">
                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                                    Aktif
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-xs font-bold bg-rose-500/10 text-rose-400 border border-rose-500/20">
                                    <span class="w-1.5 h-1.5 rounded-full bg-rose-500"></span>
                                    Pasif
                                </span>
                            }
                        </td>

                        <td class="px-4 py-3 align-middle text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a asp-action="Edit" asp-controller="Etkinlikler" asp-area="Admin" asp-route-id="@item.Id" class="w-8 h-8 rounded-xl bg-amber-500/10 text-amber-400 border border-amber-500/20 flex items-center justify-center hover:bg-amber-500 hover:text-white hover:shadow-[0_0_15px_rgba(245,158,11,0.4)] transition duration-300" title="Düzenle">
                                    <i class="fa-solid fa-pen-to-square text-xs"></i>
                                </a>

                                <a asp-action="Delete" asp-controller="Etkinlikler" asp-area="Admin" asp-route-id="@item.Id" onclick="showDeleteWarning(event, this.href);" class="w-8 h-8 rounded-xl bg-rose-500/10 text-rose-400 border border-rose-500/20 flex items-center justify-center hover:bg-rose-500 hover:text-white hover:shadow-[0_0_15px_rgba(243,64,84,0.4)] transition duration-300" title="Sil">
                                    <i class="fa-solid fa-trash text-xs"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="text-center py-12">
                <div class="w-16 h-16 rounded-full bg-white/5 border border-white/10 flex items-center justify-center mx-auto mb-4 text-fuchsia-500/50 text-2xl shadow-inner">
                    <i class="fa-regular fa-calendar-xmark"></i>
                </div>
                <p class="text-slate-400 font-medium">Henüz planlanmış bir etkinlik bulunmamaktadır.</p>
            </div>
        }
    </div>
</div>

<script>
    function showDeleteWarning(event, url) {
        event.preventDefault();

        Swal.fire({
            title: 'Etkinliği Sil?',
            text: "Bu etkinliği kalıcı olarak sileceksiniz. Onaylıyor musunuz?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#f43f5e',
            cancelButtonColor: '#64748b',
            confirmButtonText: '<i class="fa-solid fa-trash mr-2"></i> Evet, Sil!',
            cancelButtonText: 'Vazgeç',
            background: '#1e293b',
            color: '#f8fafc',
            customClass: {
                popup: 'rounded-2xl border border-slate-700 shadow-2xl',
            }
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = url;
            }
        })
    }
</script>