<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Gazi Sağlık Panel</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700;900&display=swap" rel="stylesheet">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Outfit', 'sans-serif'] },
                    colors: {
                        darkBg: '#0f172a',
                        glassBg: 'rgba(255, 255, 255, 0.03)',
                        glassBorder: 'rgba(255, 255, 255, 0.05)'
                    }
                }
            }
        }
    </script>

    <style>
        body {
            background-color: #0f172a;
            background-image: radial-gradient(at 0% 0%, rgba(56, 189, 248, 0.15) 0px, transparent 50%), radial-gradient(at 100% 0%, rgba(168, 85, 247, 0.15) 0px, transparent 50%), radial-gradient(at 100% 100%, rgba(56, 189, 248, 0.15) 0px, transparent 50%), radial-gradient(at 0% 100%, rgba(168, 85, 247, 0.15) 0px, transparent 50%);
            background-attachment: fixed;
            color: #e2e8f0;
        }

        .glass-card {
            background: rgba(30, 41, 59, 0.4);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        #sidebar {
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        @@media (max-width: 768px) {
            #sidebar {
                position: fixed;
                top: 0;
                left: 0;
                height: calc(100% - 2rem);
                z-index: 50;
                transform: translateX(-110%);
            }

                #sidebar.open {5
                    transform: translateX(0);
                }
        }

        .text-gradient {
            background: linear-gradient(to right, #38bdf8, #818cf8, #e879f9);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .neon-icon {
            filter: drop-shadow(0 0 8px currentColor);
        }

        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: rgba(0,0,0,0.1);
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(56, 189, 248, 0.3);
            border-radius: 10px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: rgba(168, 85, 247, 0.5);
            }
    </style>
</head>
<body class="flex h-screen overflow-hidden font-sans text-slate-200">

    <div id="overlay" onclick="toggleSidebar()" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-300"></div>

    <aside id="sidebar" class="w-72 glass-card m-4 rounded-[2rem] flex flex-col relative overflow-hidden z-50 shrink-0">
        <div class="absolute top-0 left-0 w-full h-32 bg-gradient-to-b from-blue-500/10 to-transparent"></div>

        <div class="h-24 flex items-center justify-between px-8 relative z-10 border-b border-white/5">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-2xl bg-gradient-to-tr from-cyan-500 to-purple-600 flex items-center justify-center shadow-[0_0_20px_rgba(6,182,212,0.4)]">
                    <i class="fa-solid fa-staff-snake text-2xl text-white"></i>
                </div>
                <div>
                    <h1 class="text-xl font-black tracking-widest text-white">GAZİ<span class="text-cyan-400">MED</span></h1>
                    <p class="text-[10px] text-cyan-200/60 uppercase tracking-widest font-bold mt-0.5">Yönetim Üssü</p>
                </div>
            </div>
            <button onclick="toggleSidebar()" class="md:hidden text-slate-400 hover:text-white transition">
                <i class="fa-solid fa-xmark text-2xl"></i>
            </button>
        </div>

        @{
            var ctrl = ViewContext.RouteData.Values["Controller"]?.ToString();
            var action = ViewContext.RouteData.Values["Action"]?.ToString();
            var activeClass = "bg-gradient-to-r from-cyan-500/20 to-purple-500/5 text-cyan-300 border border-cyan-500/30 shadow-[0_0_15px_rgba(6,182,212,0.15)]";
            var passiveClass = "hover:bg-white/5 text-slate-400 hover:text-white border border-transparent";
        }

        <nav class="flex-1 px-4 py-8 overflow-y-auto space-y-2 relative z-10">
            <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-4 px-4">Ana Ekranlar</p>

            <a href="/Admin/Home/Index" class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all group @(ctrl == "Home" ? activeClass : passiveClass)">
                <i class="fa-solid fa-cube text-lg @(ctrl == "Home" ? "neon-icon" : "group-hover:text-cyan-400")"></i>
                <span class="font-bold tracking-wide">Gösterge Paneli</span>
            </a>
            <a href="/Admin/Doktorlar/Index" class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all group @(ctrl == "Doktorlar" ? activeClass : passiveClass)">
                <i class="fa-solid fa-user-doctor text-lg @(ctrl == "Doktorlar" ? "neon-icon" : "group-hover:text-purple-400")"></i>
                <span class="font-semibold tracking-wide">Doktorlar</span>
            </a>
            <a href="/Admin/Bolumler/Index" class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all group @(ctrl == "Bolumler" ? activeClass : passiveClass)">
                <i class="fa-solid fa-network-wired text-lg @(ctrl == "Bolumler" ? "neon-icon" : "group-hover:text-pink-400")"></i>
                <span class="font-semibold tracking-wide">Poliklinikler</span>
            </a>
            <a href="/Admin/HastaRehberi/Index" class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all group @(ctrl == "HastaRehberi" ? activeClass : passiveClass)">
                <i class="fa-solid fa-book-medical text-lg @(ctrl == "HastaRehberi" ? "neon-icon" : "group-hover:text-emerald-400")"></i>
                <span class="font-semibold tracking-wide">Hasta Rehberi</span>
            </a>
            <a href="/Admin/Iletisim/Index" class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all group @(ctrl == "Iletisim" ? activeClass : passiveClass)">
                <i class="fa-solid fa-address-book text-lg @(ctrl == "Iletisim" ? "neon-icon" : "group-hover:text-orange-400")"></i>
                <span class="font-semibold tracking-wide">İletişim</span>
            </a>

            <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-4 px-4 mt-6">Sistem Ayarları</p>

            <a href="/Admin/HizliIslem/Kalite" class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all group @(ctrl == "HizliIslem" && action == "Kalite" ? activeClass : passiveClass)">
                <i class="fa-solid fa-shield-heart text-lg @(ctrl == "HizliIslem" && action == "Kalite" ? "neon-icon" : "group-hover:text-blue-400")"></i>
                <span class="font-semibold tracking-wide">Kalite Yönetimi</span>
            </a>
            <a href="/Admin/Egitim/Index" class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all group @(ctrl == "Egitim" ? activeClass : passiveClass)">
                <i class="fa-solid fa-graduation-cap text-lg @(ctrl == "Egitim" ? "neon-icon" : "group-hover:text-orange-500")"></i>
                <span class="font-semibold tracking-wide">Eğitim Komitesi</span>
            </a>

            <a href="/Admin/HizliIslem/YemekListesi" class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all group @(ctrl == "HizliIslem" && action == "YemekListesi" ? activeClass : passiveClass)">
                <i class="fa-solid fa-utensils text-lg @(ctrl == "HizliIslem" && action == "YemekListesi" ? "neon-icon" : "group-hover:text-orange-500")"></i>
                <span class="font-semibold tracking-wide">Yemek Listesi</span>
            </a>

            <a href="/Admin/Kroki/Index" class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all group @(ctrl == "Kroki" ? activeClass : passiveClass)">
                <i class="fa-solid fa-map-location-dot text-lg @(ctrl == "Kroki" ? "neon-icon" : "group-hover:text-cyan-400")"></i>
                <span class="font-semibold tracking-wide">Kroki Yönetimi</span>
            </a>

            <a href="/Admin/HizliIslem/Gorsel"
               class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all duration-300 group
   @(ctrl == "HizliIslem" && action == "Gorsel" ? activeClass : passiveClass)">

                <i class="fa-solid fa-images text-lg transition-all duration-300
       @(ctrl == "HizliIslem" && action == "Gorsel"
                                             ? "text-pink-500 drop-shadow-[0_0_8px_rgba(236,72,153,0.8)] scale-110"
                                             : "group-hover:text-pink-400 group-hover:scale-110")"></i>

                <span class="font-semibold tracking-wide">Görseller</span>
            </a>

            <a href="/Admin/HizliIslem/Belge"
               class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all duration-300 group
   @(ctrl == "HizliIslem" && action == "Belge" ? activeClass : passiveClass)">

                <i class="fa-solid fa-file-lines text-lg transition-all duration-300
       @(ctrl == "HizliIslem" && action == "Belge"
                                             ? "text-blue-500 drop-shadow-[0_0_8px_rgba(59,130,246,0.8)] scale-110"
                                             : "group-hover:text-blue-400 group-hover:scale-110")"></i>

                <span class="font-semibold tracking-wide">Belgeler</span>
            </a>

            <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-4 px-4 mt-6">İçerik Yönetimi</p>

            <a href="/Admin/Haberler/Index" class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all group @(ctrl == "Haberler" ? activeClass : passiveClass)">
                <i class="fa-solid fa-newspaper text-lg @(ctrl == "Haberler" ? "neon-icon" : "group-hover:text-blue-400")"></i>
                <span class="font-semibold tracking-wide">Haberler</span>
            </a>
            <a href="/Admin/Etkinlikler/Index" class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all group @(ctrl == "Etkinlikler" ? activeClass : passiveClass)">
                <i class="fa-solid fa-calendar-days text-lg @(ctrl == "Etkinlikler" ? "neon-icon" : "group-hover:text-fuchsia-400")"></i>
                <span class="font-semibold tracking-wide">Etkinlikler</span>
            </a>
            <a href="/Admin/Duyurular/Index" class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all group @(ctrl == "Duyurular" ? activeClass : passiveClass)">
                <i class="fa-solid fa-bullhorn text-lg @(ctrl == "Duyurular" ? "neon-icon" : "group-hover:text-yellow-400")"></i>
                <span class="font-semibold tracking-wide">Duyurular</span>
            </a>

            <div class="space-y-1">
                <button type="button" onclick="toggleKurumsalMenu()" class="w-full flex items-center justify-between gap-4 px-4 py-3.5 rounded-2xl transition-all group @(ctrl == "Kurumsal" || ctrl == "Bashekimlik" || ctrl == "Basmudurluk" ? activeClass : passiveClass)">
                    <span class="flex items-center gap-4">
                        <i class="fa-solid fa-building text-lg @(ctrl == "Kurumsal" || ctrl == "Bashekimlik" || ctrl == "Basmudurluk" ? "neon-icon" : "group-hover:text-cyan-400")"></i>
                        <span class="font-semibold tracking-wide">Kurumsal</span>
                    </span>
                    <i id="kurumsalChevron" class="fa-solid fa-chevron-down text-xs transition-transform @(ctrl == "Kurumsal" || ctrl == "Bashekimlik" || ctrl == "Basmudurluk" ? "rotate-180" : "")"></i>
                </button>

                <div id="kurumsalSubmenu" class="ml-6 space-y-1 @(ctrl == "Kurumsal" || ctrl == "Bashekimlik" || ctrl == "Basmudurluk" ? "" : "hidden")">
                    <a href="/Admin/Kurumsal/Index" class="block text-xs px-3 py-2 rounded-xl transition @(action == "Index" && ctrl == "Kurumsal" ? "bg-cyan-500/15 text-cyan-300" : "text-slate-400 hover:bg-white/5 hover:text-white")">Sidebar Yönetimi</a>
                    <a href="/Admin/Bashekimlik/Index" class="block text-xs px-3 py-2 rounded-xl transition @(ctrl == "Bashekimlik" ? "bg-cyan-500/15 text-cyan-300" : "text-slate-400 hover:bg-white/5 hover:text-white")">Başhekimlik</a>
                    <a href="/Admin/Basmudurluk/Index" class="block text-xs px-3 py-2 rounded-xl transition @(ctrl == "Basmudurluk" ? "bg-cyan-500/15 text-cyan-300" : "text-slate-400 hover:bg-white/5 hover:text-white")">Başmüdürlük</a>
                    <a href="/Admin/Kurumsal/HemsirelikHizmetleri" class="block text-xs px-3 py-2 rounded-xl transition @(action == "HemsirelikHizmetleri" ? "bg-cyan-500/15 text-cyan-300" : "text-slate-400 hover:bg-white/5 hover:text-white")">Hemşirelik Hizmetleri</a>
                    <a href="/Admin/Kurumsal/BilgiIslemMerkezi" class="block text-xs px-3 py-2 rounded-xl transition @(action == "BilgiIslemMerkezi" ? "bg-cyan-500/15 text-cyan-300" : "text-slate-400 hover:bg-white/5 hover:text-white")">Bilgi İşlem Merkezi</a>
                    <a href="/Admin/Kurumsal/IsSagligiVeGuvenligi" class="block text-xs px-3 py-2 rounded-xl transition @(action == "IsSagligiVeGuvenligi" ? "bg-cyan-500/15 text-cyan-300" : "text-slate-400 hover:bg-white/5 hover:text-white")">İş Sağlığı ve Güvenliği</a>
                    <a href="/Admin/Kurumsal/EnfeksiyonKontrol" class="block text-xs px-3 py-2 rounded-xl transition @(action == "EnfeksiyonKontrol" ? "bg-cyan-500/15 text-cyan-300" : "text-slate-400 hover:bg-white/5 hover:text-white")">Enfeksiyon Kontrol</a>
                    <a href="/Admin/Kurumsal/EczacilikHizmetleri" class="block text-xs px-3 py-2 rounded-xl transition @(action == "EczacilikHizmetleri" ? "bg-cyan-500/15 text-cyan-300" : "text-slate-400 hover:bg-white/5 hover:text-white")">Eczacılık Hizmetleri</a>
                    <a href="/Admin/Kurumsal/SatinAlma" class="block text-xs px-3 py-2 rounded-xl transition @(action == "SatinAlma" ? "bg-cyan-500/15 text-cyan-300" : "text-slate-400 hover:bg-white/5 hover:text-white")">Satın Alma</a>
                    <a href="/Admin/Kurumsal/IstatistikVeRaporlama" class="block text-xs px-3 py-2 rounded-xl transition @(action == "IstatistikVeRaporlama" ? "bg-cyan-500/15 text-cyan-300" : "text-slate-400 hover:bg-white/5 hover:text-white")">İstatistik ve Raporlama</a>
                    <a href="/Admin/Kurumsal/ArsivBirimi" class="block text-xs px-3 py-2 rounded-xl transition @(action == "ArsivBirimi" ? "bg-cyan-500/15 text-cyan-300" : "text-slate-400 hover:bg-white/5 hover:text-white")">Arşiv Birimi</a>
                    <a href="/Admin/Kurumsal/HastaIletisimBirimi" class="block text-xs px-3 py-2 rounded-xl transition @(action == "HastaIletisimBirimi" ? "bg-cyan-500/15 text-cyan-300" : "text-slate-400 hover:bg-white/5 hover:text-white")">Hasta İletişim Birimi</a>
                    <a href="/Admin/Kurumsal/IsAkisSemalari" class="block text-xs px-3 py-2 rounded-xl transition @(action == "IsAkisSemalari" ? "bg-cyan-500/15 text-cyan-300" : "text-slate-400 hover:bg-white/5 hover:text-white")">İş Akış Şemaları</a>
                    <a href="/Admin/Kurumsal/OrganizasyonSemalari" class="block text-xs px-3 py-2 rounded-xl transition @(action == "OrganizasyonSemalari" ? "bg-cyan-500/15 text-cyan-300" : "text-slate-400 hover:bg-white/5 hover:text-white")">Organizasyon Şemaları</a>
                    <a href="/Admin/Kurumsal/IcKontrol" class="block text-xs px-3 py-2 rounded-xl transition @(action == "IcKontrol" ? "bg-cyan-500/15 text-cyan-300" : "text-slate-400 hover:bg-white/5 hover:text-white")">İç Kontrol</a>
                    <a href="/Admin/Kurumsal/BasinVeKurumsalIletisim" class="block text-xs px-3 py-2 rounded-xl transition @(action == "BasinVeKurumsalIletisim" ? "bg-cyan-500/15 text-cyan-300" : "text-slate-400 hover:bg-white/5 hover:text-white")">Basın ve Kurumsal İletişim</a>
                </div>
            </div>

            <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-4 px-4 mt-6">Güvenlik & Erişim</p>

            <a href="/Admin/Yetkililer/Index" class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all group @(ctrl == "Yetkililer" ? activeClass : passiveClass)">
                <i class="fa-solid fa-user-shield text-lg @(ctrl == "Yetkililer" ? "neon-icon" : "group-hover:text-rose-400")"></i>
                <span class="font-semibold tracking-wide">Yetkili Listesi</span>
            </a>

        </nav>
    </aside>

    <main class="flex-1 flex flex-col h-screen overflow-hidden p-4 md:py-4 md:pr-4 md:pl-0">

        <header class="glass-card h-20 rounded-[2rem] flex items-center justify-between px-6 md:px-8 mb-6 shrink-0 z-20">
            <div class="flex items-center gap-4">
                <button onclick="toggleSidebar()" class="md:hidden w-11 h-11 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-cyan-400 shadow-lg active:scale-95 transition">
                    <i class="fa-solid fa-bars-staggered text-xl"></i>
                </button>

                <div class="relative w-96 hidden lg:block">
                    <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                    <input type="text" placeholder="Sistemde ara..." class="w-full bg-black/20 border border-white/10 rounded-xl py-2.5 pl-11 pr-4 text-sm font-medium text-white placeholder-slate-500 focus:outline-none focus:border-cyan-500/50 transition">
                </div>
            </div>

            <div class="flex items-center gap-3 md:gap-5">
                <a href="/" target="_blank" class="hidden sm:flex text-sm font-medium text-slate-400 hover:text-cyan-400 transition items-center gap-2 mr-2">
                    <i class="fa-solid fa-globe"></i> <span class="hidden xl:inline">Siteye Git</span>
                </a>
                <button class="w-10 h-10 rounded-xl bg-white/5 hover:bg-white/10 border border-white/10 flex items-center justify-center text-slate-300 transition relative">
                    <i class="fa-regular fa-bell"></i>
                    <span class="absolute top-2 right-2.5 w-2 h-2 rounded-full bg-pink-500 shadow-[0_0_8px_#ec4899]"></span>
                </button>

                <div class="relative group ml-2">
                    <button class="flex items-center gap-3 bg-black/20 p-2 pr-4 rounded-2xl border border-white/5 hover:bg-black/40 hover:border-white/10 transition shadow-lg">
                        <img src="https://ui-avatars.com/api/?name=Hasret+Özdemir&background=0D8ABC&color=fff&rounded=true" class="w-9 h-9 rounded-xl" alt="Hasret Özdemir">
                        <div class="text-left hidden sm:block">
                            <p class="text-sm font-bold text-white leading-none">Hasret Özdemir</p>
                            <p class="text-[10px] text-emerald-400 font-bold tracking-wider flex items-center gap-1 mt-1"><span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span> Çevrimiçi</p>
                        </div>
                        <i class="fa-solid fa-chevron-down text-slate-400 text-xs ml-1 group-hover:text-white transition"></i>
                    </button>

                    <div class="absolute right-0 mt-2 w-56 glass-card rounded-2xl shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform origin-top-right scale-95 group-hover:scale-100 z-50">
                        <div class="p-2 space-y-1">
                            <a href="/Admin/Yetkililer/Profil" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-slate-300 hover:text-white hover:bg-white/10 transition">
                                <i class="fa-regular fa-user text-cyan-400"></i> Kullanıcı Bilgileri
                            </a>
                            <a href="/Admin/Ayarlar" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-slate-300 hover:text-white hover:bg-white/10 transition">
                                <i class="fa-solid fa-sliders text-indigo-400"></i> Panel Ayarları
                            </a>
                            <div class="h-px bg-white/10 my-1"></div>
                            <a href="/Auth/Logout" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-bold text-rose-400 hover:text-rose-300 hover:bg-rose-500/10 transition">
                                <i class="fa-solid fa-arrow-right-from-bracket"></i> Oturumu Kapat
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <div class="flex-1 overflow-y-auto custom-scroll pr-2 pb-2">
            @RenderBody()
        </div>

    </main>

    <script>
        function toggleKurumsalMenu() {
            const submenu = document.getElementById('kurumsalSubmenu');
            const chevron = document.getElementById('kurumsalChevron');
            if (!submenu || !chevron) return;

            submenu.classList.toggle('hidden');
            chevron.classList.toggle('rotate-180');
        }

        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('overlay');

            if (sidebar.classList.contains('open')) {
                sidebar.classList.remove('open');
                overlay.classList.remove('opacity-100');
                overlay.classList.add('opacity-0');
                setTimeout(() => overlay.classList.add('hidden'), 300);
            } else {
                sidebar.classList.add('open');
                overlay.classList.remove('hidden');
                setTimeout(() => {
                    overlay.classList.add('opacity-100');
                }, 10);
            }
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>