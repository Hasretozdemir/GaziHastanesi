@using System.Security.Claims
@using System.Linq
@using GaziHastane.Security
@inject GaziHastane.Data.GaziHastaneContext Db
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Gazi Sağlık Panel</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700;900&display=swap" rel="stylesheet">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Outfit', 'sans-serif'] },
                    colors: {
                        darkBg: '#0f172a',
                        glassBg: 'rgba(255, 255, 255, 0.03)',
                        glassBorder: 'rgba(255, 255, 255, 0.05)'
                    }
                }
            }
        }
    </script>

    <style>
        body {
            background-color: #0f172a;
            background-image: radial-gradient(at 0% 0%, rgba(56, 189, 248, 0.15) 0px, transparent 50%), radial-gradient(at 100% 0%, rgba(168, 85, 247, 0.15) 0px, transparent 50%), radial-gradient(at 100% 100%, rgba(56, 189, 248, 0.15) 0px, transparent 50%), radial-gradient(at 0% 100%, rgba(168, 85, 247, 0.15) 0px, transparent 50%);
            background-attachment: fixed;
            color: #e2e8f0;
        }

        .glass-card {
            background: rgba(30, 41, 59, 0.4);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        #sidebar {
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        @@media (max-width: 768px) {
            #sidebar {
                position: fixed;
                top: 0;
                left: 0;
                height: calc(100% - 2rem);
                z-index: 50;
                transform: translateX(-110%);
            }

                #sidebar.open {
                    transform: translateX(0);
                }
        }

        .text-gradient {
            background: linear-gradient(to right, #38bdf8, #818cf8, #e879f9);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .neon-icon {
            filter: drop-shadow(0 0 8px currentColor);
        }

        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: rgba(0,0,0,0.1);
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(56, 189, 248, 0.3);
            border-radius: 10px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: rgba(168, 85, 247, 0.5);
            }
    </style>
</head>
<body class="flex h-screen overflow-hidden font-sans text-slate-200">

    <div id="overlay" onclick="toggleSidebar()" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-300"></div>

    <aside id="sidebar" class="w-72 glass-card m-4 rounded-[2rem] flex flex-col relative overflow-hidden z-50 shrink-0">
        <div class="absolute top-0 left-0 w-full h-32 bg-gradient-to-b from-blue-500/10 to-transparent"></div>

        <div class="h-24 flex items-center justify-between px-8 relative z-10 border-b border-white/5">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-2xl bg-gradient-to-tr from-cyan-500 to-purple-600 flex items-center justify-center shadow-[0_0_20px_rgba(6,182,212,0.4)]">
                    <i class="fa-solid fa-staff-snake text-2xl text-white"></i>
                </div>
                <div>
                    <h1 class="text-xl font-black tracking-widest text-white">GAZİ<span class="text-cyan-400">MED</span></h1>
                    <p class="text-[10px] text-cyan-200/60 uppercase tracking-widest font-bold mt-0.5">Yönetim Üssü</p>
                </div>
            </div>
            <button onclick="toggleSidebar()" class="md:hidden text-slate-400 hover:text-white transition">
                <i class="fa-solid fa-xmark text-2xl"></i>
            </button>
        </div>

        @{
            var ctrl = ViewContext.RouteData.Values["Controller"]?.ToString();
            var action = ViewContext.RouteData.Values["Action"]?.ToString();
            var activeClass = "bg-gradient-to-r from-cyan-500/20 to-purple-500/5 text-cyan-300 border border-cyan-500/30 shadow-[0_0_15px_rgba(6,182,212,0.15)]";
            var passiveClass = "hover:bg-white/5 text-slate-400 hover:text-white border border-transparent";
            List<GaziHastane.Models.AdminMenuItem> menuItems;
            try
            {
                menuItems = Db.AdminMenuItems.Where(x => x.IsActive).OrderBy(x => x.SortOrder).ToList();
            }
            catch
            {
                menuItems = new List<GaziHastane.Models.AdminMenuItem>();
            }

            var mainLinks = AdminPanelPermissions.MainScreenLinks.ToList();
            if (menuItems.Any())
            {
                var dbMain = AdminPanelPermissions.BuildSidebarLinks(menuItems, "Main");
                foreach (var item in dbMain) { if (!mainLinks.Any(x => x.Url == item.Url)) mainLinks.Add(item); }
            }
            mainLinks = mainLinks.Where(x => string.IsNullOrWhiteSpace(x.PermissionKey) || AdminPanelPermissions.UserHasPermission(User, x.PermissionKey)).ToList();

            var systemLinks = AdminPanelPermissions.SystemSettingsLinks.ToList();
            if (menuItems.Any())
            {
                var dbSystem = AdminPanelPermissions.BuildSidebarLinks(menuItems, "System");
                foreach (var item in dbSystem) { if (!systemLinks.Any(x => x.Url == item.Url)) systemLinks.Add(item); }
            }
            systemLinks = systemLinks.Where(x => string.IsNullOrWhiteSpace(x.PermissionKey) || AdminPanelPermissions.UserHasPermission(User, x.PermissionKey)).ToList();

            var contentLinks = AdminPanelPermissions.ContentLinks.ToList();
            if (menuItems.Any())
            {
                var dbContent = AdminPanelPermissions.BuildSidebarLinks(menuItems, "Content");
                foreach (var item in dbContent) { if (!contentLinks.Any(x => x.Url == item.Url)) contentLinks.Add(item); }
            }
            contentLinks = contentLinks.Where(x => string.IsNullOrWhiteSpace(x.PermissionKey) || AdminPanelPermissions.UserHasPermission(User, x.PermissionKey)).ToList();

            var kurumsalSubLinks = AdminPanelPermissions.KurumsalSubLinks.ToList();
            if (menuItems.Any())
            {
                var dbKurumsal = AdminPanelPermissions.BuildSidebarSubLinks(menuItems, "KurumsalSub");
                foreach (var item in dbKurumsal) { if (!kurumsalSubLinks.Any(x => x.Url == item.Url)) kurumsalSubLinks.Add(item); }
            }

            var securityLinks = AdminPanelPermissions.SecurityLinks.ToList();
            if (menuItems.Any())
            {
                var dbSecurity = AdminPanelPermissions.BuildSidebarLinks(menuItems, "Security");
                foreach (var item in dbSecurity) { if (!securityLinks.Any(x => x.Url == item.Url)) securityLinks.Add(item); }
            }
            securityLinks = securityLinks.Where(x => string.IsNullOrWhiteSpace(x.PermissionKey) || AdminPanelPermissions.UserHasPermission(User, x.PermissionKey)).ToList();

            var canKurumsal = AdminPanelPermissions.UserHasPermission(User, AdminPanelPermissions.Keys.Kurumsal);
            var isSuperAdmin = AdminPanelPermissions.IsSuperAdmin(User);
            var currentUserName = User.FindFirstValue(ClaimTypes.Name) ?? "Yetkili";
            var currentUserRole = User.FindFirstValue(ClaimTypes.Role) ?? "Yönetici";
        }

        <nav class="flex-1 px-4 py-8 overflow-y-auto space-y-2 relative z-10">
            <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-4 px-4">Ana Ekranlar</p>

            @foreach (var item in mainLinks)
            {
                var isActive = AdminPanelPermissions.IsSidebarLinkActive(ctrl, action, item);
                <a href="@item.Url" class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all group @(isActive ? activeClass : passiveClass)">
                    <i class="@item.IconClass text-lg @(isActive ? item.ActiveIconClass : item.HoverIconClass)"></i>
                    <span class="font-semibold tracking-wide">@item.Label</span>
                </a>
            }

            <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-4 px-4 mt-6">Sistem Ayarları</p>

            @foreach (var item in systemLinks)
            {
                var isActive = AdminPanelPermissions.IsSidebarLinkActive(ctrl, action, item);
                <a href="@item.Url" class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all duration-300 group @(isActive ? activeClass : passiveClass)">
                    <i class="@item.IconClass text-lg transition-all duration-300 @(isActive ? item.ActiveIconClass : item.HoverIconClass)"></i>
                    <span class="font-semibold tracking-wide">@item.Label</span>
                </a>
            }

            <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-4 px-4 mt-6">İçerik Yönetimi</p>

            @foreach (var item in contentLinks)
            {
                var isActive = AdminPanelPermissions.IsSidebarLinkActive(ctrl, action, item);
                <a href="@item.Url" class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all group @(isActive ? activeClass : passiveClass)">
                    <i class="@item.IconClass text-lg @(isActive ? item.ActiveIconClass : item.HoverIconClass)"></i>
                    <span class="font-semibold tracking-wide">@item.Label</span>
                </a>
            }

            @if (canKurumsal)
            {
            <div class="space-y-1">
                <button type="button" onclick="toggleKurumsalMenu()" class="w-full flex items-center justify-between gap-4 px-4 py-3.5 rounded-2xl transition-all group @(ctrl == "Kurumsal" || ctrl == "Bashekimlik" || ctrl == "Basmudurluk" ? activeClass : passiveClass)">
                    <span class="flex items-center gap-4">
                        <i class="fa-solid fa-building text-lg @(ctrl == "Kurumsal" || ctrl == "Bashekimlik" || ctrl == "Basmudurluk" ? "neon-icon" : "group-hover:text-cyan-400")"></i>
                        <span class="font-semibold tracking-wide">Kurumsal</span>
                    </span>
                    <i id="kurumsalChevron" class="fa-solid fa-chevron-down text-xs transition-transform @(ctrl == "Kurumsal" || ctrl == "Bashekimlik" || ctrl == "Basmudurluk" ? "rotate-180" : "")"></i>
                </button>

                <div id="kurumsalSubmenu" class="ml-6 space-y-1 @(ctrl == "Kurumsal" || ctrl == "Bashekimlik" || ctrl == "Basmudurluk" ? "" : "hidden")">
                    @foreach (var item in kurumsalSubLinks)
                    {
                        var isSubActive = AdminPanelPermissions.IsSidebarSubLinkActive(ctrl, action, item);
                        <a href="@item.Url" class="block text-xs px-3 py-2 rounded-xl transition @(isSubActive ? "bg-cyan-500/15 text-cyan-300" : "text-slate-400 hover:bg-white/5 hover:text-white")">@item.Label</a>
                    }
                </div>
            </div>
            }

            <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-4 px-4 mt-6">Güvenlik & Erişim</p>

            @if (securityLinks.Any())
            {
                foreach (var item in securityLinks)
                {
                    var isActive = AdminPanelPermissions.IsSidebarLinkActive(ctrl, action, item);
                    <a href="@item.Url" class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all group @(isActive ? activeClass : passiveClass)">
                        <i class="@item.IconClass text-lg @(isActive ? item.ActiveIconClass : item.HoverIconClass)"></i>
                        <span class="font-semibold tracking-wide">@item.Label</span>
                    </a>
                }
            }

            <a href="/Admin/SistemLog/Index" class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all group @(ctrl == "SistemLog" ? activeClass : passiveClass)">
                <i class="fa-solid fa-clock-rotate-left text-lg @(ctrl == "SistemLog" ? "neon-icon" : "group-hover:text-cyan-400")"></i>
                <span class="font-semibold tracking-wide">Sistem Hareketleri</span>
            </a>

        </nav>
    </aside>

    <main class="flex-1 flex flex-col h-screen overflow-hidden p-4 md:py-4 md:pr-4 md:pl-0">

        <header class="glass-card h-20 rounded-[2rem] flex items-center justify-between px-6 md:px-8 mb-6 shrink-0 z-20">
            <div class="flex items-center gap-4">
                <button onclick="toggleSidebar()" class="md:hidden w-11 h-11 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-cyan-400 shadow-lg active:scale-95 transition">
                    <i class="fa-solid fa-bars-staggered text-xl"></i>
                </button>

                <div class="relative w-96 hidden lg:block">
                    <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                    <input type="text" placeholder="Sistemde ara..." class="w-full bg-black/20 border border-white/10 rounded-xl py-2.5 pl-11 pr-4 text-sm font-medium text-white placeholder-slate-500 focus:outline-none focus:border-cyan-500/50 transition">
                </div>
            </div>

            <div class="flex items-center gap-3 md:gap-5">
                <a href="/" target="_blank" class="hidden sm:flex text-sm font-medium text-slate-400 hover:text-cyan-400 transition items-center gap-2 mr-2">
                    <i class="fa-solid fa-globe"></i> <span class="hidden xl:inline">Siteye Git</span>
                </a>
                <button class="w-10 h-10 rounded-xl bg-white/5 hover:bg-white/10 border border-white/10 flex items-center justify-center text-slate-300 transition relative">
                    <i class="fa-regular fa-bell"></i>
                    <span class="absolute top-2 right-2.5 w-2 h-2 rounded-full bg-pink-500 shadow-[0_0_8px_#ec4899]"></span>
                </button>

                <div class="relative group ml-2">
                    <button class="flex items-center gap-3 bg-black/20 p-2 pr-4 rounded-2xl border border-white/5 hover:bg-black/40 hover:border-white/10 transition shadow-lg">
                        <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(currentUserName)&background=0D8ABC&color=fff&rounded=true" class="w-9 h-9 rounded-xl" alt="@currentUserName">
                        <div class="text-left hidden sm:block">
                            <p class="text-sm font-bold text-white leading-none">@currentUserName</p>
                            <p class="text-[10px] text-emerald-400 font-bold tracking-wider flex items-center gap-1 mt-1"><span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span> @currentUserRole</p>
                        </div>
                        <i class="fa-solid fa-chevron-down text-slate-400 text-xs ml-1 group-hover:text-white transition"></i>
                    </button>

                    <div class="absolute right-0 mt-2 w-56 glass-card rounded-2xl shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform origin-top-right scale-95 group-hover:scale-100 z-50">
                        <div class="p-2 space-y-1">
                            <a href="/Admin/Yetkililer/Profil" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-slate-300 hover:text-white hover:bg-white/10 transition">
                                <i class="fa-regular fa-user text-cyan-400"></i> Kullanıcı Bilgileri
                            </a>
                            <a href="/Admin/Ayarlar" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-slate-300 hover:text-white hover:bg-white/10 transition">
                                <i class="fa-solid fa-sliders text-indigo-400"></i> Panel Ayarları
                            </a>
                            <div class="h-px bg-white/10 my-1"></div>
                            <a href="/Admin/Auth/Logout" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-bold text-rose-400 hover:text-rose-300 hover:bg-rose-500/10 transition">
                                <i class="fa-solid fa-arrow-right-from-bracket"></i> Oturumu Kapat
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <div class="flex-1 overflow-y-auto custom-scroll pr-2 pb-2">
            @RenderBody()
        </div>

    </main>

    <script>
        function toggleKurumsalMenu() {
            const submenu = document.getElementById('kurumsalSubmenu');
            const chevron = document.getElementById('kurumsalChevron');
            if (!submenu || !chevron) return;

            submenu.classList.toggle('hidden');
            chevron.classList.toggle('rotate-180');
        }

        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('overlay');

            if (sidebar.classList.contains('open')) {
                sidebar.classList.remove('open');
                overlay.classList.remove('opacity-100');
                overlay.classList.add('opacity-0');
                setTimeout(() => overlay.classList.add('hidden'), 300);
            } else {
                sidebar.classList.add('open');
                overlay.classList.remove('hidden');
                setTimeout(() => {
                    overlay.classList.add('opacity-100');
                }, 10);
            }
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>