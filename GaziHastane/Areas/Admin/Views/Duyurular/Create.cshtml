@model GaziHastane.Models.Duyuru
@{
    ViewData["Title"] = "Duyuru Ekle/Düzenle";
}

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Duyuru Bilgileri</h6>
    </div>
    <div class="card-body">
        <form asp-action="Create">
            <input type="hidden" asp-for="Id" />

            <div class="row">
                <div class="col-md-12 mb-3">
                    <label asp-for="Baslik" class="form-label">Duyuru Başlığı</label>
                    <input asp-for="Baslik" class="form-control" placeholder="Örn: Personel İçin İSG Yenileme Eğitimi Hakkında" required />
                    <span asp-validation-for="Baslik" class="text-danger"></span>
                </div>

                <div class="col-md-12 mb-3">
                    <label asp-for="Icerik" class="form-label">Duyuru İçeriği (Detay)</label>
                    <textarea asp-for="Icerik" class="form-control" rows="4" required></textarea>
                    <span asp-validation-for="Icerik" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="GorselUrl" class="form-label">Görsel URL (İsteğe Bağlı)</label>
                    <input asp-for="GorselUrl" class="form-control" placeholder="/assets/duyuru-resmi.jpg" />
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="YayinTarihi" class="form-label">Yayın Tarihi</label>
                    <input asp-for="YayinTarihi" type="datetime-local" class="form-control" required />
                </div>

                <div class="col-md-12 mb-3 form-check ms-3">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">Sitede Göster (Aktif Mi?)</label>
                </div>
            </div>

            <hr />
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Kaydet</button>
            <a asp-action="Index" class="btn btn-secondary">Vazgeç</a>
        </form>
    </div>
</div>