@model IEnumerable<GaziHastane.Models.Doktor>
@{
    ViewData["Title"] = "Doktor Yönetimi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="mb-8 pl-2 flex justify-between items-end">
    <div>
        <h2 class="text-3xl md:text-4xl font-black mb-2 tracking-tight">Doktor <span class="text-gradient">Listesi</span> 👨‍⚕️</h2>
        <p class="text-slate-400 font-medium">Sistemde kayıtlı tüm doktorları buradan yönetebilirsiniz.</p>
    </div>
    <a href="/Admin/Doktorlar/Create" class="bg-gradient-to-r from-emerald-500 to-teal-600 text-white px-6 py-2.5 rounded-xl font-bold text-sm shadow-[0_0_20px_rgba(16,185,129,0.3)] hover:scale-105 transition">
        <i class="fa-solid fa-plus mr-2"></i>Yeni Doktor Ekle
    </a>
</div>

<div class="glass-card rounded-[2rem] overflow-hidden mb-8">
    <div class="overflow-x-auto">
        <table class="w-full text-left whitespace-nowrap">
            <thead class="bg-black/20">
                <tr>
                    <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-white/5">Hekim</th>
                    <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-white/5">Birim (Poliklinik)</th>
                    <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-white/5">Uzmanlık Alanı</th>
                    <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-white/5">Durum</th>
                    <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-white/5 text-right">İşlemler</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-white/5">

                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        // İsim ve Soyismin baş harflerini al (Resim yoksa avatar yapmak için)
                        var adHarf = !string.IsNullOrEmpty(item.Ad) ? item.Ad.Substring(0, 1).ToUpper() : "";
                        var soyadHarf = !string.IsNullOrEmpty(item.Soyad) ? item.Soyad.Substring(0, 1).ToUpper() : "";
                        var initials = adHarf + soyadHarf;

                        <tr class="hover:bg-white/5 transition duration-200">
                            <td class="px-8 py-5">
                                <div class="flex items-center gap-4">
                                    @if (!string.IsNullOrEmpty(item.FotografUrl))
                                    {
                                        <img src="@item.FotografUrl" class="w-10 h-10 rounded-xl object-cover shadow-[0_0_15px_rgba(6,182,212,0.4)]" alt="@item.Ad">
                                    }
                                    else
                                    {
                                        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center font-black text-white shadow-[0_0_15px_rgba(99,102,241,0.4)]">
                                            @initials
                                        </div>
                                    }
                                    <div>
                                        <p class="font-bold text-white text-sm">@item.Unvan @item.Ad @item.Soyad</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-8 py-5">
                                <span class="text-sm font-bold text-cyan-300 bg-cyan-500/10 border border-cyan-500/20 px-3 py-1.5 rounded-lg">
                                    @(item.Bolum != null ? item.Bolum.Ad : "Atanmadı")
                                </span>
                            </td>
                            <td class="px-8 py-5 text-slate-300 text-sm">
                                @(string.IsNullOrEmpty(item.UzmanlikAlani) ? "-" : item.UzmanlikAlani)
                            </td>
                            <td class="px-8 py-5">
                                @if (item.IsActive)
                                {
                                    <span class="flex items-center gap-2 text-xs font-bold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-3 py-1.5 rounded-lg w-max">
                                        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse shadow-[0_0_5px_#34d399]"></span> Aktif
                                    </span>
                                }
                                else
                                {
                                    <span class="flex items-center gap-2 text-xs font-bold text-rose-400 bg-rose-500/10 border border-rose-500/20 px-3 py-1.5 rounded-lg w-max">
                                        <span class="w-2 h-2 rounded-full bg-rose-400 shadow-[0_0_5px_#f43f5e]"></span> Pasif
                                    </span>
                                }
                            </td>
                            <td class="px-8 py-5 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="/Admin/Doktorlar/Edit/@item.Id" class="w-8 h-8 rounded-lg bg-blue-500/10 hover:bg-blue-500/30 text-blue-400 transition flex items-center justify-center border border-blue-500/20" title="Düzenle">
                                        <i class="fa-solid fa-pen text-xs"></i>
                                    </a>
                                    <a href="/Admin/Doktorlar/Delete/@item.Id" class="w-8 h-8 rounded-lg bg-rose-500/10 hover:bg-rose-500/30 text-rose-400 transition flex items-center justify-center border border-rose-500/20" title="Sil">
                                        <i class="fa-solid fa-trash text-xs"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="px-8 py-12 text-center text-slate-400">
                            <i class="fa-solid fa-user-doctor text-4xl mb-4 opacity-50 block"></i>
                            <p>Sistemde henüz kayıtlı doktor bulunmamaktadır.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>