@{
    ViewData["Title"] = "Hekim Kadrosu";
}

<div class="animate-[fadeIn_0.5s_ease-out] pr-2 pb-2">
    
    <div class="mb-8 pl-2 flex flex-col md:flex-row justify-between items-start md:items-end gap-4 relative z-10">
        <div>
            <h2 class="text-4xl md:text-5xl font-black mb-2 tracking-tight">Hekim <span class="text-gradient">Kadrosu</span> 👨‍⚕️</h2>
            <p class="text-slate-400 font-medium">Sistemde kayıtlı tüm doktorları yönetin, düzenleyin veya yeni hekim atayın.</p>
        </div>
        <button class="bg-gradient-to-r from-purple-500 to-pink-600 text-white px-6 py-3 rounded-xl font-bold text-sm shadow-[0_0_20px_rgba(236,72,153,0.3)] hover:scale-105 transition flex items-center gap-2">
            <i class="fa-solid fa-user-plus"></i> Yeni Hekim Ekle
        </button>
    </div>

    <div class="glass-card p-4 rounded-2xl mb-8 flex flex-wrap gap-4 items-center justify-between relative z-10">
        <div class="flex gap-2">
            <button class="bg-cyan-500/20 text-cyan-300 border border-cyan-500/30 px-4 py-2 rounded-xl text-xs font-bold shadow-[0_0_10px_rgba(6,182,212,0.2)]">Tümü</button>
            <button class="bg-white/5 text-slate-400 hover:text-white hover:bg-white/10 border border-white/5 px-4 py-2 rounded-xl text-xs font-bold transition">Cerrahlar</button>
            <button class="bg-white/5 text-slate-400 hover:text-white hover:bg-white/10 border border-white/5 px-4 py-2 rounded-xl text-xs font-bold transition">Uzmanlar</button>
        </div>
        <div class="text-slate-400 text-sm font-medium">Toplam <span class="text-white font-bold">124</span> Hekim Listeleniyor</div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 relative z-10">
        
        <div class="glass-card p-6 rounded-[2rem] relative group text-center overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-b from-cyan-500/10 to-transparent opacity-0 group-hover:opacity-100 transition duration-500"></div>
            <div class="relative z-10">
                <div class="relative w-20 h-20 mx-auto mb-4">
                    <img src="https://ui-avatars.com/api/?name=Hasret+Özdemir&background=0D8ABC&color=fff&rounded=true" class="w-full h-full rounded-2xl border-2 border-cyan-500/50 shadow-[0_0_15px_rgba(6,182,212,0.4)]" alt="Avatar">
                    <span class="absolute -bottom-1 -right-1 w-4 h-4 bg-emerald-400 border-2 border-[#1e293b] rounded-full shadow-[0_0_8px_#34d399]"></span>
                </div>
                <h3 class="text-lg font-black text-white mb-1">Hasret Özdemir</h3>
                <p class="text-xs font-bold text-cyan-400 uppercase tracking-widest mb-4">Kardiyoloji</p>
                <div class="flex justify-center gap-2 mb-6">
                    <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-lg text-[10px] text-slate-300 font-semibold"><i class="fa-solid fa-stethoscope text-slate-400 mr-1"></i> Uzman Dr.</span>
                    <span class="px-3 py-1 bg-amber-500/10 border border-amber-500/20 rounded-lg text-[10px] text-amber-300 font-semibold"><i class="fa-solid fa-star text-amber-400 mr-1"></i> 4.9</span>
                </div>
                <div class="flex gap-2">
                    <button class="flex-1 bg-white/5 hover:bg-cyan-500/20 text-white border border-white/10 hover:border-cyan-500/30 py-2 rounded-xl text-xs font-bold transition"><i class="fa-solid fa-pen"></i> Düzenle</button>
                    <button class="w-10 bg-white/5 hover:bg-rose-500/20 text-slate-400 hover:text-rose-400 border border-white/10 hover:border-rose-500/30 py-2 rounded-xl transition flex items-center justify-center"><i class="fa-solid fa-trash"></i></button>
                </div>
            </div>
        </div>

        <div class="glass-card p-6 rounded-[2rem] relative group text-center overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-b from-purple-500/10 to-transparent opacity-0 group-hover:opacity-100 transition duration-500"></div>
            <div class="relative z-10">
                <div class="relative w-20 h-20 mx-auto mb-4">
                    <div class="w-full h-full rounded-2xl bg-gradient-to-br from-purple-500 to-indigo-600 flex items-center justify-center text-2xl font-black text-white border-2 border-purple-500/50 shadow-[0_0_15px_rgba(168,85,247,0.4)]">SK</div>
                    <span class="absolute -bottom-1 -right-1 w-4 h-4 bg-emerald-400 border-2 border-[#1e293b] rounded-full shadow-[0_0_8px_#34d399]"></span>
                </div>
                <h3 class="text-lg font-black text-white mb-1">Sude Kılıç</h3>
                <p class="text-xs font-bold text-purple-400 uppercase tracking-widest mb-4">Göz Hastalıkları</p>
                <div class="flex justify-center gap-2 mb-6">
                    <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-lg text-[10px] text-slate-300 font-semibold"><i class="fa-solid fa-microscope text-slate-400 mr-1"></i> Prof. Dr.</span>
                    <span class="px-3 py-1 bg-amber-500/10 border border-amber-500/20 rounded-lg text-[10px] text-amber-300 font-semibold"><i class="fa-solid fa-star text-amber-400 mr-1"></i> 5.0</span>
                </div>
                <div class="flex gap-2">
                    <button class="flex-1 bg-white/5 hover:bg-cyan-500/20 text-white border border-white/10 hover:border-cyan-500/30 py-2 rounded-xl text-xs font-bold transition"><i class="fa-solid fa-pen"></i> Düzenle</button>
                    <button class="w-10 bg-white/5 hover:bg-rose-500/20 text-slate-400 hover:text-rose-400 border border-white/10 hover:border-rose-500/30 py-2 rounded-xl transition flex items-center justify-center"><i class="fa-solid fa-trash"></i></button>
                </div>
            </div>
        </div>

        <div class="glass-card p-6 rounded-[2rem] relative group text-center overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-b from-rose-500/10 to-transparent opacity-0 group-hover:opacity-100 transition duration-500"></div>
            <div class="relative z-10">
                <div class="relative w-20 h-20 mx-auto mb-4">
                    <img src="https://ui-avatars.com/api/?name=Ali+Yılmaz&background=f43f5e&color=fff&rounded=true" class="w-full h-full rounded-2xl border-2 border-rose-500/50 shadow-[0_0_15px_rgba(244,63,94,0.4)]" alt="Avatar">
                    <span class="absolute -bottom-1 -right-1 w-4 h-4 bg-rose-500 border-2 border-[#1e293b] rounded-full shadow-[0_0_8px_#f43f5e]"></span>
                </div>
                <h3 class="text-lg font-black text-white mb-1">Ali Yılmaz</h3>
                <p class="text-xs font-bold text-rose-400 uppercase tracking-widest mb-4">Acil Tıp</p>
                <div class="flex justify-center gap-2 mb-6">
                    <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-lg text-[10px] text-slate-300 font-semibold"><i class="fa-solid fa-truck-medical text-slate-400 mr-1"></i> Pratisyen</span>
                    <span class="px-3 py-1 bg-rose-500/10 border border-rose-500/20 rounded-lg text-[10px] text-rose-300 font-semibold">İzinde</span>
                </div>
                <div class="flex gap-2">
                    <button class="flex-1 bg-white/5 hover:bg-cyan-500/20 text-white border border-white/10 hover:border-cyan-500/30 py-2 rounded-xl text-xs font-bold transition"><i class="fa-solid fa-pen"></i> Düzenle</button>
                    <button class="w-10 bg-white/5 hover:bg-rose-500/20 text-slate-400 hover:text-rose-400 border border-white/10 hover:border-rose-500/30 py-2 rounded-xl transition flex items-center justify-center"><i class="fa-solid fa-trash"></i></button>
                </div>
            </div>
        </div>

    </div>
</div>