@using GaziHastane.Models
@model IEnumerable<Doktor>

@{
    ViewData["Title"] = "Hekim Kadrosu";
}

<div class="animate-[fadeIn_0.5s_ease-out] pr-2 pb-2">
    
    <div class="mb-8 pl-2 flex flex-col md:flex-row justify-between items-start md:items-end gap-4 relative z-10">
        <div>
            <h2 class="text-4xl md:text-5xl font-black mb-2 tracking-tight">Hekim <span class="text-gradient">Kadrosu</span> 👨‍⚕️</h2>
            <p class="text-slate-400 font-medium">Sistemde kayıtlı tüm doktorları yönetin, düzenleyin veya yeni hekim atayın.</p>
        </div>
        <a asp-action="Create" class="bg-gradient-to-r from-purple-500 to-pink-600 text-white px-6 py-3 rounded-xl font-bold text-sm shadow-[0_0_20px_rgba(236,72,153,0.3)] hover:scale-105 transition flex items-center gap-2 decoration-none">
            <i class="fa-solid fa-user-plus"></i> Yeni Hekim Ekle
        </a>
    </div>

    <!-- Filtreleme Bölümü (Şimdilik Statik) -->
    <div class="glass-card p-4 rounded-2xl mb-8 flex flex-wrap gap-4 items-center justify-between relative z-10">
        <div class="flex gap-2">
            <button class="bg-cyan-500/20 text-cyan-300 border border-cyan-500/30 px-4 py-2 rounded-xl text-xs font-bold shadow-[0_0_10px_rgba(6,182,212,0.2)]">Tümü</button>
            <!-- Diğer filtreler eklenebilir -->
        </div>
        <div class="text-slate-400 text-sm font-medium">Toplam <span class="text-white font-bold">@Model.Count()</span> Hekim Listeleniyor</div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 relative z-10">
        
        @foreach (var item in Model)
        {
            <div class="glass-card p-6 rounded-[2rem] relative group text-center overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-b from-cyan-500/10 to-transparent opacity-0 group-hover:opacity-100 transition duration-500"></div>
                <div class="relative z-10">
                    <div class="relative w-20 h-20 mx-auto mb-4">
                        <!-- Avatar: Eğer FotografUrl varsa onu kullan, yoksa isme göre avatar oluştur -->
                        @if (!string.IsNullOrEmpty(item.FotografUrl))
                        {
                             <img src="@item.FotografUrl" class="w-full h-full rounded-2xl border-2 border-cyan-500/50 shadow-[0_0_15px_rgba(6,182,212,0.4)] object-cover" alt="@item.Ad @item.Soyad">
                        }
                        else
                        {
                             <img src="https://ui-avatars.com/api/?name=@item.Ad+@item.Soyad&background=random&color=fff&rounded=true" class="w-full h-full rounded-2xl border-2 border-cyan-500/50 shadow-[0_0_15px_rgba(6,182,212,0.4)]" alt="Avatar">
                        }
                        
                        <!-- Aktiflik Durumu -->
                        @if(item.IsActive)
                        {
                            <span class="absolute -bottom-1 -right-1 w-4 h-4 bg-emerald-400 border-2 border-[#1e293b] rounded-full shadow-[0_0_8px_#34d399]" title="Aktif"></span>
                        }
                        else
                        {
                             <span class="absolute -bottom-1 -right-1 w-4 h-4 bg-rose-500 border-2 border-[#1e293b] rounded-full shadow-[0_0_8px_#f43f5e]" title="Pasif"></span>
                        }
                    </div>
                    
                    <h3 class="text-lg font-black text-white mb-1">@item.Ad @item.Soyad</h3>
                    <p class="text-xs font-bold text-cyan-400 uppercase tracking-widest mb-4">@(item.Bolum?.Ad ?? "Bölüm Yok")</p>
                    
                    <div class="flex justify-center gap-2 mb-6">
                        <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-lg text-[10px] text-slate-300 font-semibold">
                            <i class="fa-solid fa-stethoscope text-slate-400 mr-1"></i> @(item.Unvan ?? "Dr.")
                        </span>
                        <!-- Uzmanlık Alanı Varsa Göster -->
                        @if(!string.IsNullOrEmpty(item.UzmanlikAlani))
                        {
                             <span class="px-3 py-1 bg-amber-500/10 border border-amber-500/20 rounded-lg text-[10px] text-amber-300 font-semibold" title="Uzmanlık Alanı">
                                 <i class="fa-solid fa-star text-amber-400 mr-1"></i> @item.UzmanlikAlani
                             </span>
                        }
                    </div>
                    
                    <div class="flex gap-2">
                        <!-- Düzenle ve Sil butonları (Şimdilik işlevsiz, daha sonra eklenebilir) -->
                        <a asp-action="Edit" asp-route-id="@item.Id" class="flex-1 bg-white/5 hover:bg-cyan-500/20 text-white border border-white/10 hover:border-cyan-500/30 py-2 rounded-xl text-xs font-bold transition decoration-none flex items-center justify-center gap-2">
                            <i class="fa-solid fa-pen"></i> Düzenle
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="w-10 bg-white/5 hover:bg-rose-500/20 text-slate-400 hover:text-rose-400 border border-white/10 hover:border-rose-500/30 py-2 rounded-xl transition flex items-center justify-center decoration-none">
                            <i class="fa-solid fa-trash"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
        
        <!-- Eğer liste boşsa mesaj göster -->
        @if (!Model.Any())
        {
            <div class="col-span-full text-center text-slate-500 py-10">
                <i class="fa-solid fa-user-doctor text-4xl mb-3 opacity-50"></i>
                <p>Henüz kayıtlı doktor bulunmamaktadır.</p>
            </div>
        }

    </div>
</div>