@model IEnumerable<GaziHastane.Models.KrokiBlok>
@{
    ViewData["Title"] = "Hastane Krokisi Yönetimi";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2 class="mb-0 text-primary"><i class="fas fa-sitemap me-2"></i>Kroki Yönetimi</h2>
            <button class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#blokModal" onclick="yeniBlok()">
                <i class="fas fa-plus me-2"></i>Yeni Blok Ekle
            </button>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Content -->
    <div class="row">
        @foreach(var blok in Model)
        {
            <div class="col-12 mb-4">
                <div class="card shadow-sm border-0 border-start border-5" style="border-color: @(blok.Renk ?? "#000") !important;">
                    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                        <h4 class="mb-0 fw-bold">
                            <span class="badge" style="background-color: @(blok.Renk ?? "#000");">@blok.BlokAdi</span>
                        </h4>
                        <div>
                            <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#katModal" onclick="yeniKat(@blok.Id)">
                                <i class="fas fa-plus"></i> Kat Ekle
                            </button>
                            <button class="btn btn-sm btn-outline-warning mx-1" data-bs-toggle="modal" data-bs-target="#blokModal" onclick="duzenleBlok(@blok.Id, '@blok.BlokAdi', '@blok.Renk')">
                                <i class="fas fa-edit"></i>
                            </button>
                            <form asp-action="BlokSil" asp-route-id="@blok.Id" method="post" class="d-inline" onsubmit="return confirm('Bu bloğu ve içindeki tüm katları/bölümleri silmek istediğinize emin misiniz?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                            </form>
                        </div>
                    </div>
                    
                    <div class="card-body bg-light">
                        @if(blok.Katlar != null && blok.Katlar.Any())
                        {
                            <div class="accordion" id="accBlok_@blok.Id">
                                @foreach(var kat in blok.Katlar)
                                {
                                    <div class="accordion-item mb-2 border-0 shadow-sm rounded">
                                        <h2 class="accordion-header" id="heading_@kat.Id">
                                            <button class="accordion-button collapsed fw-bold text-dark rounded" type="button" data-bs-toggle="collapse" data-bs-target="#col_@kat.Id" aria-expanded="false" aria-controls="col_@kat.Id">
                                                <i class="fas fa-layer-group text-secondary me-2"></i>@kat.KatAdi
                                            </button>
                                        </h2>
                                        <div id="col_@kat.Id" class="accordion-collapse collapse" aria-labelledby="heading_@kat.Id" data-bs-parent="#accBlok_@blok.Id">
                                            <div class="accordion-body bg-white rounded-bottom">
                                                
                                                <div class="d-flex justify-content-between mb-3 border-bottom pb-2 align-items-center">
                                                    <span class="text-muted small">Bu kata ait bölümler listesi</span>
                                                    <div>
                                                        <button class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#bolumModal" onclick="yeniBolum(@kat.Id)">
                                                            <i class="fas fa-plus me-1"></i> Bölüm Ekle
                                                        </button>
                                                        <button class="btn btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#katModal" onclick="duzenleKat(@kat.Id, '@kat.KatAdi', @blok.Id)">
                                                            <i class="fas fa-edit"></i>
                                                        </button>
                                                        <form asp-action="KatSil" asp-route-id="@kat.Id" method="post" class="d-inline" onsubmit="return confirm('Bu katı silmek istediğinize emin misiniz?');">
                                                            <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                                                        </form>
                                                    </div>
                                                </div>

                                                <ul class="list-group list-group-flush">
                                                    @if(kat.Bolumler != null && kat.Bolumler.Any())
                                                    {
                                                        @foreach(var bolum in kat.Bolumler)
                                                        {
                                                            <li class="list-group-item d-flex justify-content-between align-items-center py-3 border-0 rounded bg-light mb-2">
                                                                <div>
                                                                    <div class="rounded-circle d-inline-flex justify-content-center align-items-center bg-white shadow-sm me-3" style="width: 40px; height: 40px;">
                                                                        <i class="fas @(bolum.Ikon ?? "fa-circle") text-primary"></i>
                                                                    </div>
                                                                    <span class="fw-semibold @(bolum.IsEmpty ? "text-muted fst-italic" : "text-dark")">@bolum.BirimAdi</span>
                                                                    @if(bolum.IsEmpty) { <span class="badge bg-secondary ms-2 small">Sadece Görsel</span> }
                                                                </div>
                                                                <div>
                                                                    <button class="btn btn-sm btn-light text-warning shadow-sm" data-bs-toggle="modal" data-bs-target="#bolumModal" onclick="duzenleBolum(@bolum.Id, '@bolum.BirimAdi', '@bolum.Ikon', @(bolum.IsEmpty.ToString().ToLower()), @kat.Id)">
                                                                        <i class="fas fa-pen"></i>
                                                                    </button>
                                                                    <form asp-action="BolumSil" asp-route-id="@bolum.Id" method="post" class="d-inline" onsubmit="return confirm('Emin misiniz?');">
                                                                        <button type="submit" class="btn btn-sm btn-light text-danger shadow-sm"><i class="fas fa-times"></i></button>
                                                                    </form>
                                                                </div>
                                                            </li>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <li class="list-group-item text-center text-muted border-0 py-4 bg-transparent">Bu katta henüz bir bölüm yok.</li>
                                                    }
                                                </ul>

                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-center text-muted my-3 mb-0">Bu bloka henüz kat eklenmemiş.</p>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Blok Modal -->
<div class="modal fade" id="blokModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="BlokKaydet" method="post" class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Blok Bilgisi</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" name="Id" id="blok_Id" value="0" />
                <div class="mb-3">
                    <label class="form-label">Blok Adı (D Blok, Poliklinikler vb.)</label>
                    <input type="text" name="BlokAdi" id="blok_Ad" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Blok Rengi</label>
                    <input type="color" name="Renk" id="blok_Renk" class="form-control form-control-color w-100" value="#003366" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
                <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Kaydet</button>
            </div>
        </form>
    </div>
</div>

<!-- Kat Modal -->
<div class="modal fade" id="katModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="KatKaydet" method="post" class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Kat Bilgisi</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" name="Id" id="kat_Id" value="0" />
                <input type="hidden" name="BlokId" id="kat_BlokId" />
                <div class="mb-3">
                    <label class="form-label">Kat Adı (Örn: Zemin Kat, 1. Kat)</label>
                    <input type="text" name="KatAdi" id="kat_Ad" class="form-control" required />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
                <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Kaydet</button>
            </div>
        </form>
    </div>
</div>

<!-- Bölüm Modal -->
<div class="modal fade" id="bolumModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="BolumKaydet" method="post" class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Bölüm / Birim Bilgisi</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" name="Id" id="bolum_Id" value="0" />
                <input type="hidden" name="KatId" id="bolum_KatId" />
                <div class="mb-3">
                    <label class="form-label">Birim/Bölüm Adı</label>
                    <input type="text" name="BirimAdi" id="bolum_Ad" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">FontAwesome İkon Sınıfı (Örn: fa-bed, fa-user-md)</label>
                    <input type="text" name="Ikon" id="bolum_Ikon" class="form-control" value="fa-layer-group" />
                    <small class="text-muted"><a href="https://fontawesome.com/icons" target="_blank">İkonları gör</a></small>
                </div>
                <div class="form-check form-switch mt-3">
                    <input class="form-check-input" type="checkbox" role="switch" name="IsEmpty" id="bolum_Empty" value="true">
                    <label class="form-check-label" for="bolum_Empty">Bu birim sadece boş idari/arşiv ofisi mi? (Açık renk görünür)</label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
                <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Kaydet</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function yeniBlok() {
        document.getElementById('blok_Id').value = 0;
        document.getElementById('blok_Ad').value = '';
        document.getElementById('blok_Renk').value = '#003366';
    }
    function duzenleBlok(id, ad, renk) {
        document.getElementById('blok_Id').value = id;
        document.getElementById('blok_Ad').value = ad;
        document.getElementById('blok_Renk').value = renk;
    }
    
    function yeniKat(blokId) {
        document.getElementById('kat_Id').value = 0;
        document.getElementById('kat_BlokId').value = blokId;
        document.getElementById('kat_Ad').value = '';
    }
    function duzenleKat(id, ad, blokId) {
        document.getElementById('kat_Id').value = id;
        document.getElementById('kat_BlokId').value = blokId;
        document.getElementById('kat_Ad').value = ad;
    }

    function yeniBolum(katId) {
        document.getElementById('bolum_Id').value = 0;
        document.getElementById('bolum_KatId').value = katId;
        document.getElementById('bolum_Ad').value = '';
        document.getElementById('bolum_Ikon').value = 'fa-layer-group';
        document.getElementById('bolum_Empty').checked = false;
    }
    function duzenleBolum(id, ad, ikon, emp, katId) {
        document.getElementById('bolum_Id').value = id;
        document.getElementById('bolum_KatId').value = katId;
        document.getElementById('bolum_Ad').value = ad;
        document.getElementById('bolum_Ikon').value = ikon || 'fa-layer-group';
        document.getElementById('bolum_Empty').checked = emp;
    }
</script>
}