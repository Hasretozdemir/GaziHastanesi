@model IEnumerable<GaziHastane.Models.KrokiBirim>
@{
    ViewData["Title"] = "Kroki Yönetimi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="glass-card p-6 md:p-8 rounded-[2rem] mb-6 relative z-10">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
        <div>
            <h2 class="text-2xl font-black text-white flex items-center gap-3">
                <i class="fa-solid fa-map-location-dot text-cyan-400"></i> İnteraktif Kroki Yönetimi
            </h2>
            <p class="text-slate-400 text-sm mt-1">Hastanenin dijital haritasındaki odaları, koridorları ve poliklinikleri yönetin.</p>
        </div>
        <button onclick="openKrokiModal()" class="bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-400 hover:to-blue-500 text-white px-6 py-3 rounded-xl font-bold shadow-lg shadow-cyan-500/30 transition-all flex items-center gap-2">
            <i class="fa-solid fa-plus"></i> Yeni Birim Çiz
        </button>
    </div>

    <div class="bg-cyan-500/10 border border-cyan-500/20 rounded-2xl p-4 mb-6 flex items-start gap-4">
        <i class="fa-solid fa-circle-info text-cyan-400 text-xl mt-0.5"></i>
        <div class="text-sm text-cyan-100">
            <strong class="text-cyan-300">Nasıl Çizilir?</strong> Harita 10 sütun ve 8 satırlık bir ızgara (grid) sistemidir.
            Örneğin bir odanın 1. sütundan başlayıp 3. sütuna kadar uzanmasını istiyorsanız <strong>Sütun Konumu</strong> kısmına <code>1 / 3</code> yazmalısınız.
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="border-b border-white/10 text-xs uppercase tracking-widest text-slate-400">
                    <th class="pb-4 pl-4">Kat</th>
                    <th class="pb-4">Başlık / Birim</th>
                    <th class="pb-4">Tip</th>
                    <th class="pb-4">Bağlı Poliklinik</th>
                    <th class="pb-4">Konum (Sütun x Satır)</th>
                    <th class="pb-4 text-right pr-4">İşlem</th>
                </tr>
            </thead>
            <tbody class="text-sm">
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model.OrderBy(x => x.KatAdi).ThenBy(x => x.Baslik))
                    {
                        <tr class="border-b border-white/5 hover:bg-white/5 transition">
                            <td class="py-4 pl-4 font-bold text-white">@item.KatAdi</td>
                            <td class="py-4 font-semibold text-cyan-300">
                                @if (!string.IsNullOrEmpty(item.Ikon))
                                {
                                    <i class="@item.Ikon mr-1 text-slate-400"></i>
                                }
                                @item.Baslik
                            </td>
                            <td class="py-4 text-slate-300">
                                @if (item.TipSinifi == "corridor")
                                {
                                    <span class="bg-slate-700 px-2 py-1 rounded text-xs">Koridor</span>
                                }
                                else if (item.TipSinifi.Contains("wc"))
                                {

                                    <span class="bg-rose-900/50 text-rose-300 px-2 py-1 rounded text-xs">Lavabo</span>
                                }
                                else
                                {

                                    <span class="bg-blue-900/50 text-blue-300 px-2 py-1 rounded text-xs">Oda / Poliklinik</span>
                                }
                            </td>
                            <td class="py-4 text-slate-400">
                                @(item.Bolum != null ? item.Bolum.Ad : "-")
                            </td>
                            <td class="py-4 text-slate-400 font-mono text-xs">
                                C: @item.GridColumn | R: @item.GridRow
                            </td>
                            <td class="py-4 text-right pr-4 flex justify-end gap-2">
                                <button onclick="editKroki(@item.Id, '@item.KatAdi', '@item.Baslik', '@item.Aciklama', '@item.Ikon', '@item.GridColumn', '@item.GridRow', '@item.TipSinifi', '@item.BolumId')" class="w-8 h-8 rounded-lg bg-emerald-500/10 text-emerald-400 hover:bg-emerald-500/20 flex items-center justify-center transition">
                                    <i class="fa-solid fa-pen text-xs"></i>
                                </button>

                                <form asp-action="Sil" method="post" onsubmit="return confirm('Bu birimi haritadan silmek istediğinize emin misiniz?');">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="w-8 h-8 rounded-lg bg-rose-500/10 text-rose-400 hover:bg-rose-500/20 flex items-center justify-center transition">
                                        <i class="fa-solid fa-trash text-xs"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="py-8 text-center text-slate-500 italic">Henüz krokide hiç birim çizilmemiş.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div id="krokiModal" class="fixed inset-0 z-[100] hidden items-center justify-center">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="closeKrokiModal()"></div>

    <div class="glass-card w-full max-w-2xl rounded-[2rem] relative z-10 max-h-[90vh] overflow-y-auto m-4 custom-scroll border border-white/10">
        <div class="p-6 md:p-8">
            <div class="flex justify-between items-center mb-6 border-b border-white/10 pb-4">
                <h3 class="text-xl font-bold text-white" id="modalTitle">Yeni Birim Çiz</h3>
                <button onclick="closeKrokiModal()" class="text-slate-400 hover:text-white transition"><i class="fa-solid fa-xmark text-xl"></i></button>
            </div>

            <form asp-action="Kaydet" method="post">
                <input type="hidden" id="Id" name="Id" value="0" />

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                    <div>
                        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Kat Adı</label>
                        <select id="KatAdi" name="KatAdi" class="w-full bg-black/20 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-cyan-500 transition" required>
                            <option value="Zemin Kat">Zemin Kat</option>
                            <option value="1. Kat">1. Kat</option>
                            <option value="2. Kat">2. Kat</option>
                            <option value="3. Kat">3. Kat</option>
                            <option value="Acil Servis">Acil Servis</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Başlık (Kutu İçindeki Yazı)</label>
                        <input type="text" id="Baslik" name="Baslik" class="w-full bg-black/20 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-cyan-500 transition" required />
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                    <div>
                        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Birim Tipi / Rengi</label>
                        <select id="TipSinifi" name="TipSinifi" class="w-full bg-black/20 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-cyan-500 transition">
                            <option value="room">Standart Oda / Poliklinik (Beyaz)</option>
                            <option value="corridor">Koridor (Gri Şerit)</option>
                            <option value="room wc">Lavabo / WC (Kırmızımsı)</option>
                            <option value="room exit">Çıkış / Acil (Yeşilimsi)</option>
                            <option value="room stairs">Merdiven / Asansör (Sarımsı)</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Bağlı Poliklinik (İsteğe Bağlı)</label>
                        <select id="BolumId" name="BolumId" asp-items="@ViewBag.Bolumler" class="w-full bg-black/20 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-cyan-500 transition">
                            <option value="">-- Sadece Görsel İse Boş Bırak --</option>
                        </select>
                        <p class="text-[10px] text-cyan-400 mt-1">Eğer randevu alınan bir bölümse buradan seçin.</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6 p-4 bg-white/5 rounded-2xl border border-white/5">
                    <div>
                        <label class="block text-xs font-bold text-cyan-400 uppercase tracking-wider mb-2">Sütun Konumu (Grid Column)</label>
                        <input type="text" id="GridColumn" name="GridColumn" placeholder="Örn: 1 / 3" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-cyan-500 transition font-mono" required />
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-cyan-400 uppercase tracking-wider mb-2">Satır Konumu (Grid Row)</label>
                        <input type="text" id="GridRow" name="GridRow" placeholder="Örn: 1 / 2" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-cyan-500 transition font-mono" required />
                    </div>
                </div>

                <div class="mb-6">
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">İkon (FontAwesome Sınıfı)</label>
                    <input type="text" id="Ikon" name="Ikon" placeholder="Örn: fa-solid fa-bed" class="w-full bg-black/20 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-cyan-500 transition" />
                </div>

                <div class="mb-8">
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Kısa Açıklama (Tıklayınca Açılır)</label>
                    <textarea id="Aciklama" name="Aciklama" rows="2" class="w-full bg-black/20 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-cyan-500 transition"></textarea>
                </div>

                <div class="flex justify-end gap-3">
                    <button type="button" onclick="closeKrokiModal()" class="px-6 py-3 rounded-xl font-bold text-slate-300 hover:text-white hover:bg-white/10 transition">İptal</button>
                    <button type="submit" class="bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-400 hover:to-blue-500 text-white px-8 py-3 rounded-xl font-bold shadow-lg shadow-cyan-500/30 transition-all">
                        <i class="fa-solid fa-save mr-2"></i> Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const modal = document.getElementById('krokiModal');

        function openKrokiModal() {
            // Formu Sıfırla
            document.getElementById('Id').value = "0";
            document.getElementById('KatAdi').value = "Zemin Kat";
            document.getElementById('Baslik').value = "";
            document.getElementById('TipSinifi').value = "room";
            document.getElementById('BolumId').value = "";
            document.getElementById('GridColumn').value = "1 / 2";
            document.getElementById('GridRow').value = "1 / 2";
            document.getElementById('Ikon').value = "";
            document.getElementById('Aciklama').value = "";

            document.getElementById('modalTitle').innerText = "Yeni Birim Çiz";

            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function editKroki(id, katAdi, baslik, aciklama, ikon, gridCol, gridRow, tipSinifi, bolumId) {
            document.getElementById('Id').value = id;
            document.getElementById('KatAdi').value = katAdi;
            document.getElementById('Baslik').value = baslik;

            // Null check (JavaScript stringlerinde 'null' yazmasın diye)
            document.getElementById('Aciklama').value = aciklama !== 'null' && aciklama ? aciklama : "";
            document.getElementById('Ikon').value = ikon !== 'null' && ikon ? ikon : "";

            document.getElementById('GridColumn').value = gridCol;
            document.getElementById('GridRow').value = gridRow;
            document.getElementById('TipSinifi').value = tipSinifi;
            document.getElementById('BolumId').value = bolumId !== 'null' && bolumId ? bolumId : "";

            document.getElementById('modalTitle').innerText = "Birimi Düzenle";

            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeKrokiModal() {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }
    </script>
}