@* RAZOR KOD BLOĞU: Sunucu (C#) tarafında çalışan kodlar. *@
@{
    ViewData["Title"] = "Gazi Hastanesi | Profesyonel Randevu Sistemi";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        :root {
            --sidebar-width: 360px;
            --primary: #2563eb;
            --primary-dark: #1e40af;
            --secondary: #10b981;
            --navy: #1e293b;
            --bg-main: #f1f5f9;
            --surface: #ffffff;
            --border-soft: #e2e8f0;
            --text-muted: #64748b;
        }

        body, html {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-main);
            margin: 0;
            padding: 0;
            height: 100vh;
            overflow: hidden;
            color: var(--navy);
        }

        .app-container {
            display: flex;
            height: 100vh;
            width: 100vw;
        }

        /* ================= SOL SİDEBAR ================= */
        .sidebar {
            width: var(--sidebar-width);
            background: var(--surface);
            height: 100vh;
            border-right: 1px solid var(--border-soft);
            box-shadow: 4px 0 24px rgba(0,0,0,0.02);
            display: flex;
            flex-direction: column;
            z-index: 1030;
        }

        .sidebar-header {
            padding: 25px;
            border-bottom: 1px solid var(--border-soft);
            background: var(--surface);
        }

        .brand-logo {
            color: var(--primary);
            font-size: 26px;
            margin-right: 12px;
        }

        .brand-title {
            font-weight: 800;
            color: var(--navy);
            margin: 0;
            font-size: 17px;
            letter-spacing: -0.5px;
        }

        .sidebar-scroll-area {
            flex-grow: 1;
            overflow-y: auto;
            padding: 25px;
        }

            .sidebar-scroll-area::-webkit-scrollbar {
                width: 4px;
            }

            .sidebar-scroll-area::-webkit-scrollbar-thumb {
                background: #cbd5e1;
                border-radius: 10px;
            }

        .user-card {
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            color: white;
            box-shadow: 0 10px 25px rgba(15,23,42,0.1);
            margin-bottom: 25px;
        }

        .avatar-circle {
            width: 50px;
            height: 50px;
            background: rgba(255,255,255,0.15);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            font-weight: 700;
            margin: 0 auto 10px auto;
        }

        .btn-menu {
            width: 100%;
            text-align: left;
            background: transparent;
            border: 1px solid transparent;
            padding: 14px 20px;
            border-radius: 12px;
            font-weight: 600;
            color: var(--text-muted);
            transition: all 0.2s;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 14px;
        }

            .btn-menu:hover {
                background: #f8fafc;
                color: var(--navy);
            }

            .btn-menu.active {
                background: #eff6ff;
                color: var(--primary);
                font-weight: 700;
            }

        .form-label-custom {
            font-size: 11px;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            margin-bottom: 8px;
            display: block;
            letter-spacing: 0.5px;
        }

        .select-wrapper {
            position: relative;
            margin-bottom: 20px;
        }

            .select-wrapper i {
                position: absolute;
                left: 16px;
                top: 50%;
                transform: translateY(-50%);
                color: #94a3b8;
                font-size: 15px;
                pointer-events: none;
            }

        .form-select-pro {
            width: 100%;
            height: 50px;
            padding-left: 45px;
            border-radius: 12px;
            border: 1px solid var(--border-soft);
            background-color: #f8fafc;
            font-weight: 500;
            color: var(--navy);
            font-size: 14px;
            transition: 0.2s;
            cursor: pointer;
            outline: none;
            box-shadow: none;
        }

            .form-select-pro:focus {
                border-color: var(--primary);
                background: #fff;
                box-shadow: 0 0 0 4px rgba(37,99,235,0.1);
            }

        .radio-group-pro {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        .radio-option-pro {
            position: relative;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 14px;
            border: 1px solid var(--border-soft);
            border-radius: 12px;
            background: #f8fafc;
            cursor: pointer;
            font-size: 13px;
            font-weight: 600;
            color: var(--navy);
            transition: .2s;
        }

        .radio-option-pro:hover {
            border-color: #93c5fd;
            background: #ffffff;
        }

        .radio-option-pro input[type="radio"] {
            accent-color: #2563eb;
            width: 15px;
            height: 15px;
            margin: 0;
        }

        .radio-option-pro:has(input[type="radio"]:checked) {
            border-color: #2563eb;
            background: #eff6ff;
            box-shadow: 0 0 0 3px rgba(37,99,235,0.12);
        }

        .btn-search {
            background: var(--primary);
            color: white;
            width: 100%;
            border: none;
            border-radius: 12px;
            padding: 15px;
            font-weight: 700;
            font-size: 14px;
            transition: 0.3s;
            box-shadow: 0 4px 12px rgba(37,99,235,0.2);
        }

            .btn-search:hover {
                background: var(--primary-dark);
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(37,99,235,0.3);
            }

        /* ================= SAĞ İÇERİK ================= */
        .main-content {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            position: relative;
            background: var(--bg-main);
            width: calc(100vw - var(--sidebar-width));
        }

        .topbar {
            background: var(--surface);
            height: 75px;
            padding: 0 40px;
            border-bottom: 1px solid var(--border-soft);
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 5;
        }

        .content-area {
            flex-grow: 1;
            overflow-y: auto;
            padding: 40px;
            position: relative;
        }

            .content-area::-webkit-scrollbar {
                width: 6px;
            }

            .content-area::-webkit-scrollbar-thumb {
                background: #cbd5e1;
                border-radius: 10px;
            }

        .view-panel {
            display: none;
        }

            .view-panel.active {
                display: block;
                animation: fadeIn 0.3s ease-out;
            }

        @@keyframes fadeIn {
            from

        {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        .welcome-box {
            background: transparent;
            text-align: center;
            max-width: 600px;
            margin: 80px auto;
        }

        /* ================= AYLIK TAKVİM (GRID) ================= */
        .calendar-wrapper {
            background: var(--surface);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.02);
            margin-bottom: 30px;
            border: 1px solid var(--border-soft);
        }

        .month-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            border-bottom: 1px solid var(--border-soft);
            padding-bottom: 15px;
        }

        .doctor-info-badge {
            background: #f8fafc;
            padding: 8px 16px;
            border-radius: 12px;
            border: 1px solid var(--border-soft);
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

            .doctor-info-badge i {
                color: var(--primary);
            }

            .doctor-info-badge span {
                font-weight: 600;
                font-size: 14px;
            }

        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            gap: 12px;
        }

        .calendar-weekday {
            text-align: center;
            font-size: 12px;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            padding-bottom: 10px;
        }

        .calendar-empty {
            min-height: 90px;
            background: transparent;
        }

        .date-card {
            border: 1px solid var(--border-soft);
            border-radius: 14px;
            padding: 15px 5px;
            text-align: center;
            background: var(--surface);
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 95px;
            justify-content: center;
        }

            .date-card:hover:not(.disabled) {
                border-color: var(--primary);
                transform: translateY(-3px);
                box-shadow: 0 8px 15px rgba(37,99,235,0.08);
            }

            .date-card.active {
                background: var(--primary);
                border-color: var(--primary);
                box-shadow: 0 8px 20px rgba(37,99,235,0.2);
            }

                .date-card.active * {
                    color: white !important;
                }

            .date-card.disabled {
                opacity: 0.6;
                cursor: not-allowed;
                background: #f8fafc;
                border-color: transparent;
            }

            .date-card.full {
                border-color: #fecaca;
                background: #fff5f5;
            }

            .date-card .day-num {
                font-size: 22px;
                font-weight: 800;
                color: var(--navy);
                line-height: 1;
                margin-bottom: 6px;
            }

            .date-card .slot-badge {
                font-size: 10px;
                font-weight: 700;
                background: #f1f5f9;
                color: var(--text-muted);
                padding: 4px 8px;
                border-radius: 8px;
            }

            .date-card.active .slot-badge {
                background: rgba(255,255,255,0.2);
                color: white;
            }

            .date-card.full .slot-badge {
                background: #fee2e2;
                color: #ef4444;
            }

        /* Saat Çipleri */
        .time-section {
            background: var(--surface);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.02);
            margin-bottom: 100px;
            border: 1px solid var(--border-soft);
        }

        .time-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(95px, 1fr));
            gap: 12px;
        }

        .time-chip {
            background: #f8fafc;
            border: 1px solid var(--border-soft);
            padding: 12px;
            border-radius: 12px;
            font-weight: 600;
            color: var(--navy);
            font-size: 14px;
            text-align: center;
            cursor: pointer;
            transition: 0.2s;
        }

            .time-chip:hover:not(:disabled) {
                border-color: var(--secondary);
                color: var(--secondary);
                background: #fff;
            }

            .time-chip.active {
                background: var(--secondary);
                color: white;
                border-color: var(--secondary);
                box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
            }

            .time-chip:disabled {
                opacity: 0.4;
                text-decoration: line-through;
                cursor: not-allowed;
                border-color: transparent;
            }

            .time-chip.full {
                background: #fef2f2;
                color: #ef4444;
                border-color: #fecaca;
                opacity: 1;
            }

        /* ================= LİSTE TASARIMI ================= */
        .modern-list-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 12px;
            margin-top: -12px;
            min-width: 700px;
        }

            .modern-list-table th {
                font-size: 12px;
                font-weight: 700;
                color: var(--text-muted);
                text-transform: uppercase;
                padding: 0 20px 5px 20px;
                border: none;
                letter-spacing: 0.5px;
            }

            .modern-list-table td {
                background: var(--surface);
                padding: 18px 20px;
                vertical-align: middle;
                border-top: 1px solid var(--border-soft);
                border-bottom: 1px solid var(--border-soft);
            }

                .modern-list-table td:first-child {
                    border-left: 1px solid var(--border-soft);
                    border-top-left-radius: 16px;
                    border-bottom-left-radius: 16px;
                }

                .modern-list-table td:last-child {
                    border-right: 1px solid var(--border-soft);
                    border-top-right-radius: 16px;
                    border-bottom-right-radius: 16px;
                }

            .modern-list-table tbody tr {
                transition: 0.2s;
                box-shadow: 0 2px 8px rgba(0,0,0,0.01);
            }

                .modern-list-table tbody tr:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 6px 15px rgba(0,0,0,0.04);
                }

        .list-icon-box {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .bg-blue-soft {
            background: #eff6ff;
            color: var(--primary);
        }

        .soft-badge {
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            white-space: nowrap;
        }

        .badge-success-soft {
            background: #dcfce7;
            color: #16a34a;
        }

        .badge-danger-soft {
            background: #fee2e2;
            color: #dc2626;
        }

        .badge-warning-soft {
            background: #fef3c7;
            color: #d97706;
        }

        .badge-secondary-soft {
            background: #f1f5f9;
            color: #64748b;
        }

        .badge-muayene-soft {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .badge-sonuc-soft {
            background: #ede9fe;
            color: #6d28d9;
        }

        .btn-action-outline {
            border: 1px solid #e2e8f0;
            background: transparent;
            color: #dc2626;
            font-weight: 600;
            padding: 8px 16px;
            border-radius: 8px;
            transition: 0.2s;
            font-size: 13px;
            white-space: nowrap;
        }

            .btn-action-outline:hover {
                background: #fee2e2;
                border-color: #fca5a5;
            }

        /* Yüzen Onay Barı */
        .floating-confirm-bar {
            position: fixed;
            bottom: 0;
            left: var(--sidebar-width);
            right: 0;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-top: 1px solid var(--border-soft);
            padding: 15px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transform: translateY(100%);
            transition: transform 0.3s ease-out;
            box-shadow: 0 -10px 20px rgba(0,0,0,0.03);
            z-index: 20;
        }

            .floating-confirm-bar.show {
                transform: translateY(0);
            }

        .btn-confirm {
            background: var(--primary);
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 15px;
            transition: 0.2s;
        }

            .btn-confirm:hover {
                background: var(--primary-dark);
                transform: translateY(-2px);
            }

        /* ================= SWEETALERT 2 ================= */
        .custom-swal-popup {
            border-radius: 20px !important;
            padding: 2em !important;
            box-shadow: 0 20px 50px rgba(15, 23, 42, 0.1) !important;
            border: 1px solid var(--border-soft) !important;
        }

        .custom-swal-title {
            font-family: 'Plus Jakarta Sans', sans-serif !important;
            font-weight: 800 !important;
            color: var(--navy) !important;
            font-size: 22px !important;
        }

        .custom-swal-text {
            font-family: 'Plus Jakarta Sans', sans-serif !important;
            color: var(--text-muted) !important;
            font-weight: 500 !important;
        }

        .custom-swal-confirm-btn {
            background: var(--primary) !important;
            color: white !important;
            border-radius: 12px !important;
            padding: 12px 30px !important;
            font-weight: 700 !important;
            font-family: 'Plus Jakarta Sans', sans-serif !important;
            border: none !important;
            box-shadow: 0 4px 15px rgba(37, 99, 235, 0.2) !important;
            transition: all 0.3s ease !important;
        }

            .custom-swal-confirm-btn:hover {
                background: var(--primary-dark) !important;
                transform: translateY(-2px) !important;
                box-shadow: 0 8px 25px rgba(37, 99, 235, 0.3) !important;
            }

        .custom-swal-cancel-btn {
            background: #f1f5f9 !important;
            color: #64748b !important;
            border-radius: 12px !important;
            padding: 12px 30px !important;
            font-weight: 700 !important;
            font-family: 'Plus Jakarta Sans', sans-serif !important;
            border: none !important;
            transition: all 0.3s ease !important;
        }

            .custom-swal-cancel-btn:hover {
                background: #e2e8f0 !important;
                color: var(--navy) !important;
                transform: translateY(-2px) !important;
            }

        .custom-swal-danger-btn {
            background: #ef4444 !important;
            color: white !important;
            border-radius: 12px !important;
            padding: 12px 30px !important;
            font-weight: 700 !important;
            font-family: 'Plus Jakarta Sans', sans-serif !important;
            border: none !important;
            box-shadow: 0 4px 15px rgba(239, 68, 68, 0.2) !important;
            transition: all 0.3s ease !important;
        }

            .custom-swal-danger-btn:hover {
                background: #dc2626 !important;
                transform: translateY(-2px) !important;
                box-shadow: 0 8px 25px rgba(239, 68, 68, 0.3) !important;
            }

        /* ================= MOBİL (RESPONSIVE) TASARIM ================= */
        .sidebar-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(15, 23, 42, 0.6);
            z-index: 1020;
            backdrop-filter: blur(2px);
            transition: opacity 0.3s;
            opacity: 0;
        }

            .sidebar-overlay.show {
                display: block;
                opacity: 1;
            }

        @@media (max-width: 991.98px) {
            .app-container

        {
            flex-direction: column;
            width: 100%;
        }

        .main-content {
            width: 100%;
        }

        /* Sidebar Off-Canvas Menüye Dönüşür */
        .sidebar {
            position: fixed;
            left: -360px;
            top: 0;
            height: 100vh;
            transition: left 0.3s ease;
            width: 300px;
            max-width: 85vw;
        }

            .sidebar.open {
                left: 0;
            }

        .topbar {
            padding: 0 20px;
            height: 70px;
        }

        .content-area {
            padding: 20px 15px;
        }

        .welcome-box {
            margin: 20px auto;
            padding: 30px 20px;
        }

        .floating-confirm-bar {
            left: 0;
            padding: 15px 20px;
        }

        /* Takvim Küçültme */
        .calendar-wrapper {
            padding: 20px 15px;
            margin-bottom: 20px;
        }

        .month-header {
            flex-direction: column;
            gap: 15px;
            text-align: center;
        }

        .calendar-grid {
            gap: 6px;
        }

        .calendar-weekday {
            font-size: 10px;
            padding-bottom: 5px;
        }

        .calendar-empty {
            min-height: 70px;
        }

        .date-card {
            min-height: 75px;
            padding: 10px 2px;
        }

            .date-card .day-num {
                font-size: 18px;
            }

            .date-card .slot-badge {
                font-size: 9px;
                padding: 3px 5px;
            }

        /* Saatler Küçültme */
        .time-section {
            padding: 20px 15px;
            margin-bottom: 90px;
        }

        .time-grid {
            grid-template-columns: repeat(auto-fill, minmax(75px, 1fr));
            gap: 8px;
        }

        .time-chip {
            padding: 10px 5px;
            font-size: 13px;
        }

        }
    </style>
</head>
<body>

    <input type="hidden" id="aktifHastaId" value="@ViewBag.KullaniciId" />

    <div class="app-container">

        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <i class="fas fa-hospital-symbol brand-logo"></i>
                    <h1 class="brand-title">GAZİ HASTANESİ</h1>
                </div>
                <button class="btn btn-light btn-sm d-lg-none border-0" id="closeSidebarBtn"><i class="fas fa-times fa-lg"></i></button>
            </div>

            <div class="sidebar-scroll-area">
                <div class="user-card">
                    <div class="avatar-circle">@ViewBag.KullaniciBasHarfler</div>
                    <h5 class="fw-700 mb-1" style="font-size: 16px;">Sn. @ViewBag.KullaniciAdSoyad</h5>
                    <p class="small opacity-75 mb-0" style="font-weight: 400;">Hasta Portalı</p>
                </div>

                <div class="mb-4">
                    <button class="btn-menu active" onclick="switchView('viewWelcome', this)"><i class="fas fa-search" style="width:20px; color:var(--primary);"></i> Yeni Randevu Al</button>
                    <button class="btn-menu" onclick="switchView('viewAppointments', this)"><i class="far fa-calendar-check" style="width:20px; color:var(--secondary);"></i> Aktif Randevularım</button>
                    <button class="btn-menu" onclick="switchView('viewPast', this)"><i class="fas fa-history" style="width:20px; color:var(--text-muted);"></i> Geçmiş Randevular</button>
                </div>

                <div class="filter-box border-top pt-4">
                    <h6 class="fw-700 text-navy mb-3" style="font-size: 14px;">Hızlı Filtreler</h6>

                    <div class="mb-3">
                        <label class="form-label-custom">Hekim Tipi</label>
                        <div class="radio-group-pro" style="grid-template-columns: 1fr 1fr 1fr; gap:5px;">
                            <label class="radio-option-pro" style="padding: 10px 5px; font-size:12px; justify-content:center;">
                                <input type="radio" name="hekimTipi" value="0" onchange="updateBolumler()" checked />
                                <span>Tümü</span>
                            </label>
                            <label class="radio-option-pro" style="padding: 10px 5px; font-size:12px; justify-content:center;">
                                <input type="radio" name="hekimTipi" value="1" onchange="updateBolumler()" />
                                <span><i class="fa-solid fa-user-tie text-primary mr-1"></i> Uzman</span>
                            </label>
                            <label class="radio-option-pro" style="padding: 10px 5px; font-size:12px; justify-content:center;">
                                <input type="radio" name="hekimTipi" value="2" onchange="updateBolumler()" />
                                <span><i class="fa-solid fa-user-doctor text-secondary mr-1"></i> Asistan</span>
                            </label>
                        </div>
                    </div>

                    <div class="select-wrapper">
                        <label class="form-label-custom">Hastane / Kampüs</label>
                        <i class="far fa-building"></i>
                        <select class="form-select-pro">
                            <option>Gazi Üniversitesi Merkez Hastanesi</option>
                        </select>
                    </div>

                    <div class="select-wrapper">
                        <label class="form-label-custom">Poliklinik / Birim</label>
                        <i class="fas fa-stethoscope"></i>
                        <select class="form-select-pro" id="birimSelect" onchange="updateSelection()">
                            <option value="" selected disabled>Seçiniz...</option>
                            @if (ViewBag.Bolumler != null)
                            {
                                foreach (var bolum in ViewBag.Bolumler)
                                {
                                    <option value="@bolum.Id" data-blok="@(bolum.Blok ?? "")" data-kat="@(bolum.Kat ?? "")">@bolum.Ad</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="select-wrapper mb-3">
                        <label class="form-label-custom">Uzman Hekim</label>
                        <i class="fas fa-user-md"></i>
                        <select class="form-select-pro" id="drSelect" onchange="resetSearchState()">
                            <option value="" selected disabled>Önce Birim Seçiniz</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label-custom">Randevu Türü</label>
                        <div class="radio-group-pro">
                            <label class="radio-option-pro">
                                <input type="radio" name="randevuTipi" value="1" onchange="resetSearchState()" />
                                <span><i class="fa-solid fa-stethoscope me-1 text-primary"></i> Muayene</span>
                            </label>
                            <label class="radio-option-pro">
                                <input type="radio" name="randevuTipi" value="2" onchange="resetSearchState()" />
                                <span><i class="fa-solid fa-flask me-1" style="color:#6d28d9"></i> Sonuç</span>
                            </label>
                        </div>
                    </div>

                    <button class="btn-search mt-2" onclick="randevuAra()">
                        Randevu Ara <i class="fas fa-arrow-right ms-2"></i>
                    </button>
                </div>
            </div>
        </aside>

        <main class="main-content">
            <header class="topbar">
                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-light d-lg-none border" id="mobileMenuBtn"><i class="fas fa-bars"></i></button>
                    <h4 class="fw-700 text-navy mb-0" id="pageTitle" style="font-size: 18px;">Randevu Planlama</h4>
                </div>
                <div>
                    <a href="/Home/Cikis" class="btn btn-light btn-sm fw-600 text-danger rounded-pill px-3 border"><i class="fas fa-sign-out-alt"></i> <span class="d-none d-sm-inline ms-1">Çıkış</span></a>
                </div>
            </header>

            <div class="content-area" id="mainContainer">

                <div id="viewWelcome" class="view-panel active">
                    <div class="welcome-box">
                        <i class="far fa-calendar-alt fa-3x text-primary opacity-50 mb-3"></i>
                        <h3 class="fw-700 text-navy mb-2">Randevu Arama Asistanı</h3>
                        <p class="text-muted" style="font-size: 15px;">
                            Lütfen menüden poliklinik ve uzman hekim seçiminizi yapıp aramayı başlatın.
                        </p>
                    </div>
                </div>

                <div id="viewCalendar" class="view-panel">
                    <div class="calendar-wrapper">
                        <div class="month-header">
                            <h4 class="fw-700 text-navy mb-0" id="monthLabel" style="font-size: 18px;">Ay Yükleniyor...</h4>

                            <div class="d-flex align-items-center gap-3">
                                <div class="doctor-info-badge d-none d-md-flex">
                                    <i class="fas fa-user-md"></i>
                                    <span id="lblSelectedDoctorBirim">Dr. - Poliklinik</span>
                                </div>
                                <div class="btn-group">
                                    <button class="btn btn-light border fw-600 px-3 btn-sm" onclick="changeMonth(-1)"><i class="fas fa-chevron-left"></i></button>
                                    <button class="btn btn-light border fw-600 px-3 btn-sm" onclick="changeMonth(1)"><i class="fas fa-chevron-right"></i></button>
                                </div>
                            </div>
                        </div>

                        <div id="dateAlani">
                            <div class="text-center py-4"><div class="spinner-border text-primary"></div></div>
                        </div>
                    </div>

                    <div class="time-section d-none animate__animated animate__fadeInUp" id="timeSection">
                        <h6 class="fw-700 text-navy mb-3 border-bottom pb-2" style="font-size: 15px;"><i class="far fa-clock text-secondary me-2"></i>Uygun Saatler</h6>
                        <div class="time-grid" id="saatAlani">
                        </div>
                    </div>
                </div>

                <div id="viewAppointments" class="view-panel">
                    <h4 class="fw-700 text-navy mb-4" style="font-size: 18px;"><i class="far fa-calendar-check text-success me-2"></i>Aktif Randevularım</h4>

                    @if (ViewBag.YaklasanRandevular != null && ViewBag.YaklasanRandevular.Count > 0)
                    {
                        <div class="table-responsive" style="border-radius: 16px;">
                            <table class="modern-list-table">
                                <thead>
                                    <tr>
                                        <th>Randevu Zamanı</th>
                                        <th>Poliklinik Bilgisi</th>
                                        <th>Uzman Hekim</th>
                                        <th>Randevu Türü</th>
                                        <th>Durum</th>
                                        <th class="text-end">İşlem</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var randevu in ViewBag.YaklasanRandevular)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center gap-3">
                                                    <div class="list-icon-box bg-blue-soft"><i class="far fa-calendar-alt"></i></div>
                                                    <div>
                                                        <div class="fw-700 text-navy" style="font-size: 14px;">@randevu.RandevuTarihi.ToString("dd.MM.yyyy")</div>
                                                        <div class="text-muted fw-600" style="font-size: 12px;">@randevu.RandevuTarihi.ToString("HH:mm")</div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="fw-600 text-navy" style="font-size: 14px;">@(randevu.Bolum?.Ad ?? "-")</td>
                                            <td class="text-muted fw-500" style="font-size: 14px;">Dr. @(randevu.Doktor?.Ad) @(randevu.Doktor?.Soyad)</td>
                                            <td>
                                                @if (randevu.RandevuTipi == 2)
                                                {
                                                    <span class="soft-badge badge-sonuc-soft"><i class="fa-solid fa-flask"></i> Sonuç</span>
                                                }
                                                else
                                                {
                                                    <span class="soft-badge badge-muayene-soft"><i class="fa-solid fa-stethoscope"></i> Muayene</span>
                                                }
                                            </td>
                                            <td><span class="soft-badge badge-success-soft"><i class="fas fa-circle" style="font-size:6px;"></i> Onaylandı</span></td>
                                            <td class="text-end">
                                                <div class="d-flex justify-content-end gap-2">
                                                    <button class="btn btn-light btn-sm border" onclick="randevuFisiAc(@randevu.Id)" title="Randevu Fişi / QR">
                                                        <i class="fa-solid fa-qrcode"></i>
                                                    </button>
                                                    <button class="btn-action-outline" onclick="iptalEt(@randevu.Id)">İptal Et</button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="welcome-box mt-0 pt-5 border-0">
                            <i class="far fa-folder-open fa-3x text-muted opacity-25 mb-3"></i>
                            <h5 class="text-muted fw-600">Planlanmış aktif randevunuz bulunmuyor.</h5>
                        </div>
                    }
                </div>

                <div id="viewPast" class="view-panel">
                    <h4 class="fw-700 text-navy mb-4" style="font-size: 18px;"><i class="fas fa-history text-secondary me-2"></i>Geçmiş Randevularım</h4>

                    @if (ViewBag.GecmisRandevular != null && ViewBag.GecmisRandevular.Count > 0)
                    {
                        <div class="table-responsive" style="border-radius: 16px;">
                            <table class="modern-list-table opacity-75">
                                <thead>
                                    <tr>
                                        <th>Randevu Zamanı</th>
                                        <th>Poliklinik Bilgisi</th>
                                        <th>Uzman Hekim</th>
                                        <th>Randevu Türü</th>
                                        <th>Durum</th>
                                        <th class="text-end">Fiş</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var randevu in ViewBag.GecmisRandevular)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center gap-3">
                                                    <div class="list-icon-box" style="background:#f1f5f9; color:#64748b;"><i class="far fa-calendar-check"></i></div>
                                                    <div>
                                                        <div class="fw-700 text-navy" style="font-size: 14px;">@randevu.RandevuTarihi.ToString("dd.MM.yyyy")</div>
                                                        <div class="text-muted fw-600" style="font-size: 12px;">@randevu.RandevuTarihi.ToString("HH:mm")</div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="fw-600 text-navy" style="font-size: 14px;">@(randevu.Bolum?.Ad ?? "-")</td>
                                            <td class="text-muted fw-500" style="font-size: 14px;">Dr. @(randevu.Doktor?.Ad) @(randevu.Doktor?.Soyad)</td>
                                            <td>
                                                @if (randevu.RandevuTipi == 2)
                                                {
                                                    <span class="soft-badge badge-sonuc-soft"><i class="fa-solid fa-flask"></i> Sonuç</span>
                                                }
                                                else
                                                {
                                                    <span class="soft-badge badge-muayene-soft"><i class="fa-solid fa-stethoscope"></i> Muayene</span>
                                                }
                                            </td>
                                            <td>
                                                @if (randevu.Durum == 2)
                                                {
                                                    <span class="soft-badge badge-danger-soft">İptal Edildi</span>
                                                }
                                                else if (randevu.Durum == 3)
                                                {

                                                    <span class="soft-badge badge-warning-soft">Gelmedi</span>
                                                }
                                                else
                                                {

                                                    <span class="soft-badge badge-secondary-soft">Tamamlandı</span>
                                                }
                                            </td>
                                            <td class="text-end">
                                                <button class="btn btn-light btn-sm border" onclick="randevuFisiAc(@randevu.Id)" title="Randevu Fişi / QR">
                                                    <i class="fa-solid fa-qrcode"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="welcome-box mt-0 pt-5 border-0">
                            <i class="fas fa-archive fa-3x text-muted opacity-25 mb-3"></i>
                            <h5 class="text-muted fw-600">Geçmiş randevu kaydınız bulunmuyor.</h5>
                        </div>
                    }
                </div>

            </div>

            <div class="floating-confirm-bar" id="confirmBar">
                <div>
                    <span class="text-muted fw-700 text-uppercase d-block" style="font-size:10px; letter-spacing:0.5px;">Seçilen Zaman</span>
                    <h4 class="fw-800 text-primary mb-0" id="lblFinalTime" style="font-size: 18px;">-</h4>
                </div>
                <button class="btn-confirm" onclick="confirmAppointment()">
                    Randevuyu Onayla <i class="fas fa-arrow-right ms-2"></i>
                </button>
            </div>
        </main>
    </div>

    <div id="randevuFisiModal" class="position-fixed top-0 start-0 w-100 h-100 d-none align-items-center justify-content-center p-3" style="background: rgba(15,23,42,0.65); z-index: 1200; backdrop-filter: blur(2px);">
        <div class="bg-white rounded-4 shadow-lg w-100" style="max-width: 480px;">
            <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom">
                <h5 class="m-0 fw-bold text-primary"><i class="fa-solid fa-receipt me-2"></i>Randevu Bilgi Fişi</h5>
                <button class="btn btn-light btn-sm border-0" onclick="randevuFisiKapat()"><i class="fa-solid fa-xmark"></i></button>
            </div>

            <div class="p-4">
                <div id="pdf-randevu-fisi" class="mx-auto rounded-4 p-4" style="max-width: 420px; border: 2px dashed #2563eb; background: linear-gradient(180deg,#ffffff 0%,#f0f6ff 100%);">

                    <div class="text-center mb-3">
                        <img src="~/assets/gazilogo.jpg" alt="Gazi Logo" style="height:52px; width:auto;" />
                        <h6 class="mt-2 mb-0 fw-bold text-primary" style="font-size:15px;">Gazi Üniversitesi Hastanesi</h6>
                        <p class="text-muted mb-0" style="font-size: 11px;">Randevu Bilgi Fişi &nbsp;&bull;&nbsp; Fiş No: <span id="fisNoText">-</span></p>
                        <hr class="my-2" />
                    </div>

                    <div style="font-size: 13.5px;">
                        <table class="w-100" style="border-collapse:collapse;">
                            <tr><td class="py-1 pe-2 fw-bold text-secondary" style="width:42%; font-size:12px;">TC Kimlik No</td><td class="py-1" id="tcKimlikText">-</td></tr>
                            <tr><td class="py-1 pe-2 fw-bold text-secondary" style="font-size:12px;">Hasta Adı</td><td class="py-1 fw-bold" id="hastaAdText">-</td></tr>
                            <tr><td class="py-1 pe-2 fw-bold text-secondary" style="font-size:12px;">Poliklinik</td><td class="py-1" id="bolumAdText">-</td></tr>
                            <tr><td class="py-1 pe-2 fw-bold text-secondary" style="font-size:12px;">Doktor</td><td class="py-1" id="doktorAdText">-</td></tr>
                            <tr><td class="py-1 pe-2 fw-bold text-secondary" style="font-size:12px;">Tarih &amp; Saat</td><td class="py-1 fw-bold text-primary" id="tarihSaatText">-</td></tr>
                            <tr><td class="py-1 pe-2 fw-bold text-secondary" style="font-size:12px;">Randevu Tipi</td><td class="py-1" id="randevuTipiText">-</td></tr>
                            <tr><td class="py-1 pe-2 fw-bold text-secondary" style="font-size:12px;">Durum</td><td class="py-1" id="durumText">-</td></tr>
                            <tr><td class="py-1 pe-2 fw-bold text-secondary" style="font-size:12px;">Konum</td><td class="py-1" id="konumText">-</td></tr>
                        </table>
                    </div>

                    <div class="text-center mt-3 pt-2 border-top">
                        <p class="text-muted mb-0" style="font-size:10px;">Bu fiş Gazi Üniversitesi Hastanesi tarafından oluşturulmuştur.</p>
                    </div>
                </div>

                <button onclick="fisiIndir()" class="btn btn-primary w-100 mt-3 fw-bold">
                    <i class="fa-solid fa-file-pdf me-2"></i>PDF İndir
                </button>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // --- MOBİL SİDEBAR MANTIĞI ---
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        const mobileBtn = document.getElementById('mobileMenuBtn');
        const closeSidebarBtn = document.getElementById('closeSidebarBtn');

        function toggleSidebar() {
            sidebar.classList.toggle('open');
            overlay.classList.toggle('show');
        }

        function closeSidebarIfMobile() {
            if (window.innerWidth <= 991.98) {
                sidebar.classList.remove('open');
                overlay.classList.remove('show');
            }
        }

        mobileBtn.addEventListener('click', toggleSidebar);
        closeSidebarBtn.addEventListener('click', toggleSidebar);
        overlay.addEventListener('click', toggleSidebar);

        // --- DEĞİŞKENLER ---
        let seciliTarih = '';
        let seciliSaat = '';
        let seciliRandevuTipi = '';
        let seciliGunAdi = '';
        let seciliYil = new Date().getFullYear();
        let seciliAy = new Date().getMonth() + 1;

        window.onload = function() { updateMonthLabel(); };

        function switchView(viewId, btnElement) {
            document.querySelectorAll('.view-panel').forEach(p => p.classList.remove('active'));
            document.getElementById(viewId).classList.add('active');

            if(btnElement) {
                document.querySelectorAll('.btn-menu').forEach(btn => btn.classList.remove('active'));
                btnElement.classList.add('active');
            }

            const titles = {
                viewWelcome: 'Randevu Planlama',
                viewCalendar: 'Tarih ve Saat Seçimi',
                viewAppointments: 'Aktif Randevular',
                viewPast: 'Geçmiş Randevular'
            };
            document.getElementById('pageTitle').innerText = titles[viewId] || 'Randevu Sistemi';

            if(viewId !== 'viewCalendar') document.getElementById('confirmBar').classList.remove('show');

            // Mobilde menü değiştirildiğinde sidebarı otomatik kapat
            closeSidebarIfMobile();
        }

        function updateBolumler() {
            const hekimTipi = document.querySelector('input[name="hekimTipi"]:checked').value;
            const birimSelect = document.getElementById("birimSelect");
            const drSelect = document.getElementById("drSelect");
            
            resetSearchState();
            
            birimSelect.innerHTML = '<option value="" selected disabled>Yükleniyor...</option>';
            drSelect.innerHTML = '<option value="" selected disabled>Önce Birim Seçiniz</option>';
            
            fetch('/Randevu/GetBolumlerByHekimTipi?hekimTipi=' + hekimTipi)
                .then(r => r.json())
                .then(data => {
                    birimSelect.innerHTML = '<option value="" selected disabled>Seçiniz...</option>';
                    data.forEach(b => {
                        const option = document.createElement("option");
                        option.value = b.id;
                        option.textContent = b.ad;
                        option.setAttribute("data-blok", b.blok);
                        option.setAttribute("data-kat", b.kat);
                        birimSelect.appendChild(option);
                    });
                });
        }

        function updateSelection() {
            const birim = document.getElementById("birimSelect");
            const hekimSelect = document.getElementById("drSelect");
            const hekimTipi = document.querySelector('input[name="hekimTipi"]:checked').value;
            resetSearchState();

            if(birim.selectedIndex > 0) {
                hekimSelect.innerHTML = '<option value="" selected disabled>Yükleniyor...</option>';
                fetch('/Randevu/GetDoktorlar?bolumId=' + birim.value + '&hekimTipi=' + hekimTipi)
                    .then(r => r.json())
                    .then(data => {
                        hekimSelect.innerHTML = '<option value="" selected disabled>Hekim Seçiniz</option>';
                        data.forEach(dr => hekimSelect.add(new Option(dr.adSoyad, dr.id)));
                    });
            }
        }

        function resetSearchState() {
            seciliTarih = ''; seciliSaat = '';
            document.getElementById('timeSection').classList.add('d-none');
            document.getElementById('confirmBar').classList.remove('show');
        }

        function randevuAra() {
            const birim = document.getElementById("birimSelect");
            const drSelect = document.getElementById("drSelect");
            const randevuTipiSecili = document.querySelector('input[name="randevuTipi"]:checked');

            if(birim.selectedIndex <= 0 || drSelect.selectedIndex <= 0 || !randevuTipiSecili) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Uyarı',
                    text: 'Lütfen poliklinik, doktor ve randevu türünü seçin.',
                    buttonsStyling: false,
                    customClass: { popup: 'custom-swal-popup', title: 'custom-swal-title', htmlContainer: 'custom-swal-text', confirmButton: 'custom-swal-confirm-btn' }
                });
                return;
            }

            seciliRandevuTipi = randevuTipiSecili.value;

            const drName = drSelect.options[drSelect.selectedIndex].text;
            const brName = birim.options[birim.selectedIndex].text;
            document.getElementById("lblSelectedDoctorBirim").innerText = `Dr. ${drName} - ${brName}`;

            switchView('viewCalendar');
            document.querySelectorAll('.btn-menu').forEach(btn => btn.classList.remove('active'));
            loadDoctorOpenDays();

            // Mobilde arama yapıldığında takvimi göstermek için menüyü kapat
            closeSidebarIfMobile();
        }

        function updateMonthLabel() {
            const dt = new Date(seciliYil, seciliAy - 1, 1);
            document.getElementById('monthLabel').innerText = dt.toLocaleString('tr-TR', { month: 'long', year: 'numeric' });
        }

        function changeMonth(delta) {
            seciliAy += delta;
            if (seciliAy < 1) { seciliAy = 12; seciliYil -= 1; }
            else if (seciliAy > 12) { seciliAy = 1; seciliYil += 1; }
            updateMonthLabel();
            loadDoctorOpenDays();
        }

        function loadDoctorOpenDays() {
            const doktorId = document.getElementById("drSelect").value;
            const dateAlani = document.getElementById("dateAlani");

            document.getElementById('timeSection').classList.add('d-none');
            document.getElementById('confirmBar').classList.remove('show');

            dateAlani.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary"></div></div>';

            fetch(`/Randevu/GetDoktorAcilanGunler?doktorId=${doktorId}&yil=${seciliYil}&ay=${seciliAy}`)
                .then(res => res.json())
                .then(data => {
                    if (!data || data.length === 0) {
                        dateAlani.innerHTML = '<div class="text-center py-4 text-danger fw-600">Bu ay için randevu günü bulunamadı.</div>';
                        return;
                    }

                    let html = '<div class="calendar-grid">';
                    const haftaBasliklari = ['Pzt', 'Sal', 'Çar', 'Per', 'Cum', 'Cmt', 'Paz'];
                    haftaBasliklari.forEach(h => html += `<div class="calendar-weekday">${h}</div>`);

                    const firstDate = new Date(data[0].tarih + 'T00:00:00');
                    const firstOffset = (firstDate.getDay() + 6) % 7;
                    for (let i = 0; i < firstOffset; i++) { html += '<div class="calendar-empty"></div>'; }

                    data.forEach((g) => {
                        const isClosed = !g.isOpen;
                        const isFull = !!g.isFull || (g.isOpen && g.slot === 0);
                        const isActive = !isClosed && !isFull && g.tarih === seciliTarih;
                        const badgeText = isClosed ? 'Kapalı' : (isFull ? 'Dolu' : (g.slot + ' Randevu'));

                        html += `
                            <div class="date-card ${isClosed ? 'disabled' : ''} ${isFull ? 'full disabled' : ''} ${isActive ? 'active' : ''}"
                                 data-tarih="${g.tarih}" data-gun="${g.gunNo} ${g.ay} ${g.gun}" onclick="selectDate(this)">
                                <span class="day-num">${g.gunNo}</span>
                                <span class="slot-badge">${badgeText}</span>
                            </div>`;
                    });

                    const toplamHucre = firstOffset + data.length;
                    const tail = toplamHucre % 7 === 0 ? 0 : 7 - (toplamHucre % 7);
                    for (let i = 0; i < tail; i++) { html += '<div class="calendar-empty"></div>'; }

                    html += '</div>';
                    dateAlani.innerHTML = html;
                })
                .catch(() => { dateAlani.innerHTML = '<div class="text-center py-4 text-danger">Bağlantı hatası.</div>'; });
        }

        function selectDate(element) {
            if (element.classList.contains('disabled')) return;

            document.querySelectorAll('.date-card').forEach(el => el.classList.remove('active'));
            element.classList.add('active');

            seciliTarih = element.getAttribute('data-tarih');
            seciliGunAdi = element.getAttribute('data-gun');
            seciliSaat = '';

            document.getElementById('confirmBar').classList.remove('show');
            saatleriGetir();
        }

        function saatleriGetir() {
            const doktorId = document.getElementById("drSelect").value;
            const timeSection = document.getElementById("timeSection");
            const saatAlani = document.getElementById("saatAlani");

            timeSection.classList.remove('d-none');
            saatAlani.innerHTML = '<div class="text-center py-3"><div class="spinner-border spinner-border-sm text-secondary"></div></div>';
            timeSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

            fetch(`/Randevu/GetUygunSaatler?doktorId=${doktorId}&tarih=${seciliTarih}`)
                .then(res => res.json())
                .then(data => {
                    saatAlani.innerHTML = '';
                    if(!data || data.length === 0) {
                        saatAlani.innerHTML = '<span class="text-danger fw-600">Uygun saat bulunamadı.</span>';
                        return;
                    }

                    data.forEach(item => {
                        const saat = typeof item === 'string' ? item : item.saat;
                        const musait = typeof item === 'string' ? true : item.musait;
                        const dolu = typeof item === 'string' ? false : item.dolu;
                        const ogleMolasi = typeof item === 'string' ? false : item.ogleMolasi;

                        if (ogleMolasi) return;

                        const btn = document.createElement("button");
                        btn.className = dolu || !musait ? "time-chip full" : "time-chip";
                        btn.innerText = saat;
                        if (!musait) btn.disabled = true;
                        else btn.onclick = function() { selectTime(this, saat); };

                        saatAlani.appendChild(btn);
                    });

                    if (!saatAlani.children.length) saatAlani.innerHTML = '<span class="text-danger fw-600">Uygun saat bulunamadı.</span>';
                }).catch(() => { saatAlani.innerHTML = '<span class="text-danger">Hata.</span>'; });
        }

        function selectTime(element, saat) {
            if(element.disabled) return;
            document.querySelectorAll('.time-chip').forEach(el => el.classList.remove('active'));
            element.classList.add('active');
            seciliSaat = saat;

            document.getElementById('lblFinalTime').innerText = seciliGunAdi + " - " + saat;
            document.getElementById('confirmBar').classList.add('show');
        }

        function confirmAppointment() {
            const bolumId = document.getElementById("birimSelect").value;
            const doktorId = document.getElementById("drSelect").value;
            const hastaId = document.getElementById("aktifHastaId").value;
            const randevuTipiSecili = document.querySelector('input[name="randevuTipi"]:checked');
            const randevuTipi = seciliRandevuTipi || (randevuTipiSecili ? randevuTipiSecili.value : '');

            if(!bolumId || !doktorId || !seciliTarih || !seciliSaat || !randevuTipi) return;

            const formData = new FormData();
            formData.append("BolumId", bolumId);
            formData.append("DoktorId", doktorId);
            formData.append("Tarih", seciliTarih);
            formData.append("Saat", seciliSaat);
            formData.append("HastaId", hastaId);
            formData.append("RandevuTipi", randevuTipi);

            Swal.fire({
                title: 'İşleniyor...',
                text: 'Randevunuz oluşturuluyor.',
                allowOutsideClick: false,
                didOpen: () => Swal.showLoading(),
                buttonsStyling: false,
                customClass: { popup: 'custom-swal-popup', title: 'custom-swal-title', htmlContainer: 'custom-swal-text' }
            });

            fetch('/Randevu/RandevuKaydet', { method: 'POST', body: formData })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    const bolumAd = document.getElementById('birimSelect').options[document.getElementById('birimSelect').selectedIndex]?.text || '';
                    const doktorAd = document.getElementById('drSelect').options[document.getElementById('drSelect').selectedIndex]?.text || '';
                    const randevuTipiLabel = seciliRandevuTipi == '2' ? 'Sonuç Randevusu' : 'Muayene Randevusu';

                    Swal.fire({
                        html: `
                            <div style="text-align:center; padding: 10px 0;">
                                <div style="width:72px;height:72px;background:linear-gradient(135deg,#10b981,#059669);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px auto;box-shadow:0 8px 24px rgba(16,185,129,0.35);">
                                    <svg xmlns='http://www.w3.org/2000/svg' width='36' height='36' viewBox='0 0 24 24' fill='none' stroke='white' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'><polyline points='20 6 9 17 4 12'></polyline></svg>
                                </div>
                                <h4 style="font-weight:800;color:#1e293b;font-size:20px;margin-bottom:6px;">Randevunuz Onaylandı!</h4>
                                <p style="color:#64748b;font-size:13px;margin-bottom:20px;">Aşağıda randevu detaylarınız yer almaktadır.</p>
                                <div style="background:#f8fafc;border-radius:14px;padding:16px;text-align:left;border:1px solid #e2e8f0;">
                                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
                                        <span style="font-size:18px;">&#x1F3E5;</span>
                                        <div><p style="margin:0;font-size:11px;color:#94a3b8;font-weight:700;text-transform:uppercase;letter-spacing:.5px;">Poliklinik</p><p style="margin:0;font-weight:700;color:#1e293b;font-size:14px;">${bolumAd}</p></div>
                                    </div>
                                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
                                        <span style="font-size:18px;">&#x1F9D1;&#x200D;&#x2695;&#xFE0F;</span>
                                        <div><p style="margin:0;font-size:11px;color:#94a3b8;font-weight:700;text-transform:uppercase;letter-spacing:.5px;">Hekim</p><p style="margin:0;font-weight:700;color:#1e293b;font-size:14px;">${doktorAd}</p></div>
                                    </div>
                                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
                                        <span style="font-size:18px;">&#x1F4C5;</span>
                                        <div><p style="margin:0;font-size:11px;color:#94a3b8;font-weight:700;text-transform:uppercase;letter-spacing:.5px;">Tarih &amp; Saat</p><p style="margin:0;font-weight:700;color:#2563eb;font-size:14px;">${document.getElementById('lblFinalTime').innerText}</p></div>
                                    </div>
                                    <div style="display:flex;align-items:center;gap:10px;">
                                        <span style="font-size:18px;">&#x1F4CB;</span>
                                        <div><p style="margin:0;font-size:11px;color:#94a3b8;font-weight:700;text-transform:uppercase;letter-spacing:.5px;">Randevu Tipi</p><p style="margin:0;font-weight:700;color:#1e293b;font-size:14px;">${randevuTipiLabel}</p></div>
                                    </div>
                                </div>
                            </div>`,
                        showConfirmButton: true,
                        confirmButtonText: '<i class="fa-solid fa-receipt me-1"></i> Randevu Fişini Gör',
                        showCancelButton: true,
                        cancelButtonText: 'Kapat',
                        buttonsStyling: false,
                        customClass: { popup: 'custom-swal-popup', confirmButton: 'custom-swal-confirm-btn me-2', cancelButton: 'custom-swal-cancel-btn' }
                    }).then(result => {
                        if (result.isConfirmed && data.randevuId) {
                            randevuFisiAc(data.randevuId);
                        }
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Hata',
                        text: data.message,
                        buttonsStyling: false,
                        customClass: { popup: 'custom-swal-popup', title: 'custom-swal-title', htmlContainer: 'custom-swal-text', confirmButton: 'custom-swal-confirm-btn' }
                    });
                }
            }).catch(() => {
                Swal.fire({ icon: 'error', title: 'Hata', text: 'Sistem hatası.', buttonsStyling: false, customClass: { popup: 'custom-swal-popup', title: 'custom-swal-title', htmlContainer: 'custom-swal-text', confirmButton: 'custom-swal-confirm-btn' } });
            });
        }

        function iptalEt(randevuId) {
            Swal.fire({
                title: 'Emin misiniz?',
                text: 'Bu randevu kalıcı olarak iptal edilecektir.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: '<i class="fas fa-trash-alt me-2"></i> İptal Et',
                cancelButtonText: 'Vazgeç',
                buttonsStyling: false,
                customClass: { popup: 'custom-swal-popup', title: 'custom-swal-title', htmlContainer: 'custom-swal-text', confirmButton: 'custom-swal-danger-btn me-3', cancelButton: 'custom-swal-cancel-btn' }
            }).then(result => {
                if (!result.isConfirmed) return;

                Swal.fire({
                    title: 'İptal Ediliyor...', allowOutsideClick: false, didOpen: () => Swal.showLoading(), buttonsStyling: false, customClass: { popup: 'custom-swal-popup', title: 'custom-swal-title', htmlContainer: 'custom-swal-text' }
                });

                fetch('/Randevu/RandevuIptal?id=' + randevuId, { method: 'POST' })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire({ icon: 'success', title: 'İptal edildi', text: 'Randevunuz başarıyla sistemden silindi.', buttonsStyling: false, customClass: { popup: 'custom-swal-popup', title: 'custom-swal-title', htmlContainer: 'custom-swal-text', confirmButton: 'custom-swal-confirm-btn' } }).then(() => window.location.reload());
                        } else {
                            Swal.fire({ icon: 'error', title: 'Hata', text: data.message || 'İptal başarısız.', buttonsStyling: false, customClass: { popup: 'custom-swal-popup', title: 'custom-swal-title', htmlContainer: 'custom-swal-text', confirmButton: 'custom-swal-confirm-btn' } });
                        }
                    });
            });
        }

        function randevuFisiAc(randevuId) {
            const hastaId = document.getElementById('aktifHastaId')?.value || '';
            fetch(`/Randevu/GetRandevuFisi?randevuId=${randevuId}&hastaId=${hastaId}`)
                .then(res => res.json())
                .then(resp => {
                    if (!resp || !resp.success || !resp.data) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Hata',
                            text: resp?.message || 'Randevu fişi getirilemedi.',
                            buttonsStyling: false,
                            customClass: { popup: 'custom-swal-popup', title: 'custom-swal-title', htmlContainer: 'custom-swal-text', confirmButton: 'custom-swal-confirm-btn' }
                        });
                        return;
                    }

                    const d = resp.data;
                    document.getElementById('fisNoText').innerText = `#${d.randevuNo}`;
                    document.getElementById('tcKimlikText').innerText = d.tcKimlikNo;
                    document.getElementById('hastaAdText').innerText = d.hastaAd;
                    document.getElementById('bolumAdText').innerText = d.bolumAd;
                    document.getElementById('doktorAdText').innerText = d.doktorAd;
                    document.getElementById('tarihSaatText').innerText = d.tarihSaat;
                    document.getElementById('randevuTipiText').innerText = d.randevuTipi;
                    document.getElementById('durumText').innerText = d.durum;
                    document.getElementById('konumText').innerText = d.konum || '-';

                    const modal = document.getElementById('randevuFisiModal');
                    modal.classList.remove('d-none');
                    modal.classList.add('d-flex');

                    // Arka planı sabitle
                    const scrollBarWidth = window.innerWidth - document.documentElement.clientWidth;
                    document.body.style.paddingRight = scrollBarWidth + 'px';
                    document.body.classList.add('modal-open');
                    document.documentElement.classList.add('modal-open');
                })
                .catch(() => {
                    Swal.fire({
                        icon: 'error',
                        title: 'Hata',
                        text: 'Randevu fişi yüklenirken bir hata oluştu.',
                        buttonsStyling: false,
                        customClass: { popup: 'custom-swal-popup', title: 'custom-swal-title', htmlContainer: 'custom-swal-text', confirmButton: 'custom-swal-confirm-btn' }
                    });
                });
        }

        function randevuFisiKapat() {
            const modal = document.getElementById('randevuFisiModal');
            modal.classList.remove('d-flex');
            modal.classList.add('d-none');
            
            document.body.classList.remove('modal-open');
            document.documentElement.classList.remove('modal-open');
            document.body.style.paddingRight = '';
        }

        function fisiIndir() {
            const element = document.getElementById('pdf-randevu-fisi');
            if (!element) return;

            const fisNo = document.getElementById('fisNoText')?.innerText?.replace('#', '') || 'Randevu';
            const opt = {
                margin: 0.4,
                filename: `GaziHastanesi_RandevuFisi_${fisNo}.pdf`,
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2 },
                jsPDF: { unit: 'in', format: 'a5', orientation: 'portrait' }
            };

            html2pdf().set(opt).from(element).save();
        }
    </script>
</body>
</html>