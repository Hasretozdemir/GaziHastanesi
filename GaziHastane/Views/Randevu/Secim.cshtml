@* RAZOR KOD BLOĞU: Sunucu (C#) tarafında çalışan kodlar. *@
@{
    // Sayfanın başlığı belirleniyor. Bu başlık tarayıcı sekmesinde görünür.
    ViewData["Title"] = "Gazi Sağlık | Randevu Planlama";
}

<div class="appointment-dashboard">

    <div class="container pb-5 dashboard-safe-area">

        <div class="dashboard-center-wrapper mx-auto" style="max-width: 1150px;">

            <header class="glass-nav d-flex justify-content-between align-items-center mb-5 p-3 animate__animated animate__fadeIn">

                <div class="d-flex align-items-center ms-md-3 flex-wrap">
                    <div class="brand-box me-3"><i class="fas fa-h-square fa-2x text-primary"></i></div>

                    <div class="brand-text">
                        <h4 class="fw-800 mb-0 text-navy">GAZİ ÜNİVERSİTESİ</h4>
                        <span class="status-badge small text-muted">Hastane Randevu Sistemi</span>
                    </div>
                </div>

                <div class="user-profile me-md-3 d-flex align-items-center">
                    <div class="text-end me-3 d-none d-md-block">
                        <p class="mb-0 fw-bold small">@ViewBag.KullaniciAdSoyad</p>
                        <span class="text-success extra-small">● Çevrimiçi</span>
                    </div>
                    <div class="avatar-circle">@ViewBag.KullaniciBasHarfler</div>
                </div>
            </header>

            <input type="hidden" id="aktifHastaId" value="@ViewBag.KullaniciId" />

            <div class="row g-4 justify-content-center">

                <div class="col-xl-8 col-lg-7">
                    <div class="content-card shadow-sm border-0 animate__animated animate__fadeInLeft">

                        <div class="mb-4">
                            <h3 class="fw-800 text-navy">Randevu Detayları</h3>
                            <p class="text-muted small">Lütfen poliklinik ve hekim seçiminizi yapınız.</p>
                        </div>

                        <div class="row g-4">

                            <div class="col-md-6">
                                <label class="section-label-small">Tıbbi Birim</label>
                                <select class="form-select-modern" name="BolumId" id="birimSelect" onchange="updateSelection()">
                                    <option value="" selected disabled>Birim Seçiniz</option>
                                    @if (ViewBag.Bolumler != null)
                                    {
                                        foreach (var bolum in ViewBag.Bolumler)
                                        {
                                            <option value="@bolum.Id" data-blok="Ana Bina" data-kat="Zemin" data-oda="100">@bolum.Ad</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="section-label-small">Uzman Doktor</label>
                                <select class="form-select-modern" name="DoktorId" id="drSelect" onchange="updateDoctorSelection()">
                                    <option value="" selected disabled>Önce Birim Seçiniz</option>
                                </select>
                            </div>

                            <div class="col-12" id="locationAlert" style="display:none;">
                                <div class="location-notif d-flex align-items-center">
                                    <div class="loc-icon-mini me-3"><i class="fas fa-map-marker-alt"></i></div>
                                    <div>
                                        <small class="text-muted d-block fw-bold" style="font-size: 10px;">RANDEVU KONUMU</small>
                                        <span id="txtFormKonum" class="fw-bold text-navy">-</span>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 mt-4">
                                <label class="section-label">Uygun Tarihler</label>
                                <div class="date-swipe-wrapper">
                                    @for (int i = 0; i < 7; i++)
                                    {
                                        var gecerliTarih = DateTime.Now.AddDays(i).ToString("yyyy-MM-dd");
                                        <div class="date-card @(i == 0 ? "active" : "")" data-tarih="@gecerliTarih" onclick="selectDate(this)">
                                            <span class="day">@DateTime.Now.AddDays(i).ToString("ddd")</span>
                                            <span class="number">@DateTime.Now.AddDays(i).Day</span>
                                            <span class="month">@DateTime.Now.AddDays(i).ToString("MMM")</span>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="col-12 mt-4">
                                <label class="section-label">Müsait Saatler</label>
                                <div class="time-grid-modern">
                                    <button class="time-chip" onclick="selectTime(this, '09:00')">09:00</button>
                                    <button class="time-chip active" onclick="selectTime(this, '09:30')">09:30</button>
                                    <button class="time-chip" onclick="selectTime(this, '10:00')">10:00</button>
                                    <button class="time-chip" onclick="selectTime(this, '11:00')">11:00</button>
                                    <button class="time-chip" onclick="selectTime(this, '14:00')">14:00</button>
                                    <button class="time-chip" onclick="selectTime(this, '15:00')">15:00</button>
                                </div>
                            </div>
                        </div>

                        <button class="btn-confirm-modern mt-5 shadow-lg" onclick="confirmAppointment()">
                            <span>RANDEVUYU ONAYLA</span>
                            <i class="fas fa-check-circle ms-2"></i>
                        </button>
                    </div>
                </div>

                <div class="col-xl-4 col-lg-5">
                    <div class="summary-panel-modern shadow-sm animate__animated animate__fadeInRight">
                        <h5 class="fw-800 text-navy mb-4">Seçim Özeti</h5>

                        <div class="summary-list">
                            <div class="summary-item mb-3">
                                <div class="s-icon blue"><i class="fas fa-stethoscope"></i></div>
                                <div><small>Poliklinik</small><p id="sumBirim" class="m-0 fw-bold">-</p></div>
                            </div>

                            <div class="summary-item mb-3">
                                <div class="s-icon purple"><i class="fas fa-user-md"></i></div>
                                <div><small>Hekim</small><p id="sumHekim" class="m-0 fw-bold">-</p></div>
                            </div>

                            <div class="summary-item mb-4">
                                <div class="s-icon orange"><i class="fas fa-calendar-day"></i></div>
                                <div><small>Tarih & Saat</small><p id="sumTarihSaat" class="m-0 fw-bold text-primary">@DateTime.Now.ToString("dd MMM") - 09:30</p></div>
                            </div>

                            <div id="sumLocation" class="location-summary-box animate__animated animate__zoomIn" style="display:none;">
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-building text-muted me-2"></i>
                                    <span class="extra-small fw-bold text-muted">HASTANE KONUM BİLGİSİ</span>
                                </div>
                                <p id="txtSumKonum" class="m-0 mt-1 fw-800 text-success">A Blok - Kat: 3</p>
                                <small class="text-muted" style="font-size: 11px;">Oda Numarası: <span id="txtSumOda">302</span></small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* CSS Değişkenleri: Renkleri ve boyutları merkezi yönetmek için */
        :root {
            --navy: #0f172a; /* Koyu lacivert tema rengi */
            --primary: #2563eb; /* Ana mavi vurgu rengi */
            --bg-gray: #eef2f6; /* Sayfa arka plan rengi */
            --navbar-height: 90px; /* Üst Appbar yüksekliği (Layout'a göre ayarlanabilir) */
        }

        /* Genel Sayfa Ayarları */
        body, html {
            height: 100%;
            margin: 0;
            background-color: var(--bg-gray);
            font-family: 'Plus Jakarta Sans', sans-serif;
            overflow-x: hidden; /* Yatay kaydırmayı engelle */
        }

        /* Ana Kapsayıcı Flex Ayarları (Dikey Ortalama) */
        .appointment-dashboard {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: var(--bg-gray);
        }

        /* Güvenli Alan: İçeriğin, üstteki sabit navbarın altında kalmasını engeller */
        .dashboard-safe-area {
            padding-top: calc(var(--navbar-height) + 30px);
        }

        /* Merkez Hizalama Kutusu */
        .dashboard-center-wrapper {
            width: 100%;
            z-index: 2;
        }

        /* Marka Başlığı Ayarları */
        .brand-text h4 {
            line-height: 1.2;
            white-space: nowrap; /* Metnin alt satıra geçmesini engelle */
        }

        /* İçerik ve Özet Kartlarının Ortak Stili */
        .content-card, .summary-panel-modern {
            background: #ffffff;
            border-radius: 35px; /* Köşeleri yuvarla */
            padding: 40px; /* İç boşluğu artır */
            height: 100%; /* Kartların yüksekliğini eşitle */
        }

        /* Header (Nav) için Buzlu Cam Efekti */
        .glass-nav {
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(10px); /* Arka planı bulanıklaştır */
            border-radius: 25px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.03); /* Hafif gölge */
            border: 1px solid rgba(255,255,255,0.5); /* Hafif kenarlık */
        }

        /* Küçük Etiket Stili (Tıbbi Birim vb.) */
        .section-label-small {
            font-size: 11px;
            font-weight: 800;
            color: #94a3b8;
            margin-bottom: 8px;
            display: block;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Normal Etiket Stili (Uygun Tarihler vb.) */
        .section-label {
            font-size: 13px;
            font-weight: 800;
            color: var(--navy);
            margin-bottom: 12px;
            display: block;
        }

        /* Modern Select Kutusu */
        .form-select-modern {
            width: 100%;
            padding: 15px;
            border-radius: 15px;
            border: 2px solid #f1f5f9;
            background: #f8fafc;
            font-weight: 600;
            color: var(--navy);
            outline: none;
            transition: 0.3s;
        }
            /* Select kutusu odaklanınca (focus) */
            .form-select-modern:focus {
                border-color: var(--primary); /* Çerçeveyi mavi yap */
                background: white;
            }

        /* Tarihlerin Yatay Kaydırılabilir Alanı */
        .date-swipe-wrapper {
            display: flex;
            gap: 12px;
            overflow-x: auto; /* Yatay scroll */
            padding-bottom: 10px;
        }

        /* Tarih Kartı */
        .date-card {
            min-width: 80px;
            padding: 15px 10px;
            border-radius: 20px;
            border: 2px solid #f1f5f9;
            text-align: center;
            cursor: pointer;
            background: #fff;
            transition: 0.3s;
            display: flex;
            flex-direction: column;
        }
            /* Tarih Kartı İçerikleri */
            .date-card .day {
                font-size: 11px;
                font-weight: 700;
                color: #94a3b8;
            }

            .date-card .number {
                font-size: 22px;
                font-weight: 900;
                color: var(--navy);
                line-height: 1.2;
                margin: 4px 0;
            }

            .date-card .month {
                font-size: 11px;
                font-weight: 700;
                color: #94a3b8;
            }

            /* Seçili Tarih Kartı */
            .date-card.active {
                background: var(--primary);
                border-color: var(--primary);
                box-shadow: 0 10px 20px rgba(37,99,235,0.2);
            }
                /* Seçili kartın içindeki yazıları beyaz yap */
                .date-card.active span {
                    color: white !important;
                }

        /* Saatlerin Izgara (Grid) Yapısı */
        .time-grid-modern {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(85px, 1fr)); /* Sığdıkça yan yana diz */
            gap: 10px;
        }

        /* Saat Butonu (Chip) */
        .time-chip {
            background: #f1f5f9;
            border: 2px solid transparent;
            padding: 12px;
            border-radius: 12px;
            font-weight: 700;
            color: #64748b;
            transition: 0.3s;
        }
            /* Saat Üzerine Gelince */
            .time-chip:hover {
                border-color: var(--navy);
                color: var(--navy);
            }
            /* Seçili Saat */
            .time-chip.active {
                background: var(--navy);
                color: #fff;
                border-color: var(--navy);
            }

        /* Onay Butonu */
        .btn-confirm-modern {
            width: 100%;
            height: 65px;
            background: var(--navy);
            color: #fff;
            border: none;
            border-radius: 22px;
            font-weight: 800;
            transition: 0.4s;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
        }
            /* Onay Butonu Hover */
            .btn-confirm-modern:hover {
                background: var(--primary);
                transform: translateY(-3px); /* Hafif yukarı kalkar */
                box-shadow: 0 15px 30px rgba(37,99,235,0.2) !important;
            }

        /* Kullanıcı Avatarı (Yuvarlak) */
        .avatar-circle {
            width: 45px;
            height: 45px;
            background: var(--navy);
            color: #fff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
        }

        /* Özet Listesi Öğesi */
        .summary-item {
            display: flex;
            align-items: center;
        }

            .summary-item small {
                color: #94a3b8;
                font-weight: 700;
                font-size: 11px;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

        /* Simgelerin Kutusu */
        .s-icon {
            width: 45px;
            height: 45px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 15px;
            font-size: 1.2rem;
        }

        /* Renk Temaları */
        .blue {
            background: #eff6ff;
            color: #2563eb;
        }

        .purple {
            background: #faf5ff;
            color: #9333ea;
        }

        .orange {
            background: #fff7ed;
            color: #ea580c;
        }

        /* Konum Bildirim Alanı */
        .location-notif {
            background: #f0fdf4;
            border: 1px dashed #22c55e;
            padding: 15px;
            border-radius: 20px;
        }

        /* Konum Özeti Alanı */
        .location-summary-box {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            padding: 15px;
            border-radius: 20px;
        }

        /* Küçük Yeşil Konum İkonu */
        .loc-icon-mini {
            color: #22c55e;
            background: #dcfce7;
            width: 35px;
            height: 35px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Yardımcı Sınıflar */
        .fw-800 {
            font-weight: 800;
        }

        .text-navy {
            color: var(--navy);
        }

        /* Mobil Cihaz Uyumluluğu (Responsive) */
        @@media (max-width: 768px) {
            .content-card, .summary-panel-modern {
                padding: 25px; /* Kart iç boşluğunu azalt */
            }

            .dashboard-safe-area {
                padding-top: calc(var(--navbar-height) + 15px); /* Üst boşluğu ayarla */
            }
        }
    </style>
}

@section Scripts {
    <script>
        // Sayfa yüklendiğinde varsayılan tarih ve saat değerleri
        let seciliTarih = '@DateTime.Now.ToString("yyyy-MM-dd")';
        let seciliSaat = '09:30';

        // Görsel Tarih Kutularına Tıklama İşlemi
        function selectDate(element) {
            document.querySelectorAll('.date-card').forEach(el => el.classList.remove('active'));
            element.classList.add('active');

            seciliTarih = element.getAttribute('data-tarih');
            updateSummaryTarihSaat();
        }

        // Görsel Saat Kutularına Tıklama İşlemi
        function selectTime(element, saat) {
            document.querySelectorAll('.time-chip').forEach(el => el.classList.remove('active'));
            element.classList.add('active');

            seciliSaat = saat;
            updateSummaryTarihSaat();
        }

        // Seçimler değiştikçe sağ taraftaki özeti güncelleyen fonksiyon
        function updateSummaryTarihSaat() {
            var gunAy = document.querySelector('.date-card.active .number').innerText + " " + document.querySelector('.date-card.active .month').innerText;
            document.getElementById('sumTarihSaat').innerText = gunAy + " - " + seciliSaat;
        }

        // Seçimler değiştiğinde çalışacak fonksiyon
        function updateSelection() {
            var birim = document.getElementById("birimSelect");
            var hekimSelect = document.getElementById("drSelect");

            // Eğer bir birim seçildiyse;
            if(birim.selectedIndex > 0) {
                // Seçilen opsiyonu al
                var selectedBirim = birim.options[birim.selectedIndex];
                var bolumId = selectedBirim.value;

                // Sağ taraftaki özete birim adını yaz
                document.getElementById("sumBirim").innerText = selectedBirim.text;

                // Seçilen birimin "data-" özelliklerinden konum bilgilerini al
                var blok = selectedBirim.getAttribute("data-blok");
                var kat = selectedBirim.getAttribute("data-kat");
                var oda = selectedBirim.getAttribute("data-oda");

                // Formun içindeki konum uyarısını göster ve güncelle
                document.getElementById("locationAlert").style.display = "block";
                document.getElementById("txtFormKonum").innerText = blok + " - " + kat;

                // Sağ taraftaki konum özet kutusunu göster ve güncelle
                document.getElementById("sumLocation").style.display = "block";
                document.getElementById("txtSumKonum").innerText = blok + " - " + kat;
                document.getElementById("txtSumOda").innerText = oda;

                // Bölüme ait doktorları Fetch API ile veritabanından getir
                hekimSelect.innerHTML = '<option value="" selected disabled>Yükleniyor...</option>';

                fetch('/Randevu/GetDoktorlar?bolumId=' + bolumId)
                    .then(response => response.json())
                    .then(data => {
                        hekimSelect.innerHTML = '<option value="" selected disabled>Hekim Seçiniz</option>';
                        document.getElementById("sumHekim").innerText = "-"; // Özeti sıfırla

                        // Gelen doktorları Select içine ekle
                        data.forEach(dr => {
                            var option = document.createElement("option");
                            option.value = dr.id;
                            option.text = dr.adSoyad;
                            hekimSelect.appendChild(option);
                        });
                    })
                    .catch(error => {
                        console.error("Doktorlar yüklenirken hata oluştu:", error);
                        hekimSelect.innerHTML = '<option value="" selected disabled>Hata Oluştu</option>';
                    });
            }
        }

        // Hekim seçimi değiştiğinde sağ paneli güncelleyecek ayrı bir fonksiyon
        function updateDoctorSelection() {
            var hekim = document.getElementById("drSelect");
            if(hekim.selectedIndex > 0) {
                // Sağ taraftaki özete hekim adını yaz
                document.getElementById("sumHekim").innerText = hekim.options[hekim.selectedIndex].text;
            }
        }

        // Onay butonuna basıldığında çalışacak POST işlemi
        function confirmAppointment() {
            var bolumId = document.getElementById("birimSelect").value;
            var doktorId = document.getElementById("drSelect").value;
            var hastaId = document.getElementById("aktifHastaId").value; // Gerçek kullanıcı ID'si alındı

            if(!bolumId || !doktorId) {
                alert("Lütfen önce bölüm ve hekim seçimi yapınız.");
                return;
            }

            // Gönderilecek verileri hazırlıyoruz
            var formData = new FormData();
            formData.append("BolumId", bolumId);
            formData.append("DoktorId", doktorId);
            formData.append("Tarih", seciliTarih);
            formData.append("Saat", seciliSaat);
            formData.append("HastaId", hastaId); // Controller'a kimlik gidiyor

            // Fetch API ile veriyi Controller'a gönderiyoruz
            fetch('/Randevu/RandevuKaydet', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if(data.success) {
                    alert(data.message); // Başarılı mesajı
                    window.location.href = '/Randevu/Giris'; // İşlem bitince Giriş sayfasına yönlendir
                } else {
                    alert("Hata: " + data.message); // Hata mesajı
                }
            })
            .catch(error => {
                console.error('Randevu kaydedilemedi:', error);
                alert("Sistemsel bir sorun oluştu, lütfen daha sonra tekrar deneyin.");
            });
        }
    </script>
}