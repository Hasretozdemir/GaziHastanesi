@* ================= CSS Bïŋ―Lïŋ―Mïŋ― (ïŋ―ZEL TASARIM KODLARI) ================= *@
@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        /* DEïŋ―ïŋ―ïŋ―KENLER: Renkleri tek bir yerden kolayca yïŋ―netmek iïŋ―in. */
        :root {
            --gazi-navy: #0f172a; /* ïŋ―ok koyu lacivert/siyah tonu */
