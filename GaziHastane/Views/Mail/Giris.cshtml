@* RAZOR KOD BLOĐU: Sunucu (C#) tarafýnda çalýţan ve sayfanýn temel ayarlarýnýn yapýldýđý yer. *@
@{
    Layout = "_EmptyLayout";
    @* Sayfanýn tarayýcý sekmesinde görünecek olan baţlýđýný belirler. Kullanýcý deneyimi için gereklidir. *@
    ViewData["Title"] = "Gazi Üniversitesi | E-Posta Giriţi";
}

<div class="mail-auth-wrapper">

    <div class="main-wallpaper" style="background-image: url('/assets/gazimail.jpg');"></div>

    <div class="auth-card-glass animate__animated animate__fadeIn">

        <div class="auth-card-content">

            <div class="text-center mb-5">

                <div class="logo-circle-bg mb-3">
                    <img src="/assets/gazilogo.jpg" alt="Gazi Logo" class="brand-img">
                </div>

                <h4 class="fw-bold text-dark mb-1">GAZÝ E-POSTA</h4>

                <p class="text-muted small">Elektronik Posta Servis Giriţi</p>
            </div>

            <form action="/Mail/Login" method="post">

                <div class="input-container-modern mb-4">
                    <label class="label-premium">KULLANICI ADI</label>

                    <div class="field-wrapper">
                        <i class="fas fa-user-circle"></i>
                        <input type="text" placeholder="Örn: 23380101031" required>
                    </div>
                </div>

                <div class="input-container-modern mb-4">
                    <label class="label-premium">PAROLA</label>
                    <div class="field-wrapper">
                        <i class="fas fa-lock"></i>
                        <input type="password" placeholder="••••••••" required>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-5">

                    <div class="custom-checkbox">
                        <input type="checkbox" id="remember">
                        <label for="remember" class="text-dark small ms-1 fw-semibold">Beni hatýrla</label>
                    </div>

                    <div class="version-info">
                        <select class="minimal-select">
                            <option>Standart Sürüm</option>
                            <option>Mobil Görünüm</option>
                        </select>
                    </div>
                </div>

                <button type="submit" class="btn-gazi-primary shadow-lg">
                    <span>OTURUM AÇ</span>
                    <i class="fas fa-arrow-right"></i>
                </button>
            </form>

            <div class="footer-links-modern mt-5">
                <a href="#">Yardým Al</a>
                <span class="dot-sep">•</span> <a href="#">Ţifre Ýţlemleri</a>
            </div>

        </div>
    </div>
</div>

@* ================= CSS BÖLÜMÜ (ÖZEL TASARIM KODLARI) ================= *@
@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        /* DEĐÝŢKENLER: Renkleri tek bir yerden kolayca yönetmek için. */
        :root {
            --gazi-navy: #0f172a; /* Çok koyu lacivert/siyah tonu */
            --gazi-gold: #c5a059; /* Hastanenin kurumsal altýn/sarý rengi */
            --white-glass: rgba(255, 255, 255, 0.90); /* Kart için %90 beyaz zemin */
        }

        /* GENEL SAYFA AYARLARI */
html, body { overflow: hidden !important; }
        body {
            margin: 0;
            padding: 0; /* Sayfa kenarý boţluklarýný sýfýrlar */
            font-family: 'Plus Jakarta Sans', sans-serif; /* Modern yazý fontu */
            overflow-x: hidden; /* Sađdan/soldan taţmayý gizler */
        }

        /* ANA TAŢIYICI */
        .mail-auth-wrapper {
            position: fixed;
            inset: 0;
            overflow-y: auto;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        /* ARKA PLAN RESMÝ */
        .main-wallpaper {
            position: fixed; /* Ekraný aţađý kaydýrsak da resim yerinde kalýr */
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-size: cover; /* Resmi sündürmeden tüm ekrana yayar */
            background-position: center; /* Resmin ortasýný odaklar */
            background-repeat: no-repeat; /* Resmin kendini tekrar etmesini engeller */
            z-index: -2; /* Her ţeyin en arkasýnda kalmasýný sađlar */
            /* filter: Arka planý hafifçe karartýr */
            filter: brightness(0.7) contrast(1.1);
        }

        /* BEYAZ CAM GÖRÜNÜMLÜ (GLASSMORPHISM) GÝRÝŢ KARTI */
        .auth-card-glass {
            width: 100%;
            max-width: 440px; /* Kartýn maksimum geniţliđi */
            background: var(--white-glass); /* Arka planý yarý saydam beyaz */
            
            /* ÝŢTE CAM EFEKTÝNÝ YAPAN KOD: Arka plandaki resmi bu kartýn arkasýndan geçerken buzlu cam gibi 15px bulanýklaţtýrýr */
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px); /* Safari tarayýcý desteđi için */

            border-radius: 40px; /* Kartýn köţelerini iyice yuvarlatýr */
            border: 1px solid rgba(255, 255, 255, 0.6); /* Kenarlara ince parlaklýk */
            padding: 50px 40px; /* Ýç boţluklar */
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.15); /* Kartýn altýna yumuţak bir gölge atar (Derinlik hissi) */
            z-index: 1; /* Arka plan resminin önünde durmasýný sađlar */
        }

        /* LOGO YUVASI */
        .logo-circle-bg {
            width: 75px;
            height: 75px;
            background: white;
            border-radius: 22px; /* Kareye yakýn ama köţeleri yuvarlak bir kutu (Squircle) */
            margin: 0 auto;
            padding: 7px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08); /* Logoya hafif bir gölge ekledik */
        }

        .brand-img {
            width: 100%;
            height: 100%;
            object-fit: contain; /* Logoyu kutuya sýđdýrýr */
        }

        /* ÝNPUT ÜSTÜNDEKÝ BAŢLIKLAR (Kullanýcý Adý / Parola) */
        .label-premium {
            font-size: 11px;
            font-weight: 800;
            color: rgba(15, 23, 42, 0.6); /* Koyu lacivertin yarý saydam hali */
            margin-bottom: 8px;
            display: block;
            letter-spacing: 1px; /* Harf arasý boţluk */
        }

        /* ÝNPUT VE ÝKON TAŢIYICI */
        .field-wrapper {

            display: flex;
            align-items: center;
        }

            .field-wrapper i {
                position: absolute;
                left: 18px;
                color: rgba(15, 23, 42, 0.4); /* Beyaz fonda ikon rengi */
                font-size: 1.1rem;
            }

            /* METÝN KUTULARI (INPUTLAR) */
            .field-wrapper input {
                width: 100%;
                height: 58px;
                background: rgba(0, 0, 0, 0.03); /* Çok hafif gri arka plan */
                border: 1px solid rgba(0, 0, 0, 0.08); /* Ýnce gri çerçeve */
                border-radius: 18px;
                padding: 0 20px 0 52px; /* Soldaki ikonun üstüne yazý binmesin diye soldan 52px boţluk */
                color: var(--gazi-navy); /* Yazý rengi koyu lacivert */
                font-weight: 600; /* Girilen yazý kalýn */
                transition: 0.3s;
            }

                /* INPUTA TIKLANILDIĐINDA (YAZI YAZARKEN) OLANLAR */
                .field-wrapper input:focus {
                    background: white; /* Kutunun içi tam beyaz olur */
                    border-color: var(--gazi-gold); /* Etrafýndaki çizgi altýn rengine döner */
                    outline: none; /* Tarayýcýnýn varsayýlan mavi çerçevesini kaldýrýr */
                    box-shadow: 0 0 0 4px rgba(197, 160, 89, 0.1); /* Altýn rengi hafif odaklanma parlamasý */
                }

        /* SÜRÜM SEÇÝMÝ AÇILIR LÝSTESÝ */
        .minimal-select {
            background: transparent;
            border: none;
            color: var(--gazi-navy); /* Yazý rengi koyu */
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            outline: none;
        }
            /* Seçeneklere týklanýnca açýlan menünün arka planý */
            .minimal-select option {
                background: white;
                color: var(--gazi-navy);
            }

        /* GÝRÝŢ BUTONU */
        .btn-gazi-primary {
            width: 100%;
            height: 65px;
            background: linear-gradient(135deg, #1e40af 0%, #0f172a 100%); /* Ýki farklý lacivert/mavi tonunda geçiţli arka plan */
            border: none; /* Kenarlýk kaldýrýldý */
            border-radius: 20px;
            color: white;
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: space-between; /* Yazý ve oku iki uca atar */
            padding: 0 25px;
            transition: 0.4s; /* Hover efektine 0.4 saniyelik yumuţak geçiţ */
        }

            /* FARE BUTONUN ÜZERÝNE GELDÝĐÝNDE (HOVER) */
            .btn-gazi-primary:hover {
                transform: translateY(-3px); /* Buton hafifçe havaya kalkar */
                background: var(--gazi-gold); /* Butonun içi MAVÝDEN tamamen ALTIN RENGÝNE döner */
                color: var(--gazi-navy); /* Ýçindeki yazý beyazdan laciverte döner */
                box-shadow: 0 15px 30px rgba(197, 160, 89, 0.3); /* Butonun altýna altýn rengi parlak bir gölge atar */
            }

        /* ALT LÝNKLER (FOOTER) */
        .footer-links-modern {
            text-align: center;
        }
            /* Linklerin rengi ve alt çizgileri yok */
            .footer-links-modern a {
                color: rgba(15, 23, 42, 0.5); /* Yarý saydam koyu renk */
                text-decoration: none;
                font-size: 13px;
                font-weight: 700;
                transition: 0.3s;
            }
                /* Linklerin üzerine gelince tam belirgin koyu lacivert olurlar */
                .footer-links-modern a:hover {
                    color: var(--gazi-navy);
                }

        .dot-sep {
            color: rgba(15, 23, 42, 0.2); /* Ayrýcý nokta rengi */
            margin: 0 10px;
        }

        /* MOBÝL UYUM (TELEFON EKRANLARI) */
        /* Ekran 576 pikselden küçükse devreye girer */
        @@media (max-width: 576px) {
            .auth-card-glass {
                padding: 40px 25px; /* Kartýn iç boţluđu azaltýlýr */
                border-radius: 30px; /* Ovallik biraz düţürülür */
                margin: 15px; /* Ekran kenarlarýna sýfýra sýfýr deđmemesi için dýţ boţluk verilir */
            }
        }
    </style>
}


