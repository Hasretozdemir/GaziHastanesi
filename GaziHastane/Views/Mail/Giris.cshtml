@* RAZOR KOD BLOĞU: Sunucu (C#) tarafında çalışan ve sayfanın temel ayarlarının yapıldığı yer. *@
@{
    @* Sayfanın tarayıcı sekmesinde görünecek olan başlığını belirler. Kullanıcı deneyimi için gereklidir. *@
    ViewData["Title"] = "Gazi Üniversitesi | E-Posta Girişi";
}

<div class="mail-auth-wrapper">

    <div class="main-wallpaper" style="background-image: url('/assets/gazimail.jpg');"></div>

    <div class="auth-card-glass animate__animated animate__fadeIn">

        <div class="auth-card-content">

            <div class="text-center mb-5">

                <div class="logo-circle-bg mb-3">
                    <img src="/assets/gazilogo.jpg" alt="Gazi Logo" class="brand-img">
                </div>

                <h4 class="fw-bold text-dark mb-1">GAZİ E-POSTA</h4>

                <p class="text-muted small">Elektronik Posta Servis Girişi</p>
            </div>

            <form action="/Mail/Login" method="post">

                <div class="input-container-modern mb-4">
                    <label class="label-premium">KULLANICI ADI</label>

                    <div class="field-wrapper">
                        <i class="fas fa-user-circle"></i>
                        <input type="text" placeholder="Örn: 23380101031" required>
                    </div>
                </div>

                <div class="input-container-modern mb-4">
                    <label class="label-premium">PAROLA</label>
                    <div class="field-wrapper">
                        <i class="fas fa-lock"></i>
                        <input type="password" placeholder="••••••••" required>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-5">

                    <div class="custom-checkbox">
                        <input type="checkbox" id="remember">
                        <label for="remember" class="text-dark small ms-1 fw-semibold">Beni hatırla</label>
                    </div>

                    <div class="version-info">
                        <select class="minimal-select">
                            <option>Standart Sürüm</option>
                            <option>Mobil Görünüm</option>
                        </select>
                    </div>
                </div>

                <button type="submit" class="btn-gazi-primary shadow-lg">
                    <span>OTURUM AÇ</span>
                    <i class="fas fa-arrow-right"></i>
                </button>
            </form>

            <div class="footer-links-modern mt-5">
                <a href="#">Yardım Al</a>
                <span class="dot-sep">•</span> <a href="#">Şifre İşlemleri</a>
            </div>

        </div>
    </div>
</div>

@* ================= CSS BÖLÜMÜ (ÖZEL TASARIM KODLARI) ================= *@
@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        /* DEĞİŞKENLER: Renkleri tek bir yerden kolayca yönetmek için. */
        :root {
            --gazi-navy: #0f172a; /* Çok koyu lacivert/siyah tonu */
            --gazi-gold: #c5a059; /* Hastanenin kurumsal altın/sarı rengi */
            --white-glass: rgba(255, 255, 255, 0.90); /* Kart için %90 beyaz zemin */
        }

        /* GENEL SAYFA AYARLARI */
        body {
            margin: 0;
            padding: 0; /* Sayfa kenarı boşluklarını sıfırlar */
            font-family: 'Plus Jakarta Sans', sans-serif; /* Modern yazı fontu */
            overflow-x: hidden; /* Sağdan/soldan taşmayı gizler */
        }

        /* ANA TAŞIYICI */
        .mail-auth-wrapper {
            min-height: 100vh; /* Tam ekran yüksekliği */
            display: flex;
            align-items: center;
            justify-content: center; /* İçindeki kartı dikey/yatay ortalar */
            position: relative;
            padding: 20px; /* Kenarlara yapışmasını engeller */
        }

        /* ARKA PLAN RESMİ */
        .main-wallpaper {
            position: fixed; /* Ekranı aşağı kaydırsak da resim yerinde kalır */
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-size: cover; /* Resmi sündürmeden tüm ekrana yayar */
            background-position: center; /* Resmin ortasını odaklar */
            background-repeat: no-repeat; /* Resmin kendini tekrar etmesini engeller */
            z-index: -2; /* Her şeyin en arkasında kalmasını sağlar */
            /* filter: Arka planı hafifçe karartır */
            filter: brightness(0.7) contrast(1.1);
        }

        /* BEYAZ CAM GÖRÜNÜMLÜ (GLASSMORPHISM) GİRİŞ KARTI */
        .auth-card-glass {
            width: 100%;
            max-width: 440px; /* Kartın maksimum genişliği */
            background: var(--white-glass); /* Arka planı yarı saydam beyaz */
            
            /* İŞTE CAM EFEKTİNİ YAPAN KOD: Arka plandaki resmi bu kartın arkasından geçerken buzlu cam gibi 15px bulanıklaştırır */
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px); /* Safari tarayıcı desteği için */

            border-radius: 40px; /* Kartın köşelerini iyice yuvarlatır */
            border: 1px solid rgba(255, 255, 255, 0.6); /* Kenarlara ince parlaklık */
            padding: 50px 40px; /* İç boşluklar */
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.15); /* Kartın altına yumuşak bir gölge atar (Derinlik hissi) */
            z-index: 1; /* Arka plan resminin önünde durmasını sağlar */
        }

        /* LOGO YUVASI */
        .logo-circle-bg {
            width: 75px;
            height: 75px;
            background: white;
            border-radius: 22px; /* Kareye yakın ama köşeleri yuvarlak bir kutu (Squircle) */
            margin: 0 auto;
            padding: 7px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08); /* Logoya hafif bir gölge ekledik */
        }

        .brand-img {
            width: 100%;
            height: 100%;
            object-fit: contain; /* Logoyu kutuya sığdırır */
        }

        /* İNPUT ÜSTÜNDEKİ BAŞLIKLAR (Kullanıcı Adı / Parola) */
        .label-premium {
            font-size: 11px;
            font-weight: 800;
            color: rgba(15, 23, 42, 0.6); /* Koyu lacivertin yarı saydam hali */
            margin-bottom: 8px;
            display: block;
            letter-spacing: 1px; /* Harf arası boşluk */
        }

        /* İNPUT VE İKON TAŞIYICI */
        .field-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

            .field-wrapper i {
                position: absolute;
                left: 18px;
                color: rgba(15, 23, 42, 0.4); /* Beyaz fonda ikon rengi */
                font-size: 1.1rem;
            }

            /* METİN KUTULARI (INPUTLAR) */
            .field-wrapper input {
                width: 100%;
                height: 58px;
                background: rgba(0, 0, 0, 0.03); /* Çok hafif gri arka plan */
                border: 1px solid rgba(0, 0, 0, 0.08); /* İnce gri çerçeve */
                border-radius: 18px;
                padding: 0 20px 0 52px; /* Soldaki ikonun üstüne yazı binmesin diye soldan 52px boşluk */
                color: var(--gazi-navy); /* Yazı rengi koyu lacivert */
                font-weight: 600; /* Girilen yazı kalın */
                transition: 0.3s;
            }

                /* INPUTA TIKLANILDIĞINDA (YAZI YAZARKEN) OLANLAR */
                .field-wrapper input:focus {
                    background: white; /* Kutunun içi tam beyaz olur */
                    border-color: var(--gazi-gold); /* Etrafındaki çizgi altın rengine döner */
                    outline: none; /* Tarayıcının varsayılan mavi çerçevesini kaldırır */
                    box-shadow: 0 0 0 4px rgba(197, 160, 89, 0.1); /* Altın rengi hafif odaklanma parlaması */
                }

        /* SÜRÜM SEÇİMİ AÇILIR LİSTESİ */
        .minimal-select {
            background: transparent;
            border: none;
            color: var(--gazi-navy); /* Yazı rengi koyu */
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            outline: none;
        }
            /* Seçeneklere tıklanınca açılan menünün arka planı */
            .minimal-select option {
                background: white;
                color: var(--gazi-navy);
            }

        /* GİRİŞ BUTONU */
        .btn-gazi-primary {
            width: 100%;
            height: 65px;
            background: linear-gradient(135deg, #1e40af 0%, #0f172a 100%); /* İki farklı lacivert/mavi tonunda geçişli arka plan */
            border: none; /* Kenarlık kaldırıldı */
            border-radius: 20px;
            color: white;
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: space-between; /* Yazı ve oku iki uca atar */
            padding: 0 25px;
            transition: 0.4s; /* Hover efektine 0.4 saniyelik yumuşak geçiş */
        }

            /* FARE BUTONUN ÜZERİNE GELDİĞİNDE (HOVER) */
            .btn-gazi-primary:hover {
                transform: translateY(-3px); /* Buton hafifçe havaya kalkar */
                background: var(--gazi-gold); /* Butonun içi MAVİDEN tamamen ALTIN RENGİNE döner */
                color: var(--gazi-navy); /* İçindeki yazı beyazdan laciverte döner */
                box-shadow: 0 15px 30px rgba(197, 160, 89, 0.3); /* Butonun altına altın rengi parlak bir gölge atar */
            }

        /* ALT LİNKLER (FOOTER) */
        .footer-links-modern {
            text-align: center;
        }
            /* Linklerin rengi ve alt çizgileri yok */
            .footer-links-modern a {
                color: rgba(15, 23, 42, 0.5); /* Yarı saydam koyu renk */
                text-decoration: none;
                font-size: 13px;
                font-weight: 700;
                transition: 0.3s;
            }
                /* Linklerin üzerine gelince tam belirgin koyu lacivert olurlar */
                .footer-links-modern a:hover {
                    color: var(--gazi-navy);
                }

        .dot-sep {
            color: rgba(15, 23, 42, 0.2); /* Ayrıcı nokta rengi */
            margin: 0 10px;
        }

        /* MOBİL UYUM (TELEFON EKRANLARI) */
        /* Ekran 576 pikselden küçükse devreye girer */
        @@media (max-width: 576px) {
            .auth-card-glass {
                padding: 40px 25px; /* Kartın iç boşluğu azaltılır */
                border-radius: 30px; /* Ovallik biraz düşürülür */
                margin: 15px; /* Ekran kenarlarına sıfıra sıfır değmemesi için dış boşluk verilir */
            }
        }
    </style>
}