        /* Logoyu kutuya sïŋ―ïŋ―dïŋ―rïŋ―r */

        /* ïŋ―NPUT ïŋ―STïŋ―NDEKïŋ― BAïŋ―LIKLAR (Kullanïŋ―cïŋ― Adïŋ― / Parola) */
        .label-premium {
