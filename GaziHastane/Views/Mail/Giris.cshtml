            padding: 0 25px;
            transition: 0.4s; /* Hover efektine 0.4 saniyelik yumuïŋ―ak geïŋ―iïŋ― */
        }

            /* FARE BUTONUN ïŋ―ZERïŋ―NE GELDïŋ―ïŋ―ïŋ―NDE (HOVER) */
            .btn-gazi-primary:hover {
                transform: translateY(-3px); /* Buton hafifïŋ―e havaya kalkar */
