        /* CAM Gïŋ―Rïŋ―Nïŋ―MLïŋ― (GLASSMORPHISM) Gïŋ―Rïŋ―ïŋ― KARTI - BU SAYFANIN EN ïŋ―NEMLïŋ― KISMI */
        .auth-card-glass {
            width: 100%;
            max-width: 440px; /* Kartïŋ―n maksimum geniïŋ―liïŋ―i */
            background: rgba(15, 23, 42, 0.85); /* Arka planïŋ― koyu lacivert ama %85 saydam (hafif arkasïŋ― gïŋ―rïŋ―nïŋ―r) */
            /* ïŋ―ïŋ―TE CAM EFEKTïŋ―Nïŋ― YAPAN KOD: Arka plandaki resmi bu kartïŋ―n arkasïŋ―ndan geïŋ―erken buzlu cam gibi 10px bulanïŋ―klaïŋ―tïŋ―rïŋ―r */
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px); /* Safari tarayïŋ―cïŋ― desteïŋ―i iïŋ―in */

            border-radius: 40px; /* Kartïŋ―n kïŋ―ïŋ―elerini iyice yuvarlatïŋ―r */
            border: 1px solid rgba(255, 255, 255, 0.15); /* Cama benzemesi iïŋ―in etrafïŋ―na incecik yarïŋ― ïŋ―effaf beyaz bir ïŋ―erïŋ―eve ïŋ―izer */
            padding: 50px 40px; /* ïŋ―ïŋ― boïŋ―luklar */
            box-shadow: 0 30px 60px rgba(0,0,0,0.4); /* Kartïŋ―n altïŋ―na devasa ve yumuïŋ―ak bir koyu gïŋ―lge atar (Derinlik hissi) */
            z-index: 1; /* Arka plan resminin ïŋ―nïŋ―nde durmasïŋ―nïŋ― saïŋ―lar */
        }

        /* LOGO YUVASI */
        .logo-circle-bg {
            width: 75px;
            height: 75px;
            background: white;
            border-radius: 22px; /* Kareye yakïŋ―n ama kïŋ―ïŋ―eleri yuvarlak bir kutu (Squircle) */
