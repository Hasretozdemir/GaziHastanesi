        /* GENEL SAYFA AYARLARI */
        body {
            margin: 0;
            padding: 0; /* Sayfa kenarïŋ― boïŋ―luklarïŋ―nïŋ― sïŋ―fïŋ―rlar */
            font-family: 'Plus Jakarta Sans', sans-serif; /* Modern yazïŋ― fontu */
            overflow-x: hidden; /* Saïŋ―dan/soldan taïŋ―mayïŋ― gizler */
        }

        /* ANA TAïŋ―IYICI */
        .mail-auth-wrapper {
            min-height: 100vh; /* Tam ekran yïŋ―ksekliïŋ―i */
            display: flex;
            align-items: center;
            justify-content: center; /* ïŋ―ïŋ―indeki kartïŋ― dikey/yatay ortalar */
            position: relative;
            padding: 20px; /* Kenarlara yapïŋ―ïŋ―masïŋ―nïŋ― engeller */
        }

        /* ARKA PLAN RESMïŋ― */
        .main-wallpaper {
            position: fixed; /* Ekranïŋ― aïŋ―aïŋ―ïŋ― kaydïŋ―rsak da resim yerinde kalïŋ―r */
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-size: cover; /* Resmi sïŋ―ndïŋ―rmeden tïŋ―m ekrana yayar */
            background-position: center; /* Resmin ortasïŋ―nïŋ― odaklar */
            background-repeat: no-repeat; /* Resmin kendini tekrar etmesini engeller */
            z-index: -2; /* Her ïŋ―eyin en arkasïŋ―nda kalmasïŋ―nïŋ― saïŋ―lar */
            /* filter: Resmi %50 karartïŋ―r ve kontrastïŋ―nïŋ― biraz artïŋ―rïŋ―r (ïŋ―n taraftaki cam kart daha ïŋ―ok parlasïŋ―n diye) */
            filter: brightness(0.5) contrast(1.1);
