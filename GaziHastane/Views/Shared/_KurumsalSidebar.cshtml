@using Microsoft.EntityFrameworkCore
@using GaziHastane.Data
@inject GaziHastaneContext _context

@{
    var menuGruplari = _context.KurumsalMenuGruplar
        .Where(g => g.AktifMi)
        .OrderBy(g => g.Sira)
        .Include(g => g.Menuler.Where(m => m.AktifMi).OrderBy(m => m.Sira))
        .ToList();
}

<style>
    /* --- MOBİL DOKUNMA VE SEÇİM KORUMASI --- */
    * {
        -webkit-tap-highlight-color: transparent !important; /* Tüm sayfa genelinde dokunma mavisini kapatır */
    }

    .kurumsal-sidebar-menu {
        -webkit-user-select: none;
        -moz-user-select: none;
        -ms-user-select: none;
        user-select: none;
        outline: none;
    }

    .sidebar-link {
        outline: none;
        -webkit-user-drag: none;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.65rem 0.9rem;
        border-radius: 12px;
        font-size: 0.82rem;
        font-weight: 600;
        color: #64748b;
        text-decoration: none;
    }

    /* SADECE FARE (MOUSE) İLE KULLANILAN CİHAZLARDA HOVER ÇALIŞSIN */
    /* Bu sayede mobilde dokununca mavi kalma sorunu çözülür */
    @@media (hover: hover) {
        .sidebar-link:hover

    {
        background: #eff6ff;
        color: #2563eb;
        transform: translateX(4px);
    }

    }

    /* Aktif Menü Stili */
    .sidebar-link.active-link {
        background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%) !important;
        color: white !important;
        box-shadow: 0 4px 14px rgba(37,99,235,0.25) !important;
    }

    .section-title {
        font-size: 0.68rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: #94a3b8;
        margin: 1.4rem 0.9rem 0.4rem;
    }

    .custom-scroll::-webkit-scrollbar {
        width: 4px;
    }

    .custom-scroll::-webkit-scrollbar-track {
        background: transparent;
    }

    .custom-scroll::-webkit-scrollbar-thumb {
        background: #e2e8f0;
        border-radius: 10px;
    }

    @@media (max-width: 1023px) {
        .kurumsal-sidebar-menu

    {
        display: flex;
        overflow-x: auto;
        white-space: nowrap;
        gap: 0.5rem;
        padding-bottom: 0.5rem;
        -webkit-overflow-scrolling: touch;
        border-radius: 1rem !important;
    }

    .kurumsal-sidebar-menu::-webkit-scrollbar {
        display: none;
    }

    .kurumsal-sidebar-menu .section-title {
        display: none;
    }

    .sidebar-link .fa-chevron-right {
        display: none;
    }

    .kurumsal-sidebar-menu nav {
        display: flex;
        gap: 0.5rem;
    }

    .sidebar-link {
        margin-top: 0 !important;
        flex-shrink: 0;
        width: auto !important;
        padding: 0.6rem 1rem !important;
    }

    }
</style>

<aside class="w-full lg:w-72 flex-shrink-0 mb-6 lg:mb-0">
    <div class="bg-white rounded-[1.75rem] p-2.5 lg:p-3 shadow-sm border border-slate-100/80 lg:sticky lg:top-28 lg:max-h-[82vh] lg:overflow-y-auto custom-scroll kurumsal-sidebar-menu"
         style="box-shadow: 0 4px 24px rgba(0,0,0,0.05);">

        @if (menuGruplari.Any())
        {
            @foreach (var grup in menuGruplari)
            {
                <p class="section-title">@grup.GrupAdi</p>
                <nav class="space-y-0.5">
                    @foreach (var menu in grup.Menuler.OrderBy(m => m.Sira))
                    {
                        <a href="@menu.Url" class="sidebar-link"><span class="flex items-center gap-3"><i class="fa-solid @(string.IsNullOrWhiteSpace(menu.IconClass) ? "fa-circle-info" : menu.IconClass) w-4"></i> @menu.Baslik</span><i class="fa-solid fa-chevron-right text-[10px]"></i></a>
                    }
                </nav>
            }
        }
        else
        {
            <p class="section-title">Yönetim</p>
            <nav class="space-y-0.5">
                <a href="/Kurumsal/Bashekimlik" class="sidebar-link"><span class="flex items-center gap-3"><i class="fa-solid fa-user-tie w-4"></i> Başhekimlik</span><i class="fa-solid fa-chevron-right text-[10px]"></i></a>
                <a href="/Kurumsal/Basmudurluk" class="sidebar-link"><span class="flex items-center gap-3"><i class="fa-solid fa-users w-4"></i> Başmüdürlük</span><i class="fa-solid fa-chevron-right text-[10px]"></i></a>
            </nav>

            <p class="section-title mt-0 lg:mt-4">Kurumsal</p>
            <nav class="space-y-0.5">
                <a href="/Kurumsal/Index" class="sidebar-link"><span class="flex items-center gap-3"><i class="fa-solid fa-circle-info w-4"></i> Hakkımızda</span><i class="fa-solid fa-chevron-right text-[10px]"></i></a>
                <a href="/Kurumsal/HemsirelikHizmetleri" class="sidebar-link"><span class="flex items-center gap-3"><i class="fa-solid fa-user-nurse w-4"></i> Hemşirelik Hizmetleri</span><i class="fa-solid fa-chevron-right text-[10px]"></i></a>
                <a href="/Kurumsal/BilgiIslem" class="sidebar-link"><span class="flex items-center gap-3"><i class="fa-solid fa-microchip w-4"></i> Bilgi İşlem Merkezi</span><i class="fa-solid fa-chevron-right text-[10px]"></i></a>
                <a href="/Kurumsal/IsSagligi" class="sidebar-link"><span class="flex items-center gap-3"><i class="fa-solid fa-shield-halved w-4"></i> İş Sağlığı ve Güvenliği</span><i class="fa-solid fa-chevron-right text-[10px]"></i></a>
                <a href="/Kurumsal/Enfeksiyon" class="sidebar-link"><span class="flex items-center gap-3"><i class="fa-solid fa-virus-slash w-4"></i> Enfeksiyon Kontrol</span><i class="fa-solid fa-chevron-right text-[10px]"></i></a>
                <a href="/Kurumsal/Eczacilik" class="sidebar-link"><span class="flex items-center gap-3"><i class="fa-solid fa-pills w-4"></i> Eczacılık Hizmetleri</span><i class="fa-solid fa-chevron-right text-[10px]"></i></a>
                <a href="/Kurumsal/SatinAlma" class="sidebar-link"><span class="flex items-center gap-3"><i class="fa-solid fa-cart-shopping w-4"></i> Satın Alma</span><i class="fa-solid fa-chevron-right text-[10px]"></i></a>
                <a href="/Kurumsal/Istatistik" class="sidebar-link"><span class="flex items-center gap-3"><i class="fa-solid fa-chart-line w-4"></i> İstatistik ve Raporlama</span><i class="fa-solid fa-chevron-right text-[10px]"></i></a>
                <a href="/Kurumsal/Arsiv" class="sidebar-link"><span class="flex items-center gap-3"><i class="fa-solid fa-box-archive w-4"></i> Arşiv Birimi</span><i class="fa-solid fa-chevron-right text-[10px]"></i></a>
                <a href="/Kurumsal/HastaIletisim" class="sidebar-link"><span class="flex items-center gap-3"><i class="fa-solid fa-comment-medical w-4"></i> Hasta İletişim Birimi</span><i class="fa-solid fa-chevron-right text-[10px]"></i></a>
                <a href="/Kurumsal/IsAkis" class="sidebar-link"><span class="flex items-center gap-3"><i class="fa-solid fa-diagram-project w-4"></i> İş Akış Şemaları</span><i class="fa-solid fa-chevron-right text-[10px]"></i></a>
                <a href="/Kurumsal/Organizasyon" class="sidebar-link"><span class="flex items-center gap-3"><i class="fa-solid fa-sitemap w-4"></i> Organizasyon Şemaları</span><i class="fa-solid fa-chevron-right text-[10px]"></i></a>
                <a href="/Kurumsal/IcKontrol" class="sidebar-link"><span class="flex items-center gap-3"><i class="fa-solid fa-check-double w-4"></i> İç Kontrol</span><i class="fa-solid fa-chevron-right text-[10px]"></i></a>
                <a href="/Kurumsal/BasinIletisim" class="sidebar-link"><span class="flex items-center gap-3"><i class="fa-solid fa-bullhorn w-4"></i> Basın ve Kurumsal İletişim</span><i class="fa-solid fa-chevron-right text-[10px]"></i></a>
            </nav>
        }
    </div>
</aside>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        let currentPath = window.location.pathname.toLowerCase();
        let activeLink = null;

        // Sayfa yüklendiğinde url'ye bakıp ilgili menüyü aktif yap
        document.querySelectorAll(".sidebar-link").forEach(link => {
            let href = link.getAttribute("href").toLowerCase();

            if (href === currentPath || (currentPath === '/kurumsal' && href === '/kurumsal/index')) {
                link.classList.add("active-link");
                activeLink = link;
            } else {
                link.classList.remove("active-link");
            }
        });

        // Mobilde aktif linki ortala
        if (activeLink && window.innerWidth < 1024) {
            requestAnimationFrame(() => {
                const menu = document.querySelector(".kurumsal-sidebar-menu");
                if(menu) {
                    menu.scrollLeft = activeLink.offsetLeft - (menu.offsetWidth / 2) + (activeLink.offsetWidth / 2);
                }
            });
        }

        document.querySelectorAll(".sidebar-link").forEach(link => {
            link.addEventListener("click", function (e) {
                const href = this.getAttribute("href");

                // Zaten bulunduğumuz sayfaya tıklandıysa hiçbir şey yapma
                if (href.toLowerCase() === window.location.pathname.toLowerCase()) {
                    e.preventDefault();
                    return;
                }

                e.preventDefault();

                // Sayfayı soldur ve yönlendir
                document.body.style.transition = "opacity 0.22s ease";
                document.body.style.opacity = "0";

                setTimeout(() => {
                    window.location.href = href;
                }, 220);
            });
        });
    });

    // Geri tuşuyla gelindiğinde sayfa tekrar görünür olsun
    window.addEventListener("pageshow", function (e) {
        document.body.style.transition = "opacity 0.22s ease";
        document.body.style.opacity = "1";
    });
</script>