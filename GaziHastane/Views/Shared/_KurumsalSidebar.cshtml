<script>
    document.addEventListener("DOMContentLoaded", function () {
        // --- Aktif link ---
        let currentPath = window.location.pathname;
        let activeLink = null;

        document.querySelectorAll(".sidebar-link").forEach(link => {
            if (link.getAttribute("href") === currentPath) {
                link.style.background = "linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%)";
                link.style.color = "white";
                link.style.boxShadow = "0 4px 14px rgba(37,99,235,0.25)";
                activeLink = link;
            }
        });

        // Mobilde aktif linki ortala (sayfa scroll'u tetiklemeden)
        if (activeLink && window.innerWidth < 1024) {
            requestAnimationFrame(() => {
                const menu = document.querySelector(".kurumsal-sidebar-menu");
                menu.scrollLeft = activeLink.offsetLeft - (menu.offsetWidth / 2) + (activeLink.offsetWidth / 2);
            });
        }

        // --- Fade geçiş: sidebar linklerine tıklanınca soldur, sonra git ---
        document.querySelectorAll(".sidebar-link").forEach(link => {
            link.addEventListener("click", function (e) {
                const href = this.getAttribute("href");

                // Zaten aktif sayfadaysa bir şey yapma
                if (href === window.location.pathname) return;

                e.preventDefault();

                document.body.style.transition = "opacity 0.22s ease";
                document.body.style.opacity = "0";

                setTimeout(() => {
                    window.location.href = href;
                }, 220);
            });
        });
    });

    // Geri/İleri butonu ile gelince tekrar göster
    window.addEventListener("pageshow", function (e) {
        document.body.style.transition = "opacity 0.22s ease";
        document.body.style.opacity = "1";
    });
</script>
