            <a href="/Home/Rehber" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-slate-700 hover:bg-slate-50 text-xs font-black transition" style="text-decoration: none;"><i class="fa-solid fa-book-open w-4 text-slate-400"></i> Hasta Rehberi</a>
            <a href="/Home/Iletisim" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-slate-700 hover:bg-slate-50 text-xs font-black transition" style="text-decoration: none;"><i class="fa-solid fa-phone w-4 text-slate-400"></i> İletişim</a>
