            <a href="/Kurumsal/Index" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-slate-700 hover:bg-slate-50 text-xs font-black transition" style="text-decoration: none;"><i class="fa-solid fa-hospital w-4 text-slate-400"></i> Hastanemiz</a>
            <a href="/Home/Bolumler" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-slate-700 hover:bg-slate-50 text-xs font-black transition" style="text-decoration: none;"><i class="fa-solid fa-grip w-4 text-slate-400"></i> Bölümlerimiz</a>
