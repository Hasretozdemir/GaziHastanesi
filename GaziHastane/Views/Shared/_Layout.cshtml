<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>@ViewData["Title"] | Gazi Sağlık</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');

        * {
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #f0f4f8;
            padding-top: 64px; /* DÜZELTME 1: Menünün altındaki içeriklerin menüyle üst üste binmesini engeller */
        }

        .glass-nav {
            background: rgba(255,255,255,0.94);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            box-shadow: 0 2px 24px rgba(0,0,0,0.07);
        }

        /* DÜZELTME 2: nav-link ismi Bootstrap ile çakışmasın diye gazi-nav-link yapıldı */
        .gazi-nav-link {
            font-size: 0.65rem;
            font-weight: 800;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #64748b;
            padding: 6px 0;
            position: relative;
            transition: color 0.2s;
            text-decoration: none !important; /* Bootstrap'in altını çizmesini engeller */
        }

            .gazi-nav-link::after {
                content: '';
                position: absolute;
                bottom: -2px;
                left: 0;
                right: 0;
                height: 2px;
                background: #2563eb;
                border-radius: 99px;
                transform: scaleX(0);
                transition: transform 0.2s;
            }

            .gazi-nav-link:hover, .gazi-nav-link.active {
                color: #2563eb;
            }

                .gazi-nav-link:hover::after, .gazi-nav-link.active::after {
                    transform: scaleX(1);
                }

        #mob-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15,23,42,0.45);
            z-index: 40;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s;
        }

            #mob-overlay.open {
                opacity: 1;
                pointer-events: all;
            }

        #mob-sidebar {
            position: fixed;
            top: 0;
            left: -100%;
            width: 280px;
            height: 100vh;
            background: white;
            z-index: 50;
            transition: left 0.35s cubic-bezier(0.4,0,0.2,1);
            overflow-y: auto;
            box-shadow: 8px 0 40px rgba(0,0,0,0.12);
        }

            #mob-sidebar.open {
                left: 0;
            }

        @@keyframes pulse-ring {
            0% {
                box-shadow: 0 0 0 0 rgba(239,68,68,0.4);
            }

            70% {
                box-shadow: 0 0 0 10px rgba(239,68,68,0);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(239,68,68,0);
            }
        }

        .pulse-icon {
            animation: pulse-ring 2s ease infinite;
        }

        /* Chat Scrollbar Stili */
        #chatBody::-webkit-scrollbar {
            width: 6px;
        }

        #chatBody::-webkit-scrollbar-track {
            background: transparent;
        }

        #chatBody::-webkit-scrollbar-thumb {
            background-color: #cbd5e1;
            border-radius: 20px;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <nav class="glass-nav fixed w-full top-0 z-30 border-b border-slate-200/60">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between gap-4">

