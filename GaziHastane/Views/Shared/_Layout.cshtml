    <script>
        // Chat Açma / Kapama Animasyonları
        const chatBtn = document.getElementById('aiChatBtn');
        const chatWindow = document.getElementById('aiChatWindow');
        const closeChatBtn = document.getElementById('closeChatBtn');

        chatBtn.addEventListener('click', () => {
            chatWindow.classList.remove('hidden');
            chatBtn.classList.add('hidden');
            document.getElementById('chatInput').focus();
        });

        closeChatBtn.addEventListener('click', () => {
            chatWindow.classList.add('hidden');
            chatBtn.classList.remove('hidden');
        });

        function handleKeyPress(e) {
            if (e.key === 'Enter') {
                sendMessage();
            }
        }

        function renderChatActions(actions) {
            if (!actions || !Array.isArray(actions) || actions.length === 0) return '';

            const buttons = actions
                .filter(a => a && a.url && a.text)
                .map(a => `<a href="${a.url}" class="inline-flex items-center justify-center px-3 py-2 rounded-lg bg-blue-50 hover:bg-blue-100 text-blue-700 text-xs font-bold border border-blue-100 transition" style="text-decoration:none;">${a.text}</a>`)
                .join('');

            if (!buttons) return '';
            return `<div class="mt-3 flex flex-wrap gap-2">${buttons}</div>`;
        }

        async function sendMessage() {
            const inputFld = document.getElementById('chatInput');
            const message = inputFld.value.trim();
            if (!message) return;

            const chatBody = document.getElementById('chatBody');

            // Kullanıcı Mesajını Ekle
            chatBody.innerHTML += `
                <div class="max-w-[85%] px-4 py-3 rounded-2xl rounded-tr-sm bg-blue-600 text-white shadow-sm self-end leading-relaxed">
                    ${message}
                </div>`;
            inputFld.value = '';

            // Yükleniyor (Typing) Animasyonu Ekle
            const loadingId = 'loading-' + Date.now();
            chatBody.innerHTML += `
                <div id="${loadingId}" class="max-w-[85%] px-4 py-3 rounded-2xl rounded-tl-sm bg-white border border-slate-100 text-slate-400 shadow-sm self-start flex gap-1 items-center h-10">
                    <div class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce"></div>
                    <div class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 0.1s"></div>
                    <div class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
                </div>`;
            chatBody.scrollTop = chatBody.scrollHeight;

            try {
                // C# Backend'e İstek Atıyoruz
                const response = await fetch('/Chat/SendMessage', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ UserMessage: message })
                });

                const data = await response.json();

                // Yükleniyor animasyonunu sil
                document.getElementById(loadingId).remove();

                // Yapay Zeka Cevabını Ekle
                if (data.success) {
                    const formattedReply = data.reply.replace(/\*\*(.*?)\*\*/g, '<b class="text-slate-900">$1</b>');
                    const actionButtons = renderChatActions(data.actions);
                    chatBody.innerHTML += `
                        <div class="max-w-[85%] px-4 py-3 rounded-2xl rounded-tl-sm bg-white border border-slate-100 text-slate-700 shadow-sm self-start leading-relaxed">
                            ${formattedReply}
                            ${actionButtons}
                        </div>`;
                } else {
                    chatBody.innerHTML += `
                        <div class="max-w-[85%] px-4 py-3 rounded-2xl rounded-tl-sm bg-red-50 border border-red-100 text-red-600 shadow-sm self-start leading-relaxed">
                            <i class="fa-solid fa-circle-exclamation mr-1"></i> ${data.reply}
                        </div>`;
                }
            } catch (error) {
                document.getElementById(loadingId).remove();
                chatBody.innerHTML += `
                    <div class="max-w-[85%] px-4 py-3 rounded-2xl rounded-tl-sm bg-red-50 border border-red-100 text-red-600 shadow-sm self-start leading-relaxed">
                        <i class="fa-solid fa-wifi mr-1"></i> Bağlantı hatası oluştu. Lütfen tekrar deneyin.
                    </div>`;
            }

            chatBody.scrollTop = chatBody.scrollHeight;
        }

        function openMob() {
            document.getElementById('mob-sidebar').classList.add('open');
            document.getElementById('mob-overlay').classList.add('open');
            document.body.style.overflow='hidden';
        }

        function closeMob() {
            document.getElementById('mob-sidebar').classList.remove('open');
            document.getElementById('mob-overlay').classList.remove('open');
            document.body.style.overflow='';
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
