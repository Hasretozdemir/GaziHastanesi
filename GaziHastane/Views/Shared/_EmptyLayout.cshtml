<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] | Gazi Sağlık</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');
        * { box-sizing: border-box; }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #f0f4f8;
            margin: 0;
            padding: 0;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <a href="/Home/Index" class="fixed top-6 left-6 sm:top-8 sm:left-8 z-[100] bg-white/90 hover:bg-white backdrop-blur-md border border-slate-200 text-slate-700 hover:text-blue-600 px-5 py-2.5 rounded-2xl flex items-center gap-3 font-bold text-sm shadow-[0_8px_30px_rgb(0,0,0,0.12)] transition-all hover:-translate-x-1 hover:shadow-[0_8px_30px_rgb(0,0,0,0.2)]" style="text-decoration: none;">
        <i class="fa-solid fa-arrow-left"></i> Ana Sayfaya Dön
    </a>

    @RenderBody()
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
