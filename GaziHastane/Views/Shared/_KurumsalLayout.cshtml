@{
    Layout = "_Layout";
}

@section Styles {
    <style>
        #app-sidebar.collapsed { width: 5.5rem; }
        #app-sidebar.collapsed .sidebar-text, 
        #app-sidebar.collapsed .section-title, 
        #app-sidebar.collapsed .logo-text { opacity: 0; display: none; }
        #app-sidebar.collapsed .sidebar-link { justify-content: center; padding: 0.85rem 0; transform: none; }
        #app-sidebar.collapsed .sidebar-icon { margin-right: 0; font-size: 1.25rem; }
        #app-sidebar.collapsed .submenu-panel { display: none !important; }
        #app-sidebar.collapsed #toggle-icon { transform: rotate(180deg); }

        .sidebar-toggle-btn {
            position: absolute;
            right: -1.25rem;
            top: 4.5rem;
            width: 2.5rem;
            height: 2.5rem;
            background-color: #2563eb;
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
            border: 4px solid #ffffff;
            z-index: 50;
            cursor: pointer;
            transition: all 0.3s ease;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            let currentPath = window.location.pathname.toLowerCase();
            const sidebar = document.getElementById("app-sidebar");
            const toggleBtn = document.getElementById("sidebar-toggle");

            if (window.innerWidth > 768) {
                sidebar.classList.add("collapsed");
            }

            toggleBtn.addEventListener("click", function() {
                sidebar.classList.toggle("collapsed");
            });

            document.querySelectorAll('.sidebar-link.has-submenu').forEach(link => {
                link.addEventListener('click', function (e) {
                    e.preventDefault();
                    if (sidebar.classList.contains('collapsed')) sidebar.classList.remove('collapsed');
                    const targetId = link.getAttribute('data-submenu-target');
                    const target = targetId ? document.getElementById(targetId) : null;
                    if (target) target.classList.toggle('open');
                });
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
}

<div class="flex w-full overflow-hidden bg-slate-50" style="height: calc(100vh - 64px); position: fixed; top: 64px; left: 0; right: 0; bottom: 0; z-index: 20;">
    <aside id="app-sidebar" class="relative flex flex-col bg-white border-r border-slate-200 h-full w-[280px] z-40 shrink-0 shadow-[4px_0_24px_rgba(0,0,0,0.02)] transition-all duration-300 group">
        <button id="sidebar-toggle" class="sidebar-toggle-btn hidden md:flex">
            <i class="fa-solid fa-bars text-[12px]" id="toggle-icon"></i>
        </button>

        <div class="flex items-center gap-4 px-6 py-7 border-b border-slate-100 min-h-[5.5rem]">
            <div class="w-12 h-12 rounded-2xl bg-blue-50 text-blue-600 flex items-center justify-center shrink-0">
                <i class="fa-solid fa-hospital text-xl"></i>
            </div>
            <div class="logo-text flex flex-col overflow-hidden transition-opacity duration-300">
                <span class="font-extrabold text-slate-800 text-[15px] tracking-tight whitespace-nowrap">GAZ&#304; HASTANES&#304;</span>
                <span class="text-[10px] text-slate-500 whitespace-nowrap font-bold mt-0.5">Gazi &#220;niversitesi</span>
            </div>
        </div>

        <div class="flex-1 overflow-y-auto p-4 custom-scroll">
            @await Html.PartialAsync("_KurumsalSidebar")
        </div>
    </aside>

    <main class="flex-1 overflow-y-auto bg-[#f8fafc] relative w-full pt-6 pb-24 px-6 md:px-10 custom-scroll h-full">
        @RenderBody()
    </main>
</div>
