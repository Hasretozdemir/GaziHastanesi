@model IEnumerable<GaziHastane.Models.HastaRehberi>
@{
    ViewData["Title"] = "Hasta Rehberi";
}

@section Scripts {
    <style>
        .guide-card {
            background: white;
            border-radius: 1.5rem;
            border: 1px solid #f1f5f9;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            transition: all 0.25s ease;
            position: relative;
        }

            .guide-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                opacity: 0;
                transition: opacity 0.25s ease;
            }

            .guide-card:hover {
                transform: translateY(-5px);
            }

                .guide-card:hover::before {
                    opacity: 1;
                }

        /* Temalar */
        .gc-blue:hover {
            box-shadow: 0 16px 44px rgba(37,99,235,0.12);
            border-color: #bfdbfe;
        }

        .gc-blue::before {
            background: linear-gradient(90deg, #2563eb, #60a5fa);
        }
        /* ... Diğer renk temaları (gc-purple, gc-red vb.) aynen kalacak ... */

        .icon-w {
            width: 50px;
            height: 50px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.15rem;
            flex-shrink: 0;
        }

        .iw-blue {
            background: #eff6ff;
            color: #2563eb;
        }
        /* ... Diğer ikon renkleri (iw-purple, iw-red vb.) aynen kalacak ... */

        .btn-go {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.6rem 0.75rem;
            background: #f8fafc;
            border-radius: 10px;
            color: #64748b;
            font-weight: 800;
            font-size: 0.7rem;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            border: 1px solid #f1f5f9;
            transition: all 0.2s;
        }

        .section-bar {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.25rem;
        }

        .section-bar-line {
            flex: 1;
            height: 1px;
            background: linear-gradient(to right, #e2e8f0, transparent);
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 0.6rem;
            font-weight: 800;
            text-transform: uppercase;
            padding: 3px 8px;
            border-radius: 99px;
        }

        .badge-blue {
            background: #dbeafe;
            color: #1d4ed8;
        }
    </style>
}

<main class="max-w-7xl mx-auto px-4 sm:px-6 py-8 space-y-8 mt-24">
    <div class="bg-gradient-to-r from-blue-600 to-blue-800 rounded-[1.75rem] p-6 sm:p-10 relative overflow-hidden" style="box-shadow: 0 12px 40px rgba(37,99,235,0.25);">
        <div class="relative z-10 flex flex-col sm:flex-row sm:items-center justify-between gap-5 text-white">
            <div>
                <p class="text-blue-300 text-[10px] font-black tracking-[0.2em] uppercase mb-1">Gazi Üniversitesi Hastanesi</p>
                <h2 class="text-2xl sm:text-4xl font-black tracking-tight">Hasta Rehberi</h2>
                <p class="text-blue-200/80 text-sm font-medium mt-2 max-w-lg">Süreçler, kurallar ve size özel hizmetler tek sayfada.</p>
            </div>
            <div class="flex gap-5 flex-shrink-0">
                <div class="text-center">
                    @* Model null ise 0, değilse eleman sayısını göster *@
                    <p class="text-2xl font-black">@(Model?.Count() ?? 0)</p>
                    <p class="text-blue-300 text-[9px] font-black uppercase">Konu</p>
                </div>
                <div class="w-px bg-white/20"></div>
                <div class="text-center"><p class="text-2xl font-black">7/24</p><p class="text-blue-300 text-[9px] font-black uppercase">Destek</p></div>
            </div>
        </div>
    </div>

    <div class="section-bar">
        <span class="badge badge-blue"><i class="fa-solid fa-circle-dot"></i> Bilgilendirme</span>
        <h2 class="text-lg font-black text-slate-800">Rehber İçerikleri</h2>
        <div class="section-bar-line"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="guide-card gc-@item.Tema">
                    <div class="p-5 flex flex-col gap-4 flex-1">
                        <div class="flex items-start justify-between">
                            <div class="icon-w iw-@item.Tema"><i class="@item.Ikon"></i></div>
                            <div class="btn-go text-[9px] px-2 py-1 ml-auto"><i class="fa-solid fa-arrow-right text-[8px]"></i></div>
                        </div>
                        <div class="flex-1">
                            <h3 class="text-sm font-black text-slate-800 leading-snug mb-1.5">@item.Baslik</h3>
                            <p class="text-slate-500 text-xs leading-relaxed">@item.Icerik</p>
                        </div>
                        <a href="#" class="btn-go">Detay <i class="fa-solid fa-chevron-right text-[8px]"></i></a>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-span-full text-center py-10 bg-slate-50 rounded-2xl border-2 border-dashed border-slate-200">
                <p class="text-slate-400 font-medium">Henüz bir rehber içeriği eklenmemiş.</p>
            </div>
        }
    </div>
</main>