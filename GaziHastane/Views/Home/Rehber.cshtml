@{
    ViewData["Title"] = "Hasta Rehberi";
}

@section Scripts {
    <style>
        /* ── Guide Card ── */
        .guide-card {
            background: white;
            border-radius: 1.5rem;
            border: 1px solid #f1f5f9;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            transition: all 0.25s ease;
            position: relative;
        }

            .guide-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                opacity: 0;
                transition: opacity 0.25s ease;
            }

            .guide-card:hover {
                transform: translateY(-5px);
            }

                .guide-card:hover::before {
                    opacity: 1;
                }

        /* Card color themes */
        .gc-blue:hover {
            box-shadow: 0 16px 44px rgba(37,99,235,0.12);
            border-color: #bfdbfe;
        }

        .gc-purple:hover {
            box-shadow: 0 16px 44px rgba(139,92,246,0.12);
            border-color: #ddd6fe;
        }

        .gc-red:hover {
            box-shadow: 0 16px 44px rgba(239,68,68,0.12);
            border-color: #fecaca;
        }

        .gc-teal:hover {
            box-shadow: 0 16px 44px rgba(13,148,136,0.12);
            border-color: #99f6e4;
        }

        .gc-orange:hover {
            box-shadow: 0 16px 44px rgba(234,88,12,0.12);
            border-color: #fed7aa;
        }

        .gc-violet:hover {
            box-shadow: 0 16px 44px rgba(109,40,217,0.12);
            border-color: #e9d5ff;
        }

        .gc-emerald:hover {
            box-shadow: 0 16px 44px rgba(16,185,129,0.12);
            border-color: #a7f3d0;
        }

        .gc-amber:hover {
            box-shadow: 0 16px 44px rgba(245,158,11,0.12);
            border-color: #fde68a;
        }

        .gc-rose:hover {
            box-shadow: 0 16px 44px rgba(244,63,94,0.12);
            border-color: #fecdd3;
        }

        .gc-blue::before {
            background: linear-gradient(90deg, #2563eb, #60a5fa);
        }

        .gc-purple::before {
            background: linear-gradient(90deg, #8b5cf6, #a78bfa);
        }

        .gc-red::before {
            background: linear-gradient(90deg, #ef4444, #f87171);
        }

        .gc-teal::before {
            background: linear-gradient(90deg, #0d9488, #2dd4bf);
        }

        .gc-orange::before {
            background: linear-gradient(90deg, #ea580c, #fb923c);
        }

        .gc-violet::before {
            background: linear-gradient(90deg, #7c3aed, #a78bfa);
        }

        .gc-emerald::before {
            background: linear-gradient(90deg, #10b981, #6ee7b7);
        }

        .gc-amber::before {
            background: linear-gradient(90deg, #f59e0b, #fcd34d);
        }

        .gc-rose::before {
            background: linear-gradient(90deg, #f43f5e, #fb7185);
        }

        /* ── Icon wrapper ── */
        .icon-w {
            width: 50px;
            height: 50px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.15rem;
            flex-shrink: 0;
        }

        .iw-blue {
            background: #eff6ff;
            color: #2563eb;
        }

        .iw-purple {
            background: #f5f3ff;
            color: #8b5cf6;
        }

        .iw-red {
            background: #fef2f2;
            color: #ef4444;
        }

        .iw-teal {
            background: #f0fdfa;
            color: #0d9488;
        }

        .iw-orange {
            background: #fff7ed;
            color: #ea580c;
        }

        .iw-violet {
            background: #faf5ff;
            color: #7c3aed;
        }

        .iw-emerald {
            background: #ecfdf5;
            color: #10b981;
        }

        .iw-amber {
            background: #fffbeb;
            color: #f59e0b;
        }

        .iw-rose {
            background: #fff1f2;
            color: #f43f5e;
        }

        /* ── Go btn ── */
        .btn-go {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.6rem 0.75rem;
            background: #f8fafc;
            border-radius: 10px;
            color: #64748b;
            font-weight: 800;
            font-size: 0.7rem;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            text-decoration: none;
            border: 1px solid #f1f5f9;
            transition: all 0.2s;
        }

        .gc-blue:hover .btn-go {
            background: #eff6ff;
            color: #2563eb;
            border-color: #bfdbfe;
        }

        .gc-purple:hover .btn-go {
            background: #f5f3ff;
            color: #8b5cf6;
            border-color: #ddd6fe;
        }

        .gc-red:hover .btn-go {
            background: #fef2f2;
            color: #ef4444;
            border-color: #fecaca;
        }

        .gc-teal:hover .btn-go {
            background: #f0fdfa;
            color: #0d9488;
            border-color: #99f6e4;
        }

        .gc-orange:hover .btn-go {
            background: #fff7ed;
            color: #ea580c;
            border-color: #fed7aa;
        }

        .gc-violet:hover .btn-go {
            background: #faf5ff;
            color: #7c3aed;
            border-color: #e9d5ff;
        }

        .gc-emerald:hover .btn-go {
            background: #ecfdf5;
            color: #10b981;
            border-color: #a7f3d0;
        }

        .gc-amber:hover .btn-go {
            background: #fffbeb;
            color: #f59e0b;
            border-color: #fde68a;
        }

        .gc-rose:hover .btn-go {
            background: #fff1f2;
            color: #f43f5e;
            border-color: #fecdd3;
        }

        /* ── Section divider ── */
        .section-bar {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.25rem;
        }

        .section-bar-line {
            flex: 1;
            height: 1px;
            background: linear-gradient(to right, #e2e8f0, transparent);
        }

        /* ── Step item ── */
        .step-num {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
            font-weight: 900;
            flex-shrink: 0;
        }

        /* ── Badge ── */
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 0.6rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            padding: 3px 8px;
            border-radius: 99px;
        }

        .badge-blue {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .badge-red {
            background: #fee2e2;
            color: #b91c1c;
        }

        .badge-green {
            background: #dcfce7;
            color: #15803d;
        }

        /* ── Hotline card ── */
        @@keyframes pulse-ring {
            0% {
                box-shadow: 0 0 0 0 rgba(239,68,68,0.35);
            }

            70% {
                box-shadow: 0 0 0 10px rgba(239,68,68,0);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(239,68,68,0);
            }
        }

        .pulse-badge {
            animation: pulse-ring 2s ease infinite;
        }
    </style>
}

<main class="max-w-7xl mx-auto px-4 sm:px-6 py-8 space-y-8 mt-24">

    <div class="bg-gradient-to-r from-blue-600 to-blue-800 rounded-[1.75rem] p-6 sm:p-10 relative overflow-hidden" style="box-shadow: 0 12px 40px rgba(37,99,235,0.25);">
        <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full translate-x-20 -translate-y-20"></div>
        <div class="absolute bottom-0 right-24 w-32 h-32 bg-white/5 rounded-full translate-y-12"></div>
        <div class="relative z-10 flex flex-col sm:flex-row sm:items-center justify-between gap-5">
            <div>
                <p class="text-blue-300 text-[10px] font-black tracking-[0.2em] uppercase mb-1">Gazi Üniversitesi Hastanesi</p>
                <h2 class="text-white text-2xl sm:text-4xl font-black leading-tight tracking-tight">Hasta Rehberi</h2>
                <p class="text-blue-200/80 text-sm font-medium mt-2 max-w-lg">Süreçler, kurallar ve size özel hizmetler hakkında merak ettiğiniz her şey tek sayfada.</p>
            </div>
            <div class="flex gap-5 flex-shrink-0">
                <div class="text-center">
                    <p class="text-white text-2xl font-black">9</p>
                    <p class="text-blue-300 text-[9px] font-black uppercase tracking-widest">Konu</p>
                </div>
                <div class="w-px bg-white/20"></div>
                <div class="text-center">
                    <p class="text-white text-2xl font-black">7/24</p>
                    <p class="text-blue-300 text-[9px] font-black uppercase tracking-widest">Destek</p>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-[1.5rem] p-4 sm:p-6 border border-slate-100 flex flex-wrap gap-3" style="box-shadow: 0 4px 24px rgba(0,0,0,0.04);">
        <a href="#ziyaret" class="flex items-center gap-2 px-4 py-2 rounded-xl bg-blue-50 text-blue-700 text-xs font-black hover:bg-blue-100 transition"><i class="fa-solid fa-users text-[10px]"></i> Ziyaret</a>
        <a href="#basvuru" class="flex items-center gap-2 px-4 py-2 rounded-xl bg-teal-50 text-teal-700 text-xs font-black hover:bg-teal-100 transition"><i class="fa-solid fa-file-signature text-[10px]"></i> Başvuru</a>
        <a href="#randevu" class="flex items-center gap-2 px-4 py-2 rounded-xl bg-orange-50 text-orange-700 text-xs font-black hover:bg-orange-100 transition"><i class="fa-solid fa-calendar-check text-[10px]"></i> Randevu</a>
        <a href="#haklar" class="flex items-center gap-2 px-4 py-2 rounded-xl bg-violet-50 text-violet-700 text-xs font-black hover:bg-violet-100 transition"><i class="fa-solid fa-shield-halved text-[10px]"></i> Hasta Hakları</a>
        <a href="#iletisim" class="flex items-center gap-2 px-4 py-2 rounded-xl bg-emerald-50 text-emerald-700 text-xs font-black hover:bg-emerald-100 transition"><i class="fa-solid fa-phone text-[10px]"></i> İletişim</a>
    </div>

    <div id="ziyaret">
        <div class="section-bar">
            <span class="badge badge-blue"><i class="fa-solid fa-circle-dot"></i> Ziyaret</span>
            <h2 class="text-lg font-black text-slate-800">Ziyaret & Konaklama</h2>
            <div class="section-bar-line"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">

            <div class="guide-card gc-blue">
                <div class="p-5 flex flex-col gap-4 flex-1">
                    <div class="flex items-start justify-between">
                        <div class="icon-w iw-blue"><i class="fa-solid fa-users"></i></div>
                        <div class="btn-go text-[9px] px-2 py-1 ml-auto"><i class="fa-solid fa-arrow-right text-[8px]"></i></div>
                    </div>
                    <div class="flex-1">
