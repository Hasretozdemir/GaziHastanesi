                            <p class="text-[10px] text-slate-400 font-bold">Online & telefon ile randevu</p>
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-3">
                        <div class="p-3 bg-orange-50 rounded-xl border border-orange-100">
                            <i class="fa-solid fa-globe text-orange-500 text-base mb-1.5"></i>
                            <p class="text-xs font-black text-slate-700">Online</p>
