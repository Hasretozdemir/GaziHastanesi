@model IEnumerable<GaziHastane.Models.HastaRehberi>
@{
    ViewData["Title"] = "Hasta Rehberi";

    // Kartlar için sırayla dönecek renk temalarını tanımlıyoruz
    var renkTemalari = new List<(string AcikArkaplan, string YaziRengi, string HoverArkaplan, string HoverYaziRengi, string HoverGolge, string UstCizgi)>
    {
        ("bg-blue-50", "text-blue-600", "group-hover:bg-blue-600", "group-hover:text-blue-600", "group-hover:shadow-blue-600/30", "from-blue-500 to-blue-400"),
        ("bg-emerald-50", "text-emerald-600", "group-hover:bg-emerald-600", "group-hover:text-emerald-600", "group-hover:shadow-emerald-600/30", "from-emerald-500 to-emerald-400"),
        ("bg-purple-50", "text-purple-600", "group-hover:bg-purple-600", "group-hover:text-purple-600", "group-hover:shadow-purple-600/30", "from-purple-500 to-purple-400"),
        ("bg-rose-50", "text-rose-600", "group-hover:bg-rose-600", "group-hover:text-rose-600", "group-hover:shadow-rose-600/30", "from-rose-500 to-rose-400"),
        ("bg-amber-50", "text-amber-600", "group-hover:bg-amber-600", "group-hover:text-amber-600", "group-hover:shadow-amber-600/30", "from-amber-500 to-amber-400"),
        ("bg-teal-50", "text-teal-600", "group-hover:bg-teal-600", "group-hover:text-teal-600", "group-hover:shadow-teal-600/30", "from-teal-500 to-teal-400")
    };
    int kartIndeks = 0;
}

@section Scripts {
    <style>
        html {
            scroll-behavior: smooth;
            overflow-x: hidden;
        }
        body {
            overflow-x: hidden;
            width: 100%;
            max-width: 100%;
            margin: 0;
        }
    </style>
    <script>
        const rehberData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            (Model ?? Enumerable.Empty<GaziHastane.Models.HastaRehberi>()).Select(x => new
            {
                x.Id,
                x.Baslik,
                x.Icerik,
                x.ModalIcerik
            })
        ));

        window.openRehberDetay = function (id) {
            const item = rehberData.find(x => (x.id ?? x.Id) === id);
            if (!item) return;

            const titleEl = document.getElementById('rehberModalTitle');
            const bodyEl = document.getElementById('rehberModalBody');
            const modal = document.getElementById('rehberModal');
            const content = document.getElementById('rehberModalContent');

            if (!titleEl || !bodyEl || !modal || !content) return;

            titleEl.textContent = item.baslik ?? item.Baslik;
            bodyEl.innerHTML = item.modalIcerik ?? item.ModalIcerik ?? item.icerik ?? item.Icerik ?? '';

            // Arka planı sabitle ve kaymayı önle
            const scrollBarWidth = window.innerWidth - document.documentElement.clientWidth;
            document.body.style.paddingRight = scrollBarWidth + 'px';
            document.body.classList.add('modal-open');
            document.documentElement.classList.add('modal-open');

            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                content.classList.remove('scale-95');
            }, 10);
        }

        window.closeRehberModal = function () {
            const modal = document.getElementById('rehberModal');
            const content = document.getElementById('rehberModalContent');
            if (!modal || !content) return;

            modal.classList.add('opacity-0');
            content.classList.add('scale-95');
            
            setTimeout(() => {
                modal.classList.add('hidden');
                document.body.classList.remove('modal-open');
                document.documentElement.classList.remove('modal-open');
                document.body.style.paddingRight = '';
            }, 200);
        }

        document.addEventListener('click', (e) => {
            const modal = document.getElementById('rehberModal');
            if (!modal || modal.classList.contains('hidden')) return;
            if (e.target && e.target.id === 'rehberModal') {
                window.closeRehberModal();
            }
        });
    </script>
}

<main class="w-full px-6 sm:px-10 lg:px-16 py-10 space-y-12 min-h-screen">

    <div class="bg-gradient-to-br from-slate-800 via-slate-700 to-slate-900 rounded-[2rem] p-8 sm:p-12 relative overflow-hidden shadow-[0_20px_50px_rgba(15,23,42,0.2)]">
        <div class="absolute top-0 right-0 -mr-20 -mt-20 w-72 h-72 rounded-full bg-emerald-500/10 blur-3xl"></div>
        <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-72 h-72 rounded-full bg-blue-500/10 blur-3xl"></div>

        <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-8 text-white">
            <div>
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-slate-300 text-[10px] font-black tracking-widest uppercase mb-4 backdrop-blur-sm">
                    <i class="fa-solid fa-hospital"></i> Gazi Üniversitesi Hastanesi
                </div>
                <h2 class="text-3xl sm:text-5xl font-black tracking-tight mb-3">Hasta Rehberi</h2>
                <p class="text-slate-300 text-base font-medium max-w-xl leading-relaxed">
                    Hastanemizdeki süreçler, kurallar ve size özel sunulan hizmetler hakkında detaylı bilgilere buradan ulaşabilirsiniz. Sağlığınız ve konforunuz bizim için önemli.
                </p>
            </div>

            <div class="flex gap-6 flex-shrink-0 bg-white/5 p-5 rounded-2xl backdrop-blur-md border border-white/10">
                <div class="text-center px-4">
                    <p class="text-3xl font-black mb-1">@(Model?.Count() ?? 0)</p>
                    <p class="text-slate-400 text-[10px] font-black uppercase tracking-wider">Rehber Konusu</p>
                </div>
                <div class="w-px bg-white/10"></div>
                <div class="text-center px-4">
                    <p class="text-3xl font-black mb-1">7/24</p>
                    <p class="text-slate-400 text-[10px] font-black uppercase tracking-wider">Kesintisiz Hizmet</p>
                </div>
            </div>
        </div>
    </div>

    <div class="flex items-center gap-4">
        <h3 class="text-xl font-black text-slate-800">Bilgilendirme İçerikleri</h3>
        <div class="flex-1 h-[2px] bg-gradient-to-r from-slate-200 to-transparent rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 lg:gap-6 w-full">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                // Mevcut sıradaki kartın temasını belirliyoruz (6 renkten biri döngüsel olarak seçilir)
                var tema = renkTemalari[kartIndeks % renkTemalari.Count];
                kartIndeks++;

                <button type="button" onclick="openRehberDetay(@item.Id)" class="group bg-white rounded-2xl p-4 lg:p-5 border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col h-full relative overflow-hidden cursor-pointer text-left w-full">

                    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r @tema.UstCizgi opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

                    <div class="w-12 h-12 rounded-2xl @tema.AcikArkaplan @tema.YaziRengi flex items-center justify-center text-xl mb-4 @tema.HoverArkaplan group-hover:text-white transition-colors duration-300 group-hover:shadow-lg @tema.HoverGolge">
                        <i class="@item.Ikon"></i>
                    </div>

                    <h4 class="text-base font-bold text-slate-800 mb-2 leading-snug @tema.HoverYaziRengi transition-colors">@item.Baslik</h4>

                    <p class="text-slate-500 text-xs leading-relaxed mb-4 line-clamp-3 flex-1">@item.Icerik</p>

                    <div class="mt-auto pt-3 border-t border-slate-100 flex items-center justify-between">
                        <span class="text-xs font-bold @tema.YaziRengi">Detayları İncele</span>
                        <div class="w-7 h-7 rounded-full @tema.AcikArkaplan flex items-center justify-center @tema.YaziRengi @tema.HoverArkaplan group-hover:text-white transition-all duration-300 group-hover:translate-x-1">
                            <i class="fa-solid fa-arrow-right text-[10px]"></i>
                        </div>
                    </div>

                </button>
            }
        }
        else
        {
            <div class="col-span-full flex flex-col items-center justify-center py-20 px-4 bg-white rounded-3xl border-2 border-dashed border-slate-200 text-center">
                <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center text-slate-300 text-4xl mb-4">
                    <i class="fa-regular fa-folder-open"></i>
                </div>
                <h3 class="text-lg font-bold text-slate-700 mb-2">Henüz İçerik Bulunmuyor</h3>
                <p class="text-slate-500 text-sm max-w-sm">Hastanemiz ile ilgili bilgilendirme içerikleri en kısa sürede buraya eklenecektir.</p>
            </div>
        }
    </div>
<div id="rehberModal" class="fixed inset-0 z-[120] hidden bg-black/55 backdrop-blur-sm flex items-center justify-center p-4 opacity-0 transition-opacity duration-200">
    <div id="rehberModalContent" class="bg-white w-full max-w-3xl rounded-3xl border border-slate-200 shadow-2xl transform scale-95 transition-transform duration-200 max-h-[88vh] flex flex-col overflow-hidden">
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
            <h3 id="rehberModalTitle" class="text-xl font-black text-slate-800"></h3>
            <button type="button" onclick="closeRehberModal()" class="w-9 h-9 rounded-full bg-slate-100 text-slate-600 hover:bg-slate-200">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <div id="rehberModalBody" class="p-6 overflow-y-auto text-slate-700 leading-relaxed"></div>
    </div>
</div>
</main>
