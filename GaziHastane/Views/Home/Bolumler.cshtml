@* RAZOR KOD BLOĞU: Sunucu (C#) tarafında sayfa ayarları *@
@* Sayfa render edilmeden önce bu blok sunucuda çalışır. *@
@{
    // "Title" (Başlık) değeri "Bölümlerimiz" olarak ayarlanıyor.
    // Bu değer, layout dosyasındaki <title> etiketine yerleştirilir.
    ViewData["Title"] = "Bölümlerimiz";
}

@* 'Scripts' bölümü (section): Burada sayfaya özel scriptler ve stiller bulunur. *@
@section Scripts {
    <!-- SAYFA STİLLERİ (CSS) -->
    <style>
        /* Google Fonts'tan 'Plus Jakarta Sans' font ailesini projeye dahil et. */
        @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@@300;400;500;600;700;800&display=swap');

        /* ── YAPIŞKAN YAN MENÜ (STICKY SIDEBAR) ── */
        /* Sayfanın sol tarafındaki menünün kaydırma sırasında sabit kalmasını sağlayan stil. */
        .sidebar-sticky {
            /* Position: sticky ile element, belirli bir kaydırma noktasına kadar normal davranır, sonra sabitlenir. */
            position: sticky; 
            /* Sabitlendiğinde üstten 7rem boşluk bırakır (Navbar'ın altı). */
            top: 7rem; 
            /* Maksimum yükseklik ekran boyundan 8rem eksik olsun (taşmayı engellemek için). */
            max-height: calc(100vh - 8rem); 
            /* Eğer içerik bu yüksekliği aşarsa dikey kaydırma çubuğu (scroll) çıkar. */
            overflow-y: auto; 
        }

            /* Kaydırma çubuğu (Scrollbar) stil özelleştirmeleri (Webkit tabanlı tarayıcılar için) */
            .sidebar-sticky::-webkit-scrollbar {
                /* Scrollbar genişliği 4px. */
                width: 4px;
            }

            /* Scrollbar'ın arka planı (yolu). */
            .sidebar-sticky::-webkit-scrollbar-track {
                /* Şeffaf arka plan. */
                background: transparent;
            }

            /* Scrollbar'ın tutamacı (thumb - hareket eden kısım). */
            .sidebar-sticky::-webkit-scrollbar-thumb {
                /* Rengi gri tonda (#e2e8f0). */
                background: #e2e8f0;
                /* Kenarları oval olsun. */
                border-radius: 10px;
            }

        /* ── KATEGORİ LİNKLERİ (Yan Menüdeki Linkler) ── */
        .cat-link {
            /* Flexbox ile simge ve yazıyı yan yana diz. */
            display: flex;
            /* Dikeyde ortala. */
            align-items: center;
            /* Simge ve yazı arasında 0.75rem boşluk. */
            gap: 0.75rem;
            /* İç boşluk: üst-alt 0.75rem, sağ-sol 1rem. */
            padding: 0.75rem 1rem;
            /* Köşeleri ovalleştir (14px). */
            border-radius: 14px;
            /* Yazı boyutu 0.82rem. */
            font-size: 0.82rem;
            /* Yazı kalınlığı (bold). */
            font-weight: 700;
            /* Renk gri. */
            color: #64748b;
            /* Link alt çizgisini kaldır. */
            text-decoration: none;
            /* Tüm değişimler 0.2s sürsün. */
            transition: all 0.2s ease;
        }

            /* Linkin üzerine gelince (Hover) */
            .cat-link:hover {
                /* Arka planı açık gri yap. */
                background: #f1f5f9;
                /* Yazı rengini koyulaştır. */
                color: #1e293b;
                /* Sağa doğru 3px kaydır. */
                transform: translateX(3px); 
            }

            /* Aktif kategori renkleri (Seçili olduğunda veya özel sınıflarla) */
            /* Mavi tema (Dahili Tıp Bilimleri için) */
            .cat-link.active-blue {
                background: #eff6ff; /* Açık mavi arka plan */
                color: #2563eb; /* Mavi yazı */
            }

            /* Kırmızı tema (Cerrahi Tıp Bilimleri için) */
            .cat-link.active-red {
                background: #fef2f2; /* Açık kırmızı arka plan */
                color: #ef4444; /* Kırmızı yazı */
            }

            /* Yeşil tema (Temel Tıp Bilimleri için) */
            .cat-link.active-green {
                background: #f0fdf4; /* Açık yeşil arka plan */
                color: #16a34a; /* Yeşil yazı */
            }

        /* ── ARAMA KUTUSU ── */
        /* Arama kutusuna tıklandığında (focus) */
        .search-input:focus {
            /* Varsayılan tarayıcı çerçevesini kaldır (outline). */
            outline: none;
            /* Etrafına mavi, flu bir gölge ekle (glow efekti). */
            box-shadow: 0 0 0 3px rgba(37,99,235,0.15); 
            /* Kenarlık rengini mavi yap. */
            border-color: #93c5fd;
        }

        /* ── BÖLÜM AYIRICI ÇİZGİ VE BAŞLIK I ── */
        /* Dahili, Cerrahi vb. başlıklarının olduğu satır. */
        .section-bar {
            /* Flexbox ile yan yana dizilim. */
            display: flex;
            /* Dikey ortala. */
            align-items: center;
            /* Elemanlar arası boşluk 1rem. */
            gap: 1rem;
            /* Alt tarafa 1.5rem boşluk bırak. */
            margin-bottom: 1.5rem;
        }

        /* Başlık yanındaki uzun çizgi */
        .section-bar-line {
            /* Kalan tüm boşluğu kapla (flex: 1). */
            flex: 1;
            /* Yükseklik 1px (ince çizgi). */
            height: 1px;
            /* Soldan sağa gri'den şeffafa giden renk geçişi. */
            background: linear-gradient(to right, #e2e8f0, transparent);
        }

        /* ── BÖLÜM KARTLARI (KARDİYOLOJİ VB.) ── */
        /* Her bir bölümü temsil eden kutu */
        .dept-card {
            /* Arka plan beyaz. */
            background: white;
            /* Köşeler 1.5rem yuvarlatılmış. */
            border-radius: 1.5rem;
            /* İç boşluk 1.5rem. */
            padding: 1.5rem;
            /* İnce çerçeve. */
            border: 1px solid #f1f5f9;
            /* Geçişler 0.25sn. */
            transition: all 0.25s ease;
            /* Flexbox (dikey düzen). */
            display: flex;
            /* İçerikleri alt alta diz (column). */
            flex-direction: column;
            /* İçerikler arası boşluk 0.75rem. */
            gap: 0.75rem;
            /* İmleyici el yap. */
            cursor: pointer;
            /* Pozisyon referansı. */
            position: relative;
            /* Taşanları gizle. */
            overflow: hidden;
        }

            /* Kartın en üstündeki renkli ince çizgi (pseudo-element) */
            .dept-card::before {
                /* İçerik mecburi. */
                content: '';
                /* Mutlak konumlandırma. */
                position: absolute;
                /* En üste yapış. */
                top: 0;
                /* Sola yapış. */
                left: 0;
                /* Sağa yapış. */
                right: 0;
                /* Yükseklik 3px. */
                height: 3px;
                /* Başlangıçta görünmez (opacity: 0). */
                opacity: 0; 
                /* Opaklık geçişi animasyonlu olsun. */
                transition: opacity 0.25s ease;
                /* Sadece üst köşeleri yuvarla. */
                border-radius: 1.5rem 1.5rem 0 0;
            }

            /* Kartın üzerine gelindiğinde (Hover) */
            .dept-card:hover {
                /* Kartı 4px yukarı kaldır. */
                transform: translateY(-4px); 
            }

                /* Kart hover olunca üstteki çizgiyi görünür yap. */
                .dept-card:hover::before {
                    opacity: 1; 
                }

            /* Tipe göre Hover renkleri (Dahili - Mavi) */
            .dept-card.type-dahili:hover {
                /* Mavi gölge. */
                box-shadow: 0 12px 40px rgba(37,99,235,0.1);
                /* Kenarlık mavi. */
                border-color: #bfdbfe;
            }

            /* Dahili kartının üst çizgi rengi (Mavi gradient). */
            .dept-card.type-dahili::before {
                background: linear-gradient(90deg, #2563eb, #60a5fa);
            }

            /* Cerrahi - Kırmızı */
            .dept-card.type-cerrahi:hover {
                /* Kırmızı gölge. */
                box-shadow: 0 12px 40px rgba(239,68,68,0.1);
                /* Kenarlık kırmızı. */
                border-color: #fecaca;
            }

            /* Cerrahi kartının üst çizgi rengi (Kırmızı gradient). */
            .dept-card.type-cerrahi::before {
                background: linear-gradient(90deg, #ef4444, #f87171);
            }

            /* Temel - Yeşil */
            .dept-card.type-temel:hover {
                /* Yeşil gölge. */
                box-shadow: 0 12px 40px rgba(22,163,74,0.1);
                /* Kenarlık yeşil. */
                border-color: #bbf7d0;
            }

            /* Temel kartının üst çizgi rengi (Yeşil gradient). */
            .dept-card.type-temel::before {
                background: linear-gradient(90deg, #16a34a, #4ade80);
            }

        /* ── İKON KUTULARI (Kartın sol üstündeki kare ikonlar) ── */
        .icon-box {
            /* Genişlik 46px. */
            width: 46px;
            /* Yükseklik 46px. */
            height: 46px;
            /* Köşeleri biraz yuvarla (squircle). */
            border-radius: 13px;
            /* Merkezi hizalama. */
            display: flex;
            align-items: center;
            justify-content: center;
            /* İkon boyutu. */
            font-size: 1.1rem;
            /* Büzülmeyi engelle. */
            flex-shrink: 0;
        }

        /* Mavi İkon Kutusu */
        .ib-blue {
            background: #eff6ff;
            color: #2563eb;
        }

        /* Kırmızı İkon Kutusu */
        .ib-red {
            background: #fef2f2;
            color: #ef4444;
        }

        /* Yeşil İkon Kutusu */
        .ib-green {
            background: #f0fdf4;
            color: #16a34a;
        }

        /* ── KART OK İKONU (Kartın sağ üstündeki küçük ok) ── */
        .card-arrow {
            /* Boyutlar 28x28px. */
            width: 28px;
            height: 28px;
            /* Hafif yuvarlak köşeler. */
            border-radius: 8px;
            /* Ortala. */
            display: flex;
            align-items: center;
            justify-content: center;
            /* Arkaplan açık gri. */
            background: #f8fafc;
            /* Renk gri. */
            color: #94a3b8;
            /* Font küçük. */
            font-size: 0.65rem;
            /* Geçişli renk değişimi. */
            transition: all 0.2s;
            /* Sağa yasla (margin-left: auto sayesinde). */
            margin-left: auto;
        }

        /* Kart üzerine gelince ok stilini değiştir. */
        .dept-card:hover .card-arrow {
            /* Arka plan açık mavi. */
            background: #eff6ff;
            /* Ok rengi mavi. */
            color: #2563eb;
        }

        /* ── TİP ETİKETLERİ (BADGES - Bölüm başlığındaki "Dahili" yazısı vb.) ── */
        .badge {
            /* Yan yana dizilim. */
            display: inline-flex;
            align-items: center;
            gap: 4px;
            /* Küçük font. */
            font-size: 0.6rem;
            /* Kalın yazı. */
            font-weight: 800;
            /* Büyük harf. */
            text-transform: uppercase;
            /* Harf aralığı. */
            letter-spacing: 0.08em;
            /* İç boşluk. */
            padding: 3px 8px;
            /* Tam yuvarla. */
            border-radius: 99px;
        }

        /* Mavi Etiket */
        .badge-blue {
            background: #dbeafe;
            color: #1d4ed8;
        }

        /* Kırmızı Etiket */
        .badge-red {
            background: #fee2e2;
            color: #b91c1c;
        }

        /* Yeşil Etiket */
        .badge-green {
            background: #dcfce7;
            color: #15803d;
        }

        /* ── MOBİL YAN MENÜ KATMANLARI ── */
        /* Arka plan karartma katmanı (Overlay) */
        #mob-overlay {
            /* Başlangıçta gizli. */
            display: none;
            /* Sabit (ekrana göre). */
            position: fixed;
            /* Tüm ekranı kapla. */
            inset: 0;
            /* Yarı saydam siyah. */
            background: rgba(15,23,42,0.4); 
            /* En üstte olsun. */
            z-index: 40;
            /* Arka planı bulanıklaştır (blur). */
            backdrop-filter: blur(2px);
        }

            /* 'open' sınıfı eklendiğinde görünür yap. */
            #mob-overlay.open {
                display: block;
            }

        /* Mobil menü paneli */
        #mob-sidebar {
            /* Sabit konum. */
            position: fixed;
            /* En üstte. */
            top: 0;
            /* Başlangıçta sol ekran dışında (gizli). */
            left: -100%; 
            /* Genişlik 300px. */
            width: 300px;
            /* Yükseklik tam ekran. */
            height: 100%;
            /* Arka plan beyaz. */
            background: white;
            /* Overlay'in de üstünde (z-index: 50). */
            z-index: 50;
            /* Giriş animasyonu (soldan kayarak). */
            transition: left 0.3s ease; 
            /* İçerik taşarsa kaydır. */
            overflow-y: auto;
            /* İç boşluk. */
            padding: 1.5rem 1rem;
            /* Sağa doğru gölge. */
            box-shadow: 8px 0 30px rgba(0,0,0,0.1);
        }

            /* 'open' sınıfı eklendiğinde soldan 0 konumuna gel (görünür ol). */
            #mob-sidebar.open {
                left: 0; 
            }

        /* ── GİZLEME VE BOŞ DURUM SINIFLARI ── */
        /* Arama yapıldığında eşleşmeyen kartları gizlemek için. */
        .hidden-card {
            display: none !important;
        }

        /* Arama sonucu bulunamazsa gösterilecek alan (Empty State) */
        #empty-state {
            /* Başlangıçta gizli. */
            display: none;
        }

            /* 'show' sınıfı eklenirse flex olarak görünür. */
            #empty-state.show {
                display: flex;
            }

        /* ── SAYI ETİKETİ (YUVARLAK - Menüdeki sayılar) ── */
        .count-pill {
            font-size: 0.6rem;
            font-weight: 800;
            padding: 2px 7px;
            border-radius: 99px;
            background: #f1f5f9;
            color: #64748b;
        }
    </style>

    <!-- SAYFA İÇİ SCRİPTLER (JavaScript) -->
    <script>
        // ── MOBİL MENÜ KONTROLÜ ──
        // Elemanları değişkenlere ata.
        const mobToggle  = document.getElementById('mob-toggle'); // Menü açma butonu (Layout içinde olabilir)
        const mobSidebar = document.getElementById('mob-sidebar'); // Mobil menü
        const mobOverlay = document.getElementById('mob-overlay'); // Karartma katmanı
        const mobClose   = document.getElementById('mob-close'); // Kapatma butonu

        // Mobilde menüyü aç/kapa olaylarını dinle.
        if(mobToggle) { mobToggle.addEventListener('click', openMob); } // Toggle butonuna tıklanırsa aç
        if(mobClose) { mobClose.addEventListener('click', closeMob); }   // Kapat butonuna tıklanırsa kapat
        if(mobOverlay) { mobOverlay.addEventListener('click', closeMob); } // Dışarı (Overlay) tıklanırsa kapat

        // Menüyü açma fonksiyonu
        function openMob()  { 
            mobSidebar.classList.add('open'); // Menüye 'open' sınıfı ekle
            mobOverlay.classList.add('open'); // Overlay'e 'open' sınıfı ekle
            document.body.style.overflow = 'hidden'; // Sayfanın kaydırılmasını engelle
        }
        
        // Menüyü kapatma fonksiyonu
        function closeMob() { 
            mobSidebar.classList.remove('open'); // 'open' sınıfını kaldır
            mobOverlay.classList.remove('open'); 
            document.body.style.overflow = ''; // Sayfa kaydırmasını geri aç
        }

        // ── ARAMA VE FİLTRELEME FONKSİYONU ──
        function runSearch(term) {
            // Tüm bölüm kartlarını (.dept-card) seç
            const cards = document.querySelectorAll('.dept-card');
            cards.forEach(card => {
                // Kartın içindeki başlık yazısını (h3) al ve küçük harfe çevir
                const text = card.querySelector('h3').innerText.toLowerCase();
                // Aranan terim (term) yazı içinde geçmiyorsa (includes) 'hidden-card' sınıfı ekle, aksi halde kaldır (toggle).
                card.classList.toggle('hidden-card', !text.includes(term));
            });

            let anyVisible = false;
            // Eğer bir bölümdeki (section) tüm kartlar gizlendiyse, o bölümün başlığını da gizlemek gerekir.
            document.querySelectorAll('section.bolum-section').forEach(section => {
                // Bu bölümdeki gizli OLMAYAN kart sayısını bul.
                const visible = section.querySelectorAll('.dept-card:not(.hidden-card)').length;
                // Hiç kart yoksa bölümü komple gizle ('none'), varsa göster ('block').
                section.style.display = visible === 0 ? 'none' : 'block'; 
                // Eğer en az bir bölüm görünürse, genel olarak sonuç var demektir.
                if (visible > 0) anyVisible = true;
            });

            // Hiçbir sonuç bulunamadıysa 'empty-state' alanını göster.
            const empty = document.getElementById('empty-state');
            // Eğer hiç görünür kart yoksa VE arama kutusu doluysa.
            if (!anyVisible && term) {
                empty.classList.add('show'); // Boş durumu göster.
            } else {
                empty.classList.remove('show'); // Boş durumu gizle.
            }
        }

        // Arama kutusuna yazı yazıldıkça (input olayı) filtreleme fonksiyonunu çalıştır
        // Masaüstü arama kutusu (#deptSearch) ve Mobil arama kutusu (#deptSearchMob) için dinleyiciler.
        // ?. operatörü ile element yoksa hata vermesini engelliyoruz (Safe navigation).
        document.getElementById('deptSearch')?.addEventListener('input', e => runSearch(e.target.value.toLowerCase().trim()));
        document.getElementById('deptSearchMob')?.addEventListener('input', e => runSearch(e.target.value.toLowerCase().trim()));
    </script>
}

<!-- MOBİL SIDEBAR ELEMANLARI (Sayfa dışında duran menü) -->
<div id="mob-overlay"></div>
<div id="mob-sidebar">
    <!-- Menü Başlığı ve Kapat Butonu -->
    <div class="flex items-center justify-between mb-5">
        <span class="font-black text-slate-800 text-sm uppercase tracking-wider">Birimler</span>
        <!-- Kapat butonu (x işareti) -->
        <button id="mob-close" class="w-8 h-8 flex items-center justify-center rounded-xl bg-slate-100 text-slate-500 hover:bg-slate-200 transition">
            <i class="fa-solid fa-xmark text-sm"></i>
        </button>
    </div>
    <!-- Mobil Arama Kutusu -->
    <div class="relative mb-5">
        <!-- Büyüteç ikonu -->
        <i class="fa-solid fa-magnifying-glass absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 text-xs"></i>
        <!-- Input alanı -->
        <input type="text" id="deptSearchMob" placeholder="Bölüm ara..."
               class="search-input w-full pl-9 pr-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm font-medium text-slate-700 transition">
    </div>
    <!-- Menü Linkleri (Navigasyon) -->
    <nav class="space-y-1">
        <!-- Dahili Bölümler Linki -->
        <!-- onclick="closeMob()" ile tıklandığında menüyü kapatır. -->
        <a href="#dahili" class="cat-link active-blue" onclick="closeMob()">
            <!-- Renkli nokta -->
            <span class="w-2.5 h-2.5 rounded-full bg-blue-500 flex-shrink-0"></span>
            <span>Dahili Tıp Bilimleri</span>
            <!-- Sayı etiketi (sağa yaslı) -->
            <span class="count-pill ml-auto">9</span>
        </a>
        <!-- Cerrahi Bölümler Linki -->
        <a href="#cerrahi" class="cat-link active-red" onclick="closeMob()">
            <span class="w-2.5 h-2.5 rounded-full bg-red-500 flex-shrink-0"></span>
            <span>Cerrahi Tıp Bilimleri</span>
            <span class="count-pill ml-auto">8</span>
        </a>
        <!-- Temel Bölümler Linki -->
        <a href="#temel" class="cat-link active-green" onclick="closeMob()">
            <span class="w-2.5 h-2.5 rounded-full bg-green-500 flex-shrink-0"></span>
            <span>Temel Tıp Bilimleri</span>
            <span class="count-pill ml-auto">5</span>
        </a>
    </nav>
    <!-- Acil Çağrı Kartı (Mobil Menü İçinde) -->
    <div class="mt-6 p-4 bg-gradient-to-br from-red-50 to-red-100/60 rounded-2xl border border-red-100">
        <div class="flex items-center gap-2 mb-1">
            <div class="w-5 h-5 bg-red-500 rounded-lg flex items-center justify-center">
                <i class="fa-solid fa-phone text-white text-[8px]"></i>
            </div>
            <p class="text-[10px] font-black text-red-700 uppercase tracking-widest">Acil Çağrı</p>
        </div>
        <p class="text-xl font-black text-red-600 mt-1">444 0 911</p>
    </div>
</div>

<!-- ANA SAYFA YAPISI (Main Content) -->
<!-- max-w-[1400px] ile geniş ekranlarda içerik ortalanır. -->
<div class="max-w-[1400px] mx-auto px-4 sm:px-6 py-8 flex flex-col lg:flex-row gap-7 mt-24">
    <!-- SOL SABİT MENÜ (Yan Sidebar - SADECE MASAÜSTÜNDE GÖRÜNÜR) -->
    <!-- hidden lg:block: Mobilde gizle, geniş ekranda göster. -->
    <aside class="hidden lg:block w-72 flex-shrink-0">
        <!-- İçerik kutusu -->
        <div class="sidebar-sticky bg-white rounded-[1.75rem] p-4 border border-slate-100" style="box-shadow: 0 4px 24px rgba(0,0,0,0.05);">
            <!-- Sidebar Üst Bilgi (Hastane ikonu ve başlık) -->
            <div class="flex items-center gap-3 mb-5 px-1">
                <div class="w-10 h-10 bg-gradient-to-br from-blue-600 to-blue-700 rounded-xl flex items-center justify-center shadow-md shadow-blue-200">
                    <i class="fa-solid fa-hospital text-white text-sm"></i>
                </div>
                <div>
                    <p class="font-black text-slate-800 text-sm leading-none">Tıbbi Birimler</p>
                    <p class="text-[10px] text-slate-400 font-bold mt-0.5">22 aktif anabilim dalı</p>
                </div>
            </div>

            <!-- Masaüstü Arama Kutusu -->
            <div class="relative mb-4">
