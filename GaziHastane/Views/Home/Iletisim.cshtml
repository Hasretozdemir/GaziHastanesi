@* RAZOR KOD BLOĞU: Sayfa ayarlamaları *@
@{
    // Sayfa başlığı: İletişim & Ulaşım
    ViewData["Title"] = "İletişim & Ulaşım";
}

@section Scripts {
    <!-- SAYFAYA ÖZEL STİLLER (CSS) -->
    <style>
        /* ── KONUM KARTI STİLİ ── */
        .loc-card {
            background: white;
            border-radius: 1.5rem;
            border: 1px solid #f1f5f9;
            overflow: hidden; /* Taşmayı engelle */
            transition: all 0.25s ease;
        }
            /* Hover efekti: Kart yukarı kalkar */
            .loc-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 16px 48px rgba(37,99,235,0.1);
            }

        /* ── HARİTA YER TUTUCU (Placeholder) ── */
        /* Harita yüklenmeden önce veya harita yerine gösterilecek tasarım */
        .map-ph {
            height: 200px;
            background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 50%, #bfdbfe 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }
            /* Harita üzerindeki dekoratif sağ üst daire */
            .map-ph::before {
                content: '';
                position: absolute;
                width: 180px;
                height: 180px;
                border-radius: 50%;
                background: rgba(37,99,235,0.06);
                top: -30px;
                right: -30px;
            }

            /* Harita üzerindeki dekoratif sol alt daire */
            .map-ph::after {
                content: '';
                position: absolute;
                width: 120px;
                height: 120px;
                border-radius: 50%;
                background: rgba(37,99,235,0.06);
                bottom: -20px;
                left: -20px;
            }

        /* ── ULAŞIM ARACI KARTI ── */
        .tr-card {
            background: white;
            border-radius: 1.25rem;
            border: 1px solid #f1f5f9;
            padding: 1.25rem 1.5rem;
            display: flex;
            gap: 1rem;
            align-items: flex-start;
            transition: all 0.2s;
        }
            /* Hover efekti */
            .tr-card:hover {
                box-shadow: 0 8px 28px rgba(0,0,0,0.07);
                transform: translateY(-2px);
            }

        /* Araç ikonu kutusu */
        .tr-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            flex-shrink: 0;
        }

        /* ── ETİKETLER (Badge) ── */
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 0.6rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            padding: 3px 8px;
            border-radius: 99px;
        }
        /* Mavi etiket */
        .badge-blue {
            background: #dbeafe;
            color: #1d4ed8;
        }
        /* Turuncu etiket */
        .badge-orange {
            background: #ffedd5;
            color: #c2410c;
        }

        /* ── BÖLÜM AYIRICI ÇİZGİ ── */
        .section-bar {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.25rem;
        }
        /* Çizginin kendisi */
        .section-bar-line {
            flex: 1;
            height: 1px;
            background: linear-gradient(to right, #e2e8f0, transparent);
        }

        /* ── BİLGİ SATIRI ── */
        .info-row {
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
            padding: 0.65rem 0.85rem;
            background: #f8fafc;
            border-radius: 10px;
            border: 1px solid #f1f5f9;
        }

        /* ── NABIZ EFEKTİ (PULSE ANIMATION) ── */
        /* Acil durum ikonunun etrafında yayılan halka efekti */
        @@keyframes pulse-ring {
            0% {
                box-shadow: 0 0 0 0 rgba(239,68,68,0.35);
            }
            70% {
                box-shadow: 0 0 0 10px rgba(239,68,68,0);
            }
            100% {
                box-shadow: 0 0 0 0 rgba(239,68,68,0);
            }
        }
        
        /* Nabız animasyonunu elemente uygula */
        .pulse-badge {
            animation: pulse-ring 2s ease infinite;
        }
    </style>
}

