@* RAZOR KOD BLOĞU: Sayfa ayarlamaları *@
@{
    ViewData["Title"] = "İletişim & Ulaşım";
}

@section Scripts {
    <style>
        html {
            scroll-behavior: smooth;
            overflow-x: hidden;
        }
        body {
            background-color: #f8fafc !important; /* Tailwind'deki bg-slate-50 rengi */
            overflow-x: hidden;
            width: 100%;
            max-width: 100%;
            margin: 0;
        }
    </style>
}

<main class="w-full px-6 sm:px-10 lg:px-16 py-10 space-y-12 min-h-screen relative">

    <div class="bg-gradient-to-br from-slate-900 via-blue-900 to-slate-800 rounded-[2.5rem] p-8 sm:p-12 relative overflow-hidden shadow-[0_20px_50px_rgba(30,58,138,0.2)]">
        <div class="absolute top-0 right-0 -mr-20 -mt-20 w-80 h-80 rounded-full bg-blue-500/10 blur-3xl pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 rounded-full bg-teal-500/10 blur-3xl pointer-events-none"></div>

        <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-8">
            <div>
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 border border-white/20 text-blue-100 text-[10px] font-black tracking-widest uppercase mb-4 backdrop-blur-sm">
                    <i class="fa-solid fa-hospital"></i> Gazi Üniversitesi Hastanesi
                </div>
                <h2 class="text-white text-3xl sm:text-5xl font-black leading-tight tracking-tight mb-3">İletişim & Ulaşım</h2>
                <p class="text-blue-200 text-base font-medium max-w-xl leading-relaxed">Bize kolayca ulaşın, sorularınızı iletin ve size en yakın birimimizden kesintisiz destek alın.</p>
            </div>

            <div class="flex gap-6 flex-shrink-0 bg-white/10 p-5 rounded-2xl backdrop-blur-md border border-white/20">
                <div class="text-center px-2">
                    <p class="text-white text-3xl font-black mb-1">2</p>
                    <p class="text-blue-300 text-[10px] font-black uppercase tracking-wider">Yerleşke</p>
                </div>
                <div class="w-px bg-white/20"></div>
                <div class="text-center px-2">
                    <p class="text-white text-3xl font-black mb-1">7/24</p>
                    <p class="text-blue-300 text-[10px] font-black uppercase tracking-wider">Acil Destek</p>
                </div>
                <div class="w-px bg-white/20"></div>
                <div class="text-center px-2">
                    <p class="text-white text-3xl font-black mb-1">182</p>
                    <p class="text-blue-300 text-[10px] font-black uppercase tracking-wider">MHRS</p>
                </div>
            </div>
        </div>
    </div>



    <section>
        <div class="flex items-center gap-4 mb-8">
            <h3 class="text-xl font-black text-slate-800 flex items-center gap-2">
                <span class="w-8 h-8 rounded-lg bg-blue-100 text-blue-600 flex items-center justify-center text-sm"><i class="fa-solid fa-map-location-dot"></i></span>
                Hastane Lokasyonları
            </h3>
            <div class="flex-1 h-[2px] bg-gradient-to-r from-slate-200 to-transparent rounded-full"></div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            @if (ViewBag.Lokasyonlar != null)
            {
                foreach (var lokasyon in ViewBag.Lokasyonlar)
                {
                    <div class="group bg-gradient-to-b from-white to-slate-50 hover:to-@(lokasyon.TemaRengi)-50/50 rounded-[2rem] border-2 border-@(lokasyon.TemaRengi)-200 shadow-lg hover:shadow-2xl hover:border-@(lokasyon.TemaRengi)-400 hover:-translate-y-2 transition-all duration-500 overflow-hidden flex flex-col">

                        <div class="relative h-48 bg-slate-50 flex items-center justify-center overflow-hidden border-b-2 border-@(lokasyon.TemaRengi)-50">
                            <div class="absolute inset-0 opacity-30 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-@(lokasyon.TemaRengi)-200 via-transparent to-transparent"></div>

                            <div class="relative z-10 flex flex-col items-center gap-2 transform group-hover:scale-105 transition-transform duration-500">
                                <div class="w-14 h-14 bg-white rounded-full flex items-center justify-center shadow-lg shadow-@(lokasyon.TemaRengi)-500/20 text-@(lokasyon.TemaRengi)-600 text-xl border border-@(lokasyon.TemaRengi)-100">
                                    <i class="fa-solid fa-location-dot"></i>
                                </div>
                                <p class="text-@(lokasyon.TemaRengi)-900 text-sm font-black mt-1">@lokasyon.KisaAdres</p>
                                <p class="text-@(lokasyon.TemaRengi)-600 text-[10px] font-bold tracking-widest uppercase">@lokasyon.Koordinat</p>
                            </div>

                            <a href="@lokasyon.HaritaUrl" target="_blank" class="absolute bottom-4 right-4 z-10 flex items-center gap-2 bg-white/90 hover:bg-@(lokasyon.TemaRengi)-600 text-@(lokasyon.TemaRengi)-700 hover:text-white border border-@(lokasyon.TemaRengi)-200 text-[11px] font-black px-4 py-2 rounded-xl transition-colors duration-300 shadow-sm backdrop-blur-sm">
                                <i class="fa-solid fa-diamond-turn-right"></i> Yol Tarifi Al
                            </a>
                        </div>

                        <div class="p-6 sm:p-8 flex-1 flex flex-col gap-5">
                            <div class="flex items-start justify-between gap-4">
                                <div>
                                    <h4 class="text-lg font-black text-@(lokasyon.TemaRengi)-800 mb-1 transition-colors">@lokasyon.Baslik</h4>
                                    <span class="inline-block bg-@(lokasyon.TemaRengi)-50 text-@(lokasyon.TemaRengi)-600 text-[10px] font-black uppercase tracking-widest px-3 py-1 rounded-lg">@lokasyon.AltBaslik</span>
                                </div>
                            </div>

                            <div class="flex items-start gap-3 bg-@(lokasyon.TemaRengi)-50/50 rounded-xl p-4 border border-@(lokasyon.TemaRengi)-100">
                                <i class="fa-solid fa-location-dot text-@(lokasyon.TemaRengi)-500 mt-1"></i>
                                <p class="text-slate-600 text-sm leading-relaxed font-medium">@lokasyon.Adres</p>
                            </div>

                            <div class="grid grid-cols-2 gap-3">
                                @if (!string.IsNullOrEmpty(lokasyon.CagriMerkezi))
                                {
                                    <div class="bg-@(lokasyon.TemaRengi)-50/30 border border-@(lokasyon.TemaRengi)-100 rounded-xl p-3 flex flex-col gap-1 hover:border-@(lokasyon.TemaRengi)-300 hover:bg-@(lokasyon.TemaRengi)-50 transition-colors">
                                        <p class="text-[10px] font-black text-@(lokasyon.TemaRengi)-500 uppercase tracking-wider">Çağrı Merkezi</p>
                                        <p class="text-sm font-bold text-slate-700">@lokasyon.CagriMerkezi</p>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(lokasyon.Santral))
                                {
                                    <div class="bg-@(lokasyon.TemaRengi)-50/30 border border-@(lokasyon.TemaRengi)-100 rounded-xl p-3 flex flex-col gap-1 hover:border-@(lokasyon.TemaRengi)-300 hover:bg-@(lokasyon.TemaRengi)-50 transition-colors">
                                        <p class="text-[10px] font-black text-@(lokasyon.TemaRengi)-500 uppercase tracking-wider">Santral</p>
                                        <p class="text-sm font-bold text-slate-700">@lokasyon.Santral</p>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(lokasyon.DigerTelefonlar))
                                {
                                    foreach (var telBilgisi in lokasyon.DigerTelefonlar.Split('^'))
                                    {
                                        var bolumler = telBilgisi.Split('|');
                                        if (bolumler.Length == 2)
                                        {
                                            <div class="bg-@(lokasyon.TemaRengi)-50/30 border border-@(lokasyon.TemaRengi)-100 rounded-xl p-3 flex flex-col gap-1 hover:border-@(lokasyon.TemaRengi)-300 hover:bg-@(lokasyon.TemaRengi)-50 transition-colors">
                                                <p class="text-[10px] font-black text-@(lokasyon.TemaRengi)-500 uppercase tracking-wider">@bolumler[0]</p>
                                                <p class="text-sm font-bold text-slate-700">@bolumler[1]</p>
                                            </div>
                                        }
                                    }
                                }
                            </div>

                            <div class="mt-auto pt-4 border-t-2 border-@(lokasyon.TemaRengi)-50 space-y-3">
                                @if (!string.IsNullOrEmpty(lokasyon.Email))
                                {
                                    <div class="flex items-center gap-3 text-sm">
                                        <i class="fa-solid fa-envelope text-@(lokasyon.TemaRengi)-400 w-4 text-center"></i>
                                        <a href="mailto:@lokasyon.Email" class="text-slate-600 font-medium hover:text-@(lokasyon.TemaRengi)-600 transition-colors">@lokasyon.Email</a>
                                    </div>
                                }
                                <div class="flex items-center gap-3 text-sm">
                                    <i class="fa-solid fa-clock text-@(lokasyon.TemaRengi)-400 w-4 text-center"></i>
                                    <span class="text-slate-600 font-medium">@Html.Raw(lokasyon.CalismaSaatleri)</span>
                                </div>
                                @if (!string.IsNullOrEmpty(lokasyon.EkBilgi))
                                {
                                    <div class="flex items-start gap-3 text-sm">
                                        <i class="fa-solid fa-circle-info text-@(lokasyon.TemaRengi)-400 w-4 text-center mt-1"></i>
                                        <span class="text-slate-500 text-xs leading-relaxed font-medium">@lokasyon.EkBilgi</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </section>

    <section>
        <div class="flex items-center gap-4 mb-8">
            <h3 class="text-xl font-black text-slate-800 flex items-center gap-2">
                <span class="w-8 h-8 rounded-lg bg-amber-100 text-amber-600 flex items-center justify-center text-sm"><i class="fa-solid fa-bus"></i></span>
                Ulaşım Rehberi
            </h3>
            <div class="flex-1 h-[2px] bg-gradient-to-r from-slate-200 to-transparent rounded-full"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            @if (ViewBag.UlasimAraclari != null)
            {
                foreach (var ulasim in ViewBag.UlasimAraclari)
                {
                    <div class="group bg-gradient-to-br from-white to-slate-50 hover:to-@(ulasim.TemaRengi)-50/30 rounded-2xl p-6 border-2 border-@(ulasim.TemaRengi)-200 shadow-md hover:shadow-2xl hover:border-@(ulasim.TemaRengi)-400 hover:-translate-y-1 transition-all duration-500 flex items-start gap-5 cursor-pointer">
                        <div class="w-16 h-16 rounded-2xl bg-@(ulasim.TemaRengi)-100/80 text-@(ulasim.TemaRengi)-700 flex items-center justify-center text-2xl flex-shrink-0 transition-all duration-500 border border-@(ulasim.TemaRengi)-200 shadow-sm group-hover:bg-@(ulasim.TemaRengi)-600 group-hover:text-white group-hover:shadow-xl group-hover:shadow-@(ulasim.TemaRengi)-500/40 group-hover:-translate-y-1">
                            <i class="@ulasim.Ikon"></i>
                        </div>
                        <div>
                            <h5 class="text-lg font-black text-@(ulasim.TemaRengi)-800 mb-1.5 transition-colors group-hover:text-@(ulasim.TemaRengi)-600">@ulasim.UlasimTipi</h5>
                            <p class="text-xs text-slate-600 leading-relaxed font-medium">
                                @Html.Raw(ulasim.Icerik)
                            </p>
                        </div>
                    </div>
                }
            }
        </div>
    </section>

    <div class="bg-slate-900 rounded-[2rem] p-8 sm:p-10 flex flex-col md:flex-row md:items-center justify-between gap-8 relative overflow-hidden shadow-2xl mt-8">
        <div class="absolute right-0 top-0 w-64 h-64 bg-blue-500/10 rounded-full blur-3xl"></div>

        <div class="relative z-10">
            <p class="text-slate-400 text-[10px] font-black uppercase tracking-widest mb-2 flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span> Çevrimiçi Destek
            </p>
            <h3 class="text-white text-2xl font-black mb-2">Görüş ve Önerileriniz</h3>
            <p class="text-slate-400 text-sm max-w-md leading-relaxed">Hastanemizle ilgili görüş, öneri ve şikâyetlerinizi çevrimiçi form aracılığıyla hızlıca kalite birimimize iletebilirsiniz.</p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 relative z-10 flex-shrink-0">
            <a href="mailto:hastane@gazi.edu.tr" class="flex items-center justify-center gap-2 bg-white/5 hover:bg-white/10 border border-white/10 text-white text-sm font-bold px-6 py-3.5 rounded-xl transition duration-300 backdrop-blur-sm">
                <i class="fa-solid fa-envelope"></i> E-Posta Gönder
            </a>
            <a href="#" class="flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold px-6 py-3.5 rounded-xl transition duration-300 shadow-lg shadow-blue-600/30">
                <i class="fa-solid fa-paper-plane"></i> Formu Doldur
            </a>
        </div>
    </div>

</main>