@model IEnumerable<GaziHastane.Models.Doktor>
@* RAZOR KOD BLOĞU: Sunucu tarafında sayfa ayarları *@
@{
    ViewData["Title"] = "Doktorlarımız";

    // Veritabanından gelen verilere göre dinamik sayıları hesaplıyoruz
    int dahiliCount = Model.Count(d => d.Bolum != null && d.Bolum.Kategori == "Dahili" && d.IsActive);
    int cerrahiCount = Model.Count(d => d.Bolum != null && d.Bolum.Kategori == "Cerrahi" && d.IsActive);
    int temelCount = Model.Count(d => d.Bolum != null && d.Bolum.Kategori == "Temel" && d.IsActive);
    int totalCount = Model.Count(d => d.IsActive);
    int profCount = Model.Count(d => d.IsActive && d.Unvan != null && d.Unvan.Contains("Prof"));
}

@section Scripts {
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');

        html {
            scroll-behavior: smooth;
            overflow-x: hidden;
        }

        body {
            overflow-x: hidden;
            width: 100%;
            max-width: 100%;
            margin: 0;
        }

        /* ── YAPIŞKAN YAN MENÜ (SIDEBAR) - SADECE MASAÜSTÜNDE ── */
        @@media (min-width: 1024px) {
            .sidebar-sticky {
                position: sticky;
                top: 6rem;
                max-height: calc(100vh - 7rem);
                overflow-y: auto;
            }

                .sidebar-sticky::-webkit-scrollbar {
                    width: 4px;
                }

                .sidebar-sticky::-webkit-scrollbar-track {
                    background: transparent;
                }

                .sidebar-sticky::-webkit-scrollbar-thumb {
                    background: #e2e8f0;
                    border-radius: 10px;
                }
        }

        /* ── ARAMA KUTUSU ── */
        .search-input:focus {
            outline: none;
            box-shadow: 0 0 0 4px rgba(37,99,235,0.1);
            border-color: #60a5fa;
        }

        /* ── FİLTRE BUTONLARI (SOL MENÜ) ── */
        .nav-btn {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            width: 100%;
            padding: 0.85rem 1rem;
            border-radius: 14px;
            font-size: 0.85rem;
            font-weight: 700;
            color: #64748b;
            background: transparent;
            border: none;
            cursor: pointer;
            transition: all 0.3s ease;
            text-align: left;
        }

            .nav-btn:hover {
                background: #f8fafc;
                color: #0f172a;
                transform: translateX(4px);
            }

            .nav-btn.active-blue {
                background: #eff6ff;
                color: #2563eb;
            }

            .nav-btn.active-red {
                background: #fef2f2;
                color: #ef4444;
            }

            .nav-btn.active-green {
                background: #f0fdf4;
                color: #16a34a;
            }

        /* ── DOKTOR KARTI TASARIMI ── */
        .doctor-card {
            background: white;
            border-radius: 1.5rem;
            border: 1px solid #f1f5f9;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            overflow: hidden;
            position: relative;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        }

            .doctor-card:hover {
                transform: translateY(-8px);
            }

            .doctor-card.type-dahili:hover {
                box-shadow: 0 20px 40px -10px rgba(37,99,235,0.15);
                border-color: #bfdbfe;
            }

            .doctor-card.type-cerrahi:hover {
                box-shadow: 0 20px 40px -10px rgba(239,68,68,0.15);
                border-color: #fecaca;
            }

            .doctor-card.type-temel:hover {
                box-shadow: 0 20px 40px -10px rgba(22,163,74,0.15);
                border-color: #bbf7d0;
            }

            .doctor-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 4px;
                opacity: 0.8;
                transition: opacity 0.3s;
            }

        .type-dahili::before {
            background: linear-gradient(90deg, #2563eb, #60a5fa);
        }

        .type-cerrahi::before {
            background: linear-gradient(90deg, #ef4444, #f87171);
        }

        .type-temel::before {
            background: linear-gradient(90deg, #16a34a, #4ade80);
        }

        /* ── PROFİL FOTOĞRAFI ÇERÇEVESİ ── */
        .avatar-wrap {
            position: relative;
            width: 100px;
            height: 100px;
            margin: 0 auto;
        }

            .avatar-wrap img {
                width: 100%;
                height: 100%;
                border-radius: 50%;
                object-fit: cover;
                border: 4px solid white;
                box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1);
                position: relative;
                z-index: 2;
            }

        .avatar-ring {
            position: absolute;
            inset: -4px;
            border-radius: 50%;
            background: linear-gradient(135deg, #e2e8f0, #f8fafc);
            transition: all 0.4s ease;
            z-index: 1;
        }

        .type-dahili:hover .avatar-ring {
            background: linear-gradient(135deg, #3b82f6, #93c5fd);
            transform: scale(1.05) rotate(90deg);
        }

        .type-cerrahi:hover .avatar-ring {
            background: linear-gradient(135deg, #ef4444, #fca5a5);
            transform: scale(1.05) rotate(90deg);
        }

        .type-temel:hover .avatar-ring {
            background: linear-gradient(135deg, #22c55e, #86efac);
            transform: scale(1.05) rotate(90deg);
        }

        /* ── UNVAN ETİKETİ ── */
        .unvan-badge {
            display: inline-block;
            font-size: 0.65rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            padding: 4px 12px;
            border-radius: 99px;
        }

        /* ── ÖZGEÇMİŞ BUTONU ── */
        .cv-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            width: 100%;
            padding: 0.75rem;
            border-radius: 12px;
            font-size: 0.75rem;
            font-weight: 800;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            background: #f8fafc;
            color: #64748b;
            border: 1px solid #e2e8f0;
            cursor: pointer;
            transition: all 0.3s;
            text-decoration: none;
        }

        .type-dahili:hover .cv-btn {
            background: #2563eb;
            color: white;
            border-color: #2563eb;
            box-shadow: 0 4px 12px rgba(37,99,235,0.2);
        }

        .type-cerrahi:hover .cv-btn {
            background: #ef4444;
            color: white;
            border-color: #ef4444;
            box-shadow: 0 4px 12px rgba(239,68,68,0.2);
        }

        .type-temel:hover .cv-btn {
            background: #16a34a;
            color: white;
            border-color: #16a34a;
            box-shadow: 0 4px 12px rgba(22,163,74,0.2);
        }

        /* ── BÖLÜM AYIRICI ÇİZGİSİ ── */
        .section-bar {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .section-bar-line {
            flex: 1;
            height: 1px;
            background: linear-gradient(to right, #cbd5e1, transparent);
        }

        /* ── ROZETLER ── */
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 0.65rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            padding: 4px 10px;
            border-radius: 8px;
        }

        .badge-blue {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .badge-red {
            background: #fee2e2;
            color: #b91c1c;
        }

        .badge-green {
            background: #dcfce7;
            color: #15803d;
        }

        /* ── SAYI ETİKETİ ── */
        .count-pill {
            font-size: 0.65rem;
            font-weight: 800;
            padding: 2px 8px;
            border-radius: 99px;
            background: #e2e8f0;
            color: #475569;
            margin-left: auto;
        }

        /* ── GİZLEME SIFIFLARI ── */
        .hidden-section {
            display: none !important;
        }

        #empty-state {
            display: none;
        }

            #empty-state.show {
                display: flex;
            }

        /* ── DİNAMİK IZGARA (AUTO FIT GRID) ── */
        .auto-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            width: 100%;
        }
    </style>

    <script>
        // --- MOBİL MENÜ AÇ / KAPAT İŞLEMLERİ ---
        function toggleSidebar() {
            const sidebar = document.getElementById('main-sidebar');
            const overlay = document.getElementById('sidebar-overlay');

            if (sidebar.classList.contains('-translate-x-full')) {
                // Menüyü Aç
                sidebar.classList.remove('-translate-x-full');
                overlay.classList.remove('hidden');
                setTimeout(() => overlay.classList.remove('opacity-0'), 10);
                document.body.style.overflow = 'hidden'; // Arka plan kaydırmayı durdur
            } else {
                // Menüyü Kapat
                sidebar.classList.add('-translate-x-full');
                overlay.classList.add('opacity-0');
                setTimeout(() => overlay.classList.add('hidden'), 300);
                document.body.style.overflow = '';
            }
        }

        // --- KATEGORİ FİLTRELEME ---
        const typeConfig = {
            dahili:  { color: 'active-blue' },
            cerrahi: { color: 'active-red' },
            temel:   { color: 'active-green' },
        };

        function filterType(type) {
            // Bölümleri gizle/göster
            document.querySelectorAll('.dept-section').forEach(s => s.classList.add('hidden-section'));
            document.getElementById('section-' + type).classList.remove('hidden-section');

            // Buton aktiflik sınıflarını temizle ve tıklanana ekle
            document.querySelectorAll('.nav-btn').forEach(b => b.className = 'nav-btn');
            const activeBtn = document.getElementById('btn-' + type);
            if (activeBtn) activeBtn.classList.add(typeConfig[type].color);

            // İnline filtre butonları için aktiflik durumu
            document.querySelectorAll('.inline-nav-btn').forEach(b => {
                b.classList.remove('bg-white/30', 'border-white/40');
                b.classList.add('bg-white/10', 'border-white/20');
            });
            const activeInline = document.getElementById('inline-btn-' + type);
            if (activeInline) {
                activeInline.classList.remove('bg-white/10', 'border-white/20');
                activeInline.classList.add('bg-white/30', 'border-white/40');
            }

            // Aramayı sıfırla
            document.getElementById('mainSearch').value = '';
            document.querySelectorAll('.doctor-card').forEach(c => c.style.display = '');
            document.getElementById('empty-state').classList.remove('show');

            // Eğer mobildeysek, filtre seçildikten sonra menüyü otomatik kapat
            if (window.innerWidth < 1024) {
                toggleSidebar();
            }
        }

        // --- ARAMA İŞLEMİ ---
        function runSearch(term) {
            if (!term) {
                document.querySelectorAll('.doctor-card').forEach(c => c.style.display = '');
                document.getElementById('empty-state').classList.remove('show');
                return;
            }

            document.querySelectorAll('.dept-section').forEach(s => s.classList.remove('hidden-section'));
            document.querySelectorAll('.nav-btn').forEach(b => b.className = 'nav-btn');

            let anyVisible = false;

            document.querySelectorAll('.doctor-card').forEach(card => {
                const name = (card.getAttribute('data-name') || '').toLowerCase();
                const dept = (card.getAttribute('data-dept') || '').toLowerCase();

                const match = name.includes(term) || dept.includes(term);
                card.style.display = match ? '' : 'none';
                if (match) anyVisible = true;
            });

            document.querySelectorAll('.dept-section').forEach(section => {
                const visible = [...section.querySelectorAll('.doctor-card')].some(c => c.style.display !== 'none');
                section.style.display = visible ? '' : 'none';
            });

            document.getElementById('empty-state').classList.toggle('show', !anyVisible);
        }

        // Arama kutusunu dinle
        document.getElementById('mainSearch')?.addEventListener('input', e => {
            const val = e.target.value.toLowerCase().trim();
            runSearch(val);
            const inline = document.getElementById('inlineSearch');
            if(inline && inline.value !== e.target.value) inline.value = e.target.value;
        });

        document.getElementById('inlineSearch')?.addEventListener('input', e => {
            const val = e.target.value.toLowerCase().trim();
            runSearch(val);
            const main = document.getElementById('mainSearch');
            if(main && main.value !== e.target.value) main.value = e.target.value;
        });

        function toggleDesktopSidebar() {
            const sidebar = document.getElementById('main-sidebar');
            const icon = document.getElementById('sidebar-toggle-icon');
            const inlineFilters = document.getElementById('inline-filters');
            
            if (sidebar.classList.contains('lg:w-[300px]')) {
                sidebar.classList.remove('lg:w-[300px]', 'lg:mr-8');
                sidebar.classList.add('lg:w-0', 'lg:mr-0');
                if(icon) {
                    icon.classList.remove('fa-angles-left');
                    icon.classList.add('fa-angles-right');
                }
                if(inlineFilters) {
                    inlineFilters.classList.remove('hidden');
                    // Gecikmeli opacity ekliyoruz ki transition çalışsın
                    setTimeout(() => inlineFilters.classList.remove('opacity-0'), 50);
                }
            } else {
                sidebar.classList.remove('lg:w-0', 'lg:mr-0');
                sidebar.classList.add('lg:w-[300px]', 'lg:mr-8');
                if(icon) {
                    icon.classList.remove('fa-angles-right');
                    icon.classList.add('fa-angles-left');
                }
                if(inlineFilters) {
                    inlineFilters.classList.add('opacity-0');
                    setTimeout(() => inlineFilters.classList.add('hidden'), 300);
                }
            }
        }
    </script>
}

<div class="w-full px-4 sm:px-6 py-10 flex flex-col lg:flex-row relative">

    <div class="lg:hidden flex items-center justify-between mb-2 bg-white p-4 rounded-2xl shadow-sm border border-slate-100">
        <h1 class="text-lg font-black text-slate-800">Akademik Kadro</h1>
        <button onclick="toggleSidebar()" class="bg-blue-600 hover:bg-blue-700 text-white w-10 h-10 rounded-xl flex items-center justify-center shadow-lg shadow-blue-200 transition-all active:scale-95">
            <i class="fa-solid fa-bars text-lg"></i>
        </button>
    </div>

    <div id="sidebar-overlay" onclick="toggleSidebar()" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-300 lg:hidden"></div>

    <aside id="main-sidebar" class="fixed inset-y-0 left-0 z-50 w-72 bg-white transform -translate-x-full transition-all duration-300 ease-in-out lg:relative lg:translate-x-0 lg:block lg:z-auto lg:bg-transparent lg:w-[300px] lg:overflow-hidden lg:mr-8 flex-shrink-0 shadow-2xl lg:shadow-none overflow-y-auto">
        <div class="w-full lg:w-[300px]">
        <div class="sidebar-sticky lg:bg-white lg:rounded-[2rem] p-6 lg:p-5 lg:border lg:border-slate-100 min-h-screen lg:min-h-0" style="box-shadow: 0 10px 40px -10px rgba(0,0,0,0.05);">

            <div class="flex items-center justify-between lg:hidden mb-8 pb-4 border-b border-slate-100">
                <span class="font-black text-slate-800 text-xl tracking-tight">Kategoriler</span>
                <button onclick="toggleSidebar()" class="w-8 h-8 bg-slate-100 hover:bg-slate-200 rounded-lg text-slate-600 flex items-center justify-center transition">
                    <i class="fa-solid fa-xmark text-lg"></i>
                </button>
            </div>

            <div class="flex items-center gap-4 mb-6 px-2">
                <div class="w-12 h-12 bg-gradient-to-br from-blue-600 to-indigo-700 rounded-2xl flex items-center justify-center shadow-lg shadow-blue-200">
                    <i class="fa-solid fa-user-doctor text-white text-lg"></i>
                </div>
                <div>
                    <p class="font-black text-slate-800 text-base leading-tight">Akademik Kadro</p>
                    <p class="text-xs text-slate-500 font-bold mt-1">@totalCount uzman hekim</p>
                </div>
            </div>

            <div class="relative mb-6">
                <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-sm"></i>
                <input type="text" id="mainSearch" placeholder="Doktor veya uzmanlık..."
                       class="search-input w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-medium text-slate-700 transition">
            </div>

            <div class="space-y-1.5">
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.15em] px-3 py-2">Bölümler</p>
                <button onclick="filterType('dahili')" class="nav-btn active-blue" id="btn-dahili">
                    <span class="w-3 h-3 rounded-full bg-blue-500 flex-shrink-0 shadow-sm shadow-blue-200"></span>
                    <span>Dahili Bilimler</span>
                    <span class="count-pill">@dahiliCount</span>
                </button>
                <button onclick="filterType('cerrahi')" class="nav-btn" id="btn-cerrahi">
                    <span class="w-3 h-3 rounded-full bg-red-500 flex-shrink-0 shadow-sm shadow-red-200"></span>
                    <span>Cerrahi Bilimler</span>
                    <span class="count-pill">@cerrahiCount</span>
                </button>
                <button onclick="filterType('temel')" class="nav-btn" id="btn-temel">
                    <span class="w-3 h-3 rounded-full bg-green-500 flex-shrink-0 shadow-sm shadow-green-200"></span>
                    <span>Temel Bilimler</span>
                    <span class="count-pill">@temelCount</span>
                </button>
            </div>
        </div>
        </div>
    </aside>

    <main class="flex-1 min-w-0 relative">
        <button onclick="toggleDesktopSidebar()" class="hidden lg:flex absolute -left-5 top-10 w-10 h-10 bg-white border border-slate-200 shadow-xl rounded-full items-center justify-center text-slate-500 hover:text-blue-600 hover:scale-110 z-20 cursor-pointer transition-all">
            <i class="fa-solid fa-angles-left" id="sidebar-toggle-icon"></i>
        </button>

        <div class="bg-gradient-to-r from-blue-600 via-blue-700 to-indigo-800 rounded-[2rem] p-8 sm:p-10 mb-8 relative overflow-hidden" style="box-shadow: 0 20px 50px -10px rgba(37,99,235,0.3);">
            <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full translate-x-20 -translate-y-20 blur-2xl"></div>
            <div class="absolute bottom-0 right-20 w-32 h-32 bg-white/10 rounded-full translate-y-10 blur-xl"></div>
            <div class="relative z-10 flex flex-col sm:flex-row sm:items-center justify-between gap-6">
                <div class="w-full lg:w-auto transition-all duration-300">
                    <p class="text-blue-200 text-xs font-black tracking-[0.25em] uppercase mb-2">Gazi Üniversitesi Hastanesi</p>
                    <h2 class="text-white text-3xl sm:text-4xl font-black leading-tight tracking-tight">Akademik Kadromuz</h2>
                    <p class="text-blue-100 text-sm font-medium mt-2 max-w-md">Türkiye'nin sağlık hafızası olarak en yetkin akademik ve klinik kadro ile hizmetinizdeyiz.</p>
                    
                    <div id="inline-filters" class="hidden opacity-0 mt-6 w-full max-w-xl transition-all duration-300">
                        <div class="flex flex-col sm:flex-row gap-3">
                            <div class="relative flex-1">
                                <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-white/50 text-sm"></i>
                                <input type="text" id="inlineSearch" placeholder="Doktor veya uzmanlık ara..."
                                       class="w-full pl-10 pr-4 py-2.5 bg-white/10 border border-white/20 rounded-xl text-sm font-medium text-white placeholder-white/50 focus:bg-white/20 focus:outline-none transition shadow-inner">
                            </div>
                            <div class="flex gap-2">
                                <button onclick="filterType('dahili')" id="inline-btn-dahili" class="inline-nav-btn px-4 py-2.5 rounded-xl bg-white/10 hover:bg-white/20 border border-white/20 text-white text-xs font-bold transition flex items-center gap-2">
                                    <span class="w-2.5 h-2.5 rounded-full bg-blue-400"></span> Dahili
                                </button>
                                <button onclick="filterType('cerrahi')" id="inline-btn-cerrahi" class="inline-nav-btn px-4 py-2.5 rounded-xl bg-white/10 hover:bg-white/20 border border-white/20 text-white text-xs font-bold transition flex items-center gap-2">
                                    <span class="w-2.5 h-2.5 rounded-full bg-red-400"></span> Cerrahi
                                </button>
                                <button onclick="filterType('temel')" id="inline-btn-temel" class="inline-nav-btn px-4 py-2.5 rounded-xl bg-white/10 hover:bg-white/20 border border-white/20 text-white text-xs font-bold transition flex items-center gap-2">
                                    <span class="w-2.5 h-2.5 rounded-full bg-green-400"></span> Temel
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="flex gap-6 flex-shrink-0 bg-black/10 p-4 rounded-2xl backdrop-blur-sm border border-white/10">
                    <div class="text-center">
                        <p class="text-white text-3xl font-black">@totalCount</p>
                        <p class="text-blue-200 text-[10px] font-black uppercase tracking-widest mt-1">Uzman</p>
                    </div>
                    <div class="w-px bg-white/20"></div>
                    <div class="text-center">
                        <p class="text-white text-3xl font-black">@profCount</p>
                        <p class="text-blue-200 text-[10px] font-black uppercase tracking-widest mt-1">Profesör</p>
                    </div>
                </div>
            </div>
        </div>

        <div id="empty-state" class="flex-col items-center justify-center py-24 text-center bg-white rounded-[2rem] border border-slate-100 mb-8" style="box-shadow: 0 10px 40px -10px rgba(0,0,0,0.05);">
            <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-5 border border-slate-100">
                <i class="fa-solid fa-user-doctor text-slate-300 text-3xl"></i>
            </div>
            <p class="font-black text-slate-800 text-xl">Sonuç bulunamadı</p>
            <p class="text-slate-500 text-sm mt-2">Aradığınız kriterlere uygun bir hekim kaydı bulamadık.</p>
        </div>

        <div id="section-dahili" class="dept-section mb-12">
            <div class="section-bar">
                <div class="flex items-center gap-3">
                    <span class="badge badge-blue"><i class="fa-solid fa-stethoscope"></i> Dahili</span>
                    <h2 class="text-xl font-black text-slate-800 tracking-tight">Dahili Tıp Bilimleri</h2>
                </div>
                <div class="section-bar-line"></div>
                <span class="text-xs font-bold text-slate-400 bg-slate-100 px-3 py-1 rounded-full flex-shrink-0">@dahiliCount Uzman</span>
            </div>

            <div class="auto-grid">
                @foreach (var doktor in Model.Where(d => d.Bolum != null && d.Bolum.Kategori == "Dahili" && d.IsActive))
                {
