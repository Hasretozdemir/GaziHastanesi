@model IEnumerable<GaziHastane.Models.Doktor>
@* RAZOR KOD BLOĞU: Sunucu tarafında sayfa ayarları *@
@{
    ViewData["Title"] = "Doktorlarımız";

    // Veritabanından gelen verilere göre dinamik sayıları hesaplıyoruz
    int dahiliCount = Model.Count(d => d.Bolum != null && d.Bolum.Kategori == "Dahili" && d.IsActive);
    int cerrahiCount = Model.Count(d => d.Bolum != null && d.Bolum.Kategori == "Cerrahi" && d.IsActive);
    int temelCount = Model.Count(d => d.Bolum != null && d.Bolum.Kategori == "Temel" && d.IsActive);
    int totalCount = Model.Count(d => d.IsActive);
    int profCount = Model.Count(d => d.IsActive && d.Unvan != null && d.Unvan.Contains("Prof"));
}

@section Scripts {
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');

        /* ── YAPIŞKAN YAN MENÜ (SIDEBAR) ── */
        .sidebar-sticky {
            position: sticky;
            top: 7rem;
            max-height: calc(100vh - 8rem);
            overflow-y: auto;
        }

            .sidebar-sticky::-webkit-scrollbar {
                width: 4px;
            }

            .sidebar-sticky::-webkit-scrollbar-track {
                background: transparent;
            }

            .sidebar-sticky::-webkit-scrollbar-thumb {
                background: #e2e8f0;
                border-radius: 10px;
            }

        /* ── ARAMA KUTUSU ── */
        .search-input:focus {
            outline: none;
            box-shadow: 0 0 0 3px rgba(37,99,235,0.15);
            border-color: #93c5fd;
        }

        /* ── FİLTRE BUTONLARI (SOL MENÜ) ── */
        .nav-btn {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            width: 100%;
            padding: 0.75rem 1rem;
            border-radius: 14px;
            font-size: 0.82rem;
            font-weight: 700;
            color: #64748b;
            background: transparent;
            border: none;
            cursor: pointer;
            transition: all 0.2s ease;
            text-align: left;
        }

            .nav-btn:hover {
                background: #f1f5f9;
                color: #1e293b;
                transform: translateX(3px);
            }

            .nav-btn.active-blue {
                background: #eff6ff;
                color: #2563eb;
            }

            .nav-btn.active-red {
                background: #fef2f2;
                color: #ef4444;
            }

            .nav-btn.active-green {
                background: #f0fdf4;
                color: #16a34a;
            }

        /* ── DOKTOR KARTI TASARIMI ── */
        .doctor-card {
            background: white;
            border-radius: 1.5rem;
            border: 1px solid #f1f5f9;
            transition: all 0.25s ease;
            overflow: hidden;
            position: relative;
        }

            .doctor-card:hover {
                transform: translateY(-5px);
            }

            .doctor-card.type-dahili:hover {
                box-shadow: 0 16px 44px rgba(37,99,235,0.12);
                border-color: #bfdbfe;
            }

            .doctor-card.type-cerrahi:hover {
                box-shadow: 0 16px 44px rgba(239,68,68,0.12);
                border-color: #fecaca;
            }

            .doctor-card.type-temel:hover {
                box-shadow: 0 16px 44px rgba(22,163,74,0.12);
                border-color: #bbf7d0;
            }

            .doctor-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                opacity: 0;
                transition: opacity 0.25s;
            }

            .doctor-card:hover::before {
                opacity: 1;
            }

        .type-dahili::before {
            background: linear-gradient(90deg, #2563eb, #60a5fa);
        }

        .type-cerrahi::before {
            background: linear-gradient(90deg, #ef4444, #f87171);
        }

        .type-temel::before {
            background: linear-gradient(90deg, #16a34a, #4ade80);
        }

        /* ── PROFİL FOTOĞRAFI ÇERÇEVESİ ── */
        .avatar-wrap {
            position: relative;
            width: 88px;
            height: 88px;
            margin: 0 auto;
        }

            .avatar-wrap img {
                width: 100%;
                height: 100%;
                border-radius: 50%;
                object-fit: cover;
                border: 3px solid white;
                box-shadow: 0 4px 16px rgba(0,0,0,0.1);
            }

        .avatar-ring {
            position: absolute;
            inset: -4px;
            border-radius: 50%;
            border: 2px solid transparent;
            transition: border-color 0.25s;
        }

        .type-dahili:hover .avatar-ring {
            border-color: #bfdbfe;
        }

        .type-cerrahi:hover .avatar-ring {
            border-color: #fecaca;
        }

        .type-temel:hover .avatar-ring {
            border-color: #bbf7d0;
        }

        /* ── UNVAN ETİKETİ ── */
        .unvan-badge {
            display: inline-block;
            font-size: 0.6rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            padding: 2px 8px;
            border-radius: 99px;
        }

        /* ── ÖZGEÇMİŞ BUTONU ── */
        .cv-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            width: 100%;
            padding: 0.6rem;
            border-radius: 12px;
            font-size: 0.72rem;
            font-weight: 800;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            background: #f8fafc;
            color: #64748b;
            border: 1px solid #f1f5f9;
            cursor: pointer;
            transition: all 0.2s;
        }

        .type-dahili:hover .cv-btn {
            background: #eff6ff;
            color: #2563eb;
            border-color: #bfdbfe;
        }

        .type-cerrahi:hover .cv-btn {
            background: #fef2f2;
            color: #ef4444;
            border-color: #fecaca;
        }

        .type-temel:hover .cv-btn {
            background: #f0fdf4;
            color: #16a34a;
            border-color: #bbf7d0;
        }

        /* ── BÖLÜM AYIRICI ÇİZGİSİ ── */
        .section-bar {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .section-bar-line {
            flex: 1;
            height: 1px;
            background: linear-gradient(to right, #e2e8f0, transparent);
        }

        /* ── ROZETLER ── */
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 0.6rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            padding: 3px 8px;
            border-radius: 99px;
        }

        .badge-blue {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .badge-red {
            background: #fee2e2;
            color: #b91c1c;
        }

        .badge-green {
            background: #dcfce7;
            color: #15803d;
        }

        /* ── SAYI ETİKETİ ── */
        .count-pill {
            font-size: 0.6rem;
            font-weight: 800;
            padding: 2px 7px;
            border-radius: 99px;
            background: #f1f5f9;
            color: #64748b;
            margin-left: auto;
        }

        /* ── MOBİL YAN MENÜ ── */
        #mob-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(15,23,42,0.4);
            z-index: 40;
            backdrop-filter: blur(2px);
        }

            #mob-overlay.open {
                display: block;
            }

        #mob-sidebar {
            position: fixed;
            top: 0;
            left: -100%;
            width: 300px;
            height: 100%;
            background: white;
            z-index: 50;
            transition: left 0.3s ease;
            overflow-y: auto;
            padding: 1.5rem 1rem;
            box-shadow: 8px 0 30px rgba(0,0,0,0.1);
        }

            #mob-sidebar.open {
                left: 0;
            }

        /* ── GİZLEME ── */
        .hidden-section {
            display: none !important;
        }

        #empty-state {
            display: none;
        }

            #empty-state.show {
                display: flex;
            }
    </style>

    <script>
        const mobToggle  = document.getElementById('mob-toggle');
        const mobSidebar = document.getElementById('mob-sidebar');
        const mobOverlay = document.getElementById('mob-overlay');
        const mobClose   = document.getElementById('mob-close');

        if(mobToggle) mobToggle.addEventListener('click', openMob);
        if(mobClose) mobClose.addEventListener('click', closeMob);
        if(mobOverlay) mobOverlay.addEventListener('click', closeMob);

        function openMob()  {
            mobSidebar.classList.add('open');
            mobOverlay.classList.add('open');
            document.body.style.overflow = 'hidden';
        }
        function closeMob() {
            mobSidebar.classList.remove('open');
            mobOverlay.classList.remove('open');
            document.body.style.overflow = '';
        }

        const typeConfig = {
            dahili:  { color: 'active-blue',  label: 'Dahili'  },
            cerrahi: { color: 'active-red',   label: 'Cerrahi' },
            temel:   { color: 'active-green', label: 'Temel'   },
        };

        function filterType(type) {
            document.querySelectorAll('.dept-section').forEach(s => s.classList.add('hidden-section'));
            document.getElementById('section-' + type).classList.remove('hidden-section');

            document.querySelectorAll('#btn-dahili, #btn-cerrahi, #btn-temel').forEach(b => b.className = 'nav-btn');
            const activeBtn = document.getElementById('btn-' + type);
            if (activeBtn) activeBtn.classList.add(typeConfig[type].color);

            ['dahili','cerrahi','temel'].forEach(t => {
                const mb = document.getElementById('mob-btn-' + t);
                if (mb) mb.className = 'nav-btn';
            });
            const mobActiveBtn = document.getElementById('mob-btn-' + type);
            if (mobActiveBtn) mobActiveBtn.classList.add(typeConfig[type].color);

            document.getElementById('mainSearch').value = '';
            document.getElementById('mainSearchMob').value = '';
            document.querySelectorAll('.doctor-card').forEach(c => c.style.display = '');
            document.getElementById('empty-state').classList.remove('show');
        }

        function runSearch(term) {
            if (!term) {
                document.querySelectorAll('.doctor-card').forEach(c => c.style.display = '');
                document.getElementById('empty-state').classList.remove('show');
                return;
            }

            document.querySelectorAll('.dept-section').forEach(s => s.classList.remove('hidden-section'));
            document.querySelectorAll('#btn-dahili, #btn-cerrahi, #btn-temel, #mob-btn-dahili, #mob-btn-cerrahi, #mob-btn-temel').forEach(b => b.className = 'nav-btn');

            let anyVisible = false;

            document.querySelectorAll('.doctor-card').forEach(card => {
                const name = (card.getAttribute('data-name') || '').toLowerCase();
                const dept = (card.getAttribute('data-dept') || '').toLowerCase();

                const match = name.includes(term) || dept.includes(term);
                card.style.display = match ? '' : 'none';
                if (match) anyVisible = true;
            });

            document.querySelectorAll('.dept-section').forEach(section => {
                const visible = [...section.querySelectorAll('.doctor-card')].some(c => c.style.display !== 'none');
                section.style.display = visible ? '' : 'none';
            });

            document.getElementById('empty-state').classList.toggle('show', !anyVisible);
        }

        document.getElementById('mainSearch')?.addEventListener('input', e => runSearch(e.target.value.toLowerCase().trim()));
        document.getElementById('mainSearchMob')?.addEventListener('input', e => runSearch(e.target.value.toLowerCase().trim()));
    </script>
}

<div id="mob-overlay"></div>
<div id="mob-sidebar">
    <div class="flex items-center justify-between mb-5">
        <span class="font-black text-slate-800 text-sm uppercase tracking-wider">Filtrele</span>
        <button id="mob-close" class="w-8 h-8 flex items-center justify-center rounded-xl bg-slate-100 text-slate-500 hover:bg-slate-200 transition">
            <i class="fa-solid fa-xmark text-sm"></i>
        </button>
    </div>
    <div class="relative mb-4">
        <i class="fa-solid fa-magnifying-glass absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 text-xs"></i>
        <input type="text" id="mainSearchMob" placeholder="Doktor veya uzmanlık..."
               class="search-input w-full pl-9 pr-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm font-medium text-slate-700 transition">
    </div>
    <p class="text-[9px] font-black text-slate-400 uppercase tracking-[0.15em] px-2 py-1">Kategoriler</p>
    <div class="space-y-1">
        <button onclick="filterType('dahili'); closeMob();" class="nav-btn active-blue" id="mob-btn-dahili">
            <span class="w-2.5 h-2.5 rounded-full bg-blue-500 flex-shrink-0"></span>
            <span>Dahili Bilimler</span><span class="count-pill">@dahiliCount</span>
        </button>
        <button onclick="filterType('cerrahi'); closeMob();" class="nav-btn" id="mob-btn-cerrahi">
            <span class="w-2.5 h-2.5 rounded-full bg-red-500 flex-shrink-0"></span>
            <span>Cerrahi Bilimler</span><span class="count-pill">@cerrahiCount</span>
        </button>
        <button onclick="filterType('temel'); closeMob();" class="nav-btn" id="mob-btn-temel">
            <span class="w-2.5 h-2.5 rounded-full bg-green-500 flex-shrink-0"></span>
            <span>Temel Bilimler</span><span class="count-pill">@temelCount</span>
        </button>
    </div>
</div>

<div class="max-w-[1400px] mx-auto px-4 sm:px-6 py-8 flex flex-col lg:flex-row gap-7 mt-24">
    <aside class="hidden lg:block w-72 flex-shrink-0">
        <div class="sidebar-sticky bg-white rounded-[1.75rem] p-4 border border-slate-100" style="box-shadow: 0 4px 24px rgba(0,0,0,0.05);">
            <div class="flex items-center gap-3 mb-5 px-1">
                <div class="w-10 h-10 bg-gradient-to-br from-blue-600 to-blue-700 rounded-xl flex items-center justify-center shadow-md shadow-blue-200">
                    <i class="fa-solid fa-user-doctor text-white text-sm"></i>
                </div>
                <div>
                    <p class="font-black text-slate-800 text-sm leading-none">Akademik Kadro</p>
                    <p class="text-[10px] text-slate-400 font-bold mt-0.5">@totalCount uzman hekim</p>
                </div>
            </div>

            <div class="relative mb-4">
                <i class="fa-solid fa-magnifying-glass absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 text-xs"></i>
                <input type="text" id="mainSearch" placeholder="Doktor veya uzmanlık..."
                       class="search-input w-full pl-9 pr-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm font-medium text-slate-700 transition">
            </div>

            <div class="space-y-1 mb-5">
                <p class="text-[9px] font-black text-slate-400 uppercase tracking-[0.15em] px-2 py-1">Kategoriler</p>
                <button onclick="filterType('dahili')" class="nav-btn active-blue" id="btn-dahili">
                    <span class="w-2.5 h-2.5 rounded-full bg-blue-500 flex-shrink-0"></span>
                    <span>Dahili Bilimler</span>
                    <span class="count-pill">@dahiliCount</span>
                </button>
                <button onclick="filterType('cerrahi')" class="nav-btn" id="btn-cerrahi">
                    <span class="w-2.5 h-2.5 rounded-full bg-red-500 flex-shrink-0"></span>
                    <span>Cerrahi Bilimler</span>
                    <span class="count-pill">@cerrahiCount</span>
                </button>
                <button onclick="filterType('temel')" class="nav-btn" id="btn-temel">
                    <span class="w-2.5 h-2.5 rounded-full bg-green-500 flex-shrink-0"></span>
                    <span>Temel Bilimler</span>
                    <span class="count-pill">@temelCount</span>
                </button>
            </div>
        </div>
    </aside>

    <main class="flex-1 min-w-0">
        <div class="bg-gradient-to-r from-blue-600 to-blue-800 rounded-[1.75rem] p-6 sm:p-8 mb-7 relative overflow-hidden" style="box-shadow: 0 12px 40px rgba(37,99,235,0.25);">
            <div class="absolute top-0 right-0 w-48 h-48 bg-white/5 rounded-full translate-x-16 -translate-y-16"></div>
            <div class="absolute bottom-0 right-16 w-28 h-28 bg-white/5 rounded-full translate-y-10"></div>
            <div class="relative z-10 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                <div>
                    <p class="text-blue-300 text-[10px] font-black tracking-[0.2em] uppercase mb-1">Gazi Üniversitesi Hastanesi</p>
                    <h2 class="text-white text-2xl sm:text-3xl font-black leading-tight tracking-tight">Akademik Kadromuz</h2>
                    <p class="text-blue-200/80 text-sm font-medium mt-1.5">@totalCount uzman hekim · 3 kategori · Akademik ve klinik uzmanlık</p>
                </div>
                <div class="flex gap-5 flex-shrink-0">
                    <div class="text-center">
                        <p class="text-white text-2xl font-black">@totalCount</p>
                        <p class="text-blue-300 text-[9px] font-black uppercase tracking-widest">Uzman</p>
                    </div>
                    <div class="w-px bg-white/20"></div>
                    <div class="text-center">
                        <p class="text-white text-2xl font-black">@profCount</p>
                        <p class="text-blue-300 text-[9px] font-black uppercase tracking-widest">Profesör</p>
                    </div>
                </div>
            </div>
        </div>

        <div id="empty-state" class="flex-col items-center justify-center py-20 text-center bg-white rounded-[1.75rem] border border-slate-100 mb-7" style="box-shadow: 0 4px 24px rgba(0,0,0,0.04);">
            <div class="w-16 h-16 bg-slate-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <i class="fa-solid fa-user-doctor text-slate-400 text-xl"></i>
            </div>
            <p class="font-black text-slate-700 text-lg">Sonuç bulunamadı</p>
            <p class="text-slate-400 text-sm mt-1">Farklı bir isim veya uzmanlık alanı deneyin.</p>
        </div>

        <div id="section-dahili" class="dept-section mb-10">
            <div class="section-bar">
                <div class="flex items-center gap-3">
                    <span class="badge badge-blue"><i class="fa-solid fa-circle-dot"></i> Dahili</span>
                    <h2 class="text-lg font-black text-slate-800">Dahili Tıp Bilimleri</h2>
                </div>
                <div class="section-bar-line"></div>
                <span class="text-[10px] font-black text-slate-400 uppercase tracking-wider flex-shrink-0">@dahiliCount uzman</span>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
                @foreach (var doktor in Model.Where(d => d.Bolum != null && d.Bolum.Kategori == "Dahili" && d.IsActive))
                {
                    <div class="doctor-card type-dahili" data-name="@doktor.Ad @doktor.Soyad" data-dept="@(doktor.Bolum?.Ad ?? doktor.UzmanlikAlani)">
                        <div class="p-5 text-center">
                            <div class="avatar-wrap mb-4">
                                <img src="@(string.IsNullOrEmpty(doktor.FotografUrl) ? $"https://ui-avatars.com/api/?name={doktor.Ad}+{doktor.Soyad}&background=dbeafe&color=1d4ed8&bold=true&size=128" : doktor.FotografUrl)" alt="@doktor.Ad @doktor.Soyad">
                                <div class="avatar-ring"></div>
                            </div>
                            <span class="unvan-badge bg-blue-50 text-blue-700 mb-1">@doktor.Unvan</span>
                            <h3 class="text-sm font-black text-slate-800 mt-1 leading-snug">@doktor.Ad @doktor.Soyad</h3>
                            <p class="text-slate-500 text-xs font-semibold mt-1">@(doktor.Bolum?.Ad ?? doktor.UzmanlikAlani)</p>
                            <button class="cv-btn mt-3"><i class="fa-solid fa-id-card text-[10px]"></i> Özgeçmişi İncele</button>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div id="section-cerrahi" class="dept-section hidden-section mb-10">
            <div class="section-bar">
                <div class="flex items-center gap-3">
                    <span class="badge badge-red"><i class="fa-solid fa-circle-dot"></i> Cerrahi</span>
                    <h2 class="text-lg font-black text-slate-800">Cerrahi Tıp Bilimleri</h2>
                </div>
                <div class="section-bar-line"></div>
                <span class="text-[10px] font-black text-slate-400 uppercase tracking-wider flex-shrink-0">@cerrahiCount uzman</span>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
                @foreach (var doktor in Model.Where(d => d.Bolum != null && d.Bolum.Kategori == "Cerrahi" && d.IsActive))
                {
                    <div class="doctor-card type-cerrahi" data-name="@doktor.Ad @doktor.Soyad" data-dept="@(doktor.Bolum?.Ad ?? doktor.UzmanlikAlani)">
                        <div class="p-5 text-center">
                            <div class="avatar-wrap mb-4">
                                <img src="@(string.IsNullOrEmpty(doktor.FotografUrl) ? $"https://ui-avatars.com/api/?name={doktor.Ad}+{doktor.Soyad}&background=fee2e2&color=b91c1c&bold=true&size=128" : doktor.FotografUrl)" alt="@doktor.Ad @doktor.Soyad">
                                <div class="avatar-ring"></div>
                            </div>
                            <span class="unvan-badge bg-red-50 text-red-700 mb-1">@doktor.Unvan</span>
                            <h3 class="text-sm font-black text-slate-800 mt-1 leading-snug">@doktor.Ad @doktor.Soyad</h3>
                            <p class="text-slate-500 text-xs font-semibold mt-1">@(doktor.Bolum?.Ad ?? doktor.UzmanlikAlani)</p>
                            <button class="cv-btn mt-3"><i class="fa-solid fa-id-card text-[10px]"></i> Özgeçmişi İncele</button>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div id="section-temel" class="dept-section hidden-section mb-10">
            <div class="section-bar">
                <div class="flex items-center gap-3">
                    <span class="badge badge-green"><i class="fa-solid fa-circle-dot"></i> Temel</span>
                    <h2 class="text-lg font-black text-slate-800">Temel Tıp Bilimleri</h2>
                </div>
                <div class="section-bar-line"></div>
                <span class="text-[10px] font-black text-slate-400 uppercase tracking-wider flex-shrink-0">@temelCount uzman</span>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
                @foreach (var doktor in Model.Where(d => d.Bolum != null && d.Bolum.Kategori == "Temel" && d.IsActive))
                {
                    <div class="doctor-card type-temel" data-name="@doktor.Ad @doktor.Soyad" data-dept="@(doktor.Bolum?.Ad ?? doktor.UzmanlikAlani)">
                        <div class="p-5 text-center">
                            <div class="avatar-wrap mb-4">
                                <img src="@(string.IsNullOrEmpty(doktor.FotografUrl) ? $"https://ui-avatars.com/api/?name={doktor.Ad}+{doktor.Soyad}&background=dcfce7&color=15803d&bold=true&size=128" : doktor.FotografUrl)" alt="@doktor.Ad @doktor.Soyad">
                                <div class="avatar-ring"></div>
                            </div>
                            <span class="unvan-badge bg-green-50 text-green-700 mb-1">@doktor.Unvan</span>
                            <h3 class="text-sm font-black text-slate-800 mt-1 leading-snug">@doktor.Ad @doktor.Soyad</h3>
                            <p class="text-slate-500 text-xs font-semibold mt-1">@(doktor.Bolum?.Ad ?? doktor.UzmanlikAlani)</p>
                            <button class="cv-btn mt-3"><i class="fa-solid fa-id-card text-[10px]"></i> Özgeçmişi İncele</button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </main>
</div>