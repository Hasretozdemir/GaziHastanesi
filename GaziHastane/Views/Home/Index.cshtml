<section class="max-w-[96%] 2xl:max-w-[1600px] mx-auto px-4 sm:px-6 py-12" style="background: #f8fafc;">
    <div class="flex justify-between items-end mb-8">
        <div>
            <p class="sec-label mb-1" style="color: #ea580c;">KONGRE & SEMPOZYUM</p>
            <h2 class="text-2xl sm:text-3xl font-black text-slate-900 leading-tight">Yaklaşan Etkinlikler</h2>
        </div>
        <a href="/Etkinlikler" class="text-sm font-bold text-orange-600 hover:text-orange-800 transition flex items-center gap-2">Tümü <i class="fa-solid fa-arrow-right"></i></a>
    </div>

    <div class="grid lg:grid-cols-2 gap-6">
        @if (Model.Etkinlikler != null && Model.Etkinlikler.Any())
        {
            @foreach (var etkinlik in Model.Etkinlikler)
            {
                <button type="button" onclick="openEtkinlikModal(@etkinlik.Id)" class="activity-card group text-decoration-none text-left w-full">
                    <div class="activity-date-box">
                        <span class="text-2xl font-black">@etkinlik.Tarih.ToString("dd")</span>
                        <span class="text-[10px] font-bold uppercase">@etkinlik.Tarih.ToString("MMM")</span>
                    </div>
                    <div>
                        <div class="flex items-center gap-3 mb-1">
                            <span class="text-[10px] font-bold bg-orange-100 text-orange-700 px-2 py-0.5 rounded uppercase">@etkinlik.EtkinlikTipi</span>
                        </div>
                        <h3 class="text-base font-bold text-slate-800 group-hover:text-blue-600 transition">@etkinlik.Baslik</h3>
                        <p class="text-sm text-slate-500"><i class="fa-solid fa-location-dot mr-1"></i> @etkinlik.Konum</p>
                    </div>
                </button>
            }
        }
    </div>
</section>

