@* RAZOR KOD BLOĞU: Sunucu tarafında (C#) çalışan kodlar. *@
@* Bu blok, sayfa render edilmeden önce sunucu tarafından işlenir. *@
@{
    // ViewData koleksiyonuna "Title" anahtarı ile bir değer atanıyor.
    // Bu değer, _Layout.cshtml dosyasındaki <title> etiketi içinde kullanılır.
    // Sayfanın tarayıcı sekmesinde "Gazi Sağlık | Ana Sayfa" yazmasını sağlar.
    ViewData["Title"] = "Gazi Sağlık | Ana Sayfa";
}

@* 'Scripts' adında bir bölüm (section) tanımlanıyor. *@
@* Bu bölüm, Layout dosyasında @RenderSection("Scripts", required: false) olan yere yerleştirilir. *@
@section Scripts {
    <!-- SAYFAYA ÖZEL STİLLER (CSS) -->
    <!-- Bu sayfaya özgü CSS kuralları burada tanımlanıyor. -->
    <style>
        /* ── HERO (KARŞILAMA) ALANI ARKA PLANI ── */
        /* Sayfanın en üstünde yer alan, geniş ve mavi gradyanlı karşılama alanı */
        .hero-bg {
            /* Arka plan rengi olarak 135 derecelik bir açıyla mavi tonlarında geçiş (gradient) kullanılıyor. */
            background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 40%, #1d4ed8 75%, #2563eb 100%);
            /* Position: relative, içindeki absolute (mutlak) konumlandırılmış öğeler (hero-orb) için referans noktası oluşturur. */
            position: relative;
            /* Overflow: hidden, bu alandan taşan içeriklerin (örneğin süsleme dairelerinin taşan kısımlarının) gizlenmesini sağlar. */
            overflow: hidden;
        }

        /* Hero alanındaki dekoratif, yarı saydam yuvarlak şekiller */
        .hero-orb {
            /* Position: absolute, bu öğeyi .hero-bg kapsayıcısına göre serbestçe konumlandırmayı sağlar. */
            position: absolute;
            /* Border-radius: 50%, kare olan div öğesini tam bir daireye dönüştürür. */
            border-radius: 50%;
            /* Arka plan olarak merkezden dışa doğru yayılan (radial) bir geçiş kullanılır. */
            /* Ortada yarı saydam mavi, dışta ise tamamen şeffaf (transparent) bir renk vardır. */
            background: radial-gradient(circle, rgba(96,165,250,0.18), transparent 70%);
        }

        /* ── HIZLI ERİŞİM ALANI (Modern & Profesyonel) ── */
        /* Sayfanın ortasında yer alan, yatay kaydırılabilir butonların olduğu beyaz kart */
        .qa-wrapper {
            /* Diğer öğelerin üzerine çıkabilmesi için z-index kullanacağız, bu yüzden position: relative gerekiyor. */
            position: relative;
            /* Genişliği kapsayıcısının %100'ü kadar olsun. */
            width: 100%;
            /* Arka plan rengi beyaz. */
            background: #ffffff;
            /* Köşeleri 2rem (yaklaşık 32px) kadar yuvarlatır. */
            border-radius: 2rem;
            /* İç boşluk: Üst-alt 2rem, sağ-sol 1.5rem. */
            padding: 2rem 1.5rem;
            /* Kutu gölgesi: Elemana derinlik hissi katar. */
            box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.05), 0 0 15px rgba(37, 99, 235, 0.03);
            /* İnce bir kenarlık ekler. */
            border: 1px solid rgba(226, 232, 240, 0.8);
            /* Z-index: 20 ile diğer standart elementlerin üzerinde görünmesi sağlanır. */
            z-index: 20;
            /* Margin-top: -3rem ile bu kutu, üstündeki Hero alanının 3rem kadar üzerine biner (taşar). */
            margin-top: -3rem;
        }

        /* Hızlı erişim kartının başlık bölümü */
        .qa-header {
            /* Flexbox düzeni kullanarak içindeki öğeleri yan yana dizer. */
            display: flex;
            /* Dikey eksende ortalar. */
            align-items: center;
            /* Yatay eksende, öğeler arasına mümkün olduğunca çok boşluk bırakarak onları kenarlara iter. */
            justify-content: space-between;
            /* Alt tarafa 1.5rem boşluk bırakır. */
            margin-bottom: 1.5rem;
            /* Sol tarafa 0.5rem iç boşluk ekler. */
            padding-left: 0.5rem;
        }

        /* Başlık metni stili */
        .qa-title {
            /* Yazı boyutu 11px. */
            font-size: 11px;
            /* Yazı kalınlığı çok kalın (900). */
            font-weight: 900;
            /* Tüm harfleri büyük harfe çevirir. */
            text-transform: uppercase;
            /* Harfler arası boşluğu 2px açar. */
            letter-spacing: 2px;
            /* Yazı rengi gri tonu. */
            color: #64748b;
            /* İkon ve metni hizalamak için flexbox kullanılır. */
            display: flex;
            /* Dikeyde ortalar. */
            align-items: center;
            /* İkon ile yazı arasında 8px boşluk bırakır. */
            gap: 8px;
        }

            /* Başlık ikonunun rengi */
            /* .qa-title içindeki i (ikon) etiketlerini hedefler. */
            .qa-title i {
                /* İkon rengi mavi. */
                color: #2563eb; 
            }

        /* Kullanıcıya yatay kaydırabileceğini söyleyen ipucu etiketi */
        .qa-scroll-hint {
            /* Yazı boyutu 10px. */
            font-size: 10px;
            /* Yazı kalınlığı 700 (bold). */
            font-weight: 700;
            /* Yazı rengi açık gri. */
            color: #94a3b8;
            /* Arka plan rengi çok açık bir gri. */
            background: #f1f5f9;
            /* İç boşluk (padding): üst-alt 4px, sağ-sol 10px. */
            padding: 4px 10px;
            /* Köşeleri tamamen yuvarlayarak hap (pill) şekli verir. */
            border-radius: 50px;
        }

        /* Butonların yatay olarak dizildiği kapsayıcı (Scroll Container) */
        .qa-container {
            /* Flexbox ile öğeleri yan yana dizer. */
            display: flex;
            /* Yatay eksende taşma olursa kaydırma çubuğu (scroll) çıkarır. */
            overflow-x: auto;
            /* Öğeler (butonlar) arasına 1.25rem boşluk koyar. */
            gap: 1.25rem;
            /* Konteynerın içine 0.5rem boşluk ekler. */
            padding: 0.5rem;
            /* Kaydırma işleminin yumuşak (smooth) olmasını sağlar. */
            scroll-behavior: smooth;
            /* Internet Explorer ve Edge için scrollbar'ı gizler. */
            -ms-overflow-style: none;
            /* Firefox için scrollbar'ı gizler. */
            scrollbar-width: none;
            /* Mouse imlecini "tutma eli" (grab) şeklinde gösterir, sürüklenebileceğini ima eder. */
            cursor: grab;
        }

            /* Webkit tarayıcılar (Chrome, Safari, Opera) için scrollbar gizleme */
            .qa-container::-webkit-scrollbar {
                /* Görünürlüğü kapatır. */
                display: none;
            }

            /* Mouse ile tıklanıp sürüklendiğinde imleç */
            .qa-container:active {
                /* İmleci "tutan el" (grabbing - sıkılmış el) yapar. */
                cursor: grabbing;
            }

        /* Hızlı Erişim Öğesi (Tekil Buton) */
        .qa-item {
            /* flex-grow: 0 (büyümesin), flex-shrink: 0 (küçülmesin), flex-basis: auto. Boyutunu korur. */
            flex: 0 0 auto;
            /* Genişliği sabit 100px. */
            width: 100px;
            /* İçerikleri (ikon ve yazı) alt alta dizer. */
            display: flex;
            /* Yönü dikey (column) yapar. */
            flex-direction: column;
            /* Yatayda ortalar. */
            align-items: center;
            /* Link olduğu için altındaki varsayılan çizgiyi kaldırır. */
            text-decoration: none;
            /* Değişikliklerin 0.3 saniyede animasyonlu olmasını sağlar. */
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            /* Pozisyonlama için referans noktası. */
            position: relative;
        }

        /* İkonun bulunduğu kutu */
        .qa-icon-wrapper {
            /* Genişlik 64px. */
            width: 64px;
            /* Yükseklik 64px. */
            height: 64px;
            /* Köşeleri 20px yuvarlatır (Squircle şekli). */
            border-radius: 20px;
            /* İçindeki ikonu ortalamak için flexbox. */
            display: flex;
            /* Dikeyde ortala. */
            align-items: center;
            /* Yatayda ortala. */
            justify-content: center;
            /* İkon boyutu 1.4rem. */
            font-size: 1.4rem;
            /* Arka plan rengi çok açık gri/beyazımsı. */
            background: #f8fafc;
            /* İkon rengi mavi. */
            color: #3b82f6;
            /* Altındaki metinle arasına 12px boşluk koyar. */
            margin-bottom: 12px;
            /* Geçiş efektleri için süre ayarı. */
            transition: all 0.3s ease;
            /* Z-index ve relative pozisyon ile katman sıralamasını ayarlar. */
            position: relative;
            z-index: 2;
            /* Kenarlık 2px kalınlığında ve şeffaf (başlangıçta görünmez). */
            border: 2px solid transparent;
        }

            /* İkonların arkasındaki parlama efekti (pseudo-element) */
            .qa-icon-wrapper::after {
                /* İçerik boş string (gerekli). */
                content: '';
                /* Ana elementin üzerini tam kaplaması için absolute pozisyon. */
                position: absolute;
                /* Genişlik %100. */
                width: 100%;
                /* Yükseklik %100. */
                height: 100%;
                /* Arka plan rengini ebeveynden miras alır. */
                background: inherit;
                /* Bulanıklık efekti (blur) verir, parlama gibi görünür. */
                filter: blur(12px);
                /* Başlangıçta opaklık 0 (görünmez). */
                opacity: 0;
                /* İkonun arkasında kalması için z-index -1. */
                z-index: -1;
                /* Geçiş efekti süresi. */
                transition: 0.3s ease;
            }

        /* Buton altındaki etiket metni */
        .qa-label {
            /* Yazı boyutu 10px. */
            font-size: 10px;
            /* Yazı kalınlığı 800 (bold). */
            font-weight: 800;
            /* Yazı rengi koyu gri. */
            color: #475569;
            /* Metni ortalar. */
            text-align: center;
            /* Satır yüksekliği 1.3. */
            line-height: 1.3;
            /* Renk değişiminde geçiş efekti. */
            transition: all 0.3s ease;
        }

        /* Hover Efektleri (Mouse öğe üzerine gelince çalışır) */
        .qa-item:hover {
            /* Öğeyi 8px yukarı kaydırır (zıplama efekti). */
            transform: translateY(-8px);
        }

            /* Mouse üzerine gelince ikon kutusunun stilini değiştir. */
            .qa-item:hover .qa-icon-wrapper {
                /* Arka planı koyu mavi yap. */
                background: #2563eb;
                /* İkon rengini beyaz yap. */
                color: white;
                /* Kenarlığı yarı saydam beyaz yap. */
                border-color: rgba(255, 255, 255, 0.5);
                /* Mavi renkte bir gölge ekle (parlama hissi). */
                box-shadow: 0 10px 25px rgba(37, 99, 235, 0.3);
            }

            /* Mouse üzerine gelince etiket rengini değiştir. */
            .qa-item:hover .qa-label {
                /* Yazı rengini mavi yap. */
                color: #2563eb;
            }

        /* Öne Çıkan (Featured) Butonlar İçin Özel Stil */
        /* class="qa-item featured" olan elementlerin içindeki ikon kutusu. */
        .qa-item.featured .qa-icon-wrapper {
            /* Arka plan açık mavi. */
            background: #eff6ff;
            /* Kenarlık daha belirgin mavi. */
            border-color: #bfdbfe;
        }

        /* ── SOL VE SAĞ SOLMA EFEKTİ (FADE) ── */
        /* Listenin kenarlarında içerik olduğunu hissettiren beyaz gölgeler */
        .qa-fade-left, .qa-fade-right {
            /* Kapsayıcıya göre konumlandır. */
            position: absolute;
            /* Üstten 0. */
            top: 0;
            /* Alttan 0 (tam boy). */
            bottom: 0;
            /* Genişlik 40px. */
            width: 40px;
            /* Diğer içeriklerin üzerinde görünsün. */
            z-index: 5;
            /* Tıklamaları engelle (arkadaki butona tıklanabilsin). */
            pointer-events: none;
        }

        /* Sol taraftaki beyaz geçiş */
        .qa-fade-left {
            /* Sola yasla. */
            left: 0;
            /* Soldan sağa beyazdan şeffafa geçiş. */
            background: linear-gradient(to right, white, transparent);
            /* Köşeleri yuvarla. */
            border-radius: 2rem 0 0 2rem;
        }

        /* Sağ taraftaki beyaz geçiş */
        .qa-fade-right {
            /* Sağa yasla. */
            right: 0;
            /* Sağdan sola beyazdan şeffafa geçiş. */
            background: linear-gradient(to left, white, transparent);
            /* Köşeleri yuvarla. */
            border-radius: 0 2rem 2rem 0;
        }

        /* ── BRANŞ KARTLARI TASARIMI ── */
        .dept-card {
            /* Arka plan beyaz. */
            background: white;
            /* Köşeler 1.5rem yuvarlatılmış. */
            border-radius: 1.5rem;
            /* İnce gri kenarlık. */
            border: 1px solid #f1f5f9;
            /* İçerik taşarsa (örneğin resim) gizle (köşelerin yuvarlak kalması için). */
            overflow: hidden;
            /* Tüm değişimler 0.3sn sürsün. */
            transition: all 0.3s;
        }
            /* Kart hover efekti: Mouse üzerine gelince */
            .dept-card:hover {
                /* Kartı 5px yukarı kaldır. */
                transform: translateY(-5px);
                /* Altına gölge ekle. */
                box-shadow: 0 20px 50px rgba(0,0,0,0.1);
            }
                /* Kartın üzerine gelindiğinde içindeki resme (img) etki et. */
                .dept-card:hover .dept-img {
                    /* Resmi %6 oranında büyüt (Zoom efekti). */
                    transform: scale(1.06);
                }

        /* Bölüm resmi geçiş efekti */
        .dept-img {
            /* Transform işlemi 0.5 saniye sürsün. */
            transition: transform 0.5s;
        }

        /* Bölüm ana başlık etiketi (küçük üst yazı) */
        .sec-label {
            /* Yazı boyutu çok küçük (0.6rem). */
            font-size: 0.6rem;
            /* Yazı çok kalın. */
            font-weight: 900;
            /* Büyük harf. */
            text-transform: uppercase;
            /* Harf aralığı geniş. */
            letter-spacing: 0.22em;
            /* Renk mavi. */
            color: #2563eb;
        }

        /* ── Sağa sola gidip gelme (Bounce) Animasyonu ── */
        /* Keyframes: Animasyonun karelerini tanımlar. */
        @@keyframes bounce-x {
            /* Başlangıç ve bitişte (0% ve 100%) olduğu yerde dursun. */
            0%, 100% {
                transform: translateX(0);
            }
            /* Ortada (50%) 4px sağa kaysın. */
            50% {
                transform: translateX(4px);
            }
        }

        /* Animasyonu uygulayan sınıf */
        .bounce-x {
            /* bounce-x animasyonunu 1.2 saniyede, sonsuz döngüde çalıştır. */
            animation: bounce-x 1.2s ease infinite;
        }
    </style>

    <!-- JS: SÜRÜKLE VE KAYDIR (DRAG & SCROLL) -->
    <!-- Hızlı erişim menüsünü mouse ile tutup sürükleyebilmek için gerekli JavaScript kodları -->
    <script>
        // Sayfa tamamen yüklendiğinde çalışacak kod bloğu.
        document.addEventListener('DOMContentLoaded', function () {
            // .qa-container sınıfına sahip elementi (kaydırılacak alan) seç.
            const slider = document.querySelector('.qa-container');
            // Mouse'un basılı olup olmadığını tutan değişken.
            let isDown = false;
            // Tıklama başlangıç X koordinatı.
            let startX;
            // Tıklama anındaki kaydırma pozisyonu.
            let scrollLeft;

            // Mouse tuşuna basıldığında tetiklenir.
            slider.addEventListener('mousedown', (e) => {
                isDown = true; // Basılı durumda işaretle.
                slider.style.cursor = 'grabbing'; // İmleci tutan el yap.
                // Mouse'un sayfadaki X konumundan slider'ın sol boşluğunu çıkararak slider içindeki X'i bul.
                startX = e.pageX - slider.offsetLeft;
                // Şu anki kaydırma miktarını kaydet.
                scrollLeft = slider.scrollLeft;
            });

            // Mouse slider alanından dışarı çıktığında tetiklenir.
            slider.addEventListener('mouseleave', () => {
                isDown = false; // Basılı durumunu iptal et.
                slider.style.cursor = 'grab'; // İmleci normal tutma eli yap.
            });

            // Mouse tuşu bırakıldığında tetiklenir.
            slider.addEventListener('mouseup', () => {
                isDown = false; // Basılı durumunu iptal et.
                slider.style.cursor = 'grab'; // İmleci normal tutma eli yap.
            });

            // Mouse hareket ettirildiğinde tetiklenir (en önemli kısım).
            slider.addEventListener('mousemove', (e) => {
                if (!isDown) return; // Eğer mouse basılı değilse fonksiyondan çık.
                e.preventDefault(); // Varsayılan seçim vb. davranışları engelle.
                // Yeni X koordinatını al.
                const x = e.pageX - slider.offsetLeft;
                // Ne kadar hareket edildiğini hesapla (hızlandırmak için 2 ile çarpılmış).
                const walk = (x - startX) * 2; 
                // Slider'ı hesaplanan miktar kadar kaydır.
                slider.scrollLeft = scrollLeft - walk;
            });
        });
    </script>
}

<!-- ÜST KISIM (HEADER/HERO SECTION) -->
<!-- Başlık alanı, hero-bg sınıfı ile arka planı alıyor, pt-16 ile üstten boşluk bırakıyor. -->
<header class="hero-bg pt-16">
    <!-- Arka plan dekoratif daireler (Biri sağ üstte, biri sol altta) -->
    <!-- Mutlak konumlandırılmış süslemeler. w-[..] ve h-[..] Tailwind benzeri utility sınıfları olabilir veya CSS'de tanımlıdır. -->
