                    </div>
                    <!-- Dikey Ayırıcı Çizgi -->
                    <div class="w-px bg-white/15"></div>
                    <!-- İstatistik 2 -->
                    <div>
                        <p class="text-white text-2xl font-black">850+</p>
                        <p class="text-blue-300 text-[9px] font-black uppercase tracking-widest">Uzman Hekim</p>
                    </div>
                    <!-- Dikey Ayırıcı Çizgi -->
