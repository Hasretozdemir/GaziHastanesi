@{
    ViewData["Title"] = "Gazi Sağlık | Ana Sayfa";
}

@section Scripts {
    <style>
        /* ── Hero Arka Plan ── */
        .hero-bg {
            background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 40%, #1d4ed8 75%, #2563eb 100%);
            position: relative;
            overflow: hidden;
        }

        .hero-orb {
            position: absolute;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(96,165,250,0.18), transparent 70%);
        }

        /* ── YENİ HIZLI ERİŞİM ALANI (Modern & Profesyonel) ── */
        .qa-wrapper {
            position: relative;
            width: 100%;
            background: #ffffff;
            border-radius: 2rem;
            padding: 2rem 1.5rem;
            box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.05), 0 0 15px rgba(37, 99, 235, 0.03);
            border: 1px solid rgba(226, 232, 240, 0.8);
            z-index: 20;
            margin-top: -3rem; /* Hero'nun içine hafifçe girmesi için */
        }

        .qa-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.5rem;
            padding-left: 0.5rem;
        }

        .qa-title {
            font-size: 11px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #64748b;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .qa-title i {
                color: #2563eb;
            }

        .qa-scroll-hint {
            font-size: 10px;
            font-weight: 700;
            color: #94a3b8;
            background: #f1f5f9;
            padding: 4px 10px;
            border-radius: 50px;
        }

        .qa-container {
            display: flex;
            overflow-x: auto;
            gap: 1.25rem;
            padding: 0.5rem;
            scroll-behavior: smooth;
            -ms-overflow-style: none;
            scrollbar-width: none;
            cursor: grab;
        }

            .qa-container::-webkit-scrollbar {
                display: none;
            }

            .qa-container:active {
                cursor: grabbing;
            }

        /* Hızlı Erişim Kartları */
        .qa-item {
            flex: 0 0 auto;
            width: 100px; /* Sabit Genişlik */
            display: flex;
            flex-direction: column;
            align-items: center;
            text-decoration: none;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
        }

        .qa-icon-wrapper {
            width: 64px;
            height: 64px;
            border-radius: 20px; /* Yumuşak kare görünüm (Squircle) */
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            background: #f8fafc;
            color: #3b82f6;
            margin-bottom: 12px;
            transition: all 0.3s ease;
            position: relative;
            z-index: 2;
            border: 2px solid transparent;
        }

            /* İkonların arkasındaki hafif parlama */
            .qa-icon-wrapper::after {
                content: '';
                position: absolute;
                width: 100%;
                height: 100%;
                background: inherit;
                filter: blur(12px);
                opacity: 0;
                z-index: -1;
                transition: 0.3s ease;
            }

        .qa-label {
            font-size: 10px;
            font-weight: 800;
            color: #475569;
            text-align: center;
            line-height: 1.3;
            transition: all 0.3s ease;
        }

        /* Hover Efektleri */
        .qa-item:hover {
            transform: translateY(-8px);
        }

            .qa-item:hover .qa-icon-wrapper {
                background: #2563eb;
                color: white;
                border-color: rgba(255, 255, 255, 0.5);
                box-shadow: 0 10px 25px rgba(37, 99, 235, 0.3);
            }

            .qa-item:hover .qa-label {
                color: #2563eb;
            }

        /* Vurgulu (Önemli) Butonlar İçin Özel Sınıf */
        .qa-item.featured .qa-icon-wrapper {
            background: #eff6ff;
            border-color: #bfdbfe;
        }

        /* ── Sol ve Sağ Solma Efekti ── */
        .qa-fade-left, .qa-fade-right {
            position: absolute;
            top: 0;
            bottom: 0;
            width: 40px;
            z-index: 5;
            pointer-events: none;
        }

        .qa-fade-left {
            left: 0;
            background: linear-gradient(to right, white, transparent);
            border-radius: 2rem 0 0 2rem;
        }

        .qa-fade-right {
            right: 0;
            background: linear-gradient(to left, white, transparent);
            border-radius: 0 2rem 2rem 0;
        }

        /* ── Diğer Kartlar (Dept/Stat) ── */
        .dept-card {
            background: white;
            border-radius: 1.5rem;
            border: 1px solid #f1f5f9;
            overflow: hidden;
            transition: all 0.3s;
        }

            .dept-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 20px 50px rgba(0,0,0,0.1);
            }

                .dept-card:hover .dept-img {
                    transform: scale(1.06);
                }

        .dept-img {
            transition: transform 0.5s;
        }

        .sec-label {
            font-size: 0.6rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.22em;
            color: #2563eb;
        }

        @@keyframes bounce-x {
            0%, 100% {
                transform: translateX(0);
            }

            50% {
                transform: translateX(4px);
            }
        }

        .bounce-x {
            animation: bounce-x 1.2s ease infinite;
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const slider = document.querySelector('.qa-container');
            let isDown = false;
            let startX;
            let scrollLeft;

            slider.addEventListener('mousedown', (e) => {
                isDown = true;
                slider.style.cursor = 'grabbing';
                startX = e.pageX - slider.offsetLeft;
                scrollLeft = slider.scrollLeft;
            });
            slider.addEventListener('mouseleave', () => {
                isDown = false;
                slider.style.cursor = 'grab';
            });
            slider.addEventListener('mouseup', () => {
                isDown = false;
                slider.style.cursor = 'grab';
            });
            slider.addEventListener('mousemove', (e) => {
                if (!isDown) return;
                e.preventDefault();
                const x = e.pageX - slider.offsetLeft;
                const walk = (x - startX) * 2;
                slider.scrollLeft = scrollLeft - walk;
            });
        });
    </script>
}

