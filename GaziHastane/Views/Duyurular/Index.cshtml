@model IEnumerable<GaziHastane.Models.Duyuru>
@{
    ViewData["Title"] = "Duyurular";
    Layout = "_EmptyLayout";
}

@section Scripts {
    <style>
        html {
            overflow-y: scroll;
            overflow-x: hidden;
        }
        body {
            overflow-x: hidden;
            width: 100%;
            margin: 0;
            padding: 0;
        }
    </style>
}

<div class="bg-gradient-to-br from-slate-900 via-sky-900 to-blue-900 py-16 sm:py-20 relative overflow-hidden mb-[-2rem] z-0">
    <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 rounded-full bg-sky-500/20 blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 rounded-full bg-blue-500/20 blur-3xl pointer-events-none"></div>
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjIiIGZpbGw9IiNmZmYiIGZpbGwtb3BhY2l0eT0iMC4wNSIvPjwvc3ZnPg==')] opacity-20"></div>

    <div class="w-full mx-auto px-6 sm:px-8 lg:px-[3cm] relative z-10 pb-8">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-8">
            <div class="flex items-center gap-6">
                <div class="w-20 h-20 sm:w-24 sm:h-24 bg-white/10 backdrop-blur-md border border-white/20 text-white rounded-[2rem] flex items-center justify-center text-4xl sm:text-5xl shadow-[0_0_40px_rgba(14,165,233,0.3)]">
                    <i class="fa-regular fa-bell"></i>
                </div>
                <div>
                    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 border border-white/20 text-sky-200 text-[10px] font-black tracking-widest uppercase mb-3 backdrop-blur-sm">
                        <span class="w-2 h-2 rounded-full bg-sky-400 animate-pulse"></span>
                        Gazi Hastanesi
                    </div>
                    <h1 class="text-white text-4xl sm:text-6xl font-black leading-tight tracking-tight mb-2 drop-shadow-md">Bilgilendirme Panosu</h1>
                    <p class="text-sky-100/80 text-sm sm:text-base font-medium max-w-xl leading-relaxed">
                        Hastalarımız ve personelimiz için yayınlanan önemli duyurular, uyarılar ve genel bilgilendirmeler.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="py-16 bg-slate-50 min-h-screen relative z-10 rounded-t-[3rem] shadow-[0_-20px_40px_rgba(0,0,0,0.1)]">
    <div class="w-full mx-auto px-6 sm:px-8 lg:px-[3cm]">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 sm:gap-8">
            @if (Model != null && Model.Any())
            {
                foreach (var duyuru in Model)
                {
                    <div class="bg-white rounded-3xl p-8 shadow-md hover:shadow-xl hover:-translate-y-2 border-2 border-slate-100 hover:border-sky-300 transition-all duration-300 flex flex-col h-full relative overflow-hidden group">
                        
                        <div class="absolute top-0 right-0 w-32 h-32 bg-sky-50/50 rounded-full blur-3xl -mr-10 -mt-10 group-hover:bg-sky-100 transition-colors"></div>

                        <div class="flex items-center justify-between mb-6 relative z-10">
                            <div class="w-16 h-16 rounded-2xl bg-sky-50 text-sky-600 flex items-center justify-center group-hover:bg-sky-600 group-hover:text-white transition-colors duration-300 shadow-sm border border-sky-100 group-hover:border-transparent">
                                <i class="fa-solid fa-bullhorn text-2xl"></i>
                            </div>
                            <span class="text-xs font-bold bg-slate-50 text-slate-500 px-3 py-1.5 rounded-full flex items-center border border-slate-100">
                                <i class="fa-regular fa-clock mr-1.5 text-sky-400"></i> @duyuru.YayinTarihi.ToString("dd.MM.yyyy")
                            </span>
                        </div>
                        
                        <div class="flex flex-col flex-1 relative z-10">
                            <h3 class="text-xl font-black text-slate-800 mb-3 group-hover:text-sky-700 transition-colors leading-snug">@duyuru.Baslik</h3>
                            <p class="text-sm text-slate-500 leading-relaxed font-medium mb-6">
                                Detaylı bilgi almak için lütfen ilgili birimlerle iletişime geçiniz veya duyuru detayını inceleyiniz.
                            </p>
                            
                            <div class="mt-auto pt-4 border-t border-slate-100 flex items-center text-sm font-bold text-sky-600 group-hover:text-sky-800 transition-colors">
                                Detayları Gör <i class="fa-solid fa-arrow-right ml-2 group-hover:translate-x-1 transition-transform"></i>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-span-full flex flex-col items-center justify-center py-20 bg-white rounded-3xl border border-slate-200 border-dashed">
                    <i class="fa-regular fa-bell text-5xl text-slate-300 mb-4"></i>
                    <h3 class="text-lg font-bold text-slate-600">Güncel Duyuru Bulunmamaktadır.</h3>
                </div>
            }
        </div>
    </div>
</section>