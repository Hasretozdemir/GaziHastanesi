@{
    ViewData["Title"] = "Hakkımızda | SEGM";
}

<div class="container py-5 mt-4">
    <div class="row align-items-center mb-5">
        <div class="col-lg-6 mb-4 mb-lg-0 animate__animated animate__fadeInLeft">
            <h6 class="text-primary fw-bold text-uppercase tracking-wide mb-2">Gazi Hastanesi SEGM</h6>
            <h1 class="display-5 fw-900 color-navy mb-4">Eğitimde Mükemmeliyet,<br />Sağlıkta Gelecek.</h1>
            <p class="text-muted lead mb-4" style="line-height: 1.8;">
                Sürekli Eğitim Merkezimiz (SEGM), hastanemiz personelinin mesleki gelişimini desteklemek,
                kalite standartlarını yükseltmek ve en güncel tıbbi/idari yaklaşımları kurum kültürüne entegre etmek amacıyla faaliyet göstermektedir.
            </p>
            <div class="d-flex gap-3">
                <a href="#vizyon" class="btn btn-navy-premium px-4 py-3 rounded-3">Misyon & Vizyon <i class="fas fa-arrow-down ms-2"></i></a>
            </div>
        </div>
        <div class="col-lg-6 animate__animated animate__fadeInRight">
            <div class="position-relative">
                <img src="~/assets/gazi.jpg" alt="Gazi Hastanesi" class="img-fluid rounded-4 shadow-lg" style="object-fit: cover; height: 450px; width: 100%;">
                <div class="position-absolute bottom-0 start-0 bg-white p-4 m-4 rounded-4 shadow" style="max-width: 250px;">
                    <h3 class="fw-bold color-navy mb-1">1926'dan</h3>
                    <p class="text-muted small mb-0">Geleceğe uzanan köklü eğitim tecrübesi.</p>
                </div>
            </div>
        </div>
    </div>

    <div id="vizyon" class="row g-4 mt-5 pt-4">
        <div class="col-md-6">
            <div class="p-5 bg-white rounded-4 shadow-sm border border-light h-100 hover-lift">
                <div class="bg-soft-blue d-inline-flex p-3 rounded-3 mb-4">
                    <i class="fas fa-bullseye text-primary fs-3"></i>
                </div>
                <h3 class="fw-bold color-navy mb-3">Misyonumuz</h3>
                <p class="text-muted mb-0" style="line-height: 1.7;">
                    Sağlık hizmetlerinde kaliteyi artırmak amacıyla, tüm hastane çalışanlarımıza yenilikçi, erişilebilir ve sürdürülebilir eğitim programları sunmak; kurum içi bilgi paylaşımını ve mesleki gelişimi en üst düzeye çıkarmaktır.
                </p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="p-5 bg-white rounded-4 shadow-sm border border-light h-100 hover-lift">
                <div class="bg-soft-purple d-inline-flex p-3 rounded-3 mb-4">
                    <i class="fas fa-eye" style="color: #8b5cf6; font-size: 1.75rem;"></i>
                </div>
                <h3 class="fw-bold color-navy mb-3">Vizyonumuz</h3>
                <p class="text-muted mb-0" style="line-height: 1.7;">
                    Ulusal ve uluslararası standartlarda referans alınan, modern eğitim teknolojilerini kullanan ve sağlık sektörüne yön veren öncü bir sürekli eğitim merkezi olmak.
                </p>
            </div>
        </div>
    </div>
</div>