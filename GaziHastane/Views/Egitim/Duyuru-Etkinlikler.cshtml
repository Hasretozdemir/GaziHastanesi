@{
    ViewData["Title"] = "Duyurular | SEGM";
}

<div class="container py-5 mt-4">
    <div class="text-center mb-5 animate__animated animate__fadeInDown">
        <h2 class="fw-900 color-navy">Güncel Duyurular</h2>
        <p class="text-muted">Eğitim merkezimizden en son haberler ve güncellemeler.</p>
        <hr class="mx-auto mt-3" style="width: 60px; height: 4px; background-color: #2563eb; opacity: 1; border: none; border-radius: 5px;" />
    </div>

    <div class="row g-4">
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden hover-lift news-card">
                <div class="position-relative">
                    <img src="~/assets/gaziebys.jpg" class="card-img-top" alt="Duyuru 1" style="height: 220px; object-fit: cover;">
                    <div class="position-absolute top-0 end-0 bg-primary text-white m-3 px-3 py-2 rounded-3 text-center shadow">
                        <span class="d-block fw-bold fs-5">15</span>
                        <span class="d-block small text-uppercase">Mart</span>
                    </div>
                </div>
                <div class="card-body p-4">
                    <span class="badge bg-soft-blue text-primary mb-3 px-3 py-2 rounded-pill">Eğitim Planlaması</span>
                    <h5 class="card-title fw-bold color-navy mb-3">2026 Yılı Hizmet İçi Eğitim Takvimi Yayımlandı</h5>
                    <p class="card-text text-muted small mb-4">Tüm idari ve sağlık personelimizin katılım sağlaması gereken zorunlu hizmet içi eğitim takvimi güncellenmiştir. Detaylı listeye EBYS üzerinden ulaşabilirsiniz.</p>
                    <a href="#" class="btn btn-outline-primary rounded-pill px-4 btn-sm w-100 fw-bold">Detayları Oku</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden hover-lift news-card">
                <div class="position-relative">
                    <img src="~/assets/gazi2.jpg" class="card-img-top" alt="Duyuru 2" style="height: 220px; object-fit: cover;">
                    <div class="position-absolute top-0 end-0 bg-primary text-white m-3 px-3 py-2 rounded-3 text-center shadow">
                        <span class="d-block fw-bold fs-5">10</span>
                        <span class="d-block small text-uppercase">Mart</span>
                    </div>
                </div>
                <div class="card-body p-4">
                    <span class="badge bg-soft-red text-danger mb-3 px-3 py-2 rounded-pill">Kalite Standartları</span>
                    <h5 class="card-title fw-bold color-navy mb-3">Yeni Kalite Yönetim Sistemi Eğitimi</h5>
                    <p class="card-text text-muted small mb-4">Sağlıkta Kalite Standartları (SKS) Versiyon 6 güncellemeleri kapsamında yapılacak olan eğitim programı başvuruya açılmıştır.</p>
                    <a href="#" class="btn btn-outline-primary rounded-pill px-4 btn-sm w-100 fw-bold">Detayları Oku</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden hover-lift news-card">
                <div class="position-relative">
                    <div class="bg-light d-flex align-items-center justify-content-center" style="height: 220px;">
                        <i class="fas fa-bullhorn text-secondary opacity-25" style="font-size: 5rem;"></i>
                    </div>
                    <div class="position-absolute top-0 end-0 bg-primary text-white m-3 px-3 py-2 rounded-3 text-center shadow">
                        <span class="d-block fw-bold fs-5">05</span>
                        <span class="d-block small text-uppercase">Mart</span>
                    </div>
                </div>
                <div class="card-body p-4">
                    <span class="badge bg-soft-teal text-success mb-3 px-3 py-2 rounded-pill">Sertifika Programı</span>
                    <h5 class="card-title fw-bold color-navy mb-3">İlk Yardım Eğitici Eğitimi Sonuçları</h5>
                    <p class="card-text text-muted small mb-4">Geçtiğimiz ay düzenlenen İlk Yardım Eğitici Eğitimi sınav sonuçları ve sertifikaları personel bilgi sistemine yüklenmiştir.</p>
                    <a href="#" class="btn btn-outline-primary rounded-pill px-4 btn-sm w-100 fw-bold">Detayları Oku</a>
                </div>
            </div>
        </div>
    </div>
</div>