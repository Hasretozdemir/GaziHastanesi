@{
    ViewData["Title"] = "Fotoğraf Galerisi | SEGM";
}

<div class="container py-5 mt-4">
    <div class="d-flex justify-content-between align-items-end mb-5 border-bottom pb-3 animate__animated animate__fadeIn">
        <div>
            <h2 class="fw-900 color-navy mb-1">Fotoğraf Galerisi</h2>
            <p class="text-muted mb-0">Hastanemizden ve eğitimlerimizden kareler.</p>
        </div>
        <div>
            <button class="btn btn-sm btn-primary rounded-pill px-4">Tümünü Gör</button>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="gallery-item overflow-hidden rounded-4 shadow-sm position-relative">
                <img src="~/assets/gazi1.jpg" class="w-100 h-100 object-fit-cover" style="min-height: 250px;" alt="Galeri 1">
                <div class="gallery-overlay d-flex align-items-center justify-content-center">
                    <i class="fas fa-search-plus text-white fs-1"></i>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="gallery-item overflow-hidden rounded-4 shadow-sm position-relative">
                <img src="~/assets/gazi.jpg" class="w-100 h-100 object-fit-cover" style="min-height: 250px;" alt="Galeri 2">
                <div class="gallery-overlay d-flex align-items-center justify-content-center">
                    <i class="fas fa-search-plus text-white fs-1"></i>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="gallery-item overflow-hidden rounded-4 shadow-sm position-relative">
                <img src="~/assets/gazi3.jpg" class="w-100 h-100 object-fit-cover" style="min-height: 300px;" alt="Galeri 3">
                <div class="gallery-overlay d-flex align-items-center justify-content-center">
                    <i class="fas fa-search-plus text-white fs-1"></i>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="gallery-item overflow-hidden rounded-4 shadow-sm position-relative">
                <img src="~/assets/gazi4.jpg" class="w-100 h-100 object-fit-cover" style="min-height: 300px;" alt="Galeri 4">
                <div class="gallery-overlay d-flex align-items-center justify-content-center">
                    <i class="fas fa-search-plus text-white fs-1"></i>
                </div>
            </div>
        </div>
    </div>
</div>