@model List<GaziHastane.Models.EgitimKarti>
@{
    Layout = null;
    ViewData["Title"] = "Eğitim Komitesi Portalı | Gazi Sağlık";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <script src="https://cdn.tailwindcss.com?plugins=typography"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        body {
            background-color: #f0f4f8;
            font-family: 'Plus Jakarta Sans', sans-serif;
            overflow: hidden;
            height: 100%;
        }

        .color-navy {
            color: #0f172a;
        }

        .portal-master-card {
            background: rgba(255, 255, 255, 0.98);
            border: 2px solid #cbd5e1;
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 25px 60px rgba(0,0,0,0.12), 0 0 0 2px rgba(37,99,235,0.08);
            max-width: 1100px;
            width: 100%;
            margin: 0 auto;
            position: relative;
            z-index: 2;
        }
        .portal-master-card:hover {
            box-shadow: 0 35px 80px rgba(0,0,0,0.18), 0 0 0 3px rgba(37,99,235,0.12);
            transform: translateY(-3px);
        }

        .bg-visuals {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            z-index: 0;
            pointer-events: none;
            overflow: hidden;
        }

        .blob {
            position: absolute;
            width: 500px;
            height: 500px;
            filter: blur(100px);
            opacity: 0.5;
            border-radius: 50%;
        }

        .blob-1 {
            top: -100px;
            right: -50px;
            background: rgba(37, 99, 235, 0.08);
        }

        .blob-2 {
            bottom: -100px;
            left: -50px;
            background: rgba(15, 23, 42, 0.04);
        }

        .committee-action-card {
            background: white;
            border: 2px solid #e2e8f0;
            border-radius: 16px;
            padding: 16px;
            display: flex;
            align-items: center;
            gap: 15px;
            text-decoration: none !important;
            transition: all 0.3s ease;
            cursor: pointer;
            text-align: left;
            width: 100%;
        }

            .committee-action-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 20px 40px rgba(37,99,235,0.14);
                border-color: #2563eb !important;
                background: linear-gradient(135deg, #ffffff 0%, #eff6ff 100%);
            }

                .committee-action-card:hover .arrow-icon {
                    transform: translateX(4px);
                    color: #2563eb !important;
                }

        .card-icon-wrapper {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            flex-shrink: 0;
        }

        .card-info h5 {
            font-size: 0.95rem;
            font-weight: 900;
            color: #0f172a;
            margin-bottom: 2px;
        }

        .card-info p {
            font-size: 0.78rem;
            color: #475569; font-weight: 600;
            margin: 0;
        }

        .arrow-icon {
            transition: transform 0.3s ease, color 0.3s ease;
        }

        /* Tailwind Özel Renk Seçenekleri */
        .text-blue-400 {
            color: #60a5fa;
            background: #eff6ff;
        }

        .text-purple-400 {
            color: #c084fc;
            background: #f5f3ff;
        }

        .text-red-400 {
            color: #f87171;
            background: #fef2f2;
        }

        .text-orange-400 {
            color: #fb923c;
            background: #fff7ed;
        }

        .text-teal-400 {
            color: #2dd4bf;
            background: #f0fdfa;
        }

        .text-sky-400 {
            color: #38bdf8;
            background: #e0f2fe;
        }

        .text-yellow-400 {
            color: #facc15;
            background: #fef9c3;
        }

        .text-green-400 {
            color: #4ade80;
            background: #dcfce7;
        }

        .custom-scroll::-webkit-scrollbar {
            width: 6px;
        }

        .custom-scroll::-webkit-scrollbar-track {
            background: #f8fafc;
            border-radius: 10px;
        }

        .custom-scroll::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }
    </style>
</head>

<body style="overflow:hidden;" class="pt-20 pb-10 min-vh-100 d-flex flex-column align-items-center justify-content-center">

    <div class="bg-visuals">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
    </div>

    <header class="fixed top-0 left-0 right-0 bg-white/95 backdrop-blur-md shadow-sm border-b border-slate-200 z-[100]">
        <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
            <a href="/Home/Index" class="flex items-center gap-3 text-decoration-none">
                <img src="~/assets/gazilogo.jpg" alt="Gazi Logo" class="h-9 w-auto rounded-lg border border-slate-100 shadow-sm" />
                <div class="leading-none">
                    <p class="text-sm font-extrabold tracking-tight uppercase text-slate-900 mb-0">Gazi Üniversitesi</p>
                    <p class="text-[10px] font-bold text-blue-600 tracking-widest uppercase mb-0 mt-0.5">Hastanesi</p>
                </div>
            </a>
            <div class="flex items-center gap-2 sm:gap-3">
                <a href="tel:4440911" class="flex items-center gap-2 border border-red-200 text-red-600 text-[10px] font-black px-3 py-2 rounded-xl hover:bg-red-50 transition text-decoration-none">
                    <i class="fa-solid fa-phone animate-pulse"></i> <span class="hidden sm:inline">ARA: 444 0 911</span>
                </a>
                <a href="/Randevu/Giris" class="bg-blue-600 text-white px-3 sm:px-4 py-2 rounded-xl text-[10px] font-black tracking-widest hover:bg-blue-700 transition shadow-md shadow-blue-200 text-decoration-none">RANDEVU AL</a>
                <a href="/Home/Index" title="Ana Sayfaya Dön" class="w-9 h-9 flex items-center justify-center bg-slate-100 text-slate-600 rounded-xl hover:bg-slate-200 transition text-decoration-none">
                    <i class="fa-solid fa-house text-sm"></i>
                </a>
            </div>
        </div>
    </header>

    <div class="container px-3 mt-4">
        <div class="portal-master-card animate__animated animate__fadeInUp">

            <div class="text-center mb-5 pb-4 border-bottom">
                <div class="d-inline-flex align-items-center justify-content-center bg-blue-50 text-blue-600 rounded-circle mb-3" style="width:64px; height:64px; font-size:1.75rem;">
                    <i class="fas fa-university"></i>
                </div>
                <h2 class="fw-900 color-navy mb-1" style="font-size: 1.8rem;">Sürekli Eğitim Merkezi</h2>
                <p class="text-muted mb-0">Kurumsal Gelişim ve Eğitim Portalı <span class="text-primary fw-bold">| SEGM</span></p>
            </div>

            <div class="row g-3 justify-content-center">
                @if (Model != null && Model.Any())
                {
                    @foreach (var madde in Model)
                    {
                        <div class="col-12 col-md-6 col-lg-4">
                            @if (madde.Tip == "Panel")
                            {
                                <button onclick="icerikGoster(@madde.Id)" class="committee-action-card h-100 w-100 border-0">
                                    <div class="card-icon-wrapper @madde.Renk"><i class="fas @madde.Ikon"></i></div>
                                    <div class="card-info w-100 d-flex justify-content-between align-items-center">
                                        <div>
                                            <h5>@madde.Baslik</h5>
                                            <p>@madde.KisaAciklama</p>
                                        </div>
                                    </div>
                                </button>
                            }
                            else
                            {
                                <a href="@madde.Hedef" class="committee-action-card h-100 w-100">
                                    <div class="card-icon-wrapper @madde.Renk"><i class="fas @madde.Ikon"></i></div>
                                    <div class="card-info w-100 d-flex justify-content-between align-items-center">
                                        <div>
                                            <h5>@madde.Baslik</h5>
                                            <p>@madde.KisaAciklama</p>
                                        </div>
                                        <i class="fas fa-external-link-alt text-muted opacity-50 arrow-icon text-[10px]"></i>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                }
                else
                {
                    <p class="text-center text-slate-400 italic">Sistemde henüz bir eğitim kartı bulunmuyor.</p>
                }
            </div>
        </div>
    </div>

    <div id="contentModal" class="fixed inset-0 z-[150] hidden items-center justify-center p-4 sm:p-6 bg-slate-900/60 backdrop-blur-md transition-all duration-300">

        <div class="bg-white w-full max-w-4xl rounded-[2rem] relative max-h-[90vh] flex flex-col shadow-2xl overflow-hidden animate__animated animate__zoomIn animate__faster">

            <div id="modalHeaderImg" class="relative h-64 sm:h-80 shrink-0 w-full hidden group">
                <img id="modalFoto" src="" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
                <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/40 to-transparent"></div>

                <button onclick="modalKapat()" class="absolute top-6 right-6 w-11 h-11 bg-white/20 hover:bg-white/40 backdrop-blur-md text-white rounded-full flex items-center justify-center transition-all z-10 shadow-lg">
                    <i class="fa-solid fa-xmark text-lg"></i>
                </button>

                <div class="absolute bottom-0 left-0 right-0 p-8 md:p-12 pb-8 translate-y-2 group-hover:translate-y-0 transition-transform duration-500">
                    <span class="inline-block px-3 py-1 mb-3 text-[10px] font-black tracking-widest text-blue-300 bg-blue-900/50 rounded-full backdrop-blur-sm uppercase border border-blue-400/20">SEGM Eğitim Portalı</span>
                    <h2 id="modalBaslikImg" class="text-3xl md:text-4xl font-black text-white leading-tight drop-shadow-md"></h2>
                </div>
            </div>

            <div id="modalHeaderNoImg" class="px-8 md:px-12 pt-10 pb-6 border-b border-slate-100 flex justify-between items-start bg-slate-50/50 shrink-0 hidden">
                <div>
                    <span class="inline-block px-3 py-1 mb-3 text-[10px] font-black tracking-widest text-blue-600 bg-blue-100 rounded-full uppercase">SEGM Eğitim Portalı</span>
                    <h2 id="modalBaslik" class="text-2xl md:text-3xl font-black text-slate-800 tracking-tight"></h2>
                </div>
                <button onclick="modalKapat()" class="w-11 h-11 bg-white border border-slate-200 text-slate-500 rounded-full hover:bg-red-50 hover:text-red-500 hover:border-red-200 hover:rotate-90 transition-all flex items-center justify-center shrink-0 shadow-sm">
                    <i class="fa-solid fa-xmark text-lg"></i>
                </button>
            </div>

            <div class="p-8 md:p-12 overflow-y-auto custom-scroll flex-1 bg-white relative">

                <div id="modalIcerik" class="prose prose-slate max-w-none prose-headings:font-black prose-p:leading-relaxed prose-a:text-blue-600 prose-img:rounded-xl prose-img:shadow-md text-slate-600">
                </div>

                <div id="belgeKutusu" class="mt-12 p-1 bg-gradient-to-r from-blue-50 to-indigo-50 rounded-[1.5rem] border border-blue-100/50 hidden">
                    <div class="bg-white/60 backdrop-blur-sm rounded-[1.35rem] p-6 flex flex-col sm:flex-row items-center justify-between gap-6">
                        <div class="flex items-center gap-5 w-full">
                            <div class="w-14 h-14 bg-gradient-to-br from-red-50 to-rose-100 rounded-2xl flex items-center justify-center text-red-500 shadow-inner border border-red-200/50 shrink-0">
                                <i class="fa-solid fa-file-pdf text-2xl drop-shadow-sm"></i>
                            </div>
                            <div>
                                <p class="text-[11px] font-black text-blue-600 uppercase tracking-widest mb-1">Eğitim / Sunum Dosyası</p>
                                <p class="text-sm font-semibold text-slate-600 mb-0">Eğitime ait materyali cihazınıza indirebilirsiniz.</p>
                            </div>
                        </div>
                        <a id="modalBelgeLink" href="#" target="_blank" class="w-full sm:w-auto text-center bg-blue-600 hover:bg-blue-700 text-white px-8 py-3.5 rounded-xl font-bold text-sm transition-all text-decoration-none shrink-0 shadow-lg shadow-blue-600/30 hover:-translate-y-0.5">
                            <i class="fa-solid fa-cloud-arrow-down mr-2"></i> DOSYAYI AÇ
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function icerikGoster(id) {
            // EgitimController'daki GetEgitimDetay metodunu çağırır
            fetch(`/Egitim/GetEgitimDetay/${id}`)
                .then(res => res.json())
                .then(data => {
                    document.getElementById('modalIcerik').innerHTML = data.icerik || '<p class="text-slate-400 italic text-center py-10">Bu bölüm için henüz detaylı bir içerik girilmemiştir.</p>';

                    const headerImg = document.getElementById('modalHeaderImg');
                    const headerNoImg = document.getElementById('modalHeaderNoImg');
                    const foto = document.getElementById('modalFoto');

                    if (data.fotoUrl && data.fotoUrl !== "#") {
                        foto.src = data.fotoUrl;
                        document.getElementById('modalBaslikImg').innerText = data.baslik;
                        headerImg.style.display = 'block';
                        headerNoImg.style.display = 'none';
                    } else {
                        document.getElementById('modalBaslik').innerText = data.baslik;
                        headerImg.style.display = 'none';
                        headerNoImg.style.display = 'flex';
                    }

                    const belgeKutusu = document.getElementById('belgeKutusu');
                    const belgeLink = document.getElementById('modalBelgeLink');
                    if (data.dosyaUrl && data.dosyaUrl !== "#") {
                        belgeLink.href = data.dosyaUrl;
                        belgeKutusu.style.display = 'block';
                    } else {
                        belgeKutusu.style.display = 'none';
                    }

                    const modal = document.getElementById('contentModal');
                    modal.classList.replace('hidden', 'flex');

                    // Arka planı sabitle
                    const scrollBarWidth = window.innerWidth - document.documentElement.clientWidth;
                    document.body.style.paddingRight = scrollBarWidth + 'px';
                    document.body.classList.add('modal-open');
                    document.documentElement.classList.add('modal-open');
                });
        }

        function modalKapat() {
            const modal = document.getElementById('contentModal');
            modal.classList.replace('flex', 'hidden');
            
            document.body.classList.remove('modal-open');
            document.documentElement.classList.remove('modal-open');
            document.body.style.paddingRight = '';
        }

        window.onclick = function(event) {
            const modal = document.getElementById('contentModal');
            if (event.target == modal) { modalKapat(); }
        }
    </script>
</body>
</html>