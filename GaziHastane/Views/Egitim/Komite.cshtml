@{
    ViewData["Title"] = "Gazi Sağlık | Eğitim Komitesi Portalı";
}

<div class="portal-viewport">
    <div class="abstract-sphere"></div>
    <div class="abstract-sphere-secondary"></div>

    <div class="container d-flex align-items-center justify-content-center min-vh-100 py-5">
        <div class="portal-master-card animate__animated animate__fadeIn">

            <div class="portal-header-premium mb-4">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <div class="d-flex align-items-center">
                        <div class="header-icon-premium me-3">
                            <i class="fas fa-university"></i>
                            <div class="pulse-ring"></div>
                        </div>
                        <div>
                            <h2 class="fw-900 color-navy mb-0">Eğitim Komitesi Portalı</h2>
                            <p class="text-muted small mb-0">Sürekli Eğitim Merkezi <span class="text-primary fw-bold">| SEGM</span></p>
                        </div>
                    </div>
                    <div class="header-actions">
                        <span class="status-indicator-badge">
                            <span class="status-dot"></span> Sistem Çevrimiçi
                        </span>
                    </div>
                </div>
            </div>

            <div class="row g-3 row-cols-1 row-cols-md-2 row-cols-xl-3">

                <div class="col">
                    <a href="#" class="committee-action-card">
                        <div class="card-icon-wrapper bg-soft-blue">
                            <i class="fas fa-users-crown"></i>
                        </div>
                        <div class="card-info">
                            <h5>Komite Üyeleri</h5>
                            <p>Yürütme kurulu ve akademik temsilciler.</p>
                        </div>
                        <div class="card-arrow"><i class="fas fa-chevron-right"></i></div>
                    </a>
                </div>

                <div class="col">
                    <a href="#" class="committee-action-card">
                        <div class="card-icon-wrapper bg-soft-purple">
                            <i class="fas fa-lightbulb-on"></i>
                        </div>
                        <div class="card-info">
                            <h5>Misyon & Vizyon</h5>
                            <p>Eğitim politikaları ve kalite standartları.</p>
                        </div>
                        <div class="card-arrow"><i class="fas fa-chevron-right"></i></div>
                    </a>
                </div>

                <div class="col">
                    <a href="#" class="committee-action-card">
                        <div class="card-icon-wrapper bg-soft-teal">
                            <i class="fas fa-sitemap"></i>
                        </div>
                        <div class="card-info">
                            <h5>Personel Şeması</h5>
                            <p>İdari personel eğitim akış süreçleri.</p>
                        </div>
                        <div class="card-arrow"><i class="fas fa-chevron-right"></i></div>
                    </a>
                </div>

                <div class="col">
                    <a href="#" class="committee-action-card">
                        <div class="card-icon-wrapper bg-soft-red">
                            <i class="fas fa-user-nurse"></i>
                        </div>
                        <div class="card-info">
                            <h5>Hemşirelik Eğitimi</h5>
                            <p>Mesleki gelişim ve klinik eğitim haritası.</p>
                        </div>
                        <div class="card-arrow"><i class="fas fa-chevron-right"></i></div>
                    </a>
                </div>

                <div class="col">
                    <a href="#" class="committee-action-card">
                        <div class="card-icon-wrapper bg-soft-orange">
                            <i class="fas fa-folder-open"></i>
                        </div>
                        <div class="card-info">
                            <h5>Dijital Arşiv</h5>
                            <p>Güncel talimatlar ve eğitim materyalleri.</p>
                        </div>
                        <div class="card-arrow"><i class="fas fa-chevron-right"></i></div>
                    </a>
                </div>

                <div class="col">
                    <a href="#" class="committee-action-card">
                        <div class="card-icon-wrapper bg-soft-navy">
                            <i class="fas fa-calendar-alt"></i>
                        </div>
                        <div class="card-info">
                            <h5>Eğitim Takvimi</h5>
                            <p>Sertifika programları ve sınav duyuruları.</p>
                        </div>
                        <div class="card-arrow"><i class="fas fa-chevron-right"></i></div>
                    </a>
                </div>

            </div>

            <div class="row g-3 mt-2">
                <div class="col-md-8">
                    <div class="announcement-glass">
                        <div class="d-flex align-items-center mb-3">
                            <i class="fas fa-bullhorn text-primary me-2"></i>
                            <h6 class="mb-0 fw-bold color-navy">Son Duyurular</h6>
                        </div>
                        <div class="a-list">
                            <div class="a-row">
                                <span class="a-label">Yeni</span>
                                <p>2026 Yılı Hizmet İçi Eğitim Planı yayına alındı.</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="support-glass d-flex align-items-center justify-content-center">
                        <div class="text-center">
                            <p class="small text-muted mb-2">Sorunuz mu var?</p>
                            <button class="btn btn-navy-premium btn-sm w-100">BİLGİ İŞLEM DESTEK</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-4">
                <p class="extra-small text-muted opacity-75">© 2026 Gazi Üniversitesi Hastanesi | Bilgi İşlem Daire Başkanlığı</p>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <style>
        :root {
            --navy-dark: #0f172a;
            --navy-light: #1e293b;
            --primary-blue: #2563eb;
            --gazi-bg: #f1f5f9;
        }

        body {
            background-color: var(--gazi-bg);
            font-family: 'Plus Jakarta Sans', sans-serif;
            overflow-x: hidden;
        }

        /* Arka Plan Sanatı */
        .abstract-sphere {
            position: fixed;
            top: -10%;
            right: -5%;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(37, 99, 235, 0.05) 0%, transparent 70%);
            z-index: -1;
            filter: blur(60px);
        }

        .abstract-sphere-secondary {
            position: fixed;
            bottom: -10%;
            left: -5%;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(15, 23, 42, 0.05) 0%, transparent 70%);
            z-index: -1;
            filter: blur(50px);
        }

        /* Ana Konteynır */
        .portal-master-card {
            width: 100%;
            max-width: 1200px;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border: 1px solid white;
            border-radius: 40px;
            padding: 40px;
            box-shadow: 0 40px 100px rgba(15, 23, 42, 0.08);
        }

        /* Header Tasarımı */
        .header-icon-premium {
            width: 60px;
            height: 60px;
            background: var(--navy-dark);
            color: white;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            position: relative;
        }

        .pulse-ring {
            position: absolute;
            width: 100%;
            height: 100%;
            border: 2px solid var(--navy-dark);
            border-radius: 18px;
            animation: pulse-border 2s infinite;
        }

        @@keyframes pulse-border {
            0% {
                transform: scale(1);
                opacity: 0.5;
            }

            100% {
                transform: scale(1.4);
                opacity: 0;
            }
        }

        .status-indicator-badge {
            background: #dcfce7;
            color: #15803d;
            padding: 6px 15px;
            border-radius: 50px;
            font-size: 11px;
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .status-dot {
            width: 8px;
            height: 8px;
            background: #22c55e;
            border-radius: 50%;
        }

        /* YAN YANA AKSİYON KARTLARI */
        .committee-action-card {
            background: white;
            border: 1px solid #f1f5f9;
            border-radius: 25px;
            padding: 25px;
            display: flex;
            align-items: center;
            gap: 20px;
            text-decoration: none !important;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            height: 100%;
        }

            .committee-action-card:hover {
                transform: translateY(-8px);
                box-shadow: 0 20px 40px rgba(0,0,0,0.05);
                border-color: var(--primary-blue);
            }

        .card-icon-wrapper {
            width: 60px;
            height: 60px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            flex-shrink: 0;
        }

        /* Kart Renk Paleti */
        .bg-soft-blue {
            background: #eff6ff;
            color: #3b82f6;
        }

        .bg-soft-purple {
            background: #f5f3ff;
            color: #8b5cf6;
        }

        .bg-soft-teal {
            background: #f0fdfa;
            color: #14b8a6;
        }

        .bg-soft-red {
            background: #fef2f2;
            color: #ef4444;
        }

        .bg-soft-orange {
            background: #fff7ed;
            color: #f97316;
        }

        .bg-soft-navy {
            background: #f1f5f9;
            color: var(--navy-dark);
        }

        .card-info h5 {
            font-size: 1.1rem;
            font-weight: 800;
            color: var(--navy-dark);
            margin-bottom: 5px;
        }

        .card-info p {
            font-size: 0.85rem;
            color: #64748b;
            margin: 0;
            line-height: 1.4;
        }

        .card-arrow {
            margin-left: auto;
            color: #cbd5e1;
            transition: 0.3s;
        }

        .committee-action-card:hover .card-arrow {
            transform: translateX(5px);
            color: var(--primary-blue);
        }

        /* Alt Glass Bölümler */
        .announcement-glass, .support-glass {
            background: #f8fafc;
            border-radius: 25px;
            padding: 25px;
            height: 100%;
            border: 1px solid rgba(255,255,255,0.5);
        }

        .a-row {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .a-label {
            background: var(--primary-blue);
            color: white;
            font-size: 9px;
            font-weight: 900;
            padding: 3px 8px;
            border-radius: 6px;
        }

        .a-row p {
            font-size: 13px;
            font-weight: 600;
            color: #475569;
            margin: 0;
        }

        .btn-navy-premium {
            background: var(--navy-dark);
            color: white;
            border-radius: 12px;
            font-weight: 800;
            font-size: 11px;
            padding: 12px;
            border: none;
            transition: 0.3s;
        }

            .btn-navy-premium:hover {
                background: var(--primary-blue);
                transform: scale(1.02);
            }

        .color-navy {
            color: var(--navy-dark);
        }

        .fw-900 {
            font-weight: 900;
        }

        .extra-small {
            font-size: 10px;
            letter-spacing: 0.5px;
        }

        @@media (max-width: 1200px) {
            .portal-master-card {
                padding: 30px;
                margin: 15px;
            }
        }
    </style>
}