@* RAZOR KOD BLOĞU: Sunucu tarafında çalışan ve sayfanın temel ayarlarını tutan bölüm *@
@{
    @* Tarayıcının üst sekmesinde görünecek sayfanın başlığını (Title) belirliyoruz. 
       Arama motorları ve kullanıcı deneyimi için önemlidir. *@
    ViewData["Title"] = "Gazi Sağlık | Eğitim Komitesi Portalı";
}

<!-- SAYFA İÇERİĞİ BAŞLANGICI -->
<!-- 'portal-viewport': Tüm sayfa içeriğini kapsayan ana dış katman. -->
<div class="portal-viewport">

    <!-- ARKA PLAN EFEKTLERİ -->
    <!-- 'abstract-sphere': Sağ üst köşedeki bulanık mavi yuvarlak görsel efekt. -->
    <div class="abstract-sphere"></div>
    <!-- 'abstract-sphere-secondary': Sol alt köşedeki bulanık lacivert yuvarlak görsel efekt. -->
    <div class="abstract-sphere-secondary"></div>

    <!-- MERKEZİ KONTEYNER -->
    <!-- 'container': İçeriği ortalar.
         'd-flex align-items-center justify-content-center': İçeriği hem yatay hem dikey olarak tam ortalar.
         'min-vh-100': Sayfanın yüksekliğinin en az ekran boyu kadar olmasını sağlar.
         'py-5': Yukarıdan ve aşağıdan boşluk bırakır. -->
    <div class="container d-flex align-items-center justify-content-center min-vh-100 py-5">

        <!-- ANA KART (BEYAZ CAM PANEL) -->
        <!-- 'portal-master-card': Tüm içeriği tutan cam görünümlü beyaz kart.
             'animate__animated animate__fadeIn': Kartın sayfa açılışında belirerek gelme animasyonu. -->
        <div class="portal-master-card animate__animated animate__fadeIn">

            <!-- KART BAŞLIK ALANI -->
            <!-- 'portal-header-premium': Başlık ve ikonun bulunduğu üst kısım. -->
            <div class="portal-header-premium mb-4">

                <!-- Başlık içeriğini iki yana yaslayan Flex yapısı (Sola başlık, sağa durum rozeti) -->
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

                    <!-- SOL TARA: İKON VE METİN -->
                    <div class="d-flex align-items-center">

                        <!-- İkon Kutusu -->
                        <!-- 'header-icon-premium': İkonun içindeki lacivert kutu. -->
                        <div class="header-icon-premium me-3">
                            <!-- Üniversite ikonu (FontAwesome) -->
                            <i class="fas fa-university"></i>
                            <!-- İkonun etrafındaki hareketli halka (pulse) efekti -->
                            <div class="pulse-ring"></div>
                        </div>

                        <!-- Başlık Metinleri -->
                        <div>
                            <!-- Ana başlık: Kalın ve lacivert renkli -->
                            <h2 class="fw-900 color-navy mb-0">Eğitim Komitesi Portalı</h2>
                            <!-- Alt başlık: Daha küçük ve gri tonlu, SEGM vurgulu -->
                            <p class="text-muted small mb-0">Sürekli Eğitim Merkezi <span class="text-primary fw-bold">| SEGM</span></p>
                        </div>
                    </div>

                    <!-- SAĞ TARA: DURUM GÖSTERGESİ -->
                    <div class="header-actions">
                        <!-- 'Sistem Çevrimiçi' yazan yeşil hap şeklindeki rozet -->
                        <span class="status-indicator-badge">
                            <!-- Yeşil nokta indikatörü -->
                            <span class="status-dot"></span> Sistem Çevrimiçi
                        </span>
                    </div>
                </div>
            </div>

            <!-- KARTLARIN LİSTELENDİĞİ IZGARA (GRID) YAPISI -->
            <!-- 'row': Satır yapısı.
                 'row-cols-1': Mobilde (küçük ekran) yan yana 1 kart.
                 'row-cols-md-2': Tablette (orta ekran) yan yana 2 kart.
                 'row-cols-xl-3': Masaüstünde (geniş ekran) yan yana 3 kart gösterir. -->
            <div class="row g-3 row-cols-1 row-cols-md-2 row-cols-xl-3">

                <!-- 1. KART: Komite Üyeleri -->
                <div class="col">
                    <!-- Tıklanabilir kart bileşeni. Link (#) şimdilik boş. -->
                    <a href="#" class="committee-action-card">
                        <!-- İkon Yuvası: Mavi arka planlı (bg-soft-blue) -->
                        <div class="card-icon-wrapper bg-soft-blue">
                            <i class="fas fa-users-crown"></i>
                        </div>
                        <!-- Kart Bilgi Alanı -->
                        <div class="card-info">
                            <h5>Komite Üyeleri</h5>
                            <p>Yürütme kurulu ve akademik temsilciler.</p>
                        </div>
                        <!-- Sağdaki küçük ok ikonu -->
                        <div class="card-arrow"><i class="fas fa-chevron-right"></i></div>
                    </a>
                </div>

                <!-- 2. KART: Misyon & Vizyon -->
                <div class="col">
                    <a href="#" class="committee-action-card">
                        <!-- İkon Yuvası: Mor arka planlı (bg-soft-purple) -->
                        <div class="card-icon-wrapper bg-soft-purple">
                            <i class="fas fa-lightbulb-on"></i>
                        </div>
                        <div class="card-info">
                            <h5>Misyon & Vizyon</h5>
                            <p>Eğitim politikaları ve kalite standartları.</p>
                        </div>
                        <div class="card-arrow"><i class="fas fa-chevron-right"></i></div>
                    </a>
                </div>

                <!-- 3. KART: Personel Şeması -->
                <div class="col">
                    <a href="#" class="committee-action-card">
                        <!-- İkon Yuvası: Turkuaz arka planlı (bg-soft-teal) -->
                        <div class="card-icon-wrapper bg-soft-teal">
                            <i class="fas fa-sitemap"></i>
                        </div>
                        <div class="card-info">
                            <h5>Personel Şeması</h5>
                            <p>İdari personel eğitim akış süreçleri.</p>
                        </div>
                        <div class="card-arrow"><i class="fas fa-chevron-right"></i></div>
                    </a>
                </div>

                <!-- 4. KART: Hemşirelik Eğitimi -->
                <div class="col">
                    <a href="#" class="committee-action-card">
                        <!-- İkon Yuvası: Kırmızı arka planlı (bg-soft-red) -->
                        <div class="card-icon-wrapper bg-soft-red">
                            <i class="fas fa-user-nurse"></i>
                        </div>
                        <div class="card-info">
                            <h5>Hemşirelik Eğitimi</h5>
                            <p>Mesleki gelişim ve klinik eğitim haritası.</p>
                        </div>
                        <div class="card-arrow"><i class="fas fa-chevron-right"></i></div>
                    </a>
                </div>

                <!-- 5. KART: Dijital Arşiv -->
                <div class="col">
                    <a href="#" class="committee-action-card">
                        <!-- İkon Yuvası: Turuncu arka planlı (bg-soft-orange) -->
                        <div class="card-icon-wrapper bg-soft-orange">
                            <i class="fas fa-folder-open"></i>
                        </div>
                        <div class="card-info">
                            <h5>Dijital Arşiv</h5>
                            <p>Güncel talimatlar ve eğitim materyalleri.</p>
                        </div>
                        <div class="card-arrow"><i class="fas fa-chevron-right"></i></div>
                    </a>
                </div>

                <!-- 6. KART: Eğitim Takvimi -->
                <div class="col">
                    <a href="#" class="committee-action-card">
                        <!-- İkon Yuvası: Lacivert/Gri arka planlı (bg-soft-navy) -->
                        <div class="card-icon-wrapper bg-soft-navy">
                            <i class="fas fa-calendar-alt"></i>
                        </div>
                        <div class="card-info">
                            <h5>Eğitim Takvimi</h5>
                            <p>Sertifika programları ve sınav duyuruları.</p>
                        </div>
                        <div class="card-arrow"><i class="fas fa-chevron-right"></i></div>
                    </a>
                </div>

            </div>

            <!-- ALT BİLGİ VE DUYURU ALANI -->
            <div class="row g-3 mt-2">

                <!-- SOL TARA: SON DUYURULAR -->
                <!-- 'col-md-8': Genişliğin 3'te 2'sini kaplar (büyük alan). -->
                <div class="col-md-8">
                    <!-- 'announcement-glass': Duyuru kutusu için cam efekti -->
                    <div class="announcement-glass">
                        <!-- Duyuru Başlık Kısmı -->
                        <div class="d-flex align-items-center mb-3">
                            <i class="fas fa-bullhorn text-primary me-2"></i>
                            <h6 class="mb-0 fw-bold color-navy">Son Duyurular</h6>
                        </div>
                        <!-- Duyurular Listesi -->
                        <div class="a-list">
                            <!-- Tekil Duyuru Satırı -->
                            <div class="a-row">
                                <!-- 'Yeni' etiketi -->
                                <span class="a-label">Yeni</span>
                                <!-- Duyuru metni -->
                                <p>2026 Yılı Hizmet İçi Eğitim Planı yayına alındı.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SAĞ TARA: DESTEK BUTONU -->
                <!-- 'col-md-4': Genişliğin 3'te 1'ini kaplar (küçük alan). -->
                <div class="col-md-4">
                    <!-- 'support-glass': Destek kutusu için cam efekti -->
                    <div class="support-glass d-flex align-items-center justify-content-center">
                        <div class="text-center">
                            <!-- Yardımcı metin -->
                            <p class="small text-muted mb-2">Sorunuz mu var?</p>
                            <!-- Destek butonu -->
                            <button class="btn btn-navy-premium btn-sm w-100">BİLGİ İŞLEM DESTEK</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- FOOTER (ALTYAZI) -->
            <!-- Sayfanın en altındaki telif hakkı yazısı -->
            <div class="text-center mt-4">
                <p class="extra-small text-muted opacity-75">© 2026 Gazi Üniversitesi Hastanesi | Bilgi İşlem Daire Başkanlığı</p>
            </div>
        </div>
    </div>
</div>

@* ================= CSS BÖLÜMÜ (_Layout içindeki head kısmına eklenecek stiller) ================= *@
@section Styles {
    <!-- Animate.css: Animasyonlar için dış kütüphane -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <style>
        /* CSS DEĞİŞKENLERİ: Renk kodlarını tek bir yerden yönetmek için tanımlanmış değişkenler. */
        :root {
            --navy-dark: #0f172a; /* Koyu lacivert (Metin ve butonlar) */
            --navy-light: #1e293b; /* Açık lacivert */
            --primary-blue: #2563eb; /* Marka mavisi (Vurgular) */
            --gazi-bg: #f1f5f9; /* Sayfanın genel arka plan gri/mavi rengi */
        }

        /* Sayfa Geneli Stilleri */
        body {
            background-color: var(--gazi-bg); /* Arka plan rengini değişkenden alır */
            font-family: 'Plus Jakarta Sans', sans-serif; /* Modern yazı tipi */
            overflow-x: hidden; /* Sayfanın sağa sola kaymasını (yatay scroll) engeller */
        }

        /* ARKA PLAN SANATI (BLUR EFEKTLİ LEKELER) */
        /* Sağ üstteki mavi devasa yuvarlak */
        .abstract-sphere {
            position: fixed;
            top: -10%;
            right: -5%; /* Sağ üst köşeye sabitler */
            width: 500px;
            height: 500px; /* Boyutları */
            /* Ortası çok hafif mavi, kenarları şeffaf olan bir renk geçişi (gradient) yaratır */
            background: radial-gradient(circle, rgba(37, 99, 235, 0.05) 0%, transparent 70%);
            z-index: -1; /* Her şeyin arkasında kalmasını sağlar */
            filter: blur(60px); /* Lekenin kenarlarını 60px bulanıklaştırarak bulut/ışık efekti verir */
        }

        /* Sol alttaki lacivert yuvarlak */
        .abstract-sphere-secondary {
            position: fixed;
            bottom: -10%;
            left: -5%; /* Sol alt köşeye sabitler */
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(15, 23, 42, 0.05) 0%, transparent 70%);
            z-index: -1;
            filter: blur(50px);
        }

        /* ANA BEYAZ KART (Glassmorphism Tasarımı) */
        .portal-master-card {
            width: 100%;
            max-width: 1200px; /* Genişliği maksimum 1200px ile sınırlandırır (Masaüstü görünümü) */
            background: rgba(255, 255, 255, 0.9); /* %90 oranında opak (hafif saydam) beyaz arka plan */
            backdrop-filter: blur(10px); /* Arka plandaki renk lekelerini (sphere) bu kartın altından geçerken buzlu cam gibi bulanıklaştırır */
            border: 1px solid white; /* Kenarlık rengi beyaz */
            border-radius: 40px; /* Köşeleri büyük ölçüde yuvarlatır */
            padding: 40px; /* İçeriğin kenarlara değmemesi için 40px iç boşluk */
            box-shadow: 0 40px 100px rgba(15, 23, 42, 0.08); /* Karta derinlik katan, aşağı doğru inen devasa ama çok hafif bir gölge */
        }

        /* HEADER İKONU VE ANİMASYONU */
        /* İkonun durduğu lacivert kutu */
        .header-icon-premium {
            width: 60px;
            height: 60px;
            background: var(--navy-dark);
            color: white;
            border-radius: 18px; /* Oval köşeler */
            display: flex;
            align-items: center;
            justify-content: center; /* İkonu ortalar */
            font-size: 1.5rem; /* İkon boyutu */
            position: relative; /* İçindeki pulse halkasının konumlanması için referans noktası */
        }

        /* İkonun etrafındaki dışa doğru büyüyen halka */
        .pulse-ring {
            position: absolute;
            width: 100%;
            height: 100%;
            border: 2px solid var(--navy-dark); /* Halkanın çizgi rengi */
            border-radius: 18px; /* İkon kutusuyla aynı ovallik */
            animation: pulse-border 2s infinite; /* "pulse-border" isimli animasyonu 2 saniyede bir sonsuza kadar (infinite) tekrarla */
        }

        /* Pulse (Kalp Atışı/Yankı) Animasyonunun Kuralları */
        @@keyframes pulse-border {
            0%

        {
            transform: scale(1);
            opacity: 0.5;
        }
        /* Başlangıç: Boyut aynı, %50 görünür */
        100% {
            transform: scale(1.4);
            opacity: 0;
        }
        /* Bitiş: %40 daha büyük ve tamamen şeffaf (kaybolmuş) */
        }

        /* SİSTEM ÇEVRİMİÇİ ROZETİ */
        .status-indicator-badge {
            background: #dcfce7;
            color: #15803d; /* Açık yeşil zemin, koyu yeşil yazı */
            padding: 6px 15px;
            border-radius: 50px; /* Hap (hap) şeklinde tasarım */
            font-size: 11px;
            font-weight: 800; /* Küçük ve kalın font */
            display: flex;
            align-items: center;
            gap: 8px; /* Yanındaki nokta ile yazıyı yatay hizalar ve aralarına 8px boşluk koyar */
        }

        /* Rozetin içindeki yeşil nokta */
        .status-dot {
            width: 8px;
            height: 8px;
            background: #22c55e; /* Tam yeşil renk */
            border-radius: 50%; /* Tam yuvarlak (nokta) yapar */
        }

        /* AKSİYON KARTLARI (Menü Butonları) */
        .committee-action-card {
            background: white;
            border: 1px solid #f1f5f9; /* Çok hafif grimsi bir kenar çizgisi */
            border-radius: 25px; /* Yuvarlak köşeler */
            padding: 25px;
            display: flex;
            align-items: center;
            gap: 20px; /* İkon, yazı ve oku yan yana dizip aralarını açar */
            text-decoration: none !important; /* Linklerdeki alt çizgiyi kaldırır */
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); /* Hover (üzerine gelme) animasyonu süresi ve yumuşaklığı */
            height: 100%; /* Kartların aynı hizada ve boyda olmasını sağlar */
        }

            /* Fare Kartın Üzerine Geldiğinde (Hover) */
            .committee-action-card:hover {
                transform: translateY(-8px); /* Kartı 8 piksel yukarı kaldırır (Havalanma efekti) */
                box-shadow: 0 20px 40px rgba(0,0,0,0.05); /* Altına geniş bir gölge ekler */
                border-color: var(--primary-blue); /* Kenar çizgisini maviye çevirir */
            }

        /* Kart İçindeki İkon Yuvaları */
        .card-icon-wrapper {
            width: 60px;
            height: 60px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            flex-shrink: 0; /* Yazılar uzun olsa bile bu kutunun sıkışıp küçülmesini engeller */
        }

        /* RENKLİ İKON KUTULARI (Her kart için farklı bir soft renk) */
        .bg-soft-blue {
            background: #eff6ff;
            color: #3b82f6;
        }
        /* Mavi */
        .bg-soft-purple {
            background: #f5f3ff;
            color: #8b5cf6;
        }
        /* Mor */
        .bg-soft-teal {
            background: #f0fdfa;
            color: #14b8a6;
        }
        /* Turkuaz */
        .bg-soft-red {
            background: #fef2f2;
            color: #ef4444;
        }
        /* Kırmızı */
        .bg-soft-orange {
            background: #fff7ed;
            color: #f97316;
        }
        /* Turuncu */
        .bg-soft-navy {
            background: #f1f5f9;
            color: var(--navy-dark);
        }
        /* Lacivert */

        /* Kart İçindeki Başlık (h5) */
        .card-info h5 {
            font-size: 1.1rem;
            font-weight: 800;
            color: var(--navy-dark);
            margin-bottom: 5px;
        }

        /* Kart İçindeki Açıklama Yazısı (p) */
        .card-info p {
            font-size: 0.85rem;
            color: #64748b;
            margin: 0;
            line-height: 1.4;
        }

        /* Kartın Sağındaki Ok İkonu */
        .card-arrow {
            margin-left: auto; /* Kendini en sağa yaslar */
            color: #cbd5e1; /* Pasifken açık gri renk */
            transition: 0.3s;
        }

        /* Fare Kartın Üzerine Geldiğinde Oku Etkileyen Kısım */
        .committee-action-card:hover .card-arrow {
            transform: translateX(5px); /* Oku sağa doğru 5 piksel kaydırır */
            color: var(--primary-blue); /* Rengini mavi yapar */
        }

        /* DUYURU VE DESTEK ALANLARI (Alt Bölümler) */
        .announcement-glass, .support-glass {
            background: #f8fafc; /* Beyaza çok yakın bir gri */
            border-radius: 25px;
            padding: 25px;
            height: 100%;
            border: 1px solid rgba(255,255,255,0.5); /* Sınırlarına hafif bir beyazlık katar */
        }

        /* Duyuru Satırı Yapısı */
        .a-row {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        /* Duyurudaki "Yeni" Etiketi */
        .a-label {
            background: var(--primary-blue);
            color: white;
            font-size: 9px;
            font-weight: 900;
            padding: 3px 8px;
            border-radius: 6px;
        }

        /* Duyuru Metni */
        .a-row p {
            font-size: 13px;
            font-weight: 600;
            color: #475569;
            margin: 0;
        }

        /* DESTEK BUTONU (Lacivert Premium Tasarım) */
        .btn-navy-premium {
            background: var(--navy-dark);
            color: white;
            border-radius: 12px;
            font-weight: 800;
            font-size: 11px;
            padding: 12px;
            border: none;
            transition: 0.3s;
        }

            /* Butonun Üzerine Gelince (Hover) */
            .btn-navy-premium:hover {
                background: var(--primary-blue); /* Maviye döner */
                transform: scale(1.02); /* Çok az (%2) büyür */
            }

        /* Yardımcı Renk ve Yazı Sınıfları */
        .color-navy {
            color: var(--navy-dark);
        }

        .fw-900 {
            font-weight: 900;
        }

        .extra-small {
            font-size: 10px;
            letter-spacing: 0.5px;
        }
        /* Footer telif hakkı yazısı için */

        /* MOBİL UYUM (Responsive Design) */
        /* Ekran genişliği 1200px'den küçükse (Tablet ve Telefonlar) devreye girer */
        @@media (max-width: 1200px) {
            .portal-master-card

        {
            padding: 30px; /* İç boşluğu küçültür ki ekrana daha rahat sığsın */
            margin: 15px; /* Dış boşluk bırakarak ekran kenarlarına yapışmasını engeller */
        }

        }
    </style>
}