@* RAZOR KOD BLOĞU: Sunucu tarafında (C#) sayfa ayarlarının yapıldığı kısım. *@
@{
    // Sayfanın başlığını "Başhekimlik" olarak ayarlıyoruz.
    ViewData["Title"] = "Başhekimlik";
}

@section Scripts {
    <!-- SAYFAYA ÖZEL STİLLER (CSS) -->
    <style>
        /* ── YAN MENÜ (SIDEBAR) STİLLERİ ── */
        /* Menü linklerinin temel görünümü */
        .sidebar-link {
            transition: all 0.2s ease;
            display: flex;
            align-items: center; /* İkon ve metni dikey ortala */
            justify-content: space-between; /* İkon ve metni iki uca yasla */
            padding: 0.65rem 0.9rem;
            border-radius: 12px;
            font-size: 0.82rem;
            font-weight: 600;
            color: #64748b; /* Pasif link rengi (Gri) */
            text-decoration: none;
        }

            /* Link üzerine gelince (Hover) */
            .sidebar-link:hover {
                background: #eff6ff; /* Açık mavi arka plan */
                color: #2563eb; /* Mavi yazı rengi */
                transform: translateX(4px); /* Sağa doğru hafif kayma efekti */
            }
            
            /* AKTİF LİNK DURUMU */
            /* Şu an "Başhekimlik" sayfasında olduğumuz için bu linki özel olarak vurguluyoruz. */
            .sidebar-link[href="/Kurumsal/Bashekimlik"] {
                background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%); /* Mavi gradyan */
                color: white;
                box-shadow: 0 4px 14px rgba(37,99,235,0.25); /* Gölge efekti */
            }

        /* YAN MENÜ KATEGORİ BAŞLIKLARI */
        .section-title {
            font-size: 0.68rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: #94a3b8;
            margin: 1.4rem 0.9rem 0.4rem;
        }

        /* ÖZEL KAYDIRMA ÇUBUĞU (Scrollbar) */
        .custom-scroll::-webkit-scrollbar {
            width: 4px;
        }

        .custom-scroll::-webkit-scrollbar-track {
            background: transparent;
        }

        .custom-scroll::-webkit-scrollbar-thumb {
            background: #e2e8f0;
            border-radius: 10px;
        }

        /* ── BAŞHEKİM PROFİL KARTI ── */
        /* Başhekimin fotoğrafının ve bilgilerinin olduğu büyük kart */
        .head-card {
            background: white;
            border-radius: 1.75rem;
            border: 1px solid #f1f5f9;
            overflow: hidden;
            transition: all 0.3s ease;
            position: relative;
        }

            /* Kartın üzerine gelince (Hover) */
            .head-card:hover {
                transform: translateY(-6px); /* Yukarı doğru kalkar */
                box-shadow: 0 24px 60px rgba(37,99,235,0.15) !important; /* Büyük bir gölge oluşur */
            }

            /* Kartın en üstündeki dekoratif mavi çizgi */
            .head-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: linear-gradient(90deg, #2563eb, #60a5fa);
                z-index: 2;
            }

        /* ── YARDIMCI KARTLARI (Küçük Kartlar) ── */
        .asst-card {
            background: white;
            border-radius: 1.25rem;
            border: 1px solid #f1f5f9;
            overflow: hidden;
            display: flex;
            align-items: stretch; /* İçerikleri dikey olarak esnet */
            transition: all 0.25s ease;
            position: relative;
        }

            /* Sol taraftaki dekoratif dikey çizgi (Başlangıçta gizli) */
            .asst-card::before {
                content: '';
                position: absolute;
                left: 0;
                top: 0;
                bottom: 0;
                width: 3px;
                background: linear-gradient(180deg, #2563eb, #93c5fd);
                opacity: 0; /* Gizli */
                transition: opacity 0.25s;
            }

            /* Yardımcı kartı hover efekti */
            .asst-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 12px 36px rgba(37,99,235,0.10);
            }

                /* Hover olunca sol çizgiyi göster */
                .asst-card:hover::before {
                    opacity: 1;
                }

        /* ── AVATAR HALKASI ── */
        /* Profil resminin etrafındaki renkli çerçeve (Hover'da görünür) */
        .avatar-ring {
            position: absolute;
            inset: -3px;
            border-radius: 50%;
            border: 2.5px solid transparent;
            background: linear-gradient(135deg, #2563eb, #93c5fd) border-box;
            -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: destination-out;
            mask-composite: exclude;
            opacity: 0;
            transition: opacity 0.25s;
        }

        .asst-card:hover .avatar-ring {
            opacity: 1;
        }

        /* ── ROZETLER (Badges) ── */
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 0.58rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            padding: 3px 8px;
            border-radius: 99px;
        }

        /* Mavi Rozet */
        .badge-blue {
            background: #dbeafe;
            color: #1d4ed8;
        }

        /* Altın Sarısı Rozet */
        .badge-gold {
            background: #fef9c3;
            color: #92400e;
        }

        /* ── BÖLÜM AYIRICI ÇİZGİSİ ── */
        .section-bar {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.25rem;
        }

        /* Çizginin kendisi (sağa doğru şeffaflaşan gri çizgi) */
        .section-bar-line {
            flex: 1;
            height: 1px;
            background: linear-gradient(to right,#e2e8f0,transparent);
        }

        /* ── ORGANİZASYON ŞEMASI BAĞLANTI ÇİZGİLERİ ── */
        .org-connector {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0;
        }

        /* Bağlantı noktası (Yuvarlak) */
        .org-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #2563eb;
        }

        /* Dikey bağlantı çizgisi */
        .org-line {
            width: 2px;
            height: 24px;
            background: linear-gradient(to bottom,#2563eb,#bfdbfe);
        }

        /* ── BİLGİ SATIRI (E-posta, Telefon vb.) ── */
        .info-row {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            padding: 0.5rem 0.75rem;
            background: #f8fafc;
            border-radius: 10px;
            border: 1px solid #f1f5f9;
        }
    </style>
}

<!-- ANA İÇERİK ALANI -->
