@section Scripts {
    <style>
        /* 1. SAYFA Y?KLENME AN?MASYONU (Z?plamay? Engeller) */
        .page-fade-in {
            animation: fadeInPage 0.6s ease-out forwards;
            opacity: 0;
        }

        @@keyframes fadeInPage {
            from {
                opacity: 0;
                transform: translateY(15px);
            }

