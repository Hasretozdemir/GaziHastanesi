@model GaziHastane.Models.HemsirelikViewModel
@* RAZOR KOD BLO–U: Sunucu tarafżnda ÁalżĢan C# kodlarżnżn yazżldżūż alan. *@
@{
    // Sayfanżn baĢlżūżnż belirliyoruz. Bu baĢlżk tarayżcż sekmesinde gŲrŁnŁr.
    ViewData["Title"] = "HemĢirelik Hizmetleri - Kurumsal Bilgi Sistemi";
    var sekmeler = Model?.Sekmeler ?? new List<GaziHastane.Models.HemsirelikSekme>();
}

@section Scripts {
    <style>
        /* 1. SAYFA Y‹KLENME AN›MASYONU (Zżplamayż Engeller) */
        .page-fade-in {
            animation: fadeInPage 0.6s ease-out forwards;
            opacity: 0;
        }

        @@keyframes fadeInPage {
            from {
                opacity: 0;
                transform: translateY(15px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* 2. RESPONSIVE ›« MEN‹ (Mobilde yatay kaydżrżlabilir menŁ) */
        @@media (max-width: 1279px) { /* Tailwind xl breakpoint altż iÁin */
            .mobile-tab-menu {
                display: flex !important;
                flex-direction: row !important;
                overflow-x: auto;
                white-space: nowrap;
                gap: 0.5rem;
                padding-bottom: 0.5rem; /* Scrollbar iÁin biraz boĢluk */
                -webkit-overflow-scrolling: touch; /* Mobilde pŁrŁzsŁz kaydżrma */
            }

                .mobile-tab-menu > * {
                    margin-top: 0 !important; /* space-y-2 sżnżfżnż mobilde ezer */
                }

                .mobile-tab-menu::-webkit-scrollbar {
                    display: none; /* Mobilde Áirkin scrollbar'ż gizle */
                }

            .sub-menu-btn {
                width: auto !important;
                flex-shrink: 0;
                padding: 0.6rem 1.2rem;
            }

            .kurumsal-icerik-baslik {
                display: none; /* Mobilde baĢlżūż gizle, yer kaplamasżn */
            }
        }

        /* YAN MEN‹ L›NKLER› (Mevcut stillerin) */
        .sidebar-link {
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.65rem 0.9rem;
            border-radius: 12px;
            font-size: 0.82rem;
            font-weight: 600;
            color: #64748b;
            text-decoration: none;
        }

            .sidebar-link:hover {
                background: #eff6ff;
                color: #2563eb;
                transform: translateX(4px);
            }

            .sidebar-link[href="/Hemsirelik/Index"] {
                background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
                color: white;
                box-shadow: 0 4px 14px rgba(37,99,235,0.25);
            }

        .section-title {
            font-size: 0.68rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: #94a3b8;
            margin: 1.4rem 0.9rem 0.4rem;
        }

        .custom-scroll::-webkit-scrollbar {
            width: 4px;
        }

        .custom-scroll::-webkit-scrollbar-track {
            background: transparent;
        }

        .custom-scroll::-webkit-scrollbar-thumb {
            background: #e2e8f0;
            border-radius: 10px;
        }

        .sub-menu-btn {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            width: 100%;
            padding: 0.85rem 1rem;
            border-radius: 14px;
            font-size: 0.8rem;
            font-weight: 700;
            color: #475569;
            background: white;
            border: 1px solid #f1f5f9;
            cursor: pointer;
            transition: all 0.2s;
            text-align: left;
        }

            .sub-menu-btn:hover {
                background: #f8fafc;
                transform: translateX(3px);
            }

            .sub-menu-btn.active {
                background: #eff6ff;
                color: #2563eb;
                border-color: #bfdbfe;
                box-shadow: 0 4px 12px rgba(37,99,235,0.08);
            }

        /* 3. TAB ›«ER›KLER› YUMUřAK GE«›ř AN›MASYONU */
        .tab-content {
            display: none;
            opacity: 0;
            transform: translateY(10px);
        }

            .tab-content.active {
                display: block;
                animation: fadeInTab 0.4s ease forwards;
            }

        @@keyframes fadeInTab {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .timeline-dot {
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: #2563eb;
            flex-shrink: 0;
            margin-top: 4px;
            box-shadow: 0 0 0 4px rgba(37,99,235,0.15);
        }

        .feature-card {
            border-radius: 20px;
            padding: 1.5rem;
            transition: transform 0.2s, box-shadow 0.2s;
            position: relative;
            overflow: hidden;
        }

            .feature-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 16px 30px rgba(0,0,0,0.06);
            }

        .staff-card {
            border-radius: 16px;
            border: 1px solid #f1f5f9;
            padding: 1.25rem;
            text-align: center;
            transition: all 0.2s;
        }

            .staff-card:hover {
                border-color: #bfdbfe;
                box-shadow: 0 10px 25px rgba(37,99,235,0.05);
            }
    </style>

    <script>
        function openTab(event, tabId) {
            // Sayfanżn yenilenmesini veya yukarż zżplamasżnż engelle
            if(event) event.preventDefault();

            // 1. TŁm butonlarż pasif yap
            document.querySelectorAll('.sub-menu-btn').forEach(btn => btn.classList.remove('active'));

            // 2. Tżklanan butonu aktif yap
            if(event) {
                event.currentTarget.classList.add('active');
            } else {
                // Eūer event yoksa (sayfa ilk yŁklendiūinde URL'den geliyorsa)
                let activeBtn = document.querySelector(`[onclick*="${tabId}"]`);
                if(activeBtn) activeBtn.classList.add('active');
            }

            // 3. TŁm iÁerik alanlarżnż gizle
            document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));

            // 4. Sadece seÁilen 'tabId'ye sahip iÁeriūi gŲster
            let targetContent = document.getElementById(tabId);
            if(targetContent) targetContent.classList.add('active');

            // 5. URL'yi gŁncelle (sayfa yenilenmeden geÁmiĢe ekler)
            if(history.pushState) {
                history.pushState(null, null, '#' + tabId);
            }
        }

        // Sayfa ilk yŁklendiūinde URL'de #varsa (Ųrn: .../Hemsirelik/Index#misyon) o sekmeyi aÁ
        document.addEventListener('DOMContentLoaded', function() {
            let hash = window.location.hash.substring(1);
            if(hash && document.getElementById(hash)) {
                openTab(null, hash);
            }
        });
    </script>
}

<main class="max-w-[1400px] mx-auto px-4 sm:px-6 py-8 mt-24 page-fade-in">

    <div class="flex flex-col lg:flex-row gap-7">

        <aside class="w-full lg:w-72 flex-shrink-0">
            @await Html.PartialAsync("_KurumsalSidebar")
        </aside>

        <section class="flex-1 min-w-0">

            <nav class="flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-slate-400 mb-6">
                <i class="fa-solid fa-house text-[9px]"></i>
                <i class="fa-solid fa-chevron-right text-[8px]"></i>
                <span>Kurumsal</span>
                <i class="fa-solid fa-chevron-right text-[8px]"></i>
                <span class="text-blue-600">HemĢirelik Hizmetleri</span>
            </nav>

            <div class="flex flex-col xl:flex-row gap-6 items-start">

                <div class="mobile-tab-menu w-full xl:w-72 flex-shrink-0 space-y-2 bg-white p-4 rounded-[1.75rem] border border-slate-100" style="box-shadow: 0 4px 24px rgba(0,0,0,0.03);">
                    <p class="kurumsal-icerik-baslik text-[9px] font-black uppercase tracking-[0.2em] text-slate-400 mb-3 ml-2">›Áerik MenŁsŁ</p>

                    @if (sekmeler.Any())
                    {
                        for (int i = 0; i < sekmeler.Count; i++)
                        {
                            var sekme = sekmeler[i];
                            <button onclick="openTab(event, '@sekme.SekmeId')" class="sub-menu-btn @(i == 0 ? "active" : "")">
                                <i class="fa-solid @(string.IsNullOrWhiteSpace(sekme.IconClass) ? "fa-circle-info" : sekme.IconClass) w-5 text-center"></i> @sekme.Baslik
                            </button>
                        }
                    }
                    else
                    {
                        <div class="text-sm text-slate-400 font-semibold px-2 py-2">HenŁz sekme eklenmedi.</div>
                    }
                </div>

                <div class="flex-1 w-full bg-white rounded-[1.75rem] p-7 sm:p-10 border border-slate-100" style="box-shadow: 0 12px 40px rgba(0,0,0,0.04); min-height: 600px;">

                    <div id="misyon-vizyon" class="tab-content active">
                        <div class="flex items-center gap-3 mb-8">
                            <div class="w-1.5 h-8 bg-blue-600 rounded-full"></div>
                            <h2 class="text-2xl font-black text-slate-800">Misyon ve Vizyonumuz</h2>
                        </div>
                        <div class="grid sm:grid-cols-2 gap-5 mb-8">
                            <div class="feature-card bg-gradient-to-br from-blue-600 to-blue-800 text-white">
                                <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center mb-4">
                                    <i class="fa-solid fa-hand-holding-medical"></i>
                                </div>
                                <h4 class="font-black text-lg mb-2">Misyonumuz</h4>
                                <p class="text-blue-100 text-sm leading-relaxed font-medium">@Model.Ayarlar.Misyon</p>
                            </div>
                            <div class="feature-card bg-gradient-to-br from-slate-800 to-slate-900 text-white">
                                <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center mb-4">
                                    <i class="fa-solid fa-star-of-life"></i>
                                </div>
                                <h4 class="font-black text-lg mb-2">Vizyonumuz</h4>
                                <p class="text-slate-400 text-sm leading-relaxed font-medium">@Model.Ayarlar.Vizyon</p>
                            </div>
                        </div>
                    </div>

                    <div id="organizasyon" class="tab-content">
                        <div class="flex items-center gap-3 mb-8">
                            <div class="w-1.5 h-8 bg-blue-600 rounded-full"></div>
                            <h2 class="text-2xl font-black text-slate-800">Organizasyon řemasż</h2>
                        </div>
                        <p class="text-slate-600 leading-relaxed font-medium mb-6">HemĢirelik Hizmetleri MŁdŁrlŁūŁmŁzŁn hiyerarĢik yapżsż ve koordinasyon birimleri aĢaūżdaki Ģemada gŲsterilmektedir.</p>
                        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-8 flex items-center justify-center min-h-[300px]">
                            @if (!string.IsNullOrWhiteSpace(Model.Ayarlar.OrganizasyonSemaUrl))
                            {
                                <img src="@Model.Ayarlar.OrganizasyonSemaUrl" alt="Organizasyon řemasż" class="max-h-[320px] w-auto rounded-xl border border-slate-200" />
                            }
                            else
                            {
                                <div class="text-center text-slate-400">
                                    <i class="fa-solid fa-sitemap text-4xl mb-3"></i>
                                    <p class="text-sm font-semibold">Organizasyon Ģemasż gŲrseli buraya eklenecektir.</p>
                                </div>
                            }
                        </div>
                    </div>

                    <div id="yonetim" class="tab-content">
                        <div class="flex items-center gap-3 mb-8">
                            <div class="w-1.5 h-8 bg-blue-600 rounded-full"></div>
                            <h2 class="text-2xl font-black text-slate-800">HemĢirelik Hizmetleri YŲnetimi</h2>
                        </div>
                        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
                            @if (Model.YonetimKadrosu.Any())
                            {
                                foreach (var item in Model.YonetimKadrosu)
                                {
                                    <div class="staff-card">
                                        <div class="w-20 h-20 bg-slate-200 rounded-full mx-auto mb-4 overflow-hidden">
                                            <img src="@(!string.IsNullOrWhiteSpace(item.MedyaYolu) ? item.MedyaYolu : "/images/avatar-placeholder.jpg")" alt="@item.Baslik" class="w-full h-full object-cover @(string.IsNullOrWhiteSpace(item.MedyaYolu) ? "opacity-50" : "")" />
                                        </div>
                                        <h4 class="font-black text-slate-800 text-sm">@item.Baslik</h4>
                                        <p class="text-[11px] text-blue-600 font-bold uppercase tracking-wide mt-1">@item.AltBaslik</p>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="staff-card">
                                    <p class="text-sm text-slate-500 font-semibold">YŲnetim kadrosu henŁz eklenmedi.</p>
                                </div>
                            }
                        </div>
                    </div>

                    <div id="gorevler" class="tab-content">
                        <div class="flex items-center gap-3 mb-8">
                            <div class="w-1.5 h-8 bg-blue-600 rounded-full"></div>
                            <h2 class="text-2xl font-black text-slate-800">GŲrev, Yetki ve Sorumluluklar</h2>
                        </div>
                        <div class="space-y-3">
                            @if (Model.Gorevler.Any())
                            {
                                foreach (var item in Model.Gorevler)
                                {
                                    <div class="flex items-start gap-3 p-4 bg-slate-50 rounded-xl border border-slate-100">
                                        <i class="fa-solid fa-check text-blue-600 mt-1"></i>
                                        <div>
                                            <h4 class="font-bold text-slate-800 text-sm mb-1">@item.Baslik</h4>
                                            <p class="text-xs text-slate-600 leading-relaxed">@item.Aciklama</p>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="flex items-start gap-3 p-4 bg-slate-50 rounded-xl border border-slate-100">
                                    <i class="fa-solid fa-check text-blue-600 mt-1"></i>
                                    <div>
                                        <h4 class="font-bold text-slate-800 text-sm mb-1">GŲrev listesi boĢ</h4>
                                        <p class="text-xs text-slate-600 leading-relaxed">GŲrev ve sorumluluk iÁerikleri henŁz eklenmedi.</p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div id="icimizden-biri" class="tab-content">
                        <div class="flex items-center gap-3 mb-8">
                            <div class="w-1.5 h-8 bg-blue-600 rounded-full"></div>
                            <h2 class="text-2xl font-black text-slate-800">›Áimizden Biri</h2>
                        </div>
                        <div class="bg-blue-50 border border-blue-100 rounded-2xl p-6 flex flex-col sm:flex-row gap-6 items-center sm:items-start">
                            <div class="w-32 h-32 rounded-full bg-blue-200 flex-shrink-0 overflow-hidden">
                                @if (!string.IsNullOrWhiteSpace(Model.Ayarlar.AyinHemsiresiFotoUrl))
                                {
                                    <img src="@Model.Ayarlar.AyinHemsiresiFotoUrl" alt="@Model.Ayarlar.AyinHemsiresiAd" class="w-full h-full object-cover" />
                                }
                            </div>
                            <div>
                                <h3 class="font-black text-slate-800 text-lg">Ayżn HemĢiresi: @Model.Ayarlar.AyinHemsiresiAd</h3>
                                <p class="text-sm text-blue-600 font-semibold mb-3">@Model.Ayarlar.AyinHemsiresiBirim</p>
                                <p class="text-slate-600 text-sm leading-relaxed italic">@Model.Ayarlar.AyinHemsiresiSoz</p>
                            </div>
                        </div>
                    </div>

                    <div id="mevzuat" class="tab-content">
                        <div class="flex items-center gap-3 mb-8">
                            <div class="w-1.5 h-8 bg-blue-600 rounded-full"></div>
                            <h2 class="text-2xl font-black text-slate-800">Kanun, Yasa ve YŲnetmelik</h2>
                        </div>
                        <p class="text-slate-600 leading-relaxed font-medium mb-6">HemĢirelik mesleūinin icrasżnż dŁzenleyen ulusal mevzuat ve iÁ yŲnergelerimiz.</p>
                        <div class="space-y-3">
                            @if (Model.Mevzuatlar.Any())
                            {
                                foreach (var item in Model.Mevzuatlar)
                                {
                                    <a href="@(string.IsNullOrWhiteSpace(item.MedyaYolu) ? "#" : item.MedyaYolu)" class="flex items-center justify-between p-4 bg-slate-50 hover:bg-blue-50 border border-slate-100 rounded-xl transition group">
                                        <div class="flex items-center gap-4">
                                            <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center shadow-sm text-slate-600"><i class="fa-solid fa-book"></i></div>
                                            <div><p class="font-bold text-slate-800 text-sm group-hover:text-blue-700 transition">@item.Baslik</p></div>
                                        </div>
                                        <i class="fa-solid fa-arrow-up-right-from-square text-slate-400 group-hover:text-blue-600"></i>
                                    </a>
                                }
                            }
                            else
                            {
                                <div class="p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm text-slate-500 font-semibold">Mevzuat baūlantżsż eklenmedi.</div>
                            }
                        </div>
                    </div>

                    <div id="galeri" class="tab-content">
                        <div class="flex items-center gap-3 mb-8">
                            <div class="w-1.5 h-8 bg-blue-600 rounded-full"></div>
                            <h2 class="text-2xl font-black text-slate-800">Fotoūraf Galerisi</h2>
                        </div>
                        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                            @if (Model.GaleriFotograflari.Any())
                            {
                                foreach (var item in Model.GaleriFotograflari)
                                {
                                    <div class="bg-slate-200 aspect-square rounded-xl overflow-hidden hover:opacity-80 transition cursor-pointer flex items-center justify-center text-slate-400">
                                        @if (!string.IsNullOrWhiteSpace(item.MedyaYolu))
                                        {
                                            <img src="@item.MedyaYolu" alt="@item.Baslik" class="w-full h-full object-cover" />
                                        }
                                        else
                                        {
                                            <i class="fa-solid fa-camera text-2xl"></i>
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="bg-slate-200 aspect-square rounded-xl flex items-center justify-center text-slate-400"><i class="fa-solid fa-camera text-2xl"></i></div>
                            }
                        </div>
                    </div>

                    <div id="etkinlik" class="tab-content">
                        <div class="flex items-center gap-3 mb-8">
                            <div class="w-1.5 h-8 bg-blue-600 rounded-full"></div>
                            <h2 class="text-2xl font-black text-slate-800">Etkinlik & Duyurular</h2>
                        </div>
                        <div class="border-l-2 border-blue-200 pl-4 space-y-6">
                            @if (Model.Etkinlikler.Any())
                            {
                                for (int i = 0; i < Model.Etkinlikler.Count; i++)
                                {
                                    var item = Model.Etkinlikler[i];
                                    <div class="relative">
                                        <div class="absolute -left-[21px] top-1 w-3 h-3 @(i == 0 ? "bg-blue-600" : "bg-slate-300") rounded-full ring-4 ring-white"></div>
                                        <span class="text-xs font-bold @(i == 0 ? "text-blue-600 bg-blue-50" : "text-slate-500 bg-slate-100") px-2 py-1 rounded">@item.AltBaslik</span>
                                        <h4 class="font-black text-slate-800 mt-2">@item.Baslik</h4>
                                        <p class="text-sm text-slate-600 mt-1">@item.Aciklama</p>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-sm text-slate-500 font-semibold">Etkinlik ve duyuru bulunmuyor.</p>
                            }
                        </div>
                    </div>

                    <div id="akis-semasi" class="tab-content">
                        <div class="flex items-center gap-3 mb-8">
                            <div class="w-1.5 h-8 bg-blue-600 rounded-full"></div>
                            <h2 class="text-2xl font-black text-slate-800">SŁreÁ ve AkżĢ řemalarż</h2>
                        </div>
                        <p class="text-slate-600 leading-relaxed font-medium mb-6">Klinik iĢleyiĢ, hasta yatżĢ/ÁżkżĢ sŁreÁleri ve acil durum eylem planlarżna ait akżĢ Ģemalarż.</p>
                        <ul class="list-disc list-inside space-y-2 text-blue-600 text-sm font-semibold">
                            @if (Model.AkisSemalari.Any())
                            {
                                foreach (var item in Model.AkisSemalari)
                                {
                                    <li><a href="@(string.IsNullOrWhiteSpace(item.MedyaYolu) ? "#" : item.MedyaYolu)" class="hover:underline">@item.Baslik</a></li>
                                }
                            }
                            else
                            {
                                <li class="text-slate-500">AkżĢ Ģemasż bulunmuyor.</li>
                            }
                        </ul>
                    </div>

                    <div id="iletisim" class="tab-content">
                        <div class="flex items-center gap-3 mb-8">
                            <div class="w-1.5 h-8 bg-blue-600 rounded-full"></div>
                            <h2 class="text-2xl font-black text-slate-800">›letiĢim</h2>
                        </div>
                        <div class="bg-slate-50 rounded-2xl p-6 border border-slate-100">
                            <div class="flex items-center gap-4 mb-4">
                                <div class="w-10 h-10 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-lg"><i class="fa-solid fa-phone"></i></div>
                                <div>
                                    <p class="text-xs text-slate-500 uppercase tracking-wider font-bold">Telefon (Dahili)</p>
                                    <p class="text-slate-800 font-semibold">@Model.Ayarlar.Telefon</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-4 mb-4">
                                <div class="w-10 h-10 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-lg"><i class="fa-solid fa-envelope"></i></div>
                                <div>
                                    <p class="text-xs text-slate-500 uppercase tracking-wider font-bold">E-Posta</p>
                                    <p class="text-slate-800 font-semibold">@Model.Ayarlar.Email</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-lg"><i class="fa-solid fa-location-dot"></i></div>
                                <div>
                                    <p class="text-xs text-slate-500 uppercase tracking-wider font-bold">Adres</p>
                                    <p class="text-slate-800 font-semibold">@Model.Ayarlar.Adres</p>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

        </section>
    </div>
</main>