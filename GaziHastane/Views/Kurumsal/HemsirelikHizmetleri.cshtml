                color: #2563eb;
                border-color: #bfdbfe;
                box-shadow: 0 4px 12px rgba(37,99,235,0.08);
            }

        /* 3. TAB ??ER?KLER? YUMU?AK GE??? AN?MASYONU */
        .tab-content {
            display: none;
            opacity: 0;
            transform: translateY(10px);
        }

            .tab-content.active {
                display: block;
                animation: fadeInTab 0.4s ease forwards;
            }

        @@keyframes fadeInTab {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .timeline-dot {
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: #2563eb;
            flex-shrink: 0;
            margin-top: 4px;
            box-shadow: 0 0 0 4px rgba(37,99,235,0.15);
        }

        .feature-card {
            border-radius: 20px;
            padding: 1.5rem;
            transition: transform 0.2s, box-shadow 0.2s;
            position: relative;
            overflow: hidden;
        }

            .feature-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 16px 30px rgba(0,0,0,0.06);
            }

        .staff-card {
            border-radius: 16px;
            border: 1px solid #f1f5f9;
            padding: 1.25rem;
            text-align: center;
            transition: all 0.2s;
        }

            .staff-card:hover {
                border-color: #bfdbfe;
                box-shadow: 0 10px 25px rgba(37,99,235,0.05);
            }
    </style>

    <script>
        function openTab(event, tabId) {
            // Sayfan?n yenilenmesini veya yukar? z?plamas?n? engelle
            if(event) event.preventDefault();

            // 1. T?m butonlar? pasif yap
            document.querySelectorAll('.sub-menu-btn').forEach(btn => btn.classList.remove('active'));

            // 2. T?klanan butonu aktif yap
            if(event) {
                event.currentTarget.classList.add('active');
            } else {
                // E?er event yoksa (sayfa ilk y?klendi?inde URL'den geliyorsa)
                let activeBtn = document.querySelector(`[onclick*="${tabId}"]`);
                if(activeBtn) activeBtn.classList.add('active');
            }

            // 3. T?m i?erik alanlar?n? gizle
            document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));

            // 4. Sadece se?ilen 'tabId'ye sahip i?eri?i g?ster
            let targetContent = document.getElementById(tabId);
            if(targetContent) targetContent.classList.add('active');

            // 5. URL'yi g?ncelle (sayfa yenilenmeden ge?mi?e ekler)
            if(history.pushState) {
                history.pushState(null, null, '#' + tabId);
            }
        }

        // Sayfa ilk y?klendi?inde URL'de #varsa (?rn: .../Hemsirelik/Index#misyon) o sekmeyi a?
        document.addEventListener('DOMContentLoaded', function() {
            let hash = window.location.hash.substring(1);
            if(hash && document.getElementById(hash)) {
                openTab(null, hash);
            }
        });

        window.addEventListener('hashchange', function() {
            let hash = window.location.hash.substring(1);
            if(hash && document.getElementById(hash)) {
                openTab(null, hash);
            }
        });
    </script>
}

