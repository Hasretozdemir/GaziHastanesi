            }
        }

        /* 2. RESPONSIVE ?? MEN? (Mobilde yatay kayd?r?labilir men?) */
        @@media (max-width: 1279px) { /* Tailwind xl breakpoint alt? i?in */
            .mobile-tab-menu {
                display: flex !important;
                flex-direction: row !important;
                overflow-x: auto;
                white-space: nowrap;
                gap: 0.5rem;
                padding-bottom: 0.5rem; /* Scrollbar i?in biraz bo?luk */
                -webkit-overflow-scrolling: touch; /* Mobilde p?r?zs?z kayd?rma */
            }

                .mobile-tab-menu > * {
                    margin-top: 0 !important; /* space-y-2 s?n?f?n? mobilde ezer */
                }

                .mobile-tab-menu::-webkit-scrollbar {
                    display: none; /* Mobilde ?irkin scrollbar'? gizle */
                }

