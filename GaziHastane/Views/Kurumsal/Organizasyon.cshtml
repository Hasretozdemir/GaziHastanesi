@model List<GaziHastane.Models.KurumsalIcerik>
@using System.IO
@{
    ViewData["Title"] = "Organizasyon Şemaları - Kurumsal Bilgi Sistemi";
}

<style>
    .page-fade-in {
        animation: fadeInPage 0.6s ease-out forwards;
        opacity: 0;
    }

    @@keyframes fadeInPage {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .schema-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 1.5rem;
        padding: 1.5rem;
        box-shadow: 0 12px 40px rgba(0,0,0,0.04);
        scroll-margin-top: 120px;
    }

    .schema-file {
        display: flex;
        align-items: center;
        gap: 1rem;
        border: 1px solid #dbeafe;
        background: linear-gradient(180deg, #f8fbff, #ffffff);
        border-radius: 1rem;
        padding: 1rem 1.1rem;
        text-decoration: none;
        color: inherit;
        transition: all 0.2s ease;
    }

    .schema-file:hover {
        transform: translateY(-2px);
        border-color: #93c5fd;
        box-shadow: 0 8px 18px rgba(37,99,235,0.08);
    }

    .schema-icon {
        width: 3rem;
        height: 3rem;
        border-radius: 0.9rem;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: white;
        flex-shrink: 0;
    }
</style>

<main class="max-w-[1400px] mx-auto px-4 sm:px-6 py-8 mt-24 page-fade-in">
    <div class="flex flex-col lg:flex-row gap-7">
        <aside class="w-full lg:w-72 flex-shrink-0">
            @await Html.PartialAsync("_KurumsalSidebar")
        </aside>

        <section class="flex-1 min-w-0">
            <nav class="flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-slate-400 mb-6">
                <i class="fa-solid fa-house text-[9px]"></i>
                <i class="fa-solid fa-chevron-right text-[8px]"></i>
                <span>Kurumsal</span>
                <i class="fa-solid fa-chevron-right text-[8px]"></i>
                <span class="text-blue-600">Organizasyon Şemaları</span>
            </nav>

            @if (Model != null && Model.Any())
            {
                <div class="space-y-4">
                    @foreach (var item in Model.OrderBy(x => x.Sira))
                    {
                        <article id="org-@item.Id" class="schema-card">
                            <div class="flex items-start gap-4 mb-4">
                                <div class="w-1.5 h-10 bg-blue-600 rounded-full mt-1"></div>
                                <div class="flex-1">
                                    <h1 class="text-2xl font-black text-slate-800">@item.Baslik</h1>
                                    @if (!string.IsNullOrWhiteSpace(item.Aciklama))
                                    {
                                        <p class="text-slate-600 mt-2 leading-relaxed">@item.Aciklama</p>
                                    }
                                </div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(item.MedyaYolu))
                            {
                                <a href="@item.MedyaYolu" target="_blank" class="schema-file">
                                    <div class="schema-icon">
                                        <i class="fa-solid fa-file-image"></i>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <div class="text-sm font-bold text-slate-900">@System.IO.Path.GetFileName(item.MedyaYolu)</div>
                                        <div class="text-xs text-slate-500 mt-1">Şemayı açmak için tıklayın</div>
                                    </div>
                                    <i class="fa-solid fa-arrow-up-right-from-square text-blue-600"></i>
                                </a>
                            }
                            else
                            {
                                <div class="schema-file">
                                    <div class="schema-icon">
                                        <i class="fa-solid fa-diagram-project"></i>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <div class="text-sm font-bold text-slate-900">Dosya eklenmemiş</div>
                                        <div class="text-xs text-slate-500 mt-1">Bu başlık için henüz şema dosyası yüklenmedi.</div>
                                    </div>
                                </div>
                            }
                        </article>
                    }
                </div>
            }
            else
            {
                <div class="bg-white rounded-[1.75rem] p-12 border border-slate-100 text-center">
                    <i class="fa-solid fa-inbox text-5xl text-slate-300 mb-4"></i>
                    <p class="text-slate-500 font-medium text-lg">Organizasyon şemaları henüz eklenmemiştir.</p>
                    <p class="text-slate-400 text-sm mt-2">Admin panelinden başlık ve şema dosyası ekleyebilirsiniz.</p>
                </div>
            }
        </section>
    </div>
</main>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const hash = window.location.hash.replace('#', '');
        if (hash) {
            const target = document.getElementById(hash);
            if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        }
    });
</script>
