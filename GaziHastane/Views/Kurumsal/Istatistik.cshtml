@model List<GaziHastane.Models.KurumsalIcerik>
@{
    Layout = "_KurumsalLayout";
    ViewData["Title"] = "İstatistik ve Raporlama";
    var sekmeler = ViewBag.Sekmeler as List<GaziHastane.Models.KurumsalSekme> ?? new List<GaziHastane.Models.KurumsalSekme>();
}

<style>
    .tab-panel { display: none; }
    .tab-panel.active { display: block; animation: panelFadeIn 0.5s ease forwards; }
    @@keyframes panelFadeIn { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }
    .content-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 2rem; padding: 2.5rem; box-shadow: 0 15px 50px rgba(0,0,0,0.03); margin-bottom: 2rem; }
</style>

<div class="max-w-6xl mx-auto py-12 px-4 sm:px-6 mt-10">
    <div class="mb-10">
        <nav class="flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-slate-400 mb-4">
            <i class="fa-solid fa-house"></i> <i class="fa-solid fa-chevron-right text-[8px]"></i>
            <span>Kurumsal</span> <i class="fa-solid fa-chevron-right text-[8px]"></i>
            <span class="text-blue-600">İstatistik ve Raporlama</span>
        </nav>
        <h1 class="text-4xl sm:text-5xl font-black text-slate-800 tracking-tight mb-2">İstatistik ve Raporlama</h1>
        <p class="text-slate-500 font-medium">Faaliyet raporları, verimlilik istatistikleri ve kurumsal veriler.</p>
    </div>

    <div class="min-h-[500px]">
        @if (sekmeler.Any())
        {
            @for (int i = 0; i < sekmeler.Count; i++)
            {
                var sekme = sekmeler[i];
                var icerikler = Model?.Where(x => x.Kategori == sekme.SekmeId).OrderBy(x => x.Sira).ToList() ?? new List<GaziHastane.Models.KurumsalIcerik>();
                <div id="@sekme.SekmeId" class="tab-panel @(i == 0 ? "active" : "")">
                    <h2 class="text-2xl font-black text-slate-700 mb-6 border-b border-slate-100 pb-4">@sekme.Baslik</h2>
                    @if (!icerikler.Any())
                    {
                        <div class="bg-white rounded-[2rem] p-20 text-center border border-slate-100 shadow-sm">
                            <i class="fa-solid fa-chart-line text-5xl text-slate-200 mb-4"></i>
                            <h3 class="text-xl font-bold text-slate-400">Bu kategori için henüz içerik eklenmemiş.</h3>
                        </div>
                    }
                    else
                    {
                        <div class="space-y-8">
                            @foreach (var item in icerikler)
                            {
                                <article class="content-card">
                                    <div class="flex items-start gap-5 mb-6">
                                        <div class="w-2 h-10 bg-blue-600 rounded-full mt-1"></div>
                                        <div class="flex-1"><h2 class="text-3xl font-black text-slate-800 leading-tight">@item.Baslik</h2></div>
                                    </div>
                                    <div class="prose prose-slate max-w-none text-slate-700 leading-relaxed text-lg">@Html.Raw(item.Aciklama)</div>
                                </article>
                            }
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div class="space-y-8">
                @foreach (var item in Model.OrderBy(x => x.Sira))
                {
                    <article class="content-card">
                        <div class="flex items-start gap-5 mb-6">
                            <div class="w-2 h-10 bg-blue-600 rounded-full mt-1"></div>
                            <div class="flex-1"><h2 class="text-3xl font-black text-slate-800">@item.Baslik</h2></div>
                        </div>
                        <div class="prose prose-slate max-w-none text-slate-700 leading-relaxed text-lg">@Html.Raw(item.Aciklama)</div>
                    </article>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function switchTab(tabId) {
            document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
            const target = document.getElementById(tabId);
            if (target) target.classList.add('active');
            if(history.pushState) { history.pushState(null, null, '#' + tabId); }
        }
        function handleHash() {
            const hash = decodeURIComponent(window.location.hash.replace('#', ''));
            if (hash) { switchTab(hash); }
        }
        window.addEventListener('hashchange', handleHash);
        document.addEventListener('DOMContentLoaded', handleHash);
    </script>
}
