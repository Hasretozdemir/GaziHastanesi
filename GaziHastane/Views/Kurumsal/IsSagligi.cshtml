        /* ==========================================
                   3. ï¿½ï¿½ MENï¿½ (SEKMELER)
                   ========================================== */
        @@media (max-width: 1279px) {
            .mobile-tab-menu {
                display: flex !important;
                flex-direction: row !important;
                overflow-x: auto;
                white-space: nowrap;
                gap: 0.5rem;
                padding-bottom: 0.5rem;
                -webkit-overflow-scrolling: touch;
            }

                .mobile-tab-menu > * {
                    margin-top: 0 !important;
                }

                .mobile-tab-menu::-webkit-scrollbar {
                    display: none;
                }

