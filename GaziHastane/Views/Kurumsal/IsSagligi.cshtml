                display: none;
            }
        }

        .sub-menu-btn {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            width: 100%;
            padding: 0.85rem 1rem;
            border-radius: 14px;
            font-size: 0.8rem;
            font-weight: 700;
            color: #475569;
            background: white;
            border: 1px solid #f1f5f9;
            cursor: pointer;
            transition: all 0.2s;
            text-align: left;
        }

            .sub-menu-btn:hover {
                background: #f8fafc;
                transform: translateX(3px);
            }

            .sub-menu-btn.active {
                background: #eff6ff;
                color: #2563eb;
