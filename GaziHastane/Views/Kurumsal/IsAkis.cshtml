@model List<GaziHastane.Models.KurumsalIcerik>
@{
    Layout = "_KurumsalLayout";
    ViewData["Title"] = "İş Akış Şemaları";
    var sekmeler = ViewBag.Sekmeler as List<GaziHastane.Models.KurumsalSekme> ?? new List<GaziHastane.Models.KurumsalSekme>();
}

<style>
    .tab-nav { display: flex; gap: 0.75rem; overflow-x: auto; padding: 0.5rem 0.25rem 1.5rem; margin-bottom: 2rem; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
    .tab-nav::-webkit-scrollbar { display: none; }
    .tab-link { white-space: nowrap; padding: 0.85rem 1.5rem; border-radius: 1.25rem; background: #fff; border: 1px solid #e2e8f0; color: #64748b; font-weight: 700; font-size: 0.9rem; transition: all 0.3s ease; cursor: pointer; display: flex; align-items: center; gap: 0.6rem; }
    .tab-link:hover { background: #f8fafc; color: #2563eb; transform: translateY(-2px); }
    .tab-link.active { background: #2563eb; color: #fff; border-color: #2563eb; box-shadow: 0 10px 25px rgba(37,99,235,0.2); transform: translateY(-2px); }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; animation: panelFadeIn 0.5s ease forwards; }
    @@keyframes panelFadeIn { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }
    .content-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 2rem; padding: 2.5rem; box-shadow: 0 15px 50px rgba(0,0,0,0.03); margin-bottom: 2rem; }
    .schema-file { display: flex; align-items: center; gap: 1.25rem; border: 1px solid #dbeafe; background: linear-gradient(180deg, #f8fbff, #ffffff); border-radius: 1.5rem; padding: 1.5rem; text-decoration: none !important; color: inherit; transition: all 0.3s ease; }
    .schema-file:hover { transform: translateY(-3px); border-color: #93c5fd; box-shadow: 0 12px 30px rgba(37,99,235,0.08); }
    .custom-scroll::-webkit-scrollbar { width: 6px; height: 6px; }
    .custom-scroll::-webkit-scrollbar-track { background: transparent; }
    .custom-scroll::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    .doc-link:hover { border-color: #3b82f6; transform: translateY(-3px); box-shadow: 0 12px 30px rgba(37,99,235,0.08); }
    .hero-gradient { background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%); border-radius: 2.5rem; padding: 4.5rem; color: white; margin-bottom: 3rem; box-shadow: 0 20px 40px rgba(37,99,235,0.15); }
</style>

<div class="max-w-[1400px] mx-auto py-12 px-8 md:px-12 mt-10">
    <div class="hero-gradient">
        <nav class="flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-blue-200 mb-4">
            <i class="fa-solid fa-house"></i> <i class="fa-solid fa-chevron-right text-[8px]"></i>
            <span>Kurumsal</span> <i class="fa-solid fa-chevron-right text-[8px]"></i>
            <span class="text-white">@ViewData["Title"]</span>
        </nav>
        <h1 class="text-4xl sm:text-5xl font-black tracking-tight mb-0">@ViewData["Title"]</h1>
    </div>

    <div class="min-h-[500px]">
        @if (sekmeler.Any())
        {
            @for (int i = 0; i < sekmeler.Count; i++)
            {
                var sekme = sekmeler[i];
                var icerikler = Model?.Where(x => x.Kategori == sekme.SekmeId).OrderBy(x => x.Sira).ToList() ?? new List<GaziHastane.Models.KurumsalIcerik>();
                
                <div id="@sekme.SekmeId" class="tab-panel @(i == 0 ? "active" : "")">
                    @if (!icerikler.Any())
                    {
                        <div class="bg-white rounded-[2rem] p-20 text-center border border-slate-100 shadow-sm">
                            <i class="fa-solid fa-diagram-project text-5xl text-slate-200 mb-4"></i>
                            <h3 class="text-xl font-bold text-slate-400">Henüz akış şeması eklenmemiş.</h3>
                        </div>
                    }
                    else
                    {
                        <div class="space-y-8">
                            @foreach (var item in icerikler)
                            {
                                <article class="content-card">
                                    <div class="flex items-start gap-5 mb-6">
                                        <div class="w-2 h-10 bg-blue-600 rounded-full mt-1"></div>
                                        <div class="flex-1"><h2 class="text-3xl font-black text-slate-800 leading-tight">@item.Baslik</h2></div>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(item.Aciklama)) { <div class="prose prose-slate max-w-none text-slate-700 leading-relaxed text-lg mb-8">@Html.Raw(item.Aciklama)</div> }
                                    @if (!string.IsNullOrWhiteSpace(item.MedyaYolu)) {
                                        <a href="@item.MedyaYolu" target="_blank" class="schema-file group">
                                            <div class="w-16 h-16 bg-blue-600 text-white rounded-2xl flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform shadow-lg"><i class="fa-solid fa-file-image text-2xl"></i></div>
                                            <div class="flex-1">
                                                <div class="text-xs font-black text-blue-600 uppercase tracking-widest mb-1">Akış Şeması Dosyası</div>
                                                <div class="text-xl font-bold text-slate-900 line-clamp-1">@System.IO.Path.GetFileName(item.MedyaYolu)</div>
                                            </div>
                                            <i class="fa-solid fa-arrow-up-right-from-square text-blue-600 text-xl"></i>
                                        </a>
                                    }
                                </article>
                            }
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div class="space-y-8">
                @foreach (var item in Model.OrderBy(x => x.Sira))
                {
                    <article class="content-card">
                        <div class="flex items-start gap-5 mb-6">
                            <div class="w-2 h-10 bg-blue-600 rounded-full mt-1"></div>
                            <div class="flex-1"><h2 class="text-3xl font-black text-slate-800">@item.Baslik</h2></div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(item.Aciklama)) { <div class="prose prose-slate max-w-none text-slate-700 leading-relaxed text-lg">@Html.Raw(item.Aciklama)</div> }
                        @if (!string.IsNullOrWhiteSpace(item.MedyaYolu)) {
                            <a href="@item.MedyaYolu" target="_blank" class="schema-file mt-6">
                                <i class="fa-solid fa-file-image text-blue-600 text-2xl"></i>
                                <span class="font-bold text-slate-700">Şemayı Görüntüle</span>
                            </a>
                        }
                    </article>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function switchTab(tabId) {
            document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.tab-link').forEach(l => l.classList.remove('active'));
            const target = document.getElementById(tabId);
            const link = document.getElementById('link-' + tabId);
            if (target) target.classList.add('active');
            if (link) {
                link.classList.add('active');
                link.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
            }
            if(history.pushState) { history.pushState(null, null, '#' + tabId); }
        }
        function handleHash() {
            const hash = decodeURIComponent(window.location.hash.replace('#', ''));
            if (hash) { switchTab(hash); }
        }
        window.addEventListener('hashchange', handleHash);
        document.addEventListener('DOMContentLoaded', handleHash);
    </script>
}