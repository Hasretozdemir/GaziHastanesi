@using GaziHastane.Data
@inject GaziHastaneContext _context
@{
    Layout = "_KurumsalLayout";
    ViewData["Title"] = "Bilgi Islem Merkezi - Kurumsal Bilgi Sistemi";

    var sekmeler = _context.KurumsalSekmeler
        .Where(x => x.SayfaKey.ToLower() == "bilgiislemmerkezi" && x.AktifMi)
        .OrderBy(x => x.Sira)
        .ToList();
}

@section Scripts {
<style>
    .tab-content { display: none; opacity: 0; transform: translateY(10px); }
    .tab-content.active { display: block; animation: fadeInTab 0.35s ease forwards; }
    @@keyframes fadeInTab { to { opacity: 1; transform: translateY(0); } }

    .sub-menu-dropdown { position: relative; display: inline-block; }
    .sub-menu-dropdown::after { content: ""; position: absolute; left: 0; top: 100%; width: 100%; height: 12px; }
    .dropdown-trigger { display: flex; align-items: center; gap: 0.35rem; color: #2563eb; background: transparent; border: 0; padding: 0; font: inherit; cursor: pointer; }
    .dropdown-trigger::-webkit-details-marker { display: none; }
    .dropdown-panel {
        position: absolute; top: calc(100% + 0.55rem); left: 0; min-width: 260px;
        background: #fff; border: 1px solid #e2e8f0; border-radius: 0.9rem; padding: 0.6rem;
        box-shadow: 0 14px 34px rgba(15,23,42,0.12); opacity: 0; visibility: hidden;
        transform: translateY(8px); transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease; z-index: 60;
    }
    .sub-menu-dropdown:hover .dropdown-panel,
    .sub-menu-dropdown[open] .dropdown-panel,
    .sub-menu-dropdown:focus-within .dropdown-panel { opacity: 1; visibility: visible; transform: translateY(0); }

    .dropdown-item {
        width: 100%; border: 0; background: transparent; text-align: left; display: flex; align-items: center; gap: 0.6rem;
        border-radius: 0.7rem; padding: 0.6rem 0.75rem; color: #475569; font-size: 0.8rem; font-weight: 700;
        cursor: pointer; transition: all 0.2s ease;
    }
    .dropdown-item:hover { background: #f8fafc; color: #2563eb; }
    .dropdown-item.active { background: #eff6ff; color: #1d4ed8; }
</style>

<script>
    function openTab(event, tabId) {
        if (event) event.preventDefault();
        document.querySelectorAll('.dropdown-item').forEach(item => item.classList.remove('active'));
        if (event) {
            event.currentTarget.classList.add('active');
        } else {
            let activeBtn = document.querySelector(`[onclick*="${tabId}"]`);
            if (activeBtn) activeBtn.classList.add('active');
        }

        document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
        const target = document.getElementById(tabId);
        if (target) target.classList.add('active');

        if (history.pushState) history.pushState(null, null, '#' + tabId);

        const dropdown = document.querySelector('.sub-menu-dropdown');
        if (dropdown) dropdown.removeAttribute('open');
    }

    document.addEventListener('DOMContentLoaded', function () {
        const hash = window.location.hash.substring(1);
        if (hash && document.getElementById(hash)) {
            openTab(null, hash);
        } else {
            openTab(null, 'genel-bilgi');
        }
    });
</script>
}

<div class="flex flex-col w-full h-full">
    <section class="flex-1 min-w-0">
        <nav class="flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-slate-400 mb-6">
            <i class="fa-solid fa-house text-[9px]"></i>
            <i class="fa-solid fa-chevron-right text-[8px]"></i>
            <span>Kurumsal</span>
            <i class="fa-solid fa-chevron-right text-[8px]"></i>
            <details class="sub-menu-dropdown">
                <summary class="dropdown-trigger">Bilgi Islem Merkezi <i class="fa-solid fa-chevron-down text-[8px]"></i></summary>
                <div class="dropdown-panel">
                    <button onclick="openTab(event, 'genel-bilgi')" class="dropdown-item active">
                        <i class="fa-solid fa-circle-info w-4 text-center"></i> Genel Bilgi
                    </button>
                    @if (sekmeler != null && sekmeler.Any())
                    {
                        foreach (var sekme in sekmeler)
                        {
                            <button onclick="openTab(event, '@sekme.SekmeId')" class="dropdown-item">
                                <i class="@(string.IsNullOrWhiteSpace(sekme.IconClass) ? "fa-solid fa-circle-info" : sekme.IconClass) w-4 text-center"></i> @sekme.Baslik
                            </button>
                        }
                    }
                </div>
            </details>
        </nav>

        <div class="w-full bg-white rounded-[1.75rem] p-7 sm:p-10 border border-slate-100" style="box-shadow: 0 12px 40px rgba(0,0,0,0.04); min-height: 600px;">
            <div id="genel-bilgi" class="tab-content active">
                <div class="flex items-center gap-3 mb-8">
                    <div class="w-1.5 h-8 bg-blue-600 rounded-full"></div>
                    <h2 class="text-2xl font-black text-slate-800">Bilgi Islem Merkezi</h2>
                </div>
                <p class="text-slate-600 leading-relaxed font-medium">
                    Bilgi Islem Merkezi ile ilgili iceriklere bu alandan ulasabilirsiniz. Admin panelinden eklenen sekmeler
                    otomatik olarak menude gorunur ve tiklandiginda ilgili icerik acilir.
                </p>
            </div>

            @if (sekmeler != null && sekmeler.Any())
            {
                foreach (var sekme in sekmeler)
                {
                    <div id="@sekme.SekmeId" class="tab-content">
                        @if (!string.IsNullOrWhiteSpace(sekme.Icerik))
                        {
                            @Html.Raw(sekme.Icerik)
                        }
                    </div>
                }
            }
        </div>
    </section>
</div>
