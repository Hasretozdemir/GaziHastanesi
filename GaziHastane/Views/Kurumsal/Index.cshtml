@* RAZOR KOD BLOĐU: Sunucu tarafýnda çalýţan C# kodlarýnýn yazýldýđý alan. *@
@{
    // Sayfanýn baţlýđýný belirliyoruz. Bu baţlýk tarayýcý sekmesinde görünür.
    ViewData["Title"] = "Hakkýmýzda - Kurumsal Bilgi Sistemi";
}

@section Scripts {
    <style>
        /* 1. SAYFA YÜKLENME ANÝMASYONU (Zýplamayý Engeller) */
        .page-fade-in {
            animation: fadeInPage 0.6s ease-out forwards;
            opacity: 0;
        }

        @@keyframes fadeInPage {
            from {
                opacity: 0;
                transform: translateY(15px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* 2. RESPONSIVE ÝÇ MENÜ (Mobilde yatay kaydýrýlabilir menü) */
        @@media (max-width: 1279px) { /* Tailwind xl breakpoint altý için */
            .mobile-tab-menu {
                display: flex !important;
                flex-direction: row !important;
                overflow-x: auto;
                white-space: nowrap;
                gap: 0.5rem;
                padding-bottom: 0.5rem; /* Scrollbar için biraz boţluk */
                -webkit-overflow-scrolling: touch; /* Mobilde pürüzsüz kaydýrma */
            }

                .mobile-tab-menu > * {
                    margin-top: 0 !important; /* space-y-2 sýnýfýný mobilde ezer */
                }

                .mobile-tab-menu::-webkit-scrollbar {
                    display: none; /* Mobilde çirkin scrollbar'ý gizle */
                }

            .sub-menu-btn {
                width: auto !important;
                flex-shrink: 0;
                padding: 0.6rem 1.2rem;
            }

            .kurumsal-icerik-baslik {
                display: none; /* Mobilde baţlýđý gizle, yer kaplamasýn */
            }
        }

        /* YAN MENÜ LÝNKLERÝ (Mevcut stillerin) */
        .sidebar-link {
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.65rem 0.9rem;
            border-radius: 12px;
            font-size: 0.82rem;
            font-weight: 600;
            color: #64748b;
            text-decoration: none;
        }

            .sidebar-link:hover {
                background: #eff6ff;
                color: #2563eb;
                transform: translateX(4px);
            }

            .sidebar-link[href="/Kurumsal/Index"] {
                background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
                color: white;
                box-shadow: 0 4px 14px rgba(37,99,235,0.25);
            }

        .section-title {
            font-size: 0.68rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: #94a3b8;
            margin: 1.4rem 0.9rem 0.4rem;
        }

        .custom-scroll::-webkit-scrollbar {
            width: 4px;
        }

        .custom-scroll::-webkit-scrollbar-track {
            background: transparent;
        }

        .custom-scroll::-webkit-scrollbar-thumb {
            background: #e2e8f0;
            border-radius: 10px;
        }

        .sub-menu-btn {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            width: 100%;
            padding: 0.85rem 1rem;
            border-radius: 14px;
            font-size: 0.8rem;
            font-weight: 700;
            color: #475569;
            background: white;
            border: 1px solid #f1f5f9;
            cursor: pointer;
            transition: all 0.2s;
            text-align: left;
        }

            .sub-menu-btn:hover {
                background: #f8fafc;
                transform: translateX(3px);
            }

            .sub-menu-btn.active {
                background: #eff6ff;
                color: #2563eb;
                border-color: #bfdbfe;
                box-shadow: 0 4px 12px rgba(37,99,235,0.08);
            }

        /* 3. TAB ÝÇERÝKLERÝ YUMUŢAK GEÇÝŢ ANÝMASYONU */
        .tab-content {
            display: none;
            opacity: 0;
            transform: translateY(10px);
        }

            .tab-content.active {
                display: block;
                animation: fadeInTab 0.4s ease forwards;
            }

        @@keyframes fadeInTab {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .timeline-dot {
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: #2563eb;
            flex-shrink: 0;
            margin-top: 4px;
            box-shadow: 0 0 0 4px rgba(37,99,235,0.15);
        }

        .feature-card {
            border-radius: 20px;
            padding: 1.5rem;
            transition: transform 0.2s, box-shadow 0.2s;
            position: relative;
            overflow: hidden;
        }

            .feature-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 16px 30px rgba(0,0,0,0.06);
            }
    </style>

    <script>
        function openTab(event, tabId) {
            // Sayfanýn yenilenmesini veya yukarý zýplamasýný engelle
            if(event) event.preventDefault();

            // 1. Tüm butonlarý pasif yap
            document.querySelectorAll('.sub-menu-btn').forEach(btn => btn.classList.remove('active'));

            // 2. Týklanan butonu aktif yap
            if(event) {
                event.currentTarget.classList.add('active');
            } else {
                // Eđer event yoksa (sayfa ilk yüklendiđinde URL'den geliyorsa)
                let activeBtn = document.querySelector(`[onclick*="${tabId}"]`);
                if(activeBtn) activeBtn.classList.add('active');
            }

            // 3. Tüm içerik alanlarýný gizle
            document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));

            // 4. Sadece seçilen 'tabId'ye sahip içeriđi göster
            let targetContent = document.getElementById(tabId);
            if(targetContent) targetContent.classList.add('active');

            // 5. URL'yi güncelle (sayfa yenilenmeden geçmiţe ekler)
            if(history.pushState) {
                history.pushState(null, null, '#' + tabId);
            }
        }

        // Sayfa ilk yüklendiđinde URL'de #varsa (örn: .../Kurumsal/Index#misyon) o sekmeyi aç
        document.addEventListener('DOMContentLoaded', function() {
            let hash = window.location.hash.substring(1);
            if(hash && document.getElementById(hash)) {
                openTab(null, hash);
            }
        });
    </script>
}

