@model GaziHastane.Models.KurumsalSayfa
@{
    var breadcrumbTitle = ViewData["BreadcrumbTitle"]?.ToString() ?? Model?.Baslik ?? "Kurumsal Sayfa";
}

<main class="max-w-[1400px] mx-auto px-4 sm:px-6 py-8 mt-24">
    <div class="flex flex-col lg:flex-row gap-7">
        <aside class="w-full lg:w-72 flex-shrink-0">
            @await Html.PartialAsync("_KurumsalSidebar")
        </aside>

        <section class="flex-1 min-w-0">
            <nav class="flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-slate-400 mb-6">
                <i class="fa-solid fa-house text-[9px]"></i>
                <i class="fa-solid fa-chevron-right text-[8px]"></i>
                <span>Kurumsal</span>
                <i class="fa-solid fa-chevron-right text-[8px]"></i>
                <span class="text-blue-600">@breadcrumbTitle</span>
            </nav>

            <div class="bg-white rounded-[1.75rem] p-7 sm:p-10 border border-slate-100" style="box-shadow: 0 12px 40px rgba(0,0,0,0.04); min-height: 420px;">
                @if (!string.IsNullOrWhiteSpace(Model?.Baslik))
                {
                    <h1 class="text-2xl font-black text-slate-800 mb-6">@Model.Baslik</h1>
                }

                <div class="prose max-w-none">
                    @Html.Raw(Model?.Icerik ?? string.Empty)
                </div>
            </div>
        </section>
    </div>
</main>
