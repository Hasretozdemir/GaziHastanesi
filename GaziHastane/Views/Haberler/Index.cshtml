@model IEnumerable<GaziHastane.Models.Haber>
@{
    ViewData["Title"] = "Haberler";
    Layout = "_EmptyLayout";
}

<div class="bg-gradient-to-br from-slate-900 via-blue-900 to-indigo-900 py-16 sm:py-20 relative overflow-hidden mb-[-2rem] z-0">
    <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 rounded-full bg-blue-500/20 blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 rounded-full bg-indigo-500/20 blur-3xl pointer-events-none"></div>
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjIiIGZpbGw9IiNmZmYiIGZpbGwtb3BhY2l0eT0iMC4wNSIvPjwvc3ZnPg==')] opacity-20"></div>

    <div class="max-w-[96%] 2xl:max-w-[1600px] mx-auto px-4 sm:px-8 relative z-10 pb-8">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-8">
            <div class="flex items-center gap-6">
                <div class="w-20 h-20 sm:w-24 sm:h-24 bg-white/10 backdrop-blur-md border border-white/20 text-white rounded-[2rem] flex items-center justify-center text-4xl sm:text-5xl shadow-[0_0_40px_rgba(59,130,246,0.3)]">
                    <i class="fa-regular fa-newspaper"></i>
                </div>
                <div>
                    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 border border-white/20 text-blue-200 text-[10px] font-black tracking-widest uppercase mb-3 backdrop-blur-sm">
                        <span class="w-2 h-2 rounded-full bg-blue-400 animate-pulse"></span>
                        Gazi Hastanesi
                    </div>
                    <h1 class="text-white text-4xl sm:text-6xl font-black leading-tight tracking-tight mb-2 drop-shadow-md">Haberler</h1>
                    <p class="text-blue-100/80 text-sm sm:text-base font-medium max-w-xl leading-relaxed">
                        Hastanemizdeki en güncel gelişmeleri, tıbbi başarıları ve önemli duyuruları buradan takip edebilirsiniz.
                    </p>
                </div>
            </div>


        </div>
    </div>
</div>

<section class="py-16 bg-slate-50 min-h-screen relative z-10 rounded-t-[3rem] shadow-[0_-20px_40px_rgba(0,0,0,0.1)]">
    <div class="max-w-[96%] 2xl:max-w-[1600px] mx-auto px-4 sm:px-8">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 sm:gap-10">
            @if (Model != null && Model.Any())
            {
                foreach (var haber in Model)
                {
                    <button type="button" onclick="openHaberModal(@haber.Id)" class="bg-white rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 border-2 border-blue-200 hover:border-blue-400 group flex flex-col h-full text-left w-full">
                        <div class="h-72 overflow-hidden relative border-b-2 border-blue-100">
                            <img src="@haber.GorselUrl" alt="@haber.Baslik" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">

                            <div class="absolute top-5 left-5 bg-white/95 backdrop-blur px-4 py-2 rounded-lg text-xs uppercase tracking-wide font-black text-blue-800 shadow-md border border-white/50">
                                <i class="fa-solid fa-tag text-blue-500 mr-1"></i> @haber.Kategori
                            </div>
                        </div>
                        <div class="p-8 flex flex-col flex-1 justify-between">
                            <div>
                                <p class="text-xs text-slate-500 font-semibold mb-3 flex items-center">
                                    <i class="fa-regular fa-calendar-days mr-2 text-slate-400"></i> @haber.YayinTarihi.ToString("dd MMMM yyyy")
                                </p>
                                <h3 class="text-lg font-bold text-slate-800 group-hover:text-blue-700 transition-colors mb-3 line-clamp-2 leading-snug">
                                    @haber.Baslik
                                </h3>
                                <p class="text-sm text-slate-500 line-clamp-3 mb-4 font-medium leading-relaxed">
                                    @haber.Ozet
                                </p>
                            </div>
                            <div class="flex items-center text-sm font-bold text-blue-600 group-hover:text-blue-800 mt-auto">
                                Haberi Oku <i class="fa-solid fa-arrow-right ml-2 group-hover:translate-x-1 transition-transform"></i>
                            </div>
                        </div>
                    </button>
                }
            }
            else
            {
                <div class="col-span-full flex flex-col items-center justify-center py-24 bg-white rounded-3xl border border-slate-200 border-dashed">
                    <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mb-4">
                        <i class="fa-regular fa-newspaper text-4xl text-slate-300"></i>
                    </div>
                    <h3 class="text-xl font-bold text-slate-700 mb-1">Haber Bulunmuyor</h3>
                    <p class="text-slate-500 text-sm">Şu an için yayınlanmış güncel bir kurumsal haber bulunmamaktadır.</p>
                </div>
            }
        </div>
    </div>
</section>

<div id="haberModal" class="fixed inset-0 z-[120] hidden bg-black/60 backdrop-blur-sm flex items-center justify-center opacity-0 transition-opacity duration-200 p-4">
    <div id="haberModalContent" class="bg-white w-full max-w-3xl rounded-3xl overflow-hidden shadow-2xl border border-slate-100 transform scale-95 transition-transform duration-200 max-h-[90vh] flex flex-col">
        <div class="relative h-64">
            <img id="haberModalImage" src="" alt="Haber" class="w-full h-full object-cover">
            <button type="button" onclick="closeHaberModal()" class="absolute top-4 right-4 w-10 h-10 rounded-full bg-white/90 text-slate-700 hover:bg-white flex items-center justify-center shadow">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <div class="p-6 overflow-y-auto">
            <div class="flex items-center gap-3 mb-3">
                <span id="haberModalKategori" class="text-[10px] font-bold bg-blue-100 text-blue-700 px-2 py-1 rounded uppercase"></span>
                <span id="haberModalTarih" class="text-xs text-slate-400 font-semibold"></span>
            </div>
            <h3 id="haberModalBaslik" class="text-2xl font-black text-slate-900 mb-3"></h3>
            <p id="haberModalOzet" class="text-slate-500 text-sm mb-5"></p>
            <div id="haberModalIcerik" class="prose prose-sm max-w-none text-slate-700"></div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        html {
            overflow-y: scroll;
            overflow-x: hidden;
        }
        body {
            overflow-x: hidden;
            width: 100%;
            margin: 0;
            padding: 0;
        }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const haberModal = document.getElementById('haberModal');
            const haberModalContent = document.getElementById('haberModalContent');
            const haberModalImage = document.getElementById('haberModalImage');
            const haberModalKategori = document.getElementById('haberModalKategori');
            const haberModalTarih = document.getElementById('haberModalTarih');
            const haberModalBaslik = document.getElementById('haberModalBaslik');
            const haberModalOzet = document.getElementById('haberModalOzet');
            const haberModalIcerik = document.getElementById('haberModalIcerik');

            const haberData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                (Model ?? Enumerable.Empty<GaziHastane.Models.Haber>()).Select(h => new
                {
                    h.Id,
                    h.Baslik,
                    h.Ozet,
                    Icerik = h.Icerik ?? string.Empty,
                    h.GorselUrl,
                    h.Kategori,
                    Tarih = h.YayinTarihi.ToString("dd MMMM yyyy")
                })
            ));

            const haberMap = new Map(haberData.map(x => [x.Id ?? x.id, x]));

            window.openHaberModal = function (id) {
                const haber = haberMap.get(id);
                if (!haber) return;

                const gorselUrl = haber.GorselUrl ?? haber.gorselUrl;
                const baslik = haber.Baslik ?? haber.baslik;
                const kategori = haber.Kategori ?? haber.kategori;
                const tarih = haber.Tarih ?? haber.tarih;
                const ozet = haber.Ozet ?? haber.ozet;
                const icerik = haber.Icerik ?? haber.icerik;

                haberModalImage.src = gorselUrl;
                haberModalImage.alt = baslik;
                haberModalKategori.textContent = kategori;
                haberModalTarih.textContent = tarih;
                haberModalBaslik.textContent = baslik;
                haberModalOzet.textContent = ozet || '';
                haberModalIcerik.innerHTML = icerik || '<p class="text-slate-500 text-sm">Detay içeriği bulunmuyor.</p>';

                haberModal.classList.remove('hidden');
                setTimeout(() => {
                    haberModal.classList.remove('opacity-0');
                    haberModalContent.classList.remove('scale-95');
                }, 10);
            }

            window.closeHaberModal = function () {
                haberModal.classList.add('opacity-0');
                haberModalContent.classList.add('scale-95');
                setTimeout(() => {
                    haberModal.classList.add('hidden');
                }, 250);
            }
        });
    </script>
}