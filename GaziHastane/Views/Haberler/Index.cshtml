@model IEnumerable<GaziHastane.Models.Haber>
@{
    ViewData["Title"] = "Kurumsal Haberler";
}

<div class="bg-white border-b border-slate-200 py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row items-start sm:items-center gap-5">
        <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center text-2xl flex-shrink-0 border border-blue-100">
            <i class="fa-regular fa-newspaper"></i>
        </div>
        <div>
            <h1 class="text-3xl sm:text-4xl font-black text-slate-900 tracking-tight mb-2">Kurumsal Haberler</h1>
            <p class="text-slate-500 text-sm sm:text-base font-medium">
                Hastanemizdeki en güncel gelişmeleri, tıbbi başarıları ve duyuruları buradan takip edebilirsiniz.
            </p>
        </div>
    </div>
</div>

<section class="py-12 bg-slate-50 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            @if (Model != null && Model.Any())
            {
                foreach (var haber in Model)
                {
                    <a href="#" class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-300 border border-slate-200 group flex flex-col h-full">
                        <div class="h-56 overflow-hidden relative border-b border-slate-100">
                            <img src="@haber.GorselUrl" alt="@haber.Baslik" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">

                            <div class="absolute top-4 left-4 bg-white/95 backdrop-blur px-3 py-1.5 rounded-md text-[11px] uppercase tracking-wide font-black text-blue-700 shadow-sm border border-white/50">
                                <i class="fa-solid fa-tag text-blue-400 mr-1"></i> @haber.Kategori
                            </div>
                        </div>
                        <div class="p-6 flex flex-col flex-1 justify-between">
                            <div>
                                <p class="text-xs text-slate-500 font-semibold mb-3 flex items-center">
                                    <i class="fa-regular fa-calendar-days mr-2 text-slate-400"></i> @haber.YayinTarihi.ToString("dd MMMM yyyy")
                                </p>
                                <h3 class="text-lg font-bold text-slate-800 group-hover:text-blue-700 transition-colors mb-3 line-clamp-2 leading-snug">
                                    @haber.Baslik
                                </h3>
                                <p class="text-sm text-slate-500 line-clamp-3 mb-4 font-medium leading-relaxed">
                                    @haber.Ozet
                                </p>
                            </div>
                            <div class="flex items-center text-sm font-bold text-blue-600 group-hover:text-blue-800 mt-auto">
                                Haberi Oku <i class="fa-solid fa-arrow-right ml-2 group-hover:translate-x-1 transition-transform"></i>
                            </div>
                        </div>
                    </a>
                }
            }
            else
            {
                <div class="col-span-full flex flex-col items-center justify-center py-24 bg-white rounded-3xl border border-slate-200 border-dashed">
                    <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mb-4">
                        <i class="fa-regular fa-newspaper text-4xl text-slate-300"></i>
                    </div>
                    <h3 class="text-xl font-bold text-slate-700 mb-1">Haber Bulunmuyor</h3>
                    <p class="text-slate-500 text-sm">Şu an için yayınlanmış güncel bir kurumsal haber bulunmamaktadır.</p>
                </div>
            }
        </div>
    </div>
</section>