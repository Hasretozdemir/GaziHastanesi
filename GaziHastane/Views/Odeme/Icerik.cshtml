@model IEnumerable<GaziHastane.Models.BorcOdeme>
@{
    ViewData["Title"] = "Gazi Sağlık | Güvenli Ödeme ve Makbuz";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<div class="master-viewport">
    <div class="split-layout">

        <div class="side-left">
            <div class="panel-inner">
                <div class="d-flex justify-content-between align-items-center mb-5">
                    <img src="/assets/gazilogo.jpg" alt="Logo" class="main-logo">
                    <div class="badge-protocol">PROTOKOL: @ViewBag.Protokol</div>
                </div>

                <h2 class="title-main">Borç Bilgileri</h2>
                <p class="text-muted mb-4">Ödemek istediğiniz kalemleri seçip sağ panelden işleminizi tamamlayın.</p>

                <div class="debt-scroll-area">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var borc in Model)
                        {
                            <div class="debt-item active" id="row_@borc.Id">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="ui-checkbox">
                                        <input type="checkbox" checked id="chk_@borc.Id" class="debt-check"
                                               data-id="@borc.Id"
                                               data-name="@borc.IslemTipi"
                                               data-price="@borc.Tutar.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)">
                                        <label for="chk_@borc.Id"></label>
                                    </div>
                                    <div>
                                        <div class="debt-name">@borc.IslemTipi</div>
                                        <div class="debt-sub">Tarih: @borc.SonOdemeTarihi?.ToString("dd.MM.yyyy")</div>
                                    </div>
                                </div>
                                <div class="debt-price">@borc.Tutar.ToString("N2") ₺</div>
                            </div>
                        }
                    }
                </div>

                <div class="summary-box mt-auto">
                    <span class="summary-label">TOPLAM TUTAR</span>
                    <span class="summary-amount" id="displayTotal">0,00 ₺</span>
                </div>
            </div>
        </div>

        <div class="side-right">

            <div id="step-payment" class="panel-inner animate__animated animate__fadeIn">
                <h4 class="right-title"><i class="fas fa-shield-alt text-gold me-2"></i> Güvenli Kart Ödemesi</h4>

                <div class="card-ui mb-5">
                    <div class="d-flex justify-content-between align-items-start">
                        <i class="fas fa-microchip fs-1 text-gold"></i>
                        <i class="fab fa-cc-visa fs-2 opacity-50"></i>
                    </div>
                    <div class="mt-4 fs-4 fw-bold letter-spacing-2" id="v-card-num">**** **** **** ****</div>
                    <div class="d-flex justify-content-between mt-4">
                        <div>
                            <div class="v-small">AD SOYAD</div>
                            <div class="v-bold" id="v-card-name">@ViewBag.KullaniciAdSoyad</div>
                        </div>
                        <div>
                            <div class="v-small">SKT</div>
                            <div class="v-bold" id="v-card-date">08/29</div>
                        </div>
                    </div>
                </div>

                <form class="ui-form">
                    <div class="ui-input-group">
                        <label>KART ÜZERİNDEKİ İSİM</label>
                        <input type="text" id="in-name" placeholder="AD SOYAD" value="@ViewBag.KullaniciAdSoyad">
                    </div>
                    <div class="ui-input-group">
                        <label>KART NUMARASI</label>
                        <input type="text" id="in-num" placeholder="0000 0000 0000 0000" maxlength="19">
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="ui-input-group">
                                <label>SON KULLANMA</label>
                                <input type="text" id="in-date" placeholder="AA/YY" maxlength="5">
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="ui-input-group">
                                <label>CVV</label>
                                <input type="password" placeholder="***" maxlength="3">
                            </div>
                        </div>
                    </div>
                    <button type="button" id="btnConfirm" class="btn-pay-action mt-4">
                        ÖDEMEYİ ONAYLA <i class="fas fa-lock ms-2"></i>
                    </button>
                </form>
            </div>

            <div id="step-receipt" class="panel-inner" style="display:none;">
                <div id="success-notif" class="text-center mb-4 animate__animated animate__zoomIn">
                    <div class="success-ring"><i class="fas fa-check"></i></div>
                    <h3 class="text-white mt-3 fw-bold">Ödeme Tamamlandı!</h3>
                </div>

                <div id="faturaAlani" class="fatura-kagit animate__animated animate__fadeInUp animate__delay-1s">
                    <div class="fatura-filigran"><i class="fa-solid fa-hospital-user"></i></div>
                    <div class="fatura-icerik">
                        <div class="fatura-header d-flex justify-content-between align-items-start mb-4">
                            <div class="kurum-bilgi d-flex gap-3 align-items-center">
                                <img src="/assets/gazilogo.jpg" alt="Gazi Logo" style="height: 60px;">
                                <div class="kurum-detay">
                                    <h5 class="m-0 fw-bold color-navy">GAZİ ÜNİVERSİTESİ</h5>
                                    <p class="m-0 small text-muted">Sağlık Uygulama ve Araştırma Hastanesi</p>
                                </div>
                            </div>
                            <div class="belge-tipi text-end">
                                <h4 class="m-0 fw-black opacity-25">TAHSİLAT</h4>
                                <div class="badge bg-success small p-1 px-2 mt-1">Ödeme Onaylandı</div>
                            </div>
                        </div>

                        <div class="bilgi-grid-bg p-3 mb-4 rounded-3">
                            <div class="row g-3">
                                <div class="col-6">
                                    <small class="text-muted d-block">FATURA EDİLEN</small>
                                    <strong class="color-navy">@ViewBag.KullaniciAdSoyad</strong>
                                    <div class="small text-muted">TC: @ViewBag.TcKimlik</div>
                                </div>
                                <div class="col-6 text-end">
                                    <small class="text-muted d-block">MAKBUZ NO</small>
                                    <strong id="m-no">GZ-@DateTime.Now.Ticks.ToString().Substring(10)</strong>
                                    <div class="small text-muted" id="m-tarih">@DateTime.Now.ToString("dd.MM.yyyy HH:mm")</div>
                                </div>
                            </div>
                        </div>

                        <table class="islem-tablosu w-100 mb-4">
                            <thead>
                                <tr>
                                    <th class="text-start">İşlem Açıklaması</th>
                                    <th class="text-end">Tutar</th>
                                </tr>
                            </thead>
                            <tbody id="receipt-rows">
                            </tbody>
                        </table>

                        <div class="toplamlar-bolumu ms-auto" style="max-width: 250px;">
                            <div class="d-flex justify-content-between py-1 border-bottom border-dashed">
                                <span class="small">Ara Toplam</span>
                                <span id="r-sub" class="fw-bold">0,00 ₺</span>
                            </div>
                            <div class="d-flex justify-content-between py-1 border-bottom border-dashed">
                                <span class="small">KDV (%10)</span>
                                <span id="r-kdv" class="fw-bold">0,00 ₺</span>
                            </div>
                            <div class="d-flex justify-content-between py-2 bg-navy text-white px-2 mt-2 rounded">
                                <span class="fw-bold">GENEL TOPLAM</span>
                                <span id="r-total" class="fw-bold">0,00 ₺</span>
                            </div>
                        </div>

                        <div class="imza-not-bolumu d-flex justify-content-between align-items-end mt-5 pt-3 border-top">
                            <div class="yasal-not small text-muted" style="max-width: 60%;">
                                <i class="fa-solid fa-circle-info me-1"></i> Bu belge bilgilendirme amaçlıdır.
                            </div>
                            <div class="imza-yeri text-center">
                                <div class="imza-line mb-1"></div>
                                <div class="small fw-bold">Vezne Onayı</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <button onclick="downloadPDF()" class="btn btn-outline-light rounded-pill px-4">
                        <i class="fas fa-file-pdf me-2"></i> MAKBUZU İNDİR
                    </button>
                    <button onclick="location.reload()" class="btn btn-link text-white-50 small ms-3">Yeni Ödeme Yap</button>
                </div>
            </div>

        </div>
    </div>
</div>

@section Styles {
    <style>
        /* FULL SCREEN OVERRIDE */
        .master-viewport {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: #fff;
            z-index: 1050;
        }

        .split-layout {
            display: flex;
            height: 100vh;
            width: 100vw;
        }

        /* LEFT PANEL */
        .side-left {
            width: 50%;
            background: #f1f5f9;
            border-right: 1px solid #e2e8f0;
            overflow-y: auto;
        }

        .side-right {
            width: 50%;
            background: #0f172a;
            color: #fff;
            overflow-y: auto;
            display: flex;
            align-items: center;
        }

        .panel-inner {
            padding: 8% 12%;
            width: 100%;
        }

        /* DEBT ITEMS */
        .main-logo {
            height: 50px;
        }

        .badge-protocol {
            background: #cbd5e1;
            padding: 6px 15px;
            border-radius: 50px;
            font-weight: 800;
            font-size: 12px;
            color: #334155;
        }

        .title-main {
            font-weight: 900;
            color: #0f172a;
        }

        .debt-item {
            background: #fff;
            padding: 20px;
            border-radius: 15px;
            border: 2px solid #e2e8f0;
            margin-bottom: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: 0.3s;
        }

            .debt-item.active {
                border-color: #c5a059;
                background: #fffdf5;
                box-shadow: 0 5px 15px rgba(197, 160, 89, 0.1);
            }

        .debt-name {
            font-weight: 700;
            color: #0f172a;
        }

        .debt-sub {
            font-size: 12px;
            color: #64748b;
        }

        .debt-price {
            font-weight: 800;
            font-size: 18px;
            color: #c5a059;
        }

        .summary-box {
            background: #0f172a;
            padding: 25px;
            border-radius: 15px;
            color: #fff;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .summary-amount {
            font-weight: 900;
            font-size: 22px;
        }

        /* CARD UI */
        .card-ui {
            background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
            border-radius: 20px;
            padding: 30px;
            border: 1px solid rgba(255,255,255,0.1);
            box-shadow: 0 15px 35px rgba(0,0,0,0.4);
        }

        .text-gold {
            color: #c5a059;
        }

        .v-small {
            font-size: 10px;
            color: rgba(255,255,255,0.5);
            letter-spacing: 1px;
        }

        .v-bold {
            font-weight: 700;
            font-size: 14px;
        }

        /* FORM */
        .ui-input-group {
            margin-bottom: 18px;
        }

            .ui-input-group label {
                display: block;
                font-size: 10px;
                font-weight: 800;
                color: #94a3b8;
                margin-bottom: 6px;
            }

            .ui-input-group input {
                width: 100%;
                background: rgba(255,255,255,0.05);
                border: 1px solid rgba(255,255,255,0.1);
                padding: 15px;
                border-radius: 12px;
                color: #fff;
                font-weight: 600;
                outline: none;
                transition: 0.3s;
            }

                .ui-input-group input:focus {
                    border-color: #c5a059;
                    background: rgba(255,255,255,0.1);
                }

        .btn-pay-action {
            width: 100%;
            background: #c5a059;
            color: #0f172a;
            font-weight: 900;
            padding: 18px;
            border: none;
            border-radius: 12px;
            transition: 0.3s;
        }

            .btn-pay-action:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 20px rgba(197,160,89,0.3);
            }

        /* BAŞARI VE MAKBUZ */
        .success-ring {
            width: 60px;
            height: 60px;
            border: 4px solid #22c55e;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            color: #22c55e;
            margin: 0 auto;
        }

        .fatura-kagit {
            background: #fff;
            color: #000;
            padding: 30px;
            border-radius: 4px;
            position: relative;
            overflow: hidden;
            width: 100%;
            box-shadow: 0 15px 50px rgba(0,0,0,0.5);
        }

        .fatura-filigran {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 15rem;
            color: #000;
            opacity: 0.03;
            z-index: 0;
            pointer-events: none;
        }

        .fatura-icerik {
            position: relative;
            z-index: 1;
        }

        .bilgi-grid-bg {
            background: #f8fafc;
            border-left: 4px solid #0f172a;
        }

        .islem-tablosu thead th {
            border-bottom: 2px solid #0f172a;
            padding: 10px 0;
            font-size: 11px;
            text-transform: uppercase;
        }

        .islem-tablosu td {
            padding: 10px 0;
            border-bottom: 1px solid #f1f5f9;
            font-size: 13px;
        }

        .bg-navy {
            background: #0f172a;
        }

        .imza-line {
            border-bottom: 1px solid #000;
            width: 120px;
            height: 50px;
        }

        .color-navy {
            color: #0f172a;
        }

        /* CHECKBOX */
        .ui-checkbox input {
            display: none;
        }

        .ui-checkbox label {
            width: 24px;
            height: 24px;
            border: 2px solid #cbd5e1;
            border-radius: 6px;
            cursor: pointer;
            display: block;
            position: relative;
        }

        .ui-checkbox input:checked + label {
            background: #c5a059;
            border-color: #c5a059;
        }

            .ui-checkbox input:checked + label::after {
                content: '\f00c';
                font-family: 'Font Awesome 6 Free';
                font-weight: 900;
                color: #fff;
                font-size: 12px;
                position: absolute;
                left: 4px;
                top: 1px;
            }

        @@media (max-width: 991px) {
            .split-layout

        {
            flex-direction: column;
            overflow-y: auto;
        }

        .side-left, .side-right {
            width: 100%;
            height: auto;
        }

        .master-viewport {
            position: relative;
        }

        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {

            const totalDisplay = document.getElementById('displayTotal');

            function calculate() {
                let total = 0;
                document.querySelectorAll('.debt-check:checked').forEach(cb => {
                    total += parseFloat(cb.dataset.price);
                });
                totalDisplay.innerText = total.toLocaleString('tr-TR', {minimumFractionDigits:2}) + ' ₺';
                return total;
            }
            calculate();

            // Checkbox Değişimi
            document.querySelectorAll('.debt-check').forEach(cb => {
                cb.addEventListener('change', function() {
                    const parent = this.closest('.debt-item');
                    if(this.checked) parent.classList.add('active');
                    else parent.classList.remove('active');
                    calculate();
                });
            });

            // Kart Sync
            const inNum = document.getElementById('in-num');
            const inName = document.getElementById('in-name');
            const inDate = document.getElementById('in-date');

            inNum.oninput = (e) => {
                let v = e.target.value.replace(/\D/g, '').match(/.{1,4}/g);
                e.target.value = v ? v.join(' ') : '';
                document.getElementById('v-card-num').innerText = e.target.value || '**** **** **** ****';
            };
            inName.oninput = () => document.getElementById('v-card-name').innerText = inName.value.toUpperCase() || 'AD SOYAD';
            inDate.oninput = (e) => {
                let v = e.target.value.replace(/\D/g, '');
                if(v.length > 2) v = v.substring(0,2) + '/' + v.substring(2,4);
                e.target.value = v;
                document.getElementById('v-card-date').innerText = v || 'AA/YY';
            };

            // Ödeme Onayı ve Makbuz Entegrasyonu
            document.getElementById('btnConfirm').onclick = function() {
                const btn = this;
                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> İŞLENİYOR...';

                setTimeout(() => {
                    // 1. Makbuz Satırlarını Doldur
                    let rowsHtml = '';
                    let subTotal = calculate();
                    let kdv = subTotal * 0.10;
                    let grandTotal = subTotal + kdv;

                    document.querySelectorAll('.debt-check:checked').forEach(cb => {
                        rowsHtml += `<tr>
                                        <td class="text-start fw-bold">${cb.dataset.name}</td>
                                        <td class="text-end">${parseFloat(cb.dataset.price).toLocaleString('tr-TR', {minimumFractionDigits:2})} ₺</td>
                                     </tr>`;
                    });

                    document.getElementById('receipt-rows').innerHTML = rowsHtml;
                    document.getElementById('r-sub').innerText = subTotal.toLocaleString('tr-TR', {minimumFractionDigits:2}) + ' ₺';
                    document.getElementById('r-kdv').innerText = kdv.toLocaleString('tr-TR', {minimumFractionDigits:2}) + ' ₺';
                    document.getElementById('r-total').innerText = grandTotal.toLocaleString('tr-TR', {minimumFractionDigits:2}) + ' ₺';

                    // 2. Ekran Değiştirme
                    const stepPay = document.getElementById('step-payment');
                    const stepRec = document.getElementById('step-receipt');

                    stepPay.classList.add('animate__fadeOut');
                    setTimeout(() => {
                        stepPay.style.display = 'none';
                        stepRec.style.display = 'block';
                        // Checkboxları kilitle
                        document.querySelectorAll('.debt-check').forEach(cb => cb.disabled = true);
                    }, 500);
                      
                }, 2000);
            };
        });

        function downloadPDF() {
            const element = document.getElementById('faturaAlani');
            const opt = {
                margin: 10,
                filename: 'Gazi_Hastanesi_Makbuz.pdf',
                image: { type: 'jpeg', quality: 1.0 },
                html2canvas: { scale: 3 },
                jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
            };
            html2pdf().from(element).set(opt).save();
        }
    </script>
}