@* RAZOR KOD BLO–U: Sunucu (C#) tarafżnda ÁalżĢan sayfa yapżlandżrmasż *@
@{
    @* Tarayżcżnżn Łst sekmesinde gŲrŁnecek olan baĢlżk yazżsż. SEO ve kullanżcż deneyimi iÁin Ųnemlidir. *@
    ViewData["Title"] = "Gazi Saūlżk | GŁvenli ÷deme";
}

<!-- SAYFA ANA KAPSAYICISI -->
<!-- 'payment-master-wrapper': TŁm sayfanżn arka planżnż ve yapżsżnż tutan dżĢ katman. -->
<div class="payment-master-wrapper">

    <!-- ARKA PLAN KAPLAMASI -->
    <!-- 'payment-bg-overlay': Arka plan resimlerini veya gradientleri tutan Ģeffaf katman. -->
    <div class="payment-bg-overlay"></div>

    <!-- MERKEZ› H›ZALAMA KUTUSU -->
    <!-- 'payment-center-container': ›Áindeki Ųdeme kartżnż sayfanżn tam ortasżnda tutar. -->
    <div class="payment-center-container">

        <!-- ANA ÷DEME KARTI -->
        <!-- 'payment-card-container': Beyaz ve Lacivert iki bŲlŁme ayrżlan ana kart. -->
        <!-- 'animate__zoomIn': Sayfa aÁżlżĢżnda kartżn bŁyŁyerek gelme efekti. -->
        <div class="payment-card-container animate__animated animate__zoomIn">

            <!-- ›K› KOLONLU IZGARA (GRID) -->
            <!-- 'row g-0': BitiĢik iki sŁtun (Sol: Liste, Saū: Form). -->
            <div class="row g-0">

                <!-- SOL PANEL: ÷DEME L›STES› (BEYAZ) -->
                <!-- 'col-lg-7': GeniĢliūin %58'ini kaplar. -->
                <div class="col-lg-7 p-4 p-md-5 bg-white">

                    <!-- BAřLIK VE HASTA B›LG›S› -->
                    <!-- 'justify-content-between': Sol ve saū uca yaslama. -->
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <!-- Sol taraf: Logo ve baĢlżk -->
                        <div>
                            <img src="/assets/gazilogo.jpg" alt="Logo" style="height: 40px;" class="mb-3">
                            <h4 class="fw-800 color-navy mb-1">÷deme Detaylarż</h4>
                            <p class="text-muted small">LŁtfen Ųdemek istediūiniz kalemleri seÁiniz.</p>
                        </div>

                        <!-- Saū taraf: Protokol numarasż rozeti -->
                        <div class="text-end">
                            <span class="badge bg-soft-gold text-gold p-2 rounded-pill px-3">Protokol: 1234567</span>
                        </div>
                    </div>

                    <!-- ›řLEM L›STES› (SE«›LEB›L›R KALEMLER) -->
                    <div class="transaction-list mb-4">

                        <!-- 1. ›řLEM KALEM› (SE«›L› - ACTIVE) -->
                        <div class="transaction-item active">
                            <div class="d-flex align-items-center">

                                <!-- ÷ZEL CHECKBOX (T›K KUTUSU) -->
                                <div class="custom-check-wrapper">
                                    <input type="checkbox" checked id="item1">
                                    <label for="item1"></label>
                                </div>

                                <!-- ›řLEM ADI VE DETAYI -->
                                <div class="ms-3">
                                    <h6 class="mb-0 fw-bold">Check-up Paketi (Standart)</h6>
                                    <small class="text-muted">Kardiyoloji Birimi - 04.03.2026</small>
                                </div>
                            </div>
                            <!-- ‹CRET B›LG›S› -->
                            <span class="fw-800 color-navy">850,00 TL</span>
                        </div>

                        <!-- 2. ›řLEM KALEM› -->
                        <div class="transaction-item">
                            <div class="d-flex align-items-center">
                                <!-- SeÁim kutusu -->
                                <div class="custom-check-wrapper">
                                    <input type="checkbox" id="item2">
                                    <label for="item2"></label>
                                </div>
                                <!-- Detaylar -->
                                <div class="ms-3">
                                    <h6 class="mb-0 fw-bold">EKO / EKG Tetkik ‹creti</h6>
                                    <small class="text-muted">Tetkik Hizmetleri - 04.03.2026</small>
                                </div>
                            </div>
                            <span class="fw-800 color-navy">400,00 TL</span>
                        </div>
                    </div>

                    <!-- TOPLAM TUTAR ALANI -->
                    <!-- 'total-section': Alt kżsżmdaki toplam fiyatż gŲsteren gri kutu. -->
                    <div class="total-section p-3 rounded-4 bg-light d-flex justify-content-between align-items-center">
                        <span class="fw-600 text-muted">Toplam ÷denecek</span>
                        <h3 class="fw-900 color-navy mb-0">1.250,00 <small class="fs-6">TL</small></h3>
                    </div>
                </div>

                <!-- SA– PANEL: KRED› KARTI FORMU (LAC›VERT) -->
                <!-- 'col-lg-5': GeniĢliūin %42'sini kaplar. 'bg-navy text-white': Koyu lacivert zemin, beyaz yazż. -->
                <div class="col-lg-5 p-4 p-md-5 bg-navy text-white d-flex flex-column justify-content-center">

                    <!-- SA– TARAFTAK› BAřLIK VE G‹VENL›K ›KONU -->
                    <h5 class="fw-bold mb-4 d-flex align-items-center">
                        <i class="fas fa-shield-check text-gold me-2"></i> GŁvenli ÷deme
                    </h5>

                    <!-- G÷RSEL KRED› KARTI S›M‹LASYONU -->
                    <!-- 'visual-card': Kullanżcżya kart bilgilerinin nereye yazżlacaūżnż gŲsteren temsil, gŲrsel kart. -->
                    <!-- 'animate__flipInX': Kartżn dŲnerek gelme efekti. -->
                    <div class="visual-card mb-4 animate__animated animate__flipInX">

                        <!-- KART ‹ZER›NDEK› ›KONLAR («ip ve Visa Logosu) -->
                        <div class="d-flex justify-content-between align-items-start">
                            <i class="fas fa-chip-card fs-1 text-gold"></i>
                            <i class="fab fa-cc-visa fs-2 opacity-50"></i>
                        </div>

                        <!-- KART NUMARASI G÷STER›M› -->
                        <div class="mt-4">
                            <div class="card-number-display small opacity-75">KART NUMARASI</div>
                            <div class="fs-5 fw-bold letter-spacing-2">**** **** **** ****</div>
                        </div>

                        <!-- KART SAH›B› VE SON KULLANMA TAR›H› B›LG›LER› -->
                        <div class="d-flex justify-content-between mt-3">
                            <div>
                                <div class="small opacity-50">AD SOYAD</div>
                                <div class="small fw-bold">MURAT SARI</div>
                            </div>
                            <div>
                                <div class="small opacity-50">SKT</div>
                                <div class="small fw-bold">08/29</div>
                            </div>
                        </div>
                    </div>

                    <!-- ÷DEME FORMU BAřLANGICI -->
                    <form>
                        <!-- KART SAH›B› ADI -->
                        <div class="mb-3">
                            <label class="premium-label">KART ‹ZER›NDEK› ›S›M</label>
                            <input type="text" class="premium-input" placeholder="AD SOYAD">
                        </div>

                        <!-- KART NUMARASI G›R›ř› -->
                        <div class="mb-3">
                            <label class="premium-label">KART NUMARASI</label>
                            <input type="text" class="premium-input" placeholder="0000 0000 0000 0000">
                        </div>

                        <!-- SKT VE CVV (YAN YANA ›K› KUTU) -->
                        <div class="row g-3 mb-4">
                            <!-- Son Kullanma Tarihi -->
                            <div class="col-7">
                                <label class="premium-label">SON KULLANMA</label>
                                <input type="text" class="premium-input" placeholder="AA / YY">
                            </div>
                            <!-- GŁvenlik Kodu (CVV) -->
                            <div class="col-5">
                                <label class="premium-label">CVV</label>
                                <input type="password" class="premium-input" placeholder="***">
                            </div>
                        </div>

                        <!-- ÷DEME ONAY BUTONU -->
                        <button type="submit" class="btn-pay-now">
                            <span>÷DEMEY› ONAYLA</span>
                            <i class="fas fa-lock"></i>
                        </button>
                    </form>

                    <!-- ALTTAK› G‹VENL›K B›LG›S› (SSL) -->
                    <p class="text-center mt-4 small opacity-50">
                        <i class="fas fa-lock-alt me-1"></i> 256-bit SSL ile korunmaktadżr.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@* ================= CSS B÷L‹M‹ (÷ZEL TASARIM ST›LLER›) ================= *@
@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <style>
        /* CSS DE–›řKENLER›: Renkleri ve ŲlÁŁleri standartlaĢtżrmak iÁin */
        :root {
            --gazi-navy: #0f172a; /* Koyu lacivert */
            --gazi-gold: #c5a059; /* Kurumsal altżn rengi */
            --soft-gold: rgba(197, 160, 89, 0.15); /* SeÁili iĢlemlerin arka planż iÁin Ģeffaf altżn rengi */
            --navbar-height: 80px; /* ‹st menŁnŁn yŁksekliūi (sayfayż ortalarken hesaba katmak iÁin) */
        }

        /* Sayfanżn temel sżfżrlamalarż */
        body, html {
            height: 100%;
            margin: 0;
            overflow-x: hidden; /* Yatayda taĢmayż engeller */
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        /* Ana Arka Plan */
        .payment-master-wrapper {
            background: #f1f5f9; /* TŁm sayfanżn en arkasżndaki aÁżk gri/mavi ton */
            min-height: 100vh;
            position: relative;
        }

        /* KARTI TAM ORTAYA GET›REN H›ZALAMA KUTUSU */
        .payment-center-container {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            /* Kartżn Łst menŁnŁn (navbar) altżnda kalmamasż iÁin padding-top ayarż */
            padding: calc(var(--navbar-height) + 20px) 20px 40px 20px;
        }

        /* Yardżmcż Renk Sżnżflarż */
        .bg-navy {
            background: var(--gazi-navy);
        }

        .color-navy {
            color: var(--gazi-navy);
        }

        .text-gold {
            color: var(--gazi-gold);
        }

        .bg-soft-gold {
            background: var(--soft-gold);
        }

        .fw-800 {
            font-weight: 800;
        }

        .fw-900 {
            font-weight: 900;
        }

        /* ANA BEYAZ KARTIN TASARIMI */
        .payment-card-container {
            width: 100%;
            max-width: 1000px; /* Kart en fazla 1000px geniĢliūinde olabilir */
            background: white;
            border-radius: 40px; /* KŲĢeleri yuvarlaktżr */
            overflow: hidden; /* ›Áindeki resimlerin oval kŲĢelerden dżĢarż taĢmasżnż keser */
            box-shadow: 0 40px 100px rgba(15, 23, 42, 0.15); /* Alta devasa bir gŲlge vurur */
            z-index: 10;
        }

        /* SOL TARAFTAK› ÷DEME KALEMLER› (÷rn: Checkup Paketi satżrż) */
        .transaction-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px;
            border-radius: 20px;
            border: 2px solid #f1f5f9; /* Pasifken gri kenarlżk */
            margin-bottom: 15px;
            transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1); /* Hover ve tżklama animasyonu hżzż */
        }

            /* ÷deme Kalemi SeÁildiūinde (Aktif olduūunda) */
            .transaction-item.active {
                border-color: var(--gazi-gold); /* Kenarlżk altżn rengi olur */
                background: var(--soft-gold); /* ›Ái hafif sararżr */
            }

            /* Farenin ›mleci ÷deme Kaleminin ‹stŁne Geldiūinde */
            .transaction-item:hover {
                transform: scale(1.02); /* «ok az (%2) bŁyŁr */
                border-color: var(--gazi-gold); /* Kenarlżūż altżn rengi olur */
            }

        /* SA– TARAFTAK› G÷RSEL KRED› KARTI */
        .visual-card {
            background: linear-gradient(135deg, #1e293b 0%, #334155 100%); /* ›ki farklż gri/lacivert ton geÁiĢi */
            border-radius: 24px;
            padding: 25px;
            border: 1px solid rgba(255,255,255,0.1); /* Hafif parlak bir kenar Áizgisi */
            position: relative;
            overflow: hidden; /* TaĢan ::before efektini kesmek iÁin */
        }

            /* GŲrsel kartżn ŁstŁndeki altżn rengi parlama efekti (żĢżk sŁzmesi) */
            .visual-card::before {
                content: '';
                position: absolute;
                top: -50%;
                left: -50%;
                width: 200%;
                height: 200%;
                /* Kartżn sol ŁstŁnden yayżlan dairesel yarż saydam altżn rengi żĢżk */
                background: radial-gradient(circle, rgba(197, 160, 89, 0.1) 0%, transparent 70%);
            }

        /* SA– TARAFTAK› FORM ›NPUT BAřLIKLARI (Kart Numarasż vb.) */
        .premium-label {
            font-size: 10px;
            font-weight: 800;
            color: rgba(255,255,255,0.4); /* Yarż saydam gri/beyaz */
            letter-spacing: 1px;
            margin-bottom: 8px;
            display: block;
        }

        /* SA– TARAFTAK› ›NPUTLARIN (Metin kutularżnżn) KEND›S› */
        .premium-input {
            width: 100%;
            height: 50px;
            background: rgba(255, 255, 255, 0.05); /* «ok koyu/Ģeffaf arka plan */
            border: 1px solid rgba(255, 255, 255, 0.1); /* ›nce Ģeffaf beyaz kenarlżk */
            border-radius: 12px;
            padding: 0 15px;
            color: white;
            font-weight: 600;
            transition: 0.3s;
        }

            /* ›nputa tżklandżūżnda (Yazż yazarken) */
            .premium-input:focus {
                background: rgba(255, 255, 255, 0.1); /* Biraz aydżnlanżr */
                border-color: var(--gazi-gold); /* Kenarż altżn rengi olur */
                outline: none; /* Tarayżcżlarżn varsayżlan mavi Áizgisini yok eder */
            }

        /* ÷DEMEY› ONAYLA BUTONU */
        .btn-pay-now {
            width: 100%;
            height: 60px;
            background: var(--gazi-gold); /* Altżn rengi buton */
            color: var(--gazi-navy); /* ‹zerindeki yazż lacivert */
            border: none;
            border-radius: 15px;
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 25px;
            transition: 0.4s;
        }

            /* Butonun ŁstŁne fare ile gelindiūinde */
            .btn-pay-now:hover {
                background: #fff; /* Buton bembeyaz olur */
                transform: translateY(-5px); /* Havaya kalkar */
                box-shadow: 0 15px 30px rgba(0,0,0,0.3); /* Alta gŲlge verir */
            }

        /* ÷ZEL TASARIM CHECKBOX (SeÁim Kutusu) S›H›RL› KISMI */
        /* Tarayżcżnżn varsayżlan, standart tik kutusunu tamamen gizler */
        .custom-check-wrapper input {
            display: none;
        }

        /* Gizlenen inputun yerine bizim Áizdiūimiz boĢ kare kutu (Label) */
        .custom-check-wrapper label {
            width: 24px;
            height: 24px;
            border: 2px solid #cbd5e1; /* Gri kenarlżk */
            border-radius: 8px; /* KŲĢeleri hafif yuvarlak */
            cursor: pointer; /* ‹stŁne gelince el iĢareti Áżkar */
            position: relative;
        }

        /* Eūer gizli olan input 'checked' (seÁili) durumdaysa, hemen yanżndaki label'żn rengini deūiĢtir */
        .custom-check-wrapper input:checked + label {
            background: var(--gazi-gold); /* ›Ái altżn rengi dolar */
            border-color: var(--gazi-gold); /* «izgisi altżn rengi olur */
        }

            /* Kutu seÁiliyken iÁine FontAwesome kŁtŁphanesinden 'Onay Tiki' (Check) ikonunu Áiz */
            .custom-check-wrapper input:checked + label::after {
                content: '\f00c'; /* FontAwesome'daki Check ikonunun kodu */
                font-family: 'Font Awesome 5 Free';
                font-weight: 900;
                color: white; /* Tik rengi beyaz */
                font-size: 12px;
                position: absolute;
                left: 4px;
                top: 1px;
            }

        /* MOB›L UYUM (RESPONSIVE) - Tablet ve Telefonlar iÁin */
        @@media (max-width: 991px) {
            .payment-card-container

        {
            border-radius: 20px; /* Ekran kŁÁŁk olduūu iÁin ovalliūi dŁĢŁr */
        }

        .payment-center-container {
            /* Mobilde navbar yŁksekliūi deūiĢebileceūi iÁin Łstten biraz daha boĢluk bżrak */
            padding-top: calc(var(--navbar-height) + 30px);
        }

        }
    </style>
}