@* RAZOR KOD BLOĞU: Sunucu tarafında çalışan ve sayfa ayarlarını tutan bölüm *@
@{
    @* Sayfanın tarayıcı sekmesinde görünecek başlığını belirler. SEO ve kullanıcı deneyimi için gereklidir. *@
    ViewData["Title"] = "Gazi Sağlık | Güvenli Ödeme";
}

<!-- SAYFA YAPISI BAŞLANGICI -->
<!-- 'payment-viewport': Tüm ödeme sayfasını ortalayan ve arkaplanını ayarlayan dış kapsayıcı (wrapper). -->
<div class="payment-viewport">

    <!-- ÖDEME KARTI (ANA BEYAZ KUTU) -->
    <!-- 'payment-container': Sayfanın ortasındaki iki panelli (sol bilgi, sağ form) ana kart. -->
    <!-- 'shadow-2xl': Büyük bir gölge efekti verir. 'animate__fadeIn': Sayfa açılış animasyonu. -->
    <div class="payment-container shadow-2xl animate__animated animate__fadeIn">

        <!-- SOL PANEL: BİLGİLENDİRME VE MARKA ALANI -->
        <!-- 'side-info-panel': Lacivert arka planlı, logonun ve sloganların olduğu sol taraf. -->
        <div class="side-info-panel">

            <div class="info-inner">

                <!-- MARKA BAŞLIĞI (HEADER) -->
                <div class="brand-header mb-5">
                    <!-- Logo görseli -->
                    <img src="/assets/gazilogo.jpg" alt="Gazi Logo" class="brand-logo">
                    <!-- Başlık ve alt başlık metinleri -->
                    <div class="brand-text">
                        <h5 class="fw-800 m-0">GAZİ ÜNİVERSİTESİ</h5>
                        <p class="m-0 extra-small text-gold">TIP FAKÜLTESİ HASTANESİ</p>
                    </div>
                </div>

                <!-- ANA MESAJ (HERO CONTENTS) -->
                <div class="hero-content mt-4">
                    <!-- 'display-6': Büyük font boyutu. 'text-gold': Altın rengi vurgu. -->
                    <h1 class="display-6 fw-800 text-white">Güvenli <br><span class="text-gold">Ödeme Merkezi</span></h1>
                    <p class="text-white-50 small mt-3">Tetkik, muayene ve diğer tüm sağlık ödemelerinizi güvenle sorgulayıp tamamlayabilirsiniz.</p>
                </div>

                <!-- GÜVENLİK ÖZELLİKLERİ LİSTESİ -->
                <div class="feature-list mt-5">
                    <div class="f-item"><i class="fas fa-check-circle"></i> <span>3D Secure</span></div>
                    <div class="f-item"><i class="fas fa-check-circle"></i> <span>256-Bit SSL</span></div>
                    <div class="f-item"><i class="fas fa-check-circle"></i> <span>Tüm Kartlar</span></div>
                </div>

                <!-- GÜVENCE ROZETİ (ALT KISIM) -->
                <!-- 'mt-auto': Bu bloğu panelin en altına iter (Flexbox özelliği). -->
                <div class="mt-auto pt-5">
                    <div class="security-card p-3 rounded-4">
                        <i class="fas fa-shield-alt text-gold me-2"></i>
                        <span class="small fw-bold">Verileriniz Gazi Güvencesindedir.</span>
                    </div>
                </div>
            </div>

            <!-- Arka plandaki şeffaf hastane fotoğrafı kaplaması -->
            <div class="panel-bg-overlay"></div>
        </div>

        <!-- SAĞ PANEL: HASTA GİRİŞ FORMU -->
        <!-- 'side-form-panel': Beyaz arka planlı, TC no ve Protokol no girilen sağ taraf. -->
        <div class="side-form-panel">

            <!-- 'form-scroll-area': İçerik çok uzun olursa sadece sağ tarafın kaydırılmasını (scroll) sağlar. -->
            <div class="form-scroll-area">
                <div class="form-inner">

                    <!-- FORM BAŞLIĞI -->
                    <div class="form-header text-center mb-5">
                        <!-- Parmak izi ikonu -->
                        <div class="icon-circle-main mb-3">
                            <i class="fas fa-fingerprint text-navy"></i>
                        </div>
                        <h3 class="fw-800 text-navy">Hasta Girişi</h3>
                        <p class="text-muted small">Borç sorgulamak için bilgileri doldurun</p>
                    </div>

                    <!-- GİRİŞ FORMU -->
                    <!-- action="/Odeme/Login": Formun gönderileceği sunucu adresi. -->
                    <form id="paymentForm" action="/Odeme/Login" method="post" class="modern-form">

                        <!-- TC KİMLİK GİRİŞİ -->
                        <div class="floating-input mb-4">
                            <label>T.C. Kimlik / Pasaport No</label>
                            <div class="input-box">
                                <!-- Kimlik kartı ikonu -->
                                <i class="far fa-id-card"></i> <input type="text" placeholder="Giriş yapınız..." required maxlength="11">
                            </div>
                        </div>

                        <!-- PROTOKOL NO GİRİŞİ -->
                        <div class="floating-input mb-5">
                            <label>Protokol No</label>
                            <div class="input-box">
                                <!-- Belge ikonu -->
                                <i class="far fa-file-alt"></i> <input type="text" placeholder="Örn: 2024-550..." required>
                            </div>
                        </div>

                        <!-- SORGULAMA BUTONU -->
                        <!-- 'btn-main-payment': Ana aksiyon butonu stili. -->
                        <button type="submit" class="btn-main-payment">
                            <span class="btn-label">BORÇ SORGULA</span>
                            <!-- Sağdaki ikon kutusu -->
                            <span class="btn-icon"><i class="fas fa-search-dollar"></i></span>
                        </button>
                    </form>

                    <!-- ALT BÖLÜM: PARTNER LOGOLARI -->
                    <div class="text-center mt-5">
                        <!-- 'divider': Çizgili ayırıcı başlık. -->
                        <div class="divider"><span>Ödeme Partnerleri</span></div>

                        <!-- Kredi kartı logoları (Visa, Mastercard, Amex) -->
                        <div class="partner-logos opacity-50 d-flex justify-content-center gap-4 mt-3">
                            <i class="fab fa-cc-visa fa-2x"></i>
                            <i class="fab fa-cc-mastercard fa-2x"></i>
                            <i class="fab fa-cc-amex fa-2x"></i>
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>

@* ================= CSS BÖLÜMÜ (ÖZEL STİLLER) ================= *@
@section Styles {
    <style>
        /* CSS DEĞİŞKENLERİ: Renk kodlarını tek bir yerde tanımlayıp her yerden çağırıyoruz. */
        :root {
            --navy: #0f172a; /* Hastanenin koyu lacivert kurumsal rengi */
            --gold: #d4af37; /* Kalite ve güven hissi veren altın rengi */
            --soft-bg: #f8fafc; /* Form alanlarındaki çok hafif gri arka plan */
            --input-border: #e2e8f0; /* Çizgi renkleri için açık gri */
        }

        /* SAYFA GENELİ */
        body {
            font-family: 'Plus Jakarta Sans', sans-serif; /* Modern ve okunabilir font */
            background: #eef2f6; /* Sayfanın en arkasındaki hafif mavi/gri fon */
        }

        /* DIŞ TAŞIYICI: İçindeki kartı sayfanın ortasında tutar. */
        .payment-viewport {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px; /* Ekran küçüldüğünde kartın köşelere değmesini engeller */
        }

        /* ANA BEYAZ KART */
        .payment-container {
            width: 100%;
            max-width: 1100px; /* Genişliği 1100 piksele sınırlar */
            background: white;
            border-radius: 40px; /* Oval köşeler */
            display: flex; /* İçindeki sağ ve sol panelleri yan yana dizer */
            min-height: 700px;
            overflow: hidden; /* Sağ/sol panellerin içindeki resimlerin kartın oval köşelerinden taşmasını keser */
        }

        /* ================= SOL PANEL STİLLERİ ================= */
        .side-info-panel {
            flex: 1; /* Sağ panelle alanı %50 - %50 eşit paylaşmasını sağlar */
            background: var(--navy);
            position: relative;
            padding: 50px;
            color: white;
            display: flex;
            flex-direction: column; /* İçindeki yazıları alt alta dizers */
            z-index: 1;
        }

        /* Sol Panelin Arka Planındaki Yarı Saydam Resim */
        .panel-bg-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            /* İnternetten alınan geçici bir hastane fotoğrafı (Unsplash) */
            background: url('https://images.unsplash.com/photo-1576091160550-2173dba999ef?auto=format&fit=crop&q=80&w=1000');
            background-size: cover;
            opacity: 0.1; /* Resmi sadece %10 görünür yaparak doku hissi verir */
            z-index: -1; /* Yazıların arkasında kalmasını sağlar */
        }

        /* Sol Üstteki Hastane Logosu */
        .brand-logo {
            width: 55px;
            height: 55px;
            border-radius: 12px;
            background: white;
            padding: 5px;
            margin-right: 15px;
            float: left; /* Sağındaki yazının logonun yanına kaymasını sağlar */
        }

        /* Yardımcı Renk ve Yazı Sınıfları */
        .text-gold {
            color: var(--gold);
        }

        .fw-800 {
            font-weight: 800;
        }

        /* Güvenlik Listesi Öğeleri (3D Secure vs.) */
        .f-item {
            margin-bottom: 12px;
            font-weight: 600;
            font-size: 0.9rem;
        }

            .f-item i {
                color: var(--gold);
                margin-right: 10px;
            }
        /* İkonlar altın rengi */

        /* ================= SAĞ PANEL (FORM) STİLLERİ ================= */
        .side-form-panel {
            flex: 1;
            background: white;
            display: flex;
            flex-direction: column;
        }

        /* Kaydırma Alanı */
        .form-scroll-area {
            flex: 1;
            overflow-y: auto; /* Ekran küçükse formun kendi içinde kaymasını (scroll) sağlar */
            padding: 60px;
            scrollbar-width: none; /* Firefox'ta kaydırma çubuğunu gizler (çirkin durmasın diye) */
        }
            /* Chrome, Safari ve Edge'de kaydırma çubuğunu gizler */
            .form-scroll-area::-webkit-scrollbar {
                display: none;
            }

        /* Hasta Girişi Başlığındaki Yuvarlak İkon */
        .icon-circle-main {
            width: 75px;
            height: 75px;
            background: var(--soft-bg);
            border-radius: 25px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto;
            font-size: 2rem;
        }

        /* İNPUT TASARIMLARI */
        /* Input'un üstündeki açıklayıcı küçük etiketler (TC no vb.) */
        .floating-input label {
            display: block;
            font-size: 11px;
            font-weight: 800;
            color: #94a3b8;
            text-transform: uppercase;
            margin-bottom: 8px;
            letter-spacing: 0.5px;
        }

        /* İkon ve Metin Kutusunun Taşıyıcısı */
        .input-box {
            position: relative;
            display: flex;
            align-items: center;
        }

            .input-box i {
                position: absolute;
                left: 20px;
                color: #94a3b8;
                font-size: 1.1rem;
            }

            /* Metin Kutuları (Inputlar) */
            .input-box input {
                width: 100%;
                height: 60px;
                background: var(--soft-bg); /* Hafif gri arka plan */
                border: 2px solid transparent; /* Varsayılan olarak çerçevesiz */
                border-radius: 18px;
                padding: 0 20px 0 55px; /* İkona yazı binmesin diye soldan boşluk bırakır */
                font-weight: 700;
                color: var(--navy);
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            }

                /* Input'a Tıklanınca (Yazı Yazarken) Olanlar */
                .input-box input:focus {
                    background: #fff;
                    border-color: var(--gold); /* Kenarlık altın rengi olur */
                    box-shadow: 0 10px 25px rgba(212, 175, 55, 0.1); /* Altın rengi gölge/parlama atar */
                    outline: none; /* Tarayıcının varsayılan mavi çerçevesini kapatır */
                }

        /* ANA ONAY BUTONU */
        .btn-main-payment {
            width: 100%;
            height: 65px;
            background: var(--navy);
            border: none;
            border-radius: 22px;
            color: white;
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 25px;
            transition: 0.4s;
        }

            /* Fare Butonun Üzerine Gelince (Hover) */
            .btn-main-payment:hover {
                background: var(--gold); /* Lacivertten altın rengine döner */
                transform: translateY(-3px); /* 3 piksel havaya kalkar */
                box-shadow: 0 15px 30px rgba(212, 175, 55, 0.2);
            }

        /* Buton İçindeki İkon Kutusu */
        .btn-icon {
            width: 35px;
            height: 35px;
            background: rgba(255,255,255,0.1); /* Buton içinde hafif şeffaf kutu */
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* ================= MOBİL UYUM (RESPONSIVE) ================= */
        /* Ekran 991px'den (Tablet/Telefon) küçükse sağ-sol panelleri alt alta alır. */
        @@media (max-width: 991px) {
            .payment-container

        {
            flex-direction: column; /* Yan yana dizilimi iptal edip dikey (alt alta) diler */
            height: auto;
            min-height: unset;
            border-radius: 30px;
        }

        .side-info-panel {
            padding: 40px 30px;
            flex: none; /* Sol panel (artık üstte) kendi yazıları kadar yer kaplar */
        }

        .side-form-panel {
            flex: 1;
        }

        .form-scroll-area {
            padding: 40px 25px; /* İç boşluklar telefonda küçültülür */
        }

        .display-6 {
            font-size: 1.8rem; /* Ana slogan küçültülür */
        }

        }

        /* ================= EKSTRA GÖRSELLER ================= */
        /* Bölücü Çizgi (Ödeme Partnerleri yazısı için) */
        .divider {
            display: flex;
            align-items: center;
            font-size: 10px;
            font-weight: 800;
            color: #cbd5e1;
            text-transform: uppercase;
        }
            /* Yazının sağına ve soluna otomatik çizgi çeker (Flexbox avantajı) */
            .divider::before, .divider::after {
                content: '';
                flex: 1;
                border-bottom: 1px solid #f1f5f9;
            }

            .divider span {
                padding: 0 10px;
            }
        /* Çizgilerle yazı arasında 10px boşluk */

        /* Güvenlik Uyarı Kartı (Sol panelin en altındaki kalkanlı alan) */
        .security-card {
            background: rgba(255,255,255,0.05); /* Çok şeffaf beyaz dolgu */
            border: 1px solid rgba(255,255,255,0.1); /* Çok şeffaf beyaz kenarlık */
        }
    </style>
}