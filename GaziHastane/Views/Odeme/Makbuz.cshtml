@model GaziHastane.Models.OdemeMakbuzViewModel
@{
    ViewData["Title"] = "Ödeme Makbuzu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<style>
    /* =============================================
       PROFESYONEL MAKBUZ SAYFASI STİLLERİ
       ============================================= */
    :root {
        --primary-color: #0f284a; /* Kurumsal Lacivert */
        --secondary-color: #2563eb; /* Mavi */
        --text-main: #1e293b;
        --text-muted: #64748b;
        --bg-light: #f8fafc;
        --border-color: #e2e8f0;
        --success-color: #10b981;
    }

    .makbuz-page-wrapper {
        background: #f1f5f9;
        min-height: 100vh;
        padding: 3rem 1rem;
        font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
    }

    .makbuz-container {
        max-width: 850px;
        margin: 0 auto;
    }

    /* ---------- Üst Aksiyon Çubuğu ---------- */
    .makbuz-action-bar {
        background: #ffffff;
        padding: 1.25rem 2rem;
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .makbuz-action-bar .baslik-kismi h2 {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--primary-color);
        margin: 0 0 4px 0;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .makbuz-action-bar .baslik-kismi p {
        font-size: 0.85rem;
        color: var(--text-muted);
        margin: 0;
    }

    .action-buttons {
        display: flex;
        gap: 0.75rem;
    }

    .btn-action {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1.2rem;
        font-size: 0.85rem;
        font-weight: 600;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.2s ease;
        border: none;
        cursor: pointer;
    }

    .btn-geri {
        background: var(--bg-light);
        color: var(--text-main);
        border: 1px solid var(--border-color);
    }

    .btn-geri:hover {
        background: #e2e8f0;
        color: #0f172a;
    }

    .btn-pdf {
        background: var(--primary-color);
        color: #ffffff;
        box-shadow: 0 4px 6px rgba(15, 40, 74, 0.2);
    }

    .btn-pdf:hover {
        background: #091a32;
        transform: translateY(-1px);
        color: #ffffff;
    }

    /* ---------- Fatura/Makbuz Kağıdı ---------- */
    .fatura-kagit {
        background: #ffffff;
        padding: 3.5rem 4rem;
        border-radius: 4px; /* A4 kağıt hissi için küçük radius */
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        position: relative;
        overflow: hidden;
    }

    /* Filigran */
    .fatura-filigran {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0.02;
        pointer-events: none;
        z-index: 0;
    }

    .fatura-filigran i {
        font-size: 35rem;
        color: var(--primary-color);
    }

    /* Bütün içerikler filigranın üstünde olsun */
    .fatura-icerik {
        position: relative;
        z-index: 1;
    }

    /* ---------- Fatura Üst Bilgisi (Header) ---------- */
    .fatura-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 2.5rem;
    }

    .kurum-bilgi {
        display: flex;
        gap: 1.5rem;
        align-items: center;
    }

    .kurum-bilgi img {
        width: 85px;
        height: 85px;
        object-fit: contain;
    }

    .kurum-detay h1 {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--primary-color);
        margin: 0 0 0.2rem 0;
        letter-spacing: -0.5px;
    }

    .kurum-detay h2 {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--secondary-color);
        margin: 0 0 0.5rem 0;
    }

    .kurum-detay p {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin: 0 0 2px 0;
    }

    .belge-tipi {
        text-align: right;
    }

    .belge-tipi h3 {
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--border-color);
        text-transform: uppercase;
        letter-spacing: 2px;
        margin: 0 0 1rem 0;
    }

    .durum-rozet {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: #ecfdf5;
        color: var(--success-color);
        padding: 0.4rem 1rem;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.8rem;
        border: 1px solid #a7f3d0;
    }

    /* ---------- Fatura Orta (Müşteri/Hasta Bilgisi) ---------- */
    .bilgi-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        margin-bottom: 2.5rem;
        padding: 1.5rem;
        background: var(--bg-light);
        border-radius: 8px;
        border-left: 4px solid var(--primary-color);
    }

    .bilgi-kolon h4 {
        font-size: 0.75rem;
        text-transform: uppercase;
        color: var(--text-muted);
        font-weight: 700;
        margin: 0 0 0.5rem 0;
        letter-spacing: 0.5px;
    }

    .bilgi-satir {
        display: flex;
        margin-bottom: 0.4rem;
        font-size: 0.9rem;
    }

    .bilgi-satir .etiket {
        width: 110px;
        color: var(--text-muted);
        font-weight: 500;
    }

    .bilgi-satir .deger {
        color: var(--text-main);
        font-weight: 600;
    }

    /* ---------- Tablo ---------- */
    .islem-tablosu {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 2rem;
    }

    .islem-tablosu th {
        background: var(--primary-color);
        color: #ffffff;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        padding: 1rem;
        text-align: left;
        letter-spacing: 0.5px;
    }

    .islem-tablosu th:first-child { border-top-left-radius: 8px; border-bottom-left-radius: 8px; }
    .islem-tablosu th:last-child { border-top-right-radius: 8px; border-bottom-right-radius: 8px; }

    .islem-tablosu td {
        padding: 1rem;
        font-size: 0.9rem;
        color: var(--text-main);
        border-bottom: 1px solid var(--border-color);
    }

    .islem-tablosu tr:last-child td {
        border-bottom: none;
    }

    .islem-tablosu .text-center { text-align: center; }
    .islem-tablosu .text-right { text-align: right; }

    .islem-adi-sutun {
        font-weight: 600;
        color: var(--primary-color);
    }

    /* ---------- Toplamlar ---------- */
    .toplamlar-alani {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 3rem;
    }

    .toplam-tablo {
        width: 320px;
    }

    .toplam-satiri {
        display: flex;
        justify-content: space-between;
        padding: 0.5rem 1rem;
        font-size: 0.9rem;
        color: var(--text-muted);
    }

    .toplam-satiri .deger {
        font-weight: 600;
        color: var(--text-main);
    }

    .genel-toplam-satiri {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: var(--primary-color);
        color: #ffffff;
        padding: 1rem;
        border-radius: 8px;
        margin-top: 0.5rem;
    }

    .genel-toplam-satiri .etiket {
        font-size: 1rem;
        font-weight: 700;
    }

    .genel-toplam-satiri .deger {
        font-size: 1.35rem;
        font-weight: 800;
    }

    /* ---------- Footer ---------- */
    .fatura-footer {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        border-top: 2px solid var(--bg-light);
        padding-top: 2rem;
    }

    .yasal-not {
        max-width: 60%;
        font-size: 0.75rem;
        color: var(--text-muted);
        line-height: 1.6;
    }

    .yasal-not i {
        color: var(--secondary-color);
        margin-right: 4px;
    }

    .imza-alani {
        text-align: center;
        width: 200px;
    }

    .imza-cizgi {
        height: 60px;
        border-bottom: 1px solid var(--border-color);
        margin-bottom: 0.5rem;
    }

    .imza-isim {
        font-weight: 700;
        font-size: 0.85rem;
        color: var(--text-main);
    }

    .imza-unvan {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    /* ---------- Print Ayarları ---------- */
    @@media print {
        body { background: white; }
        .makbuz-page-wrapper { background: transparent; padding: 0; }
        .makbuz-action-bar { display: none !important; }
        .fatura-kagit { box-shadow: none; padding: 0; }
        .islem-tablosu th { background-color: #e2e8f0 !important; color: #0f284a !important; -webkit-print-color-adjust: exact; }
        .genel-toplam-satiri { background-color: #e2e8f0 !important; color: #0f284a !important; -webkit-print-color-adjust: exact; }
        .bilgi-grid { background-color: #f8fafc !important; -webkit-print-color-adjust: exact; }
    }

    /* Mobil uyumluluk */
    @@media (max-width: 768px) {
        .fatura-kagit { padding: 1.5rem; }
        .fatura-header { flex-direction: column; gap: 1.5rem; }
        .belge-tipi { text-align: left; }
        .bilgi-grid { grid-template-columns: 1fr; gap: 1.5rem; }
        .fatura-footer { flex-direction: column; gap: 2rem; align-items: flex-start; }
        .yasal-not { max-width: 100%; }
        .toplamlar-alani { justify-content: stretch; }
        .toplam-tablo { width: 100%; }
    }
</style>

<div class="makbuz-page-wrapper">
    <div class="makbuz-container">

        @* ---------- ÜST AKSİYON ÇUBUĞU ---------- *@
        <div class="makbuz-action-bar">
            <div class="baslik-kismi">
                <h2><i class="fa-solid fa-file-invoice" style="color:var(--secondary-color);"></i> İşlem Özeti</h2>
                <p>Ödemeniz başarıyla alınmıştır. İlgili belgeyi indirebilirsiniz.</p>
            </div>
            <div class="action-buttons">
                @if (ViewBag.KullaniciId != null)
                {
                    <a href="@Url.Action("Icerik", "Odeme", new { userId = ViewBag.KullaniciId })" class="btn-action btn-geri">
                        <i class="fa-solid fa-arrow-left"></i> Geri Dön
                    </a>
                }
                <button onclick="downloadInvoicePDF()" id="btnPdfIndir" class="btn-action btn-pdf">
                    <i class="fa-solid fa-download"></i> PDF İndir
                </button>
            </div>
        </div>

        @* ---------- MAKBUZ KAĞIDI ---------- *@
        <div id="faturaAlani" class="fatura-kagit">

            <div class="fatura-filigran">
                <i class="fa-solid fa-hospital-user"></i>
            </div>

            <div class="fatura-icerik">
                @* HEADER *@
                <div class="fatura-header">
                    <div class="kurum-bilgi">
                        <img src="~/assets/gazilogo.jpg" alt="Gazi Logo" onerror="this.style.display='none'">
                        <div class="kurum-detay">
                            <h1>GAZİ ÜNİVERSİTESİ</h1>
                            <h2>Sağlık Uygulama ve Araştırma Hastanesi</h2>
                            <p>Emniyet Mah. Mevlana Bulvarı No:29 Yenimahalle / ANKARA</p>
                            <p>Tel: 0312 202 40 00 &nbsp;|&nbsp; V.D: Yenimahalle</p>
                        </div>
                    </div>
                    <div class="belge-tipi">
                        <h3>TAHSİLAT</h3>
                        <div class="durum-rozet">
                            <i class="fa-solid fa-check-circle"></i> Ödeme Onaylandı
                        </div>
                    </div>
                </div>

                @* BİLGİ GRİDİ *@
                <div class="bilgi-grid">
                    <div class="bilgi-kolon">
                        <h4>Fatura Edilen</h4>
                        <div class="bilgi-satir">
                            <span class="etiket">Hasta Adı:</span>
                            <span class="deger">@Model.HastaAdSoyad.ToUpper()</span>
                        </div>
                        <div class="bilgi-satir">
                            <span class="etiket">TC Kimlik:</span>
                            <span class="deger">@Model.TcKimlik</span>
                        </div>
                    </div>
                    <div class="bilgi-kolon">
                        <h4>Makbuz Bilgileri</h4>
                        <div class="bilgi-satir">
                            <span class="etiket">Makbuz No:</span>
                            <span class="deger">@Model.MakbuzNo</span>
                        </div>
                        <div class="bilgi-satir">
                            <span class="etiket">Tarih:</span>
                            <span class="deger">@Model.IslemTarihi.ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                        <div class="bilgi-satir">
                            <span class="etiket">Ödeme Tipi:</span>
                            <span class="deger"><i class="fa-regular fa-credit-card me-1"></i> @Model.OdemeYontemi</span>
                        </div>
                        <div class="bilgi-satir">
                            <span class="etiket">İşlem Ref:</span>
                            <span class="deger" style="font-size: 0.8rem;">@Model.IslemRef</span>
                        </div>
                    </div>
                </div>

                @* İŞLEM TABLOSU *@
                <table class="islem-tablosu">
                    <thead>
                        <tr>
                            <th class="text-center" style="width: 50px;">#</th>
                            <th>İşlem Açıklaması</th>
                            <th class="text-center" style="width: 100px;">Adet</th>
                            <th class="text-right" style="width: 120px;">Birim Fiyat</th>
                            <th class="text-right" style="width: 130px;">Tutar</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Kalemler != null && Model.Kalemler.Any())
                        {
                            foreach (var kalem in Model.Kalemler)
                            {
                                <tr>
                                    <td class="text-center" style="color: var(--text-muted); font-weight: 500;">@kalem.Id</td>
                                    <td class="islem-adi-sutun">@kalem.IslemAdi</td>
                                    <td class="text-center">@kalem.Adet</td>
                                    <td class="text-right">@kalem.BirimFiyat.ToString("N2") ₺</td>
                                    <td class="text-right" style="font-weight: 700;">@kalem.Tutar.ToString("N2") ₺</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center" style="padding: 2rem; color: var(--text-muted); font-style: italic;">
                                    Kayıtlı işlem kalemi bulunamadı.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @* TOPLAMLAR *@
                <div class="toplamlar-alani">
                    <div class="toplam-tablo">
                        <div class="toplam-satiri">
                            <span>Ara Toplam</span>
                            <span class="deger">@Model.ToplamTutar.ToString("N2") ₺</span>
                        </div>
                        <div class="toplam-satiri">
                            <span>Sağlık KDV (%10)</span>
                            <span class="deger">@Model.KdvTutar.ToString("N2") ₺</span>
                        </div>
                        <div class="genel-toplam-satiri">
                            <span class="etiket">Genel Toplam</span>
                            <span class="deger">@Model.GenelToplam.ToString("N2") ₺</span>
                        </div>
                    </div>
                </div>

                @* FOOTER / İMZA *@
                <div class="fatura-footer">
                    <div class="yasal-not">
                        <p style="margin-bottom: 5px;">
                            <i class="fa-solid fa-circle-info"></i> Bu makbuz e-Fatura yerine geçmez, sadece bilgilendirme ve tahsilat kanıtı amaçlıdır.
                        </p>
                        <p style="margin: 0; font-weight: 500;">Geçmiş olsun dileklerimizle, bizi tercih ettiğiniz için teşekkür ederiz.</p>
                    </div>
                    <div class="imza-alani">
                        <p style="font-size: 0.75rem; color: var(--text-muted); font-weight: 600; margin-bottom: 0;">Tahsilatı Yapan</p>
                        <div class="imza-cizgi"></div>
                        <div class="imza-isim">@Model.KasiyerAdi</div>
                        <div class="imza-unvan">@Model.KasiyerBirim</div>
                    </div>
                </div>
            </div>
        </div>
        @* /faturaAlani *@

    </div>
</div>

@* ========== PDF İNDİRME SCRİPT ========== *@
<script>
    function downloadInvoicePDF() {
        const btn = document.getElementById('btnPdfIndir');
        const originalHtml = btn.innerHTML;

        // Butonu yükleniyor moduna al
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Hazırlanıyor...';
        btn.disabled = true;

        const element = document.getElementById('faturaAlani');

        const opt = {
            margin:      [15, 0, 15, 0],
    filename:    'Gazi_Hastanesi_Tahsilat_Makbuzu_@(Model.MakbuzNo).pdf',
            image:       { type: 'jpeg', quality: 1.0 },
            html2canvas: { scale: 3, useCORS: true, letterRendering: true },
            jsPDF:       { unit: 'mm', format: 'a4', orientation: 'portrait' }
        };

        html2pdf().set(opt).from(element).save()
            .then(() => {
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            })
            .catch(err => {
                console.error("PDF oluşturulurken hata:", err);
                btn.innerHTML = originalHtml;
                btn.disabled = false;
                alert("PDF oluşturulurken bir hata meydana geldi. Lütfen tekrar deneyin.");
            });
    }
</script>