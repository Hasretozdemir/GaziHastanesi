@{
    // Sayfanżn bažlżšżnż (title) belirliyoruz, bu "ViewData" koleksiyonu üzerinden Layout'a tažżnżr.
    ViewData["Title"] = "Gazi Sašlżk | Profesyonel Sonuē Portalż";
}

<!-- Tüm sonuē ekranżnż kaplayan ana kapsayżcż (viewport) -->
<div class="results-viewport">
    <!-- Arka plandaki bulanżk mavi daire efekti -->
    <div class="bg-blob"></div>
    <!-- Arka plandaki bulanżk altżn rengi daire efekti -->
    <div class="bg-blob-2"></div>

    <!-- Żēerik kartżnżn kendisi. Animasyonlu giriž (zoomIn) efekti verilmiž. -->
    <div class="results-container animate__animated animate__zoomIn">

        <!-- Sol taraftaki bilgi paneli (koyu renkli alan) -->
        <div class="info-side-panel">
            <!-- Bilgi iēerišini hizalamak ve düzenlemek iēin iē kapsayżcż -->
            <div class="info-inner">
                <!-- Logo ve marka isminin bulundušu üst grup -->
                <div class="brand-group-premium mb-4 mb-md-5">
                    <!-- Logo resmini tutan kutu -->
                    <div class="logo-wrapper">
                        <!-- Gazi Hastanesi logosu -->
                        <img src="/assets/gazilogo.jpg" alt="Gazi Logo">
                    </div>
                    <!-- Marka adż ve durumu gösteren metin grubu -->
                    <div class="brand-info">
                        <!-- Kurum adż bažlżšż -->
                        <h4 class="fw-900 m-0">GAZŻ ÜNŻVERSŻTESŻ</h4>
                        <!-- Altżndaki durum rozeti (Laboratuvar Ašż) -->
                        <span class="badge-online"><span class="pulse-dot"></span> LABORATUVAR AŠI</span>
                    </div>
                </div>

                <!-- Sayfanżn slogan ve aēżklama bölümü (Hero Section) -->
                <div class="hero-section mt-2 mt-md-4">
                    <!-- Büyük bažlżk. "Merkezi" kelimesi altżn rengi gradient ile vurgulanmżž. -->
                    <h1 class="display-5 fw-900 text-white">Analiz <br><span class="text-gradient-gold">Merkezi.</span></h1>
                    <!-- Aēżklama metni -->
                    <p class="text-white-50 lead-custom mt-3">Raporlarżnżz hazżr. Dijital arživinize erižerek tüm tżbbi süreēlerinizi anlżk olarak takip edebilirsiniz.</p>
                </div>

                <!-- Öne ēżkan özelliklerin listelendiši bölüm -->
                <div class="feature-stack mt-4 mt-md-5">
                    <!-- Özellik kartż: Akżllż PDF -->
                    <div class="feature-card-mini">
                        <!-- Żkon -->
                        <div class="f-icon"><i class="fas fa-file-pdf"></i></div>
                        <!-- Metin -->
                        <div class="f-text"><h6>Akżllż PDF</h6><p>HD Ēözünürlük</p></div>
                    </div>
                    <!-- Özellik kartż: Uētan Uca Žifreleme (Aktif görünümlü) -->
                    <div class="feature-card-mini active d-none d-sm-flex">
                        <!-- Żkon -->
                        <div class="f-icon"><i class="fas fa-shield-alt"></i></div>
                        <!-- Metin -->
                        <div class="f-text"><h6>Uētan Uca</h6><p>Žifreli Veri</p></div>
                    </div>
                </div>

                <!-- Alt kżsżmda sistem durumunu gösteren alan (sadece masaüstünde görünür) -->
                <div class="mt-auto pt-4 border-top border-white-10 d-none d-md-block">
                    <!-- Sistem sašlżk durumu göstergesi -->
                    <div class="system-health d-flex align-items-center">
                        <!-- Sunucu ikonu (yežil renk) -->
                        <i class="fas fa-server text-success me-3"></i>
                        <!-- Durum metni -->
                        <span class="small fw-bold text-white-50">Merkezi Sunucu Bašlantżsż Aktif</span>
                    </div>
                </div>
            </div>
            <!-- Panelin üzerine gelen cam efekti katmanż -->
            <div class="panel-overlay-glass"></div>
        </div>

        <!-- Saš taraftaki form paneli (beyaz alan) -->
        <div class="form-side-panel">
            <!-- Formun tažmasżnż önlemek ve kaydżrma özelliši iēin kapsayżcż -->
            <div class="form-scroll-wrapper">
                <!-- Formun ana kutusu -->
                <div class="form-main-box">

                    <!-- Bažlżk grubu (G sembolü ve bažlżk) -->
                    <div class="header-minimal text-center mb-4 mb-md-5">
                        <!-- Dekoratif G harfi sembolü -->
                        <div class="g-symbol">G</div>
                        <!-- Bažlżk metni -->
                        <h2 class="fw-900 text-navy mt-4">Sonuē Sorgula</h2>
                        <!-- Alt aēżklama metni -->
                        <p class="text-muted small">Güvenli protokol ile sonuēlarżnżza erižin</p>
                    </div>

                    <!-- Giriž yöntemi seēimi (TC veya Pasaport) -->
                    <div class="toggle-wrapper-premium mb-4 mb-md-5">
                        <!-- T.C. Kimlik seēeneši radio butonu -->
                        <input type="radio" name="loginType" id="tcMethod" checked onchange="updateUI('TC')">
                        <!-- T.C. Kimlik etiketi -->
                        <label for="tcMethod" class="toggle-btn">T.C. KŻMLŻK</label>

                        <!-- Pasaport seēeneši radio butonu -->
                        <input type="radio" name="loginType" id="passportMethod" onchange="updateUI('PASSPORT')">
                        <!-- Pasaport etiketi -->
                        <label for="passportMethod" class="toggle-btn">PASAPORT</label>

                        <!-- Seēili olanżn arkasżnda kayan beyaz arka plan -->
                        <div class="glider-premium"></div>
                    </div>

                    <!-- Giriž formu -->
                    <form id="sonucForm" action="/Sonuc/Login" method="post" class="auth-form-premium">
                        <!-- Kimlik numarasż giriž alanż grubu -->
                        <div class="floating-group mb-4">
                            <!-- Etiket (Javascript ile dešižebilir) -->
                            <label id="idLabel" class="label-premium">KŻMLŻK NUMARASI</label>
                            <!-- Girdi alanż ve ikonu -->
                            <div class="input-field">
                                <!-- Żkon (Javascript ile dešižebilir) -->
                                <i id="idIcon" class="far fa-id-card"></i>
                                <!-- Input alanż -->
                                <input type="text" placeholder="11 Haneli T.C. Kimlik" required maxlength="11" class="w-100">
                                <!-- Alt ēizgi efekti -->
                                <div class="input-line"></div>
                            </div>
                        </div>

                        <!-- Žifre giriž alanż grubu -->
                        <div class="floating-group mb-4 mb-md-5">
                            <!-- Etiket -->
                            <label class="label-premium">SONUĒ ŽŻFRESŻ</label>
                            <!-- Girdi alanż kapsayżcżsż -->
                            <div class="input-field">
                                <!-- Kilit ikonu -->
                                <i class="fas fa-unlock-alt"></i>
                                <!-- Žifre input alanż -->
                                <input type="password" placeholder="Žifrenizi giriniz" required class="w-100">
                                <!-- Alt ēizgi efekti -->
                                <div class="input-line"></div>
                            </div>
                        </div>

                        <!-- Gönder butonu (Submit) -->
                        <button type="submit" class="btn-glow-premium">
                            <!-- Buton üzerindeki yazż -->
                            <span class="b-text">SONUĒLARI LŻSTELE</span>
                            <!-- Butonun sašżndaki ok ikonu -->
                            <div class="b-icon"><i class="fas fa-chevron-right"></i></div>
                        </button>
                    </form>

                    <!-- Ekstra ižlemler (Žifre yenileme, Kayżt ol) -->
                    <div class="extra-actions mt-4 text-center">
                        <a href="#" class="link-luxury me-3 me-md-4">Žifremi Unuttum</a>
                        <a href="#" class="link-luxury">Kayżt Ol</a>
                    </div>

                    <!-- Alt kżsżmdaki partner logolarż (E-Nabżz) -->
                    <div class="partner-footer mt-5">
                        <!-- Bölücü metin -->
                        <div class="divider-text">GÜVENLŻ ENTEGRASYON</div>
                        <!-- Logo kapsayżcżsż -->
                        <div class="d-flex justify-content-center align-items-center gap-3 gap-md-4 mt-3">
                            <!-- E-Nabżz logosu -->
                            <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/0/01/E-Nab%C4%B1z_logo.png/640px-E-Nab%C4%B1z_logo.png" class="partner-img grayscale">
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Styles {
    <!-- Animate.css kütüphanesi (animasyonlar iēin) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <style>
        /* CSS Dešižken tanżmlarż (renkler) */
        :root {
            --navy: #0f172a; /* Koyu lacivert */
            --primary: #2563eb; /* Ana mavi */
            --gold: #c5a059; /* Altżn rengi */
            --soft-white: rgba(255,255,255,0.9); /* Yumužak beyaz */
        }

        /* Sayfa geneli gövde ayarlarż */
        body {
            background: #f1f5f9; /* Arka plan rengi */
            font-family: 'Plus Jakarta Sans', sans-serif; /* Yazż tipi */
            margin: 0;
            padding: 0;
            overflow-x: hidden; /* Yatay tažmayż engelle */
        }

        /* Sonuē ekranżnż ortalayan dżž kapsayżcż */
        .results-viewport {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            position: relative;
        }

        /* Żēerik kartżnżn kendisi */
        .results-container {
            width: 100%;
            max-width: 1150px;
            background: white;
            border-radius: 45px;
            display: flex;
            flex-direction: row;
            box-shadow: 0 40px 100px rgba(15,23,42,0.12);
            overflow: hidden;
            min-height: 700px;
        }

        /* Sol taraftaki bilgi paneli */
        .info-side-panel {
            flex: 1.1; /* Genižlik oranż */
            background: var(--navy);
            padding: 50px;
            position: relative;
            color: white;
            display: flex;
            flex-direction: column;
        }

        /* Saš taraftaki form paneli */
        .form-side-panel {
            flex: 1; /* Genižlik oranż */
            background: white;
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        /* Mobil uyumluluk (Tablet ve altż) */
        @@media (max-width: 991px) {
            .results-container {
                flex-direction: column; /* Dikey yerležim */
                height: auto;
                border-radius: 30px;
                margin-top: 20px;
                margin-bottom: 20px;
            }

            .info-side-panel {
                padding: 40px 30px;
                order: 1; /* Önce bilgi paneli */
            }

            .form-side-panel {
                padding: 10px;
                order: 2; /* Sonra form paneli */
            }

            .results-viewport {
                padding: 10px;
                align-items: flex-start;
            }

            .hero-section h1 {
                font-size: 2rem; /* Bažlżk boyutunu küēült */
            }
        }

        /* Arka plan bulanżk daire 1 */
        .bg-blob {
            position: absolute;
            top: -10%;
            right: -5%;
            width: 500px;
            height: 500px;
            background: rgba(37,99,235,0.05);
            border-radius: 50%;
            filter: blur(80px); /* Bulanżklżk */
            z-index: -1;
        }

        /* Arka plan bulanżk daire 2 */
        .bg-blob-2 {
            position: absolute;
            bottom: -10%;
            left: -5%;
            width: 400px;
            height: 400px;
            background: rgba(197,160,89,0.05);
            border-radius: 50%;
            filter: blur(80px); /* Bulanżklżk */
            z-index: -1;
        }

        /* Panelin üzerindeki cam efekti */
        .panel-overlay-glass {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(145deg, rgba(15,23,42,0.8) 0%, rgba(37,99,235,0.1) 100%);
            z-index: 0;
        }

        /* Bilgi panelinin iēeriši */
        .info-inner {
            position: relative;
            z-index: 1; /* Cam efektinin üzerinde kalmasż iēin */
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        /* Logo kapsayżcżsż */
        .logo-wrapper {
            width: 60px;
            height: 60px;
            background: white;
            border-radius: 18px;
            padding: 7px;
        }
            /* Logo resmi */
            .logo-wrapper img {
                width: 100%;
                height: 100%;
                object-fit: contain;
            }

        /* Marka grup kapsayżcżsż */
        .brand-group-premium {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        /* Online rozeti */
        .badge-online {
            font-size: 10px;
            font-weight: 800;
            color: var(--gold);
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* Yanżp sönen nokta animasyonu iēin element */
        .pulse-dot {
            width: 6px;
            height: 6px;
            background: var(--gold);
            border-radius: 50%;
            animation: pulse-gold 2s infinite; /* Animasyon tanżmż */
        }

        /* Altżn rengi gradient metin */
        .text-gradient-gold {
            background: linear-gradient(to right, #e2c27d, #c5a059);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Özellik kartlarż yżšżnż */
        .feature-stack {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        /* Küēük özellik kartż */
        .feature-card-mini {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.08);
            padding: 15px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            gap: 15px;
        }
            /* Aktif kart görünümü */
            .feature-card-mini.active {
                background: rgba(255,255,255,0.08); /* Biraz daha aēżk */
            }

        /* Żkon kutusu */
        .f-icon {
            width: 40px;
            height: 40px;
            background: var(--primary);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Yazż alanlarż */
        .f-text h6 {
            margin: 0;
            font-weight: 800;
            font-size: 0.85rem;
            color: #fff;
        }

        .f-text p {
            margin: 0;
            font-size: 0.7rem;
            opacity: 0.5;
        }

        /* Form kaydżrma alanż */
        .form-scroll-wrapper {
            flex: 1;
            padding: 40px;
        }

        /* G sembolü kutusu */
        .g-symbol {
            width: 65px;
            height: 65px;
            background: #f8fafc;
            border-radius: 22px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            font-weight: 900;
            color: var(--navy);
            margin: 0 auto;
            border: 1px solid #e2e8f0;
        }

        /* Radio buton kapsayżcżsż (Toggle) */
        .toggle-wrapper-premium {
            background: #f1f5f9;
            padding: 6px;
            border-radius: 20px;
            display: flex;
            position: relative;
            border: 1px solid #e2e8f0;
        }
            /* Radio inputlarżnż gizle */
            .toggle-wrapper-premium input {
                display: none;
            }

        /* Seēenek butonlarż */
        .toggle-btn {
            flex: 1;
            text-align: center;
            padding: 12px;
            font-size: 11px;
            font-weight: 800;
            cursor: pointer;
            z-index: 2; /* Kaydżrżcżnżn üstünde */
            color: #64748b;
            transition: 0.3s;
        }

        /* Kayan beyaz arka plan (Glider) */
        .glider-premium {
            position: absolute;
            height: calc(100% - 12px);
            width: calc(50% - 6px);
            background: white;
            border-radius: 16px;
            top: 6px;
            left: 6px;
            box-shadow: 0 8px 15px rgba(0,0,0,0.05);
            transition: 0.3s;
        }

        /* Seēime göre kaydżrżcżnżn yerini dešižtir */
        #passportMethod:checked ~ .glider-premium {
            transform: translateX(100%);
        }

        /* Seēili elemanżn rengini koyulažtżr */
        #tcMethod:checked ~ label[for="tcMethod"], #passportMethod:checked ~ label[for="passportMethod"] {
            color: var(--navy);
        }

        /* Input etiketleri */
        .label-premium {
            font-size: 11px;
            font-weight: 800;
            color: #94a3b8;
            margin-bottom: 10px;
            display: block;
        }

        /* Input alanż kapsayżcżsż */
        .input-field {
            position: relative;
        }
            /* Input ikonu */
            .input-field i {
                position: absolute;
                left: 0;
                top: 12px;
                color: #cbd5e1;
                font-size: 1rem;
            }
            /* Input stil */
            .input-field input {
                width: 100%;
                border: none;
                padding: 12px 0 12px 30px;
                font-weight: 700;
                color: var(--navy);
                background: transparent;
                outline: none;
            }

        /* Alt ēizgi animasyonu iēin element */
        .input-line {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 2px;
            background: #f1f5f9;
            transition: 0.3s;
        }

        /* Focus olunca ēizgi rengi dešižsin */
        .input-field input:focus ~ .input-line {
            background: var(--primary);
        }

        /* Buton stili */
        .btn-glow-premium {
            width: 100%;
            height: 65px;
            background: var(--navy);
            border: none;
            border-radius: 22px;
            color: white;
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 25px;
            transition: 0.4s;
        }
            /* Buton hover efekti */
            .btn-glow-premium:hover {
                background: var(--primary);
                transform: translateY(-3px);
                box-shadow: 0 15px 30px rgba(37,99,235,0.25);
            }

        /* Buton ikonu */
        .b-icon {
            width: 35px;
            height: 35px;
            background: rgba(255,255,255,0.1);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Alt linkler */
        .link-luxury {
            font-size: 11px;
            font-weight: 700;
            color: #94a3b8;
            text-decoration: none;
        }

        /* Ayżrżcż metin */
        .divider-text {
            display: flex;
            align-items: center;
            gap: 10px;
            color: #cbd5e1;
            font-size: 10px;
            font-weight: 800;
        }
            /* Ēizgiler */
            .divider-text::before, .divider-text::after {
                content: '';
                flex: 1;
                border-bottom: 1px solid #f1f5f9;
            }

        /* Partner görseli */
        .partner-img {
            height: 25px;
            filter: grayscale(1);
            opacity: 0.5;
        }

        /* Nokta animasyonu (keyframe) */
        @@keyframes pulse-gold {
            0% {
                box-shadow: 0 0 0 0 rgba(197,160,89,0.5);
            }
            70% {
                box-shadow: 0 0 0 10px rgba(197,160,89,0);
            }
            100% {
                box-shadow: 0 0 0 0 rgba(197,160,89,0);
            }
        }
    </style>
}

@section Scripts {
    <!-- Javascript kodlarż -->
    <script>
        // UI güncelleme fonksiyonu (TC/Pasaport geēiži iēin)
        function updateUI(type) {
            // Żlgili elementleri seē
            const label = document.getElementById('idLabel');
            const input = document.querySelector('.input-field input');
            const icon = document.getElementById('idIcon');

            // Ešer Pasaport seēildiyse:
            if (type === 'PASSPORT') {
                label.innerText = 'PASAPORT NUMARASI';
                input.placeholder = 'Pasaport numaranżzż giriniz';
                icon.className = 'fas fa-passport';
            } else {
                // TC Kimlik seēildiyse:
                label.innerText = 'KŻMLŻK NUMARASI';
                input.placeholder = '11 Haneli T.C. Kimlik';
                icon.className = 'far fa-id-card';
            }
        }
    </script>
}