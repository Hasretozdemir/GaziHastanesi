@model IEnumerable<GaziHastane.Models.TahlilSonuc>
@{
    // Sayfanın tarayıcı sekmesinde görünen başlığı
    ViewData["Title"] = "Gazi Sağlık | Hasta Sonuç Paneli";
}

<div class="patient-master-wrapper">
    <div class="dashboard-bg-overlay"></div>

    <div class="patient-center-container">

        <div class="dashboard-main-container animate__animated animate__fadeIn">

            <div class="glass-header-panel mb-4">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

                    <div class="d-flex align-items-center">
                        <div class="avatar-premium-wrapper me-3">
                            <div class="avatar-premium">@ViewBag.KullaniciBasHarfler</div> <div class="status-indicator online"></div>
                        </div>

                        <div>
                            <h4 class="fw-800 color-navy mb-0">@ViewBag.KullaniciAdSoyad</h4>
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge bg-soft-navy text-navy-light small">Hasta No: @ViewBag.HastaNo</span>
                                <span class="text-muted small"><i class="fas fa-map-marker-alt"></i> Ankara, Türkiye</span>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button class="btn-premium-light"><i class="fas fa-user-cog"></i> Profilim</button>
                        <a href="/Sonuc/Giris" class="btn-premium-danger text-decoration-none"><i class="fas fa-sign-out-alt"></i> Güvenli Çıkış</a>
                    </div>
                </div>
            </div>

            <div class="row g-4">

                <div class="col-lg-3 animate__animated animate__fadeInLeft">
                    <div class="dashboard-sidebar card border-0 shadow-sm rounded-5 p-3 h-100">
                        <h6 class="sidebar-title">TIBBİ ARŞİV</h6>

                        <nav class="nav flex-column sidebar-nav">
                            <a href="#" class="nav-link active">
                                <div class="nav-icon"><i class="fas fa-vial"></i></div>
                                <span>Laboratuvar</span>
                                <span class="count-badge">@(Model?.Count() ?? 0)</span>
                            </a>
                            <a href="#" class="nav-link">
                                <div class="nav-icon"><i class="fas fa-x-ray"></i></div>
                                <span>Radyoloji</span>
                            </a>
                            <a href="#" class="nav-link">
                                <div class="nav-icon"><i class="fas fa-microscope"></i></div>
                                <span>Patoloji</span>
                            </a>
                            <hr class="my-3 opacity-10">
                            <a href="#" class="nav-link text-danger">
                                <div class="nav-icon"><i class="fas fa-exclamation-circle"></i></div>
                                <span>Acil Bilgilerim</span>
                            </a>
                        </nav>
                    </div>
                </div>

                <div class="col-lg-9 animate__animated animate__fadeInRight">
                    <div class="content-card card border-0 shadow-sm rounded-5 p-4 h-100">

                        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                            <div>
                                <h5 class="fw-800 color-navy mb-1">Son Tetkikler</h5>
                                <p class="text-muted small mb-0">Tüm tıbbi tetkikleriniz listelenmektedir.</p>
                            </div>
                            <div class="search-wrapper-modern">
                                <i class="fas fa-search"></i>
                                <input type="text" id="searchInput" placeholder="Tetkik adı ara..." onkeyup="filterTable()">
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-hover-modern align-middle" id="sonucTable">
                                <thead>
                                    <tr>
                                        <th>Tetkik Adı</th>
                                        <th>Kategori</th>
                                        <th>Tarih</th>
                                        <th class="text-center">Durum</th>
                                        <th class="text-end">Aksiyon</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model != null && Model.Any())
                                    {
                                        foreach (var sonuc in Model)
                                        {
                                            // Eğer "SonucDegeri" varsa işlem tamamlanmış demektir, yoksa beklemededir.
                                            bool isCompleted = !string.IsNullOrEmpty(sonuc.SonucDegeri);
                                            string iconClass = isCompleted ? "" : "warning";
                                            string faIcon = isCompleted ? "fa-tint" : "fa-sun";
                                            string badgeClass = isCompleted ? "success" : "warning";
                                            string badgeIcon = isCompleted ? "fa-check-circle" : "fa-clock";
                                            string badgeText = isCompleted ? "Tamamlandı" : "Onay Bekliyor";

                                            <tr>
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        <div class="test-icon-bg @iconClass"><i class="fas @faIcon"></i></div>
                                                        <div class="ms-3">
                                                            <div class="fw-bold color-navy test-name">@sonuc.TestAdi</div>
                                                            <div class="extra-small text-muted">Referans: @(string.IsNullOrEmpty(sonuc.ReferansAraligi) ? "-" : sonuc.ReferansAraligi)</div>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td><span class="text-muted small fw-600">@(sonuc.TestKategorisi ?? "Genel")</span></td>
                                                <td><span class="text-muted small">@sonuc.Tarih.ToString("dd.MM.yyyy")</span></td>
                                                <td class="text-center">
                                                    <span class="badge-status @badgeClass">
                                                        <i class="fas @badgeIcon"></i> @badgeText
                                                    </span>
                                                </td>
                                                <td class="text-end">
                                                    <div class="btn-group-action justify-content-end d-flex">
                                                        <button class="btn-action view" title="Görüntüle" onclick="alert('Sonuç Değeri: @(isCompleted? sonuc.SonucDegeri: "Henüz Çıkmadı")')"><i class="fas fa-eye"></i></button>

                                                        @if (!string.IsNullOrEmpty(sonuc.RaporDosyaUrl))
                                                        {
                                                            <a href="@sonuc.RaporDosyaUrl" target="_blank" class="btn-action download text-center text-decoration-none" title="İndir" style="line-height:36px;"><i class="fas fa-file-pdf"></i></a>
                                                        }
                                                        else
                                                        {
                                                            <button class="btn-action disabled" title="Rapor Yok"><i class="fas fa-lock"></i></button>
                                                        }
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="5" class="text-center py-5">
                                                <i class="fas fa-folder-open fa-3x text-muted opacity-25 mb-3"></i>
                                                <p class="text-muted fw-bold">Sisteme kayıtlı herhangi bir tetkik sonucunuz bulunmamaktadır.</p>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filterTable() {
            var input, filter, table, tr, td, i, txtValue;
            input = document.getElementById("searchInput");
            filter = input.value.toUpperCase();
            table = document.getElementById("sonucTable");
            tr = table.getElementsByTagName("tr");

            for (i = 1; i < tr.length; i++) {
                // Sadece Tetkik Adı sütununda arama yap (0. index)
                td = tr[i].getElementsByClassName("test-name")[0];
                if (td) {
                    txtValue = td.textContent || td.innerText;
                    if (txtValue.toUpperCase().indexOf(filter) > -1) {
                        tr[i].style.display = "";
                    } else {
                        tr[i].style.display = "none";
                    }
                }
            }
        }
    </script>
}

@section Styles {
    <style>
        /* Renk Değişkenleri */
        :root {
            --gazi-navy: #0f172a; /* Temel lacivert renk */
            --gazi-blue: #2563eb; /* Vurgu mavisi */
            --gazi-gold: #c5a059; /* Altın rengi */
            --bg-light: #f1f5f9; /* Açık gri arka plan */
            --success-green: #10b981; /* Başarılı işlem yeşili */
            --warning-orange: #f59e0b; /* Uyarı turuncusu */
            --navbar-safe-gap: 80px; /* Üst bar (navbar) yüksekliği, içeriğin altında kalmaması için */
        }

        /* Temel Sayfa Ayarları */
        body, html {
            height: 100%;
            margin: 0;
            overflow-x: hidden;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        /* Ana sayfa kapsayıcısı arka planı */
        .patient-master-wrapper {
            background: var(--bg-light);
            min-height: 100vh;
            position: relative;
        }

        /* İçeriği dikey ve yatay olarak ortalayan yapı */
        .patient-center-container {
            display: flex;
            align-items: center; /* Dikeyde ortalar */
            justify-content: center; /* Yatayda ortalar */
            min-height: 100vh;
            /* Üstten navbar payı + 20px, alttan 40px boşluk */
            padding: calc(var(--navbar-safe-gap) + 20px) 20px 40px 20px;
        }

        /* İçerik genişliğini sınırlayan kutu */
        .dashboard-main-container {
            width: 100%;
            max-width: 1200px;
            margin: auto;
        }

        /* Renk yardımcı sınıfları */
        .color-navy {
            color: var(--gazi-navy);
        }

        .fw-800 {
            font-weight: 800; /* Ekstra kalın yazı tipi */
        }

        .extra-small {
            font-size: 11px;
        }

        /* Üst Profil Kartı (Cam efekti yok, düz beyaz) */
        .glass-header-panel {
            background: white;
            padding: 25px;
            border-radius: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.03); /* Hafif gölge */
            border: 1px solid rgba(0,0,0,0.05); /* İnce kenarlık */
        }

        /* Avatar Kutusu */
        .avatar-premium-wrapper {
            position: relative; /* Durum göstergesi (online) için referans */
        }

        .avatar-premium {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, var(--gazi-navy), #1e293b); /* Lacivert gradyan */
            color: white;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 1.2rem;
            box-shadow: 0 10px 20px rgba(15, 23, 42, 0.2);
        }

        /* Çevrimiçi Durum Göstergesi (Yeşil Nokta) */
        .status-indicator.online {
            width: 14px;
            height: 14px;
            background: var(--success-green);
            border: 3px solid white; /* Beyaz çerçeve ile ayrım */
            border-radius: 50%;
            position: absolute;
            bottom: -2px;
            right: -2px;
        }

        /* Üst butonlar */
        .btn-premium-light {
            border: none;
            padding: 10px 20px;
            border-radius: 12px;
            background: #f1f5f9;
            color: var(--gazi-navy);
            font-weight: 700;
            transition: 0.3s;
        }

            .btn-premium-light:hover {
                background: #e2e8f0;
            }

        .btn-premium-danger {
            border: none;
            padding: 10px 20px;
            border-radius: 12px;
            background: #fee2e2;
            color: #ef4444;
            font-weight: 700;
            transition: 0.3s;
        }

            .btn-premium-danger:hover {
                background: #fca5a5;
                color: white;
            }

        /* Sidebar Başlığı */
        .sidebar-title {
            font-size: 11px;
            font-weight: 800;
            color: #94a3b8;
            letter-spacing: 1.5px; /* Harf aralığı */
            margin-bottom: 20px;
            padding-left: 15px;
        }

        /* Sidebar Linkleri */
        .sidebar-nav .nav-link {
            display: flex;
            align-items: center;
            padding: 14px 18px;
            color: #64748b;
            font-weight: 600;
            border-radius: 16px;
            margin-bottom: 5px;
            transition: 0.3s;
        }

            .sidebar-nav .nav-link .nav-icon {
                width: 32px;
                font-size: 1.1rem;
            }

            /* Link üzerine gelince */
            .sidebar-nav .nav-link:hover {
                background: #f1f5f9;
                color: var(--gazi-navy);
            }

            /* Aktif Link */
            .sidebar-nav .nav-link.active {
                background: var(--gazi-navy);
                color: white;
                box-shadow: 0 10px 20px rgba(15, 23, 42, 0.15);
            }

        /* Bildirim Sayısı Rozeti */
        .count-badge {
            margin-left: auto;
            background: rgba(255,255,255,0.2);
            padding: 2px 8px;
            border-radius: 8px;
            font-size: 10px;
        }

        /* Arama Kutusu Stili */
        .search-wrapper-modern {
            position: relative;
            width: 100%;
            max-width: 300px;
        }

            /* Arama İkonu */
            .search-wrapper-modern i {
                position: absolute;
                left: 15px;
                top: 50%;
                transform: translateY(-50%);
                color: #94a3b8;
            }

            /* Arama Inputu */
            .search-wrapper-modern input {
                width: 100%;
                padding: 10px 15px 10px 45px;
                border-radius: 14px;
                border: 1px solid #e2e8f0;
                background: #f8fafc;
                outline: none;
                transition: 0.3s;
            }

                /* Input odaklanınca */
                .search-wrapper-modern input:focus {
                    border-color: var(--gazi-gold);
                    background: white;
                    box-shadow: 0 0 0 4px rgba(197, 160, 89, 0.1);
                }

        /* Tablo Başlıkları */
        .table-hover-modern thead th {
            color: #94a3b8;
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            padding: 20px;
            border-bottom: 2px solid #f1f5f9;
        }

        /* Tablo Satırları */
        .table-hover-modern tbody td {
            padding: 20px;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
        }

        /* Test/Tetkik İkonu Arka Planı */
        .test-icon-bg {
            width: 40px;
            height: 40px;
            background: #eff6ff; /* Mavi arka plan */
            color: var(--gazi-blue);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
        }

            /* Uyarı İkonu (Sarı) */
            .test-icon-bg.warning {
                background: #fff7ed;
                color: var(--warning-orange);
            }

        /* Durum Rozetleri */
        .badge-status {
            padding: 6px 14px;
            border-radius: 10px;
            font-size: 11px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

            .badge-status.success {
                background: #dcfce7;
                color: #15803d;
            }

            .badge-status.warning {
                background: #fef3c7;
                color: #b45309;
            }

        /* İşlem Butonları */
        .btn-action {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            border: none;
            transition: 0.2s;
            margin-left: 5px;
        }

            /* Görüntüle Butonu (Lacivert) */
            .btn-action.view {
                background: var(--gazi-navy);
                color: white;
            }

            /* İndir Butonu (Gri) */
            .btn-action.download {
                background: #f1f5f9;
                color: #64748b;
            }

            /* Buton Hover Efekti */
            .btn-action:hover:not(.disabled) {
                transform: translateY(-3px);
                box-shadow: 0 5px 10px rgba(0,0,0,0.1);
            }

        /* Mobil Uyumluluk Ayarları */
        @@media (max-width: 991px) {
            .dashboard-main-container {
                margin: 15px; /* Kenar boşluklarını azalt */
            }

            .patient-center-container {
                /* Navbar'ın altında kalmaması için üst boşluğu artır */
                padding-top: calc(var(--navbar-safe-gap) + 30px);
            }
        }
    </style>
}