@{
    // Sayfanın tarayıcı sekmesinde görünen başlığı
    ViewData["Title"] = "Gazi Sağlık | Hasta Sonuç Paneli";
}

<!-- Ana Kapsayıcı: Tüm hasta paneli içeriğini sarar -->
<div class="patient-master-wrapper">
    <!-- Arka plan katmanı (opsiyonel dekoratif amaçlı) -->
    <div class="dashboard-bg-overlay"></div>

    <!-- İçeriği dikey ve yatay olarak ortalayan yapı -->
    <div class="patient-center-container">

        <!-- Ana Panel Kutusu: Animasyonlu giriş efektiyle belirir -->
        <div class="dashboard-main-container animate__animated animate__fadeIn">

            <!-- Üst Kısım: Kullanıcı Profili ve Hızlı İşlemler -->
            <div class="glass-header-panel mb-4">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                    
                    <!-- Sol Taraf: Hasta Bilgileri -->
                    <div class="d-flex align-items-center">
                        <!-- Avatar (Profil Resmi) ve Durum Göstergesi -->
                        <div class="avatar-premium-wrapper me-3">
                            <div class="avatar-premium">MS</div> <!-- İsim Başharfleri -->
                            <div class="status-indicator online"></div> <!-- Çevrimiçi Yeşil Noktası -->
                        </div>
                        
                        <!-- İsim ve Detaylar -->
                        <div>
                            <h4 class="fw-800 color-navy mb-0">Murat SARI</h4>
                            <div class="d-flex align-items-center gap-2">
                                <!-- Hasta Numarası Rozeti -->
                                <span class="badge bg-soft-navy text-navy-light small">Hasta No: 9876543</span>
                                <!-- Konum Bilgisi -->
                                <span class="text-muted small"><i class="fas fa-map-marker-alt"></i> Ankara, Türkiye</span>
                            </div>
                        </div>
                    </div>

                    <!-- Sağ Taraf: Profil ve Çıkış Butonları -->
                    <div class="d-flex gap-2">
                        <button class="btn-premium-light"><i class="fas fa-user-cog"></i> Profilim</button>
                        <button class="btn-premium-danger"><i class="fas fa-sign-out-alt"></i> Güvenli Çıkış</button>
                    </div>
                </div>
            </div>

            <!-- Alt Kısım: Sidebar ve Ana İçerik Grid Yapısı -->
            <div class="row g-4">
                
                <!-- Sol Menü (Sidebar) - Mobilde ve küçük ekranlarda üstte, büyük ekranlarda solda -->
                <div class="col-lg-3 animate__animated animate__fadeInLeft">
                    <div class="dashboard-sidebar card border-0 shadow-sm rounded-5 p-3 h-100">
                        <!-- Menü Başlığı -->
                        <h6 class="sidebar-title">TIBBİ ARŞİV</h6>
                        
                        <!-- Menü Linkleri -->
                        <nav class="nav flex-column sidebar-nav">
                            <!-- Aktif Link (Örnek: Laboratuvar) -->
                            <a href="#" class="nav-link active">
                                <div class="nav-icon"><i class="fas fa-vial"></i></div>
                                <span>Laboratuvar</span>
                                <!-- Bildirim Sayısı Rozeti -->
                                <span class="count-badge">12</span>
                            </a>
                            <a href="#" class="nav-link">
                                <div class="nav-icon"><i class="fas fa-x-ray"></i></div>
                                <span>Radyoloji</span>
                            </a>
                            <a href="#" class="nav-link">
                                <div class="nav-icon"><i class="fas fa-microscope"></i></div>
                                <span>Patoloji</span>
                            </a>
                            <a href="#" class="nav-link">
                                <div class="nav-icon"><i class="fas fa-file-medical"></i></div>
                                <span>Raporlarım</span>
                            </a>
                            <!-- Ayırıcı Çizgi -->
                            <hr class="my-3 opacity-10">
                            <!-- Acil Bilgiler Linki (Kırmızı vurgulu) -->
                            <a href="#" class="nav-link text-danger">
                                <div class="nav-icon"><i class="fas fa-exclamation-circle"></i></div>
                                <span>Acil Bilgilerim</span>
                            </a>
                        </nav>
                    </div>
                </div>

                <!-- Sağ İçerik Alanı: Tablo ve Detaylar -->
                <div class="col-lg-9 animate__animated animate__fadeInRight">
                    <div class="content-card card border-0 shadow-sm rounded-5 p-4 h-100">
                        
                        <!-- İçerik Başlığı ve Arama Kutusu -->
                        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                            <div>
                                <h5 class="fw-800 color-navy mb-1">Son Tetkikler</h5>
                                <p class="text-muted small mb-0">Son 6 ay içerisindeki tüm tıbbi tetkikleriniz listelenmektedir.</p>
                            </div>
                            <!-- Arama Kutusu -->
                            <div class="search-wrapper-modern">
                                <i class="fas fa-search"></i>
                                <input type="text" placeholder="Tetkik adı veya birim ara...">
                            </div>
                        </div>

                        <!-- Tablo Alanı: Mobil uyumlu (responsive) -->
                        <div class="table-responsive">
                            <table class="table table-hover-modern align-middle">
                                <thead>
                                    <tr>
                                        <th>Tetkik Adı</th>
                                        <th>Birim</th>
                                        <th>Tarih</th>
                                        <th class="text-center">Durum</th>
                                        <th class="text-end">Aksiyon</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Örnek Satır 1: Tamamlanmış Tetkik -->
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <!-- İkon -->
                                                <div class="test-icon-bg"><i class="fas fa-tint"></i></div>
                                                <div class="ms-3">
                                                    <div class="fw-bold color-navy">Hemogram (Tam Kan Sayımı)</div>
                                                    <div class="extra-small text-muted">ID: #TR-4452</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td><span class="text-muted small fw-600">Biyokimya</span></td>
                                        <td><span class="text-muted small">04.03.2026</span></td>
                                        <td class="text-center">
                                            <!-- Durum Rozeti (Yeşil) -->
                                            <span class="badge-status success">
                                                <i class="fas fa-check-circle"></i> Tamamlandı
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            <!-- İşlem Butonları -->
                                            <div class="btn-group-action">
                                                <button class="btn-action view" title="Görüntüle"><i class="fas fa-eye"></i></button>
                                                <button class="btn-action download" title="İndir"><i class="fas fa-file-pdf"></i></button>
                                            </div>
                                        </td>
                                    </tr>
                                    <!-- Örnek Satır 2: Bekleyen Tetkik -->
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <!-- İkon (Sarı) -->
                                                <div class="test-icon-bg warning"><i class="fas fa-sun"></i></div>
                                                <div class="ms-3">
                                                    <div class="fw-bold color-navy">Vitamin D (25-OH)</div>
                                                    <div class="extra-small text-muted">ID: #TR-4489</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td><span class="text-muted small fw-600">Biyokimya</span></td>
                                        <td><span class="text-muted small">04.03.2026</span></td>
                                        <td class="text-center">
                                            <!-- Durum Rozeti (Sarı) -->
                                            <span class="badge-status warning">
                                                <i class="fas fa-clock"></i> Onay Bekliyor
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            <div class="btn-group-action">
                                                <button class="btn-action disabled"><i class="fas fa-lock"></i></button>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Sayfaya Özel CSS Stilleri -->
<style>
    /* Renk Değişkenleri */
    :root {
        --gazi-navy: #0f172a; /* Temel lacivert renk */
        --gazi-blue: #2563eb; /* Vurgu mavisi */
        --gazi-gold: #c5a059; /* Altın rengi */
        --bg-light: #f1f5f9; /* Açık gri arka plan */
        --success-green: #10b981; /* Başarılı işlem yeşili */
        --warning-orange: #f59e0b; /* Uyarı turuncusu */
        --navbar-safe-gap: 80px; /* Üst bar (navbar) yüksekliği, içeriğin altında kalmaması için */
    }

    /* Temel Sayfa Ayarları */
    body, html {
        height: 100%;
        margin: 0;
        overflow-x: hidden;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    /* Ana sayfa kapsayıcısı arka planı */
    .patient-master-wrapper {
        background: var(--bg-light);
        min-height: 100vh;
        position: relative;
    }

    /* İçeriği dikey ve yatay olarak ortalayan yapı */
    .patient-center-container {
        display: flex;
        align-items: center; /* Dikeyde ortalar */
        justify-content: center; /* Yatayda ortalar */
        min-height: 100vh;
        /* Üstten navbar payı + 20px, alttan 40px boşluk */
        padding: calc(var(--navbar-safe-gap) + 20px) 20px 40px 20px; 
    }

    /* İçerik genişliğini sınırlayan kutu */
    .dashboard-main-container {
        width: 100%;
        max-width: 1200px;
        margin: auto;
    }

    /* Renk yardımcı sınıfları */
    .color-navy {
        color: var(--gazi-navy);
    }

    .fw-800 {
        font-weight: 800; /* Ekstra kalın yazı tipi */
    }

    .extra-small {
        font-size: 11px;
    }

    /* Üst Profil Kartı (Cam efekti yok, düz beyaz) */
    .glass-header-panel {
        background: white;
        padding: 25px;
        border-radius: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03); /* Hafif gölge */
        border: 1px solid rgba(0,0,0,0.05); /* İnce kenarlık */
    }

    /* Avatar Kutusu */
    .avatar-premium-wrapper {
        position: relative; /* Durum göstergesi (online) için referans */
    }

    .avatar-premium {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, var(--gazi-navy), #1e293b); /* Lacivert gradyan */
        color: white;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1.2rem;
        box-shadow: 0 10px 20px rgba(15, 23, 42, 0.2);
    }

    /* Çevrimiçi Durum Göstergesi (Yeşil Nokta) */
    .status-indicator.online {
        width: 14px;
        height: 14px;
        background: var(--success-green);
        border: 3px solid white; /* Beyaz çerçeve ile ayrım */
        border-radius: 50%;
        position: absolute;
        bottom: -2px;
        right: -2px;
    }

    /* Sidebar Başlığı */
    .sidebar-title {
        font-size: 11px;
        font-weight: 800;
        color: #94a3b8;
        letter-spacing: 1.5px; /* Harf aralığı */
        margin-bottom: 20px;
        padding-left: 15px;
    }

    /* Sidebar Linkleri */
    .sidebar-nav .nav-link {
        display: flex;
        align-items: center;
        padding: 14px 18px;
        color: #64748b;
        font-weight: 600;
        border-radius: 16px;
        margin-bottom: 5px;
        transition: 0.3s;
    }

        .sidebar-nav .nav-link .nav-icon {
            width: 32px;
            font-size: 1.1rem;
        }

        /* Link üzerine gelince */
        .sidebar-nav .nav-link:hover {
            background: #f1f5f9;
            color: var(--gazi-navy);
        }

        /* Aktif Link */
        .sidebar-nav .nav-link.active {
            background: var(--gazi-navy);
            color: white;
            box-shadow: 0 10px 20px rgba(15, 23, 42, 0.15);
        }

    /* Bildirim Sayısı Rozeti */
    .count-badge {
        margin-left: auto;
        background: rgba(255,255,255,0.2);
        padding: 2px 8px;
        border-radius: 8px;
        font-size: 10px;
    }

    /* Arama Kutusu Stili */
    .search-wrapper-modern {
        position: relative;
        width: 100%;
        max-width: 300px;
    }

        /* Arama İkonu */
        .search-wrapper-modern i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
        }

        /* Arama Inputu */
        .search-wrapper-modern input {
            width: 100%;
            padding: 10px 15px 10px 45px;
            border-radius: 14px;
            border: 1px solid #e2e8f0;
            background: #f8fafc;
            outline: none;
            transition: 0.3s;
        }

            /* Input odaklanınca */
            .search-wrapper-modern input:focus {
                border-color: var(--gazi-gold);
                background: white;
                box-shadow: 0 0 0 4px rgba(197, 160, 89, 0.1);
            }

    /* Tablo Başlıkları */
    .table-hover-modern thead th {
        color: #94a3b8;
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        padding: 20px;
        border-bottom: 2px solid #f1f5f9;
    }

    /* Tablo Satırları */
    .table-hover-modern tbody td {
        padding: 20px;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
    }

    /* Test/Tetkik İkonu Arka Planı */
    .test-icon-bg {
        width: 40px;
        height: 40px;
        background: #eff6ff; /* Mavi arka plan */
        color: var(--gazi-blue);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
    }

        /* Uyarı İkonu (Sarı) */
        .test-icon-bg.warning {
            background: #fff7ed;
            color: var(--warning-orange);
        }

    /* Durum Rozetleri */
    .badge-status {
        padding: 6px 14px;
        border-radius: 10px;
        font-size: 11px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

        .badge-status.success {
            background: #dcfce7;
            color: #15803d;
        }

        .badge-status.warning {
            background: #fef3c7;
            color: #b45309;
        }

    /* İşlem Butonları */
    .btn-action {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        border: none;
        transition: 0.2s;
        margin-left: 5px;
    }

        /* Görüntüle Butonu (Lacivert) */
        .btn-action.view {
            background: var(--gazi-navy);
            color: white;
        }

        /* İndir Butonu (Gri) */
        .btn-action.download {
            background: #f1f5f9;
            color: #64748b;
        }

        /* Buton Hover Efekti */
        .btn-action:hover:not(.disabled) {
            transform: translateY(-3px);
            box-shadow: 0 5px 10px rgba(0,0,0,0.1);
        }

    /* Mobil Uyumluluk Ayarları */
    @@media (max-width: 991px) {
        .dashboard-main-container {
            margin: 15px; /* Kenar boşluklarını azalt */
        }

        .patient-center-container {
            /* Navbar'ın altında kalmaması için üst boşluğu artır */
            padding-top: calc(var(--navbar-safe-gap) + 30px);
        }
    }
</style>