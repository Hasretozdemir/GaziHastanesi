@model IEnumerable<GaziHastane.Models.TahlilSonuc>
@{
    ViewData["Title"] = "Gazi Hastanesi | Tahlil Sonuclarý";
    var seciliKategori = ((string?)ViewBag.SeciliKategori ?? "laboratuvar").ToLowerInvariant();
    var laboratuvarSayisi = (int?)ViewBag.LaboratuvarSayisi ?? 0;
    var radyolojiSayisi = (int?)ViewBag.RadyolojiSayisi ?? 0;
    var patolojiSayisi = (int?)ViewBag.PatolojiSayisi ?? 0;
    var hastaId = (int?)ViewBag.KullaniciId;
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        :root {
            --sidebar-width: 360px;
            --primary: #2563eb;
            --primary-dark: #1e40af;
            --secondary: #10b981;
            --navy: #1e293b;
            --bg-main: #f1f5f9;
            --surface: #ffffff;
            --border-soft: #e2e8f0;
            --text-muted: #64748b;
        }

        body, html {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-main);
            margin: 0;
            padding: 0;
            height: 100vh;
            overflow: hidden;
            color: var(--navy);
        }

        .app-container {
            display: flex;
            height: 100vh;
            width: 100vw;
        }

        .sidebar {
            width: var(--sidebar-width);
            background: var(--surface);
            height: 100vh;
            border-right: 1px solid var(--border-soft);
            box-shadow: 4px 0 24px rgba(0,0,0,0.02);
            display: flex;
            flex-direction: column;
            z-index: 1030;
        }

        .sidebar-header {
            padding: 25px;
            border-bottom: 1px solid var(--border-soft);
            background: var(--surface);
        }

        .brand-logo {
            color: var(--primary);
            font-size: 26px;
            margin-right: 12px;
        }

        .brand-title {
            font-weight: 800;
            color: var(--navy);
            margin: 0;
            font-size: 17px;
            letter-spacing: -0.5px;
        }

        .sidebar-scroll-area {
            flex-grow: 1;
            overflow-y: auto;
            padding: 25px;
        }

        .sidebar-scroll-area::-webkit-scrollbar {
            width: 4px;
        }

        .sidebar-scroll-area::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }

        .user-card {
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            color: white;
            box-shadow: 0 10px 25px rgba(15,23,42,0.1);
            margin-bottom: 25px;
        }

        .avatar-circle {
            width: 50px;
            height: 50px;
            background: rgba(255,255,255,0.15);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            font-weight: 700;
            margin: 0 auto 10px auto;
        }

        .btn-menu {
            width: 100%;
            text-align: left;
            background: transparent;
            border: 1px solid transparent;
            padding: 14px 20px;
            border-radius: 12px;
            font-weight: 600;
            color: var(--text-muted);
            transition: all 0.2s;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            font-size: 14px;
            text-decoration: none;
        }

        .btn-menu:hover {
            background: #f8fafc;
            color: var(--navy);
        }

        .btn-menu.active {
            background: #eff6ff;
            color: var(--primary);
            font-weight: 700;
        }

        .count-badge {
            margin-left: auto;
            background: rgba(100,116,139,0.1);
            color: var(--text-muted);
            padding: 2px 8px;
            border-radius: 8px;
            font-size: 11px;
            font-weight: 700;
        }

        .btn-menu.active .count-badge {
            background: var(--primary);
            color: white;
        }

        .main-content {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            position: relative;
            background: var(--bg-main);
            width: calc(100vw - var(--sidebar-width));
        }

        .topbar {
            background: var(--surface);
            height: 75px;
            padding: 0 40px;
            border-bottom: 1px solid var(--border-soft);
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 5;
        }

        .content-area {
            flex-grow: 1;
            overflow-y: auto;
            padding: 40px;
            position: relative;
        }

        .content-area::-webkit-scrollbar {
            width: 6px;
        }

        .content-area::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }

        .search-wrapper {
            position: relative;
            width: 100%;
            max-width: 300px;
        }

        .search-wrapper i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
        }

        .search-wrapper input {
            width: 100%;
            padding: 10px 15px 10px 45px;
            border-radius: 12px;
            border: 1px solid var(--border-soft);
            background: var(--surface);
            font-size: 14px;
            transition: 0.3s;
            outline: none;
        }

        .search-wrapper input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
        }

        .table-responsive {
            -webkit-overflow-scrolling: touch;
            overflow-x: auto;
        }

        .modern-list-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 12px;
            margin-top: -12px;
            min-width: 700px;
        }

        .modern-list-table th {
            font-size: 12px;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            padding: 0 20px 5px 20px;
            border: none;
            letter-spacing: 0.5px;
            white-space: nowrap;
        }

        .modern-list-table td {
            background: var(--surface);
            padding: 18px 20px;
            vertical-align: middle;
            border-top: 1px solid var(--border-soft);
            border-bottom: 1px solid var(--border-soft);
        }

        .modern-list-table td:first-child {
            border-left: 1px solid var(--border-soft);
            border-top-left-radius: 16px;
            border-bottom-left-radius: 16px;
        }

        .modern-list-table td:last-child {
            border-right: 1px solid var(--border-soft);
            border-top-right-radius: 16px;
            border-bottom-right-radius: 16px;
        }

        .modern-list-table tbody tr {
            transition: 0.2s;
            box-shadow: 0 2px 8px rgba(0,0,0,0.01);
        }

        .modern-list-table tbody tr:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(0,0,0,0.04);
        }

        .list-icon-box {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .bg-blue-soft {
            background: #eff6ff;
            color: var(--primary);
        }

        .bg-orange-soft {
            background: #fff7ed;
            color: #f59e0b;
        }

        .soft-badge {
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            white-space: nowrap;
        }

        .badge-success-soft {
            background: #dcfce7;
            color: #16a34a;
        }

        .badge-warning-soft {
            background: #fef3c7;
            color: #d97706;
        }

        .btn-action-square {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            border: 1px solid var(--border-soft);
            background: transparent;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: 0.2s;
            margin-left: 5px;
            color: var(--text-muted);
            text-decoration: none;
            flex-shrink: 0;
        }

        .btn-action-square.view:hover {
            background: #eff6ff;
            border-color: #93c5fd;
            color: var(--primary);
        }

        .btn-action-square.download:hover {
            background: #fee2e2;
            border-color: #fca5a5;
            color: #ef4444;
        }

        .btn-action-square.disabled {
            opacity: 0.5;
            cursor: not-allowed;
            background: #f8fafc;
        }

        .custom-swal-popup {
            border-radius: 20px !important;
            padding: 2em !important;
            border: 1px solid var(--border-soft) !important;
        }

        .custom-swal-title {
            font-family: 'Plus Jakarta Sans', sans-serif !important;
            font-weight: 800 !important;
            color: var(--navy) !important;
            font-size: 22px !important;
        }

        .custom-swal-confirm-btn {
            background: var(--primary) !important;
            color: white !important;
            border-radius: 12px !important;
            padding: 12px 30px !important;
            font-weight: 700 !important;
            font-family: 'Plus Jakarta Sans', sans-serif !important;
            border: none !important;
            transition: all 0.3s ease !important;
            width: 100%;
            max-width: 200px;
        }

        .custom-swal-confirm-btn:hover {
            background: var(--primary-dark) !important;
            transform: translateY(-2px) !important;
        }

        .sidebar-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(15, 23, 42, 0.6);
            z-index: 1020;
            backdrop-filter: blur(2px);
            transition: opacity 0.3s;
            opacity: 0;
        }

        .sidebar-overlay.show {
            display: block;
            opacity: 1;
        }

        #raporAlani {
            background: white;
            padding: 40px;
            border-radius: 12px;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .rapor-baslik {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            border-bottom: 4px solid #2563eb;
            padding-bottom: 20px;
            margin-bottom: 20px;
        }

        .rapor-hasta-bilgi {
            background: #f8fafc;
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 20px;
            border: 1px solid #e2e8f0;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .rapor-bilgi-item {
            display: flex;
            flex-direction: column;
        }

        .rapor-bilgi-label {
            font-size: 11px;
            color: #94a3b8;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 4px;
        }

        .rapor-bilgi-value {
            font-size: 14px;
            font-weight: bold;
            color: #1e293b;
        }

        .rapor-tablo {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid #e2e8f0;
        }

        .rapor-tablo thead {
            background: #f1f5f9;
        }

        .rapor-tablo th {
            padding: 12px;
            border-bottom: 2px solid #e2e8f0;
            text-align: left;
            font-weight: bold;
            color: #64748b;
            text-transform: uppercase;
            font-size: 11px;
            letter-spacing: 0.5px;
        }

        .rapor-tablo td {
            padding: 12px;
            border-bottom: 1px solid #e2e8f0;
        }

        .rapor-tablo tbody tr:last-child td {
            border-bottom: none;
        }

        .rapor-footer {
            border-top: 1px solid #e2e8f0;
            padding-top: 20px;
            margin-top: 20px;
            text-align: center;
        }

        .rapor-footer-text {
            font-size: 10px;
            color: #94a3b8;
            line-height: 1.4;
        }

        @@media (max-width: 991.98px) {
            .app-container {
                flex-direction: column;
                width: 100%;
            }

            .main-content {
                width: 100%;
            }

            .sidebar {
                position: fixed;
                left: -360px;
                top: 0;
                height: 100vh;
                transition: left 0.3s ease;
                width: 300px;
                max-width: 85vw;
            }

            .sidebar.open {
                left: 0;
            }

            .topbar {
                padding: 0 20px;
                height: 70px;
            }

            .content-area {
                padding: 20px 15px;
            }

            .search-wrapper {
                max-width: 100%;
                margin-top: 15px;
            }

            .header-flex {
                flex-direction: column;
                align-items: stretch !important;
            }

            .modern-list-table th, .modern-list-table td {
                padding: 12px 15px;
            }

            #raporAlani {
                padding: 20px;
            }

            .rapor-hasta-bilgi {
                grid-template-columns: 1fr;
                gap: 12px;
            }
        }

        @@media (max-width: 575.98px) {
            .topbar {
                padding: 0 15px;
            }

            .brand-title {
                font-size: 15px;
            }

            .content-area {
                padding: 15px 10px;
            }

            .header-flex h4 {
                font-size: 18px !important;
            }

            .custom-swal-popup {
                padding: 1.5em !important;
                width: 90% !important;
            }

            .list-icon-box {
                width: 32px;
                height: 32px;
                font-size: 14px;
            }

            .test-name {
                font-size: 13px !important;
            }
        }
    </style>
</head>
<body>

    <input type="hidden" id="aktifHastaId" value="@hastaId" />

    <div class="app-container">
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <i class="fas fa-hospital-symbol brand-logo"></i>
                    <h1 class="brand-title">GAZI HASTANESI</h1>
                </div>
                <button class="btn btn-light btn-sm d-lg-none border-0" id="closeSidebarBtn"><i class="fas fa-times fa-lg"></i></button>
            </div>

            <div class="sidebar-scroll-area">
                <div class="user-card">
                    <div class="avatar-circle">@ViewBag.KullaniciBasHarfler</div>
                    <h5 class="fw-700 mb-1" style="font-size: 16px;">Sn. @ViewBag.KullaniciAdSoyad</h5>
                    <p class="small opacity-75 mb-0" style="font-weight: 400;">Hasta No: @ViewBag.HastaNo</p>
                </div>

                <div class="mb-4">
                    <h6 class="fw-700 text-muted mb-3 ms-2" style="font-size: 12px; letter-spacing: 1px;">TIBBI ARSIV</h6>

                    <a href="@Url.Action("Panel", "Sonuc", new { userId = hastaId, kategori = "laboratuvar" })" class="btn-menu @(seciliKategori == "laboratuvar" ? "active" : "")">
                        <i class="fas fa-vial" style="width:20px; color:var(--primary); margin-right: 8px;"></i> Laboratuvar
                        <span class="count-badge">@laboratuvarSayisi</span>
                    </a>

                    <a href="@Url.Action("Panel", "Sonuc", new { userId = hastaId, kategori = "radyoloji" })" class="btn-menu @(seciliKategori == "radyoloji" ? "active" : "")">
                        <i class="fas fa-x-ray" style="width:20px; color:var(--text-muted); margin-right: 8px;"></i> Radyoloji
                        <span class="count-badge">@radyolojiSayisi</span>
                    </a>

                    <a href="@Url.Action("Panel", "Sonuc", new { userId = hastaId, kategori = "patoloji" })" class="btn-menu @(seciliKategori == "patoloji" ? "active" : "")">
                        <i class="fas fa-microscope" style="width:20px; color:var(--text-muted); margin-right: 8px;"></i> Patoloji
                        <span class="count-badge">@patolojiSayisi</span>
                    </a>

                    <hr class="my-3 opacity-25">

                    <a href="#" class="btn-menu text-danger">
                        <i class="fas fa-exclamation-circle" style="width:20px; margin-right: 8px;"></i> Acil Bilgilerim
                    </a>
                </div>
            </div>
        </aside>

        <main class="main-content">
            <header class="topbar">
                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-light d-lg-none border" id="mobileMenuBtn"><i class="fas fa-bars"></i></button>
                    <h4 class="fw-700 text-navy mb-0" id="pageTitle" style="font-size: 18px;">Sonuc Paneli</h4>
                </div>
                <div>
                    <a href="/Home/Cikis" class="btn btn-light btn-sm fw-600 text-danger rounded-pill px-3 border"><i class="fas fa-sign-out-alt"></i> <span class="d-none d-sm-inline ms-1">Cikis</span></a>
                </div>
            </header>

            <div class="content-area animate__animated animate__fadeIn">
                <div class="d-flex justify-content-between align-items-center mb-4 header-flex">
                    <div>
                        <h4 class="fw-800 text-navy mb-1" style="font-size: 20px;">
                            @(seciliKategori == "radyoloji" ? "Radyoloji Sonuclari" : seciliKategori == "patoloji" ? "Patoloji Sonuclari" : "Laboratuvar Sonuclari")
                        </h4>
                        <p class="text-muted small mb-0">Tum tibbi tetkikleriniz listelenmektedir.</p>
                    </div>
                    <div class="search-wrapper">
                        <i class="fas fa-search"></i>
                        <input type="text" id="searchInput" placeholder="@(seciliKategori == "radyoloji" ? "Radyoloji sonucu ara..." : seciliKategori == "patoloji" ? "Patoloji sonucu ara..." : "Laboratuvar sonucu ara...")" onkeyup="filterTable()">
                    </div>
                </div>

                @if (Model != null && Model.Any())
                {
                    <div class="table-responsive" style="border-radius: 16px;">
                        <table class="modern-list-table" id="sonucTable">
                            <thead>
                                <tr>
                                    <th>Tetkik Adi</th>
                                    <th>Kategori</th>
                                    <th>Tarih</th>
                                    <th>Durum</th>
                                    <th class="text-end">Aksiyon</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sonuc in Model)
                                {
                                    bool isCompleted = !string.IsNullOrEmpty(sonuc.SonucDegeri);
                                    string iconBg = isCompleted ? "bg-blue-soft" : "bg-orange-soft";
                                    string iconFa = isCompleted ? "fa-tint" : "fa-sun";
                                    string badgeClass = isCompleted ? "badge-success-soft" : "badge-warning-soft";
                                    string badgeIcon = isCompleted ? "fa-check-circle" : "fa-clock";
                                    string badgeText = isCompleted ? "Tamamlandi" : "Onay Bekliyor";

                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="list-icon-box @iconBg"><i class="fas @iconFa"></i></div>
                                                <div>
                                                    <div class="fw-700 text-navy test-name" style="font-size: 14px;">@sonuc.TestAdi</div>
                                                    <div class="text-muted fw-600" style="font-size: 11px;">Referans: @(string.IsNullOrEmpty(sonuc.ReferansAraligi) ? "-" : sonuc.ReferansAraligi)</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="fw-600 text-navy" style="font-size: 14px;">@(sonuc.TestKategorisi ?? "Genel")</td>
                                        <td class="text-muted fw-500" style="font-size: 14px;">@sonuc.Tarih.ToString("dd.MM.yyyy")</td>
                                        <td>
                                            <span class="soft-badge @badgeClass"><i class="fas @badgeIcon"></i> @badgeText</span>
                                        </td>
                                        <td class="text-end">
                                            <div class="d-flex justify-content-end align-items-center">
                                                <button class="btn-action-square view" title="Gorus" onclick="gosterSonuc('@sonuc.TestAdi', '@(isCompleted? sonuc.SonucDegeri: "Sonuc henuz cikmadi")')">
                                                    <i class="fas fa-eye"></i>
                                                </button>

                                                @if (!string.IsNullOrEmpty(sonuc.RaporDosyaUrl))
                                                {
                                                    <a href="@sonuc.RaporDosyaUrl" target="_blank" class="btn-action-square download" title="PDF Indir">
                                                        <i class="fas fa-file-pdf"></i>
                                                    </a>
                                                }
                                                else
                                                {
                                                    <button class="btn-action-square disabled" title="Rapor Yok" disabled>
                                                        <i class="fas fa-lock"></i>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 mt-4" style="background: var(--surface); border-radius: 20px; border: 1px dashed var(--border-soft);">
                        <i class="fas fa-folder-open fa-3x text-muted opacity-25 mb-3"></i>
                        <h5 class="text-muted fw-600">Secili kategori icin kayit bulunmamaktadir.</h5>
                    </div>
                }
            </div>
        </main>
    </div>

    <!-- PROFESYONEL PDF RAPOR MODAL -->
    <div id="raporModal" class="position-fixed top-0 start-0 w-100 h-100 d-none align-items-center justify-content-center p-3" style="background: rgba(15,23,42,0.65); z-index: 1200; backdrop-filter: blur(2px); overflow-y: auto;">
        <div class="bg-white rounded-4 shadow-lg w-100" style="max-width: 700px; margin-top: 20px; margin-bottom: 20px;">
            <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom sticky-top bg-white rounded-top-4">
                <h5 class="m-0 fw-bold text-primary"><i class="fa-solid fa-file-waveform me-2"></i>Tahlil Sonuc Raporu</h5>
                <button class="btn btn-light btn-sm border-0" onclick="raporKapat()"><i class="fa-solid fa-xmark"></i></button>
            </div>

            <div class="p-4">
                <div id="raporAlani" style="border: 1px solid #e2e8f0;">
                    <!-- LOGO VE BASLIK -->
                    <div class="rapor-baslik">
                        <div style="display: flex; align-items: center; gap: 12px;">
                            <img src="~/assets/gazilogo.jpg" alt="Gazi Logo" style="width: 50px; height: auto; object-fit: contain;">
                            <div>
                                <h4 style="margin: 0; font-size: 16px; font-weight: bold; color: #1e293b; letter-spacing: -0.5px;">Gazi Universitesi Hastanesi</h4>
                                <p style="margin: 0; font-size: 11px; color: #94a3b8; font-weight: bold;">Merkez Laboratuvari Sonuc Raporu</p>
                            </div>
                        </div>
                        <div style="text-align: right; font-size: 11px;">
                            <p style="margin: 0; color: #475569;"><strong>Tarih:</strong> <span id="raporTarihi">-</span></p>
                            <p style="margin: 0; color: #475569;"><strong>Rapor No:</strong> <span id="raporNo">-</span></p>
                        </div>
                    </div>

                    <!-- HASTA BILGILERI -->
                    <div class="rapor-hasta-bilgi">
                        <div class="rapor-bilgi-item">
                            <span class="rapor-bilgi-label">Hasta Adi Soyadi</span>
                            <span class="rapor-bilgi-value" id="raporHastaAdi">-</span>
                        </div>
                        <div class="rapor-bilgi-item">
                            <span class="rapor-bilgi-label">T.C. Kimlik No</span>
                            <span class="rapor-bilgi-value" id="raporTcNo">-</span>
                        </div>
                        <div class="rapor-bilgi-item">
                            <span class="rapor-bilgi-label">Test Adi</span>
                            <span class="rapor-bilgi-value" id="raporTestAdi">-</span>
                        </div>
                        <div class="rapor-bilgi-item">
                            <span class="rapor-bilgi-label">Kategori</span>
                            <span class="rapor-bilgi-value" id="raporKategori">-</span>
                        </div>
                        <div class="rapor-bilgi-item">
                            <span class="rapor-bilgi-label">Doktor</span>
                            <span class="rapor-bilgi-value" id="raporDoktor">-</span>
                        </div>
                        <div class="rapor-bilgi-item">
                            <span class="rapor-bilgi-label">Test Tarihi</span>
                            <span class="rapor-bilgi-value" id="raporTestTarihi">-</span>
                        </div>
                    </div>

                    <!-- SONUC TABLOSU -->
                    <table class="rapor-tablo">
                        <thead>
                            <tr>
                                <th>Parametre</th>
                                <th>Sonuc</th>
                                <th>Birim</th>
                                <th>Referans Araligi</th>
                                <th style="text-align: center;">Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td style="font-weight: bold; color: #1e293b;" id="raporParameter">-</td>
                                <td style="font-weight: bold; font-size: 15px; color: #1e293b;" id="raporSonucValue">-</td>
                                <td style="color: #475569;">-</td>
                                <td style="color: #475569;" id="raporReferans">-</td>
                                <td style="text-align: center;">
                                    <span id="raporDurumBadge" style="display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; border-radius: 6px; font-size: 11px; font-weight: bold; background: #dcfce7; color: #16a34a;">
                                        <i class="fa-solid fa-check-circle"></i> Normal
                                    </span>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <!-- QR KOD -->
                    <div style="text-align: center; border-top: 1px solid #e2e8f0; padding-top: 20px; margin-top: 20px;">
                        <p style="font-size: 11px; color: #94a3b8; margin: 0 0 12px 0;">Polikliniđe ulaţim icin QR kodu okutabilirsiniz</p>
                        <img id="raporQrCode" src="" alt="Kroki QR Kod" style="width: 120px; height: 120px; border: 1px solid #dbe4f0; padding: 6px; border-radius: 10px; background: white;">
                    </div>

                    <!-- ALT METIN -->
                    <div class="rapor-footer">
                        <p class="rapor-footer-text">
                            Bu rapor elektronik olarak onaylanmistir, islak imzaya gerek yoktur.<br>
                            Laboratuvar Uzmani: <span id="raporLabUzmani">-</span><br>
                            <span style="margin-top: 8px; font-weight: bold; color: #cbd5e1; display: block;">Gazi Hastanesi Laboratuvar Bilgi Sistemi</span>
                        </p>
                    </div>
                </div>

                <div class="d-flex flex-column flex-sm-row gap-2 mt-4">
                    <a id="raporKrokiUrl" href="#" target="_blank" class="btn btn-outline-primary w-100">
                        <i class="fa-solid fa-location-dot me-1"></i> Krokiyi Ac
                    </a>
                    <button onclick="raporPdfIndir()" class="btn btn-primary w-100">
                        <i class="fa-solid fa-file-pdf me-1"></i> PDF Indir
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        const mobileBtn = document.getElementById('mobileMenuBtn');
        const closeSidebarBtn = document.getElementById('closeSidebarBtn');

        function toggleSidebar() {
            sidebar.classList.toggle('open');
            overlay.classList.toggle('show');
        }

        mobileBtn.addEventListener('click', toggleSidebar);
        closeSidebarBtn.addEventListener('click', toggleSidebar);
        overlay.addEventListener('click', toggleSidebar);

        function filterTable() {
            var input, filter, table, tr, td, i, txtValue;
            input = document.getElementById("searchInput");
            filter = input.value.toUpperCase();
            table = document.getElementById("sonucTable");

            if(!table) return;

            tr = table.getElementsByTagName("tr");

            for (i = 1; i < tr.length; i++) {
                td = tr[i].getElementsByClassName("test-name")[0];
                if (td) {
                    txtValue = td.textContent || td.innerText;
                    if (txtValue.toUpperCase().indexOf(filter) > -1) {
                        tr[i].style.display = "";
                    } else {
                        tr[i].style.display = "none";
                    }
                }
            }
        }

        function gosterSonuc(testAdi, deger) {
            Swal.fire({
                title: testAdi,
                html: `<div class="mt-2 mb-2 p-3 rounded-3" style="background: #f8fafc; border: 1px solid #e2e8f0;">
                          <span class="text-muted fw-600 d-block mb-1" style="font-size:12px;">Olculen Deger</span>
                          <span class="fw-800 text-primary" style="font-size:24px;">${deger}</span>
                       </div>`,
                icon: 'info',
                confirmButtonText: 'Kapat',
                buttonsStyling: false,
                customClass: {
                    popup: 'custom-swal-popup',
                    title: 'custom-swal-title',
                    confirmButton: 'custom-swal-confirm-btn'
                }
            });
        }

        function raporAc(sonucId) {
            const hastaId = document.getElementById('aktifHastaId')?.value || '';
            fetch(`/Sonuc/GetSonucFisi?sonucId=${sonucId}&userId=${hastaId}`)
                .then(res => res.json())
                .then(resp => {
                    if (!resp || !resp.success || !resp.data) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Hata',
                            text: resp?.message || 'Sonuc fisi getirilemedi.',
                            buttonsStyling: false,
                            customClass: {
                                popup: 'custom-swal-popup',
                                title: 'custom-swal-title',
                                confirmButton: 'custom-swal-confirm-btn'
                            }
                        });
                        return;
                    }

                    const d = resp.data;
                    document.getElementById('raporNo').innerText = `#${d.sonucNo}`;
                    document.getElementById('raporTarihi').innerText = new Date().toLocaleDateString('tr-TR');
                    document.getElementById('raporHastaAdi').innerText = d.hastaAd;
                    document.getElementById('raporTcNo').innerText = '-';
                    document.getElementById('raporTestAdi').innerText = d.testAdi;
                    document.getElementById('raporKategori').innerText = d.kategori;
                    document.getElementById('raporDoktor').innerText = d.doktorAd;
                    document.getElementById('raporTestTarihi').innerText = d.tarih;
                    document.getElementById('raporParameter').innerText = d.testAdi;

                    const sonucDegeri = d.sonucDegeri || '-';
                    const isAnormal = sonucDegeri.includes('Yuksek') || sonucDegeri.includes('Dusuk') || sonucDegeri.includes('Anormal');

                    document.getElementById('raporSonucValue').innerText = sonucDegeri;
                    document.getElementById('raporSonucValue').style.color = isAnormal ? '#dc2626' : '#1e293b';
                    document.getElementById('raporReferans').innerText = d.referansAraligi;

                    const durumBadge = document.getElementById('raporDurumBadge');
                    if (isAnormal) {
                        durumBadge.style.background = '#fee2e2';
                        durumBadge.style.color = '#dc2626';
                        durumBadge.innerHTML = '<i class="fa-solid fa-exclamation-circle"></i> Anormal';
                    } else {
                        durumBadge.style.background = '#dcfce7';
                        durumBadge.style.color = '#16a34a';
                        durumBadge.innerHTML = '<i class="fa-solid fa-check-circle"></i> Normal';
                    }

                    document.getElementById('raporLabUzmani').innerText = d.doktorAd;
                    document.getElementById('raporQrCode').src = d.qrCode;
                    document.getElementById('raporKrokiUrl').href = d.krokiUrl;

                    const modal = document.getElementById('raporModal');
                    modal.classList.remove('d-none');
                    modal.classList.add('d-flex');
                    document.body.style.overflow = 'hidden';
                })
                .catch(() => {
                    Swal.fire({
                        icon: 'error',
                        title: 'Hata',
                        text: 'Rapor yuklenirken bir hata olustu.',
                        buttonsStyling: false,
                        customClass: {
                            popup: 'custom-swal-popup',
                            title: 'custom-swal-title',
                            confirmButton: 'custom-swal-confirm-btn'
                        }
                    });
                });
        }

        function raporKapat() {
            const modal = document.getElementById('raporModal');
            modal.classList.remove('d-flex');
            modal.classList.add('d-none');
            document.body.style.overflow = '';
        }

        function raporPdfIndir() {
            const element = document.getElementById('raporAlani');
            if (!element) return;

            const fisNo = document.getElementById('raporNo')?.innerText?.replace('#', '') || 'RaporFisi';

            const opt = {
                margin: 10,
                filename: `GaziHastanesi_TahlilRaporu_${fisNo}.pdf`,
                image: { type: 'jpeg', quality: 1.0 },
                html2canvas: { scale: 2, useCORS: true, allowTaint: true },
                jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
            };

            html2pdf().set(opt).from(element).save();
        }
    </script>
</body>
</html>
