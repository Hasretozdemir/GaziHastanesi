@model IEnumerable<GaziHastane.Models.TahlilSonuc>
@{
    ViewData["Title"] = "Gazi Hastanesi | Tahlil Sonuçlarý";
    var seciliKategori = ((string?)ViewBag.SeciliKategori ?? "laboratuvar").ToLowerInvariant();
    var laboratuvarSayisi = (int?)ViewBag.LaboratuvarSayisi ?? 0;
    var radyolojiSayisi = (int?)ViewBag.RadyolojiSayisi ?? 0;
    var patolojiSayisi = (int?)ViewBag.PatolojiSayisi ?? 0;
    var hastaId = (int?)ViewBag.KullaniciId;
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        :root {
            --sidebar-width: 360px;
            --primary: #2563eb;
            --primary-dark: #1e40af;
            --secondary: #10b981;
            --navy: #1e293b;
            --bg-main: #f1f5f9;
            --surface: #ffffff;
            --border-soft: #e2e8f0;
            --text-muted: #64748b;
        }

        body, html {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-main);
            margin: 0;
            padding: 0;
            height: 100vh;
            overflow: hidden;
            color: var(--navy);
        }

        .app-container {
            display: flex;
            height: 100vh;
            width: 100vw;
        }

        /* ================= SOL SÝDEBAR ================= */
        .sidebar {
            width: var(--sidebar-width);
            background: var(--surface);
            height: 100vh;
            border-right: 1px solid var(--border-soft);
            box-shadow: 4px 0 24px rgba(0,0,0,0.02);
            display: flex;
            flex-direction: column;
            z-index: 1030;
        }

        .sidebar-header {
            padding: 25px;
            border-bottom: 1px solid var(--border-soft);
            background: var(--surface);
        }

        .brand-logo {
            color: var(--primary);
            font-size: 26px;
            margin-right: 12px;
        }

        .brand-title {
            font-weight: 800;
            color: var(--navy);
            margin: 0;
            font-size: 17px;
            letter-spacing: -0.5px;
        }

        .sidebar-scroll-area {
            flex-grow: 1;
            overflow-y: auto;
            padding: 25px;
        }

            .sidebar-scroll-area::-webkit-scrollbar {
                width: 4px;
            }

            .sidebar-scroll-area::-webkit-scrollbar-thumb {
                background: #cbd5e1;
                border-radius: 10px;
            }

        .user-card {
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            color: white;
            box-shadow: 0 10px 25px rgba(15,23,42,0.1);
            margin-bottom: 25px;
        }

        .avatar-circle {
            width: 50px;
            height: 50px;
            background: rgba(255,255,255,0.15);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            font-weight: 700;
            margin: 0 auto 10px auto;
        }

        .btn-menu {
            width: 100%;
            text-align: left;
            background: transparent;
            border: 1px solid transparent;
            padding: 14px 20px;
            border-radius: 12px;
            font-weight: 600;
            color: var(--text-muted);
            transition: all 0.2s;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            font-size: 14px;
            text-decoration: none;
        }

            .btn-menu:hover {
                background: #f8fafc;
                color: var(--navy);
            }

            .btn-menu.active {
                background: #eff6ff;
                color: var(--primary);
                font-weight: 700;
            }

        .count-badge {
            margin-left: auto;
            background: rgba(100,116,139,0.1);
            color: var(--text-muted);
            padding: 2px 8px;
            border-radius: 8px;
            font-size: 11px;
            font-weight: 700;
        }

        .btn-menu.active .count-badge {
            background: var(--primary);
            color: white;
        }

        /* ================= SAĐ ÝÇERÝK ================= */
        .main-content {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            position: relative;
            background: var(--bg-main);
            width: calc(100vw - var(--sidebar-width));
        }

        .topbar {
            background: var(--surface);
            height: 75px;
            padding: 0 40px;
            border-bottom: 1px solid var(--border-soft);
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 5;
        }

        .content-area {
            flex-grow: 1;
            overflow-y: auto;
            padding: 40px;
            position: relative;
        }

            .content-area::-webkit-scrollbar {
                width: 6px;
            }

            .content-area::-webkit-scrollbar-thumb {
                background: #cbd5e1;
                border-radius: 10px;
            }

        /* ARAMA KUTUSU */
        .search-wrapper {
            position: relative;
            width: 100%;
            max-width: 300px;
        }

            .search-wrapper i {
                position: absolute;
                left: 15px;
                top: 50%;
                transform: translateY(-50%);
                color: #94a3b8;
            }

            .search-wrapper input {
                width: 100%;
                padding: 10px 15px 10px 45px;
                border-radius: 12px;
                border: 1px solid var(--border-soft);
                background: var(--surface);
                font-size: 14px;
                transition: 0.3s;
                outline: none;
            }

                .search-wrapper input:focus {
                    border-color: var(--primary);
                    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
                }

        /* ================= LÝSTE TASARIMI ================= */
        .table-responsive {
            -webkit-overflow-scrolling: touch;
            overflow-x: auto;
        }

        .modern-list-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 12px;
            margin-top: -12px;
            min-width: 700px;
        }

            .modern-list-table th {
                font-size: 12px;
                font-weight: 700;
                color: var(--text-muted);
                text-transform: uppercase;
                padding: 0 20px 5px 20px;
                border: none;
                letter-spacing: 0.5px;
                white-space: nowrap;
            }

            .modern-list-table td {
                background: var(--surface);
                padding: 18px 20px;
                vertical-align: middle;
                border-top: 1px solid var(--border-soft);
                border-bottom: 1px solid var(--border-soft);
            }

                .modern-list-table td:first-child {
                    border-left: 1px solid var(--border-soft);
                    border-top-left-radius: 16px;
                    border-bottom-left-radius: 16px;
                }

                .modern-list-table td:last-child {
                    border-right: 1px solid var(--border-soft);
                    border-top-right-radius: 16px;
                    border-bottom-right-radius: 16px;
                }

            .modern-list-table tbody tr {
                transition: 0.2s;
                box-shadow: 0 2px 8px rgba(0,0,0,0.01);
            }

                .modern-list-table tbody tr:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 6px 15px rgba(0,0,0,0.04);
                }

        .list-icon-box {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .bg-blue-soft {
            background: #eff6ff;
            color: var(--primary);
        }

        .bg-orange-soft {
            background: #fff7ed;
            color: #f59e0b;
        }

        .soft-badge {
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            white-space: nowrap;
        }

        .badge-success-soft {
            background: #dcfce7;
            color: #16a34a;
        }

        .badge-warning-soft {
            background: #fef3c7;
            color: #d97706;
        }

        .btn-action-square {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            border: 1px solid var(--border-soft);
            background: transparent;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: 0.2s;
            margin-left: 5px;
            color: var(--text-muted);
            text-decoration: none;
            flex-shrink: 0;
        }

            .btn-action-square.view:hover {
                background: #eff6ff;
                border-color: #93c5fd;
                color: var(--primary);
            }

            .btn-action-square.download:hover {
                background: #fee2e2;
                border-color: #fca5a5;
                color: #ef4444;
            }

            .btn-action-square.disabled {
                opacity: 0.5;
                cursor: not-allowed;
                background: #f8fafc;
            }

        /* ================= SWEETALERT 2 ================= */
        .custom-swal-popup {
            border-radius: 20px !important;
            padding: 2em !important;
            border: 1px solid var(--border-soft) !important;
        }

        .custom-swal-title {
            font-family: 'Plus Jakarta Sans', sans-serif !important;
            font-weight: 800 !important;
            color: var(--navy) !important;
            font-size: 22px !important;
        }

        .custom-swal-confirm-btn {
            background: var(--primary) !important;
            color: white !important;
            border-radius: 12px !important;
            padding: 12px 30px !important;
            font-weight: 700 !important;
            font-family: 'Plus Jakarta Sans', sans-serif !important;
            border: none !important;
            transition: all 0.3s ease !important;
            width: 100%;
            max-width: 200px;
        }

            .custom-swal-confirm-btn:hover {
                background: var(--primary-dark) !important;
                transform: translateY(-2px) !important;
            }

        /* ================= MOBÝL (RESPONSIVE) TASARIM ================= */
        .sidebar-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(15, 23, 42, 0.6);
            z-index: 1020;
            backdrop-filter: blur(2px);
            transition: opacity 0.3s;
            opacity: 0;
        }

            .sidebar-overlay.show {
                display: block;
                opacity: 1;
            }

        @@media (max-width: 991.98px) {
            .app-container {
                flex-direction: column;
                width: 100%;
            }

            .main-content {
                width: 100%;
            }

            .sidebar {
                position: fixed;
                left: -360px;
                top: 0;
                height: 100vh;
                transition: left 0.3s ease;
                width: 300px;
                max-width: 85vw;
            }

                .sidebar.open {
                    left: 0;
                }

            .topbar {
                padding: 0 20px;
                height: 70px;
            }

            .content-area {
                padding: 20px 15px;
            }

            .search-wrapper {
                max-width: 100%;
                margin-top: 15px;
            }

            .header-flex {
                flex-direction: column;
                align-items: stretch !important;
            }

            .modern-list-table th, .modern-list-table td {
                padding: 12px 15px;
            }
        }

        @@media (max-width: 575.98px) {
            .topbar {
                padding: 0 15px;
            }

            .brand-title {
                font-size: 15px;
            }

            .content-area {
                padding: 15px 10px;
            }

            .header-flex h4 {
                font-size: 18px !important;
            }

            .custom-swal-popup {
                padding: 1.5em !important;
                width: 90% !important;
            }

            .custom-swal-title {
                font-size: 18px !important;
            }

            .list-icon-box {
                width: 32px;
                height: 32px;
                font-size: 14px;
            }

            .test-name {
                font-size: 13px !important;
            }
        }
    </style>
</head>
<body>

    <input type="hidden" id="aktifHastaId" value="@hastaId" />

    <div class="app-container">

        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <i class="fas fa-hospital-symbol brand-logo"></i>
                    <h1 class="brand-title">GAZÝ HASTANESÝ</h1>
                </div>
                <button class="btn btn-light btn-sm d-lg-none border-0" id="closeSidebarBtn"><i class="fas fa-times fa-lg"></i></button>
            </div>

            <div class="sidebar-scroll-area">
                <div class="user-card">
                    <div class="avatar-circle">@ViewBag.KullaniciBasHarfler</div>
                    <h5 class="fw-700 mb-1" style="font-size: 16px;">Sn. @ViewBag.KullaniciAdSoyad</h5>
                    <p class="small opacity-75 mb-0" style="font-weight: 400;">Hasta No: @ViewBag.HastaNo</p>
                </div>

                <div class="mb-4">
                    <h6 class="fw-700 text-muted mb-3 ms-2" style="font-size: 12px; letter-spacing: 1px;">TIBBÝ ARŢÝV</h6>

                    <a href="@Url.Action("Panel", "Sonuc", new { userId = hastaId, kategori = "laboratuvar" })" class="btn-menu @(seciliKategori == "laboratuvar" ? "active" : "")">
                        <i class="fas fa-vial" style="width:20px; color:var(--primary); margin-right: 8px;"></i> Laboratuvar
                        <span class="count-badge">@laboratuvarSayisi</span>
                    </a>

                    <a href="@Url.Action("Panel", "Sonuc", new { userId = hastaId, kategori = "radyoloji" })" class="btn-menu @(seciliKategori == "radyoloji" ? "active" : "")">
                        <i class="fas fa-x-ray" style="width:20px; color:var(--text-muted); margin-right: 8px;"></i> Radyoloji
                        <span class="count-badge">@radyolojiSayisi</span>
                    </a>

                    <a href="@Url.Action("Panel", "Sonuc", new { userId = hastaId, kategori = "patoloji" })" class="btn-menu @(seciliKategori == "patoloji" ? "active" : "")">
                        <i class="fas fa-microscope" style="width:20px; color:var(--text-muted); margin-right: 8px;"></i> Patoloji
                        <span class="count-badge">@patolojiSayisi</span>
                    </a>

                    <hr class="my-3 opacity-25">

                    <a href="#" class="btn-menu text-danger">
                        <i class="fas fa-exclamation-circle" style="width:20px; margin-right: 8px;"></i> Acil Bilgilerim
                    </a>
                </div>
            </div>
        </aside>

        <main class="main-content">
            <header class="topbar">
                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-light d-lg-none border" id="mobileMenuBtn"><i class="fas fa-bars"></i></button>
                    <h4 class="fw-700 text-navy mb-0" id="pageTitle" style="font-size: 18px;">Sonuç Paneli</h4>
                </div>
                <div>
                    <a href="/Home/Cikis" class="btn btn-light btn-sm fw-600 text-danger rounded-pill px-3 border"><i class="fas fa-sign-out-alt"></i> <span class="d-none d-sm-inline ms-1">Çýkýţ</span></a>
                </div>
            </header>

            <div class="content-area animate__animated animate__fadeIn">

                <div class="d-flex justify-content-between align-items-center mb-4 header-flex">
                    <div>
                        <h4 class="fw-800 text-navy mb-1" style="font-size: 20px;">
                            @(seciliKategori == "radyoloji" ? "Radyoloji Sonuçlarý" : seciliKategori == "patoloji" ? "Patoloji Sonuçlarý" : "Laboratuvar Sonuçlarý")
                        </h4>
                        <p class="text-muted small mb-0">Tüm týbbi tetkikleriniz listelenmektedir.</p>
                    </div>
                    <div class="search-wrapper">
                        <i class="fas fa-search"></i>
                        <input type="text" id="searchInput" placeholder="@(seciliKategori == "radyoloji" ? "Radyoloji sonucu ara..." : seciliKategori == "patoloji" ? "Patoloji sonucu ara..." : "Laboratuvar sonucu ara...")" onkeyup="filterTable()">
                    </div>
                </div>

                @if (Model != null && Model.Any())
                {
                    <div class="table-responsive" style="border-radius: 16px;">
                        <table class="modern-list-table" id="sonucTable">
                            <thead>
                                <tr>
                                    <th>Tetkik Adý</th>
                                    <th>Kategori</th>
                                    <th>Tarih</th>
                                    <th>Durum</th>
                                    <th class="text-end">Aksiyon</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sonuc in Model)
                                {
                                    bool isCompleted = !string.IsNullOrEmpty(sonuc.SonucDegeri);
                                    string iconBg = isCompleted ? "bg-blue-soft" : "bg-orange-soft";
                                    string iconFa = isCompleted ? "fa-tint" : "fa-sun";
                                    string badgeClass = isCompleted ? "badge-success-soft" : "badge-warning-soft";
                                    string badgeIcon = isCompleted ? "fa-check-circle" : "fa-clock";
                                    string badgeText = isCompleted ? "Tamamlandý" : "Onay Bekliyor";

                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="list-icon-box @iconBg"><i class="fas @iconFa"></i></div>
                                                <div>
                                                    <div class="fw-700 text-navy test-name" style="font-size: 14px;">@sonuc.TestAdi</div>
                                                    <div class="text-muted fw-600" style="font-size: 11px;">Referans: @(string.IsNullOrEmpty(sonuc.ReferansAraligi) ? "-" : sonuc.ReferansAraligi)</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="fw-600 text-navy" style="font-size: 14px;">@(sonuc.TestKategorisi ?? "Genel")</td>
                                        <td class="text-muted fw-500" style="font-size: 14px;">@sonuc.Tarih.ToString("dd.MM.yyyy")</td>
                                        <td>
                                            <span class="soft-badge @badgeClass"><i class="fas @badgeIcon"></i> @badgeText</span>
                                        </td>
                                        <td class="text-end">
                                            <div class="d-flex justify-content-end align-items-center">
                                                <button class="btn-action-square view" title="Görüntüle" onclick="gosterSonuc('@sonuc.TestAdi', '@(isCompleted? sonuc.SonucDegeri: "Sonuç henüz çýkmadý")')">
                                                    <i class="fas fa-eye"></i>
                                                </button>

                                                @if (!string.IsNullOrEmpty(sonuc.RaporDosyaUrl))
                                                {
                                                    <a href="@sonuc.RaporDosyaUrl" target="_blank" class="btn-action-square download" title="PDF Ýndir">
                                                        <i class="fas fa-file-pdf"></i>
                                                    </a>
                                                }
                                                else
                                                {
                                                    <button class="btn-action-square disabled" title="Rapor Yok" disabled>
                                                        <i class="fas fa-lock"></i>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 mt-4" style="background: var(--surface); border-radius: 20px; border: 1px dashed var(--border-soft);">
                        <i class="fas fa-folder-open fa-3x text-muted opacity-25 mb-3"></i>
                        <h5 class="text-muted fw-600">Seçili kategori için kayýt bulunmamaktadýr.</h5>
                    </div>
                }

            </div>
        </main>
    </div>

    <div id="sonucFisiModal" class="position-fixed top-0 start-0 w-100 h-100 d-none align-items-center justify-content-center p-3" style="background: rgba(15,23,42,0.65); z-index: 1200; backdrop-filter: blur(2px);">
        <div class="bg-white rounded-4 shadow-lg w-100" style="max-width: 520px;">
            <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom">
                <h5 class="m-0 fw-bold text-primary"><i class="fa-solid fa-file-waveform me-2"></i>Sonuç Bilgi Fiţi</h5>
                <button class="btn btn-light btn-sm border-0" onclick="sonucFisiKapat()"><i class="fa-solid fa-xmark"></i></button>
            </div>

            <div class="p-4">
                <div id="pdf-sonuc-fisi" class="mx-auto rounded-4 p-3" style="max-width: 420px; border: 2px dashed #2563eb; background: linear-gradient(180deg,#ffffff 0%,#f8fbff 100%);">
                    <div class="text-center mb-3">
                        <img src="~/assets/gazilogo.jpg" alt="Gazi Logo" style="height:56px; width:auto;" />
                        <h6 class="mt-2 mb-1 fw-bold text-primary">Gazi Üniversitesi Hastanesi</h6>
                        <p class="text-muted mb-0" style="font-size: 12px;">Tahlil Sonuç Bilgi Fiţi</p>
                        <p class="text-muted mb-2" style="font-size: 11px;">Fiţ No: <span id="sonucFisNoText">-</span></p>
                        <hr class="my-2" />
                    </div>

                    <div class="text-start" style="font-size: 14px;">
                        <p class="mb-1"><strong>Sayýn:</strong> <span id="sonucHastaAdText">-</span></p>
                        <p class="mb-1"><strong>Test:</strong> <span id="sonucTestAdiText">-</span></p>
                        <p class="mb-1"><strong>Kategori:</strong> <span id="sonucKategoriText">-</span></p>
                        <p class="mb-1"><strong>Tarih:</strong> <span id="sonucTarihText">-</span></p>
                        <p class="mb-1"><strong>Doktor:</strong> <span id="sonucDoktorAdText">-</span></p>
                        <p class="mb-1"><strong>Deđer:</strong> <span id="sonucDegerText">-</span></p>
                        <p class="mb-1"><strong>Referans:</strong> <span id="sonucReferansText">-</span></p>
                        <p class="mb-0"><strong>Durum:</strong> <span id="sonucDurumText">-</span></p>
                    </div>

                    <div class="text-center mt-3">
                        <p class="text-muted mb-2" style="font-size: 11px;">Ýlgili birim kroki eriţimi için QR kodu okutabilirsiniz.</p>
                        <img id="sonucFisQrImage" src="" alt="Kroki QR Kod" class="img-fluid bg-white" style="width: 150px; height: 150px; border: 1px solid #dbe4f0; padding: 6px; border-radius: 10px;" />
                    </div>
                </div>

                <div class="d-flex flex-column flex-sm-row gap-2 mt-3">
                    <a id="sonucKrokiAcLink" href="#" target="_blank" class="btn btn-outline-primary w-100">
                        <i class="fa-solid fa-location-dot me-1"></i>Krokiyi Aç
                    </a>
                    <button onclick="sonucFisiIndir()" class="btn btn-primary w-100">
                        <i class="fa-solid fa-file-pdf me-1"></i>PDF Ýndir
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // --- MOBÝL SÝDEBAR MANTIĐI ---
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        const mobileBtn = document.getElementById('mobileMenuBtn');
        const closeSidebarBtn = document.getElementById('closeSidebarBtn');

        function toggleSidebar() {
            sidebar.classList.toggle('open');
            overlay.classList.toggle('show');
        }

        mobileBtn.addEventListener('click', toggleSidebar);
        closeSidebarBtn.addEventListener('click', toggleSidebar);
        overlay.addEventListener('click', toggleSidebar);

        // --- TABLO ARAMA FÝLTRESÝ ---
        function filterTable() {
            var input, filter, table, tr, td, i, txtValue;
            input = document.getElementById("searchInput");
            filter = input.value.toUpperCase();
            table = document.getElementById("sonucTable");

            if(!table) return;

            tr = table.getElementsByTagName("tr");

            for (i = 1; i < tr.length; i++) {
                td = tr[i].getElementsByClassName("test-name")[0];
                if (td) {
                    txtValue = td.textContent || td.innerText;
                    if (txtValue.toUpperCase().indexOf(filter) > -1) {
                        tr[i].style.display = "";
                    } else {
                        tr[i].style.display = "none";
                    }
                }
            }
        }

        // --- SWEETALERT ÝLE SONUÇ GÖSTERÝMÝ ---
        function gosterSonuc(testAdi, deger) {
            Swal.fire({
                title: testAdi,
                html: `<div class="mt-2 mb-2 p-3 rounded-3" style="background: #f8fafc; border: 1px solid #e2e8f0;">
                          <span class="text-muted fw-600 d-block mb-1" style="font-size:12px;">Ölçülen Deđer</span>
                          <span class="fw-800 text-primary" style="font-size:24px;">${deger}</span>
                       </div>`,
                icon: 'info',
                confirmButtonText: 'Kapat',
                buttonsStyling: false,
                customClass: {
                    popup: 'custom-swal-popup',
                    title: 'custom-swal-title',
                    confirmButton: 'custom-swal-confirm-btn'
                }
            });
        }

        function sonucFisiAc(sonucId) {
            const hastaId = document.getElementById('aktifHastaId')?.value || '';
            fetch(`/Sonuc/GetSonucFisi?sonucId=${sonucId}&userId=${hastaId}`)
                .then(res => res.json())
                .then(resp => {
                    if (!resp || !resp.success || !resp.data) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Hata',
                            text: resp?.message || 'Sonuç fiţi getirilemedi.',
                            buttonsStyling: false,
                            customClass: {
                                popup: 'custom-swal-popup',
                                title: 'custom-swal-title',
                                confirmButton: 'custom-swal-confirm-btn'
                            }
                        });
                        return;
                    }

                    const d = resp.data;
                    document.getElementById('sonucFisNoText').innerText = `#${d.sonucNo}`;
                    document.getElementById('sonucHastaAdText').innerText = d.hastaAd;
                    document.getElementById('sonucTestAdiText').innerText = d.testAdi;
                    document.getElementById('sonucKategoriText').innerText = d.kategori;
                    document.getElementById('sonucTarihText').innerText = d.tarih;
                    document.getElementById('sonucDoktorAdText').innerText = d.doktorAd;
                    document.getElementById('sonucDegerText').innerText = d.sonucDegeri;
                    document.getElementById('sonucReferansText').innerText = d.referansAraligi;
                    document.getElementById('sonucDurumText').innerText = d.durum;
                    document.getElementById('sonucFisQrImage').src = d.qrCode;
                    document.getElementById('sonucKrokiAcLink').href = d.krokiUrl;

                    const modal = document.getElementById('sonucFisiModal');
                    modal.classList.remove('d-none');
                    modal.classList.add('d-flex');
                    document.body.style.overflow = 'hidden';
                })
                .catch(() => {
                    Swal.fire({
                        icon: 'error',
                        title: 'Hata',
                        text: 'Sonuç fiţi yüklenirken bir hata oluţtu.',
                        buttonsStyling: false,
                        customClass: {
                            popup: 'custom-swal-popup',
                            title: 'custom-swal-title',
                            confirmButton: 'custom-swal-confirm-btn'
                        }
                    });
                });
        }

        function sonucFisiKapat() {
            const modal = document.getElementById('sonucFisiModal');
            modal.classList.remove('d-flex');
            modal.classList.add('d-none');
            document.body.style.overflow = '';
        }

        async function sonucFisiIndir() {
            const element = document.getElementById('pdf-sonuc-fisi');
            if (!element) return;

            const fisNo = document.getElementById('sonucFisNoText')?.innerText?.replace('#', '') || 'SonucFisi';

            try {
                if (typeof html2pdf === 'undefined') {
                    await yeniHtml2PdfYukle();
                }

                const opt = {
                    margin: 0.4,
                    filename: `GaziHastanesi_SonucFisi_${fisNo}.pdf`,
                    image: { type: 'jpeg', quality: 0.98 },
                    html2canvas: { scale: 2, useCORS: true, allowTaint: true },
                    jsPDF: { unit: 'in', format: 'a5', orientation: 'portrait' }
                };

                await html2pdf().set(opt).from(element).save();
            } catch {
                Swal.fire({
                    icon: 'error',
                    title: 'PDF Hatasý',
                    text: 'PDF oluţturulamadý. Lütfen tekrar deneyin.',
                    buttonsStyling: false,
                    customClass: {
                        popup: 'custom-swal-popup',
                        title: 'custom-swal-title',
                        confirmButton: 'custom-swal-confirm-btn'
                    }
                });
            }
        }

        function yeniHtml2PdfYukle() {
            return new Promise((resolve, reject) => {
                const mevcut = document.querySelector('script[data-html2pdf="1"]');
                if (mevcut) {
                    mevcut.addEventListener('load', () => resolve());
                    mevcut.addEventListener('error', () => reject());
                    return;
                }

                const script = document.createElement('script');
                script.src = 'https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js';
                script.async = true;
                script.dataset.html2pdf = '1';
                script.onload = () => resolve();
                script.onerror = () => reject();
                document.head.appendChild(script);
            });
        }
    </script>
</body>
</html>