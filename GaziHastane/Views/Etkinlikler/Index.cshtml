@model IEnumerable<GaziHastane.Models.Etkinlik>
@{
    ViewData["Title"] = "Etkinlikler & Kongreler";
    Layout = "_EmptyLayout";
}

<div class="bg-gradient-to-br from-slate-900 via-orange-900 to-red-900 py-24 sm:py-28 relative overflow-hidden mb-[-2rem] z-0">
    <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 rounded-full bg-orange-500/20 blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 rounded-full bg-red-500/20 blur-3xl pointer-events-none"></div>
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjIiIGZpbGw9IiNmZmYiIGZpbGwtb3BhY2l0eT0iMC4wNSIvPjwvc3ZnPg==')] opacity-20"></div>

    <div class="w-full mx-auto px-6 sm:px-8 lg:px-[3cm] relative z-10 pb-8">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-8">
            <div class="flex items-center gap-6">
                <div class="w-20 h-20 sm:w-24 sm:h-24 bg-white/10 backdrop-blur-md border border-white/20 text-white rounded-[2rem] flex items-center justify-center text-4xl sm:text-5xl shadow-[0_0_40px_rgba(249,115,22,0.3)]">
                    <i class="fa-regular fa-calendar-days"></i>
                </div>
                <div>
                    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 border border-white/20 text-orange-200 text-[10px] font-black tracking-widest uppercase mb-3 backdrop-blur-sm">
                        <span class="w-2 h-2 rounded-full bg-orange-400 animate-pulse"></span>
                        Gazi Hastanesi
                    </div>
                    <h1 class="text-white text-4xl sm:text-6xl font-black leading-tight tracking-tight mb-2 drop-shadow-md">Etkinlikler & Kongreler</h1>
                    <p class="text-orange-100/80 text-sm sm:text-base font-medium max-w-xl leading-relaxed">
                        Hastanemizde düzenlenen güncel etkinlikleri, bilimsel kongreleri ve sempozyumları buradan takip edebilirsiniz.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="py-16 bg-slate-50 min-h-screen relative z-10 rounded-t-[3rem] shadow-[0_-20px_40px_rgba(0,0,0,0.1)]">
    <div class="w-full mx-auto px-6 sm:px-8 lg:px-[3cm]">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-3 gap-8 lg:gap-10">
            @if (Model != null && Model.Any())
            {
                foreach (var etkinlik in Model)
                {
                    <button type="button" data-etkinlik-id="@etkinlik.Id" onclick="openEtkinlikModal(@etkinlik.Id)" class="js-etkinlik-card bg-white rounded-2xl p-4 sm:p-5 border border-slate-200 shadow-sm hover:shadow-xl hover:border-blue-200 hover:-translate-y-1 transition-all duration-300 flex items-center gap-5 sm:gap-6 group text-left w-full">

                        <div class="flex-shrink-0 w-20 h-24 sm:w-24 sm:h-28 rounded-xl bg-slate-50 border border-slate-100 flex flex-col items-center justify-center group-hover:bg-blue-600 group-hover:border-blue-600 transition-colors duration-300">
                            <span class="text-xs sm:text-sm font-bold uppercase tracking-widest text-slate-400 group-hover:text-blue-200 transition-colors duration-300">
                                @etkinlik.Tarih.ToString("MMM")
                            </span>
                            <span class="text-3xl sm:text-4xl font-black text-slate-800 group-hover:text-white my-1 transition-colors duration-300">
                                @etkinlik.Tarih.ToString("dd")
                            </span>
                            <span class="text-xs font-semibold text-slate-400 group-hover:text-blue-200 transition-colors duration-300">
                                @etkinlik.Tarih.ToString("yyyy")
                            </span>
                        </div>

                        <div class="flex-1">
                            <div class="mb-3">
                                <span class="text-[10px] sm:text-xs font-bold bg-blue-50 text-blue-700 px-2.5 py-1 rounded-md uppercase tracking-wide border border-blue-100">
                                    @etkinlik.EtkinlikTipi
                                </span>
                            </div>
                            <h3 class="text-base sm:text-lg font-bold text-slate-800 group-hover:text-blue-700 transition-colors line-clamp-2 mb-3 leading-snug">
                                @etkinlik.Baslik
                            </h3>

                            <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-6 text-sm text-slate-500 font-medium">
                                <div class="flex items-center gap-2">
                                    <i class="fa-solid fa-location-dot text-slate-400 group-hover:text-blue-500 transition-colors"></i>
                                    <span class="line-clamp-1">@etkinlik.Konum</span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <i class="fa-regular fa-clock text-slate-400 group-hover:text-blue-500 transition-colors"></i>
                                    <span>@etkinlik.Tarih.ToString("HH:mm")</span>
                                </div>
                            </div>
                        </div>
                    </button>
                }
            }
            
            else
            {
                <div class="col-span-full flex flex-col items-center justify-center py-24 bg-white rounded-3xl border border-slate-200 border-dashed">
                    <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mb-4">
                        <i class="fa-regular fa-calendar-xmark text-4xl text-slate-300"></i>
                    </div>
                    <h3 class="text-xl font-bold text-slate-700 mb-1">Etkinlik Bulunmuyor</h3>
                    <p class="text-slate-500 text-sm">Şu an için planlanmış yaklaşan bir etkinlik takvimi görünmüyor.</p>
                </div>
            }
        </div>
    </div>
</section>

<div id="etkinlikModal" class="fixed inset-0 z-[121] hidden bg-black/60 backdrop-blur-sm flex items-center justify-center opacity-0 transition-opacity duration-200 p-4">
    <div id="etkinlikModalContent" class="bg-white w-full max-w-3xl rounded-3xl overflow-hidden shadow-2xl border border-slate-100 transform scale-95 transition-transform duration-200 max-h-[90vh] flex flex-col">
        <div class="relative">
            <img id="etkinlikModalImage" src="" alt="Etkinlik" class="w-full h-64 object-cover">
            <button type="button" onclick="closeEtkinlikModal()" class="absolute top-4 right-4 w-10 h-10 rounded-full bg-white/90 text-slate-700 hover:bg-white flex items-center justify-center shadow">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <div class="p-6 overflow-y-auto">
            <div class="flex flex-wrap items-center gap-3 mb-3">
                <span id="etkinlikModalTip" class="text-[10px] font-bold bg-orange-100 text-orange-700 px-2 py-1 rounded uppercase"></span>
                <span id="etkinlikModalTarih" class="text-xs text-slate-400 font-semibold"></span>
            </div>
            <h3 id="etkinlikModalBaslik" class="text-2xl font-black text-slate-900 mb-2"></h3>
            <div class="flex flex-col sm:flex-row sm:items-center gap-3 text-sm text-slate-500 font-medium mb-4">
                <span id="etkinlikModalSaat" class="flex items-center gap-2"><i class="fa-regular fa-clock"></i></span>
                <span id="etkinlikModalKonum" class="flex items-center gap-2"><i class="fa-solid fa-location-dot"></i></span>
            </div>
            <p id="etkinlikModalOzet" class="text-slate-500 text-sm mb-5"></p>
            <div id="etkinlikModalIcerik" class="prose prose-sm max-w-none text-slate-700"></div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        html {
            overflow-y: scroll;
            overflow-x: hidden;
        }
        body {
            overflow-x: hidden;
            width: 100%;
            margin: 0;
            padding: 0;
        }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const etkinlikModal = document.getElementById('etkinlikModal');
            const etkinlikModalContent = document.getElementById('etkinlikModalContent');
            const etkinlikModalImage = document.getElementById('etkinlikModalImage');
            const etkinlikModalBaslik = document.getElementById('etkinlikModalBaslik');
            const etkinlikModalTip = document.getElementById('etkinlikModalTip');
            const etkinlikModalTarih = document.getElementById('etkinlikModalTarih');
            const etkinlikModalSaat = document.getElementById('etkinlikModalSaat');
            const etkinlikModalKonum = document.getElementById('etkinlikModalKonum');
            const etkinlikModalOzet = document.getElementById('etkinlikModalOzet');
            const etkinlikModalIcerik = document.getElementById('etkinlikModalIcerik');

            const etkinlikData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                (Model ?? Enumerable.Empty<GaziHastane.Models.Etkinlik>()).Select(e => new
                {
                    e.Id,
                    e.Baslik,
                    e.EtkinlikTipi,
                    e.Konum,
                    e.SaatAraligi,
                    e.Aciklama,
                    e.ModalIcerik,
                    e.GorselUrl,
                    Tarih = e.Tarih.ToString("dd MMMM yyyy")
                })
            ));

            const etkinlikMap = new Map(etkinlikData.map(x => [x.Id ?? x.id, x]));

            window.openEtkinlikModal = function (id) {
                const etkinlik = etkinlikMap.get(id);
                if (!etkinlik) return;

                const gorselUrl = etkinlik.GorselUrl ?? etkinlik.gorselUrl;
                const baslik = etkinlik.Baslik ?? etkinlik.baslik;
                const tip = etkinlik.EtkinlikTipi ?? etkinlik.etkinlikTipi;
                const tarih = etkinlik.Tarih ?? etkinlik.tarih;
                const saat = etkinlik.SaatAraligi ?? etkinlik.saatAraligi;
                const konum = etkinlik.Konum ?? etkinlik.konum;
                const aciklama = etkinlik.Aciklama ?? etkinlik.aciklama;
                const icerik = etkinlik.ModalIcerik ?? etkinlik.modalIcerik;

                if (gorselUrl) {
                    etkinlikModalImage.src = gorselUrl;
                    etkinlikModalImage.alt = baslik;
                    etkinlikModalImage.classList.remove('hidden');
                } else {
                    etkinlikModalImage.classList.add('hidden');
                }

                etkinlikModalBaslik.textContent = baslik;
                etkinlikModalTip.textContent = tip || '';
                etkinlikModalTarih.textContent = tarih || '';
                etkinlikModalSaat.textContent = saat || '';
                etkinlikModalKonum.textContent = konum || '';
                etkinlikModalOzet.textContent = aciklama || '';
                etkinlikModalIcerik.innerHTML = icerik || '<p class="text-slate-500 text-sm">Detay içerik bulunmuyor.</p>';

                etkinlikModal.classList.remove('hidden');

                // Arka planı sabitle
                const scrollBarWidth = window.innerWidth - document.documentElement.clientWidth;
                document.body.style.paddingRight = scrollBarWidth + 'px';
                document.body.classList.add('modal-open');
                document.documentElement.classList.add('modal-open');

                setTimeout(() => {
                    etkinlikModal.classList.remove('opacity-0');
                    etkinlikModalContent.classList.remove('scale-95');
                }, 10);
            }

            window.closeEtkinlikModal = function () {
                etkinlikModal.classList.add('opacity-0');
                etkinlikModalContent.classList.add('scale-95');
                setTimeout(() => {
                    etkinlikModal.classList.add('hidden');
                    document.body.classList.remove('modal-open');
                    document.documentElement.classList.remove('modal-open');
                    document.body.style.paddingRight = '';
                }, 250);
            }

            document.querySelectorAll('.js-etkinlik-card').forEach(btn => {
                btn.addEventListener('click', function () {
                    const id = parseInt(this.dataset.etkinlikId);
                    if (!Number.isNaN(id)) {
                        window.openEtkinlikModal(id);
                    }
                });
            });
        });
    </script>
}