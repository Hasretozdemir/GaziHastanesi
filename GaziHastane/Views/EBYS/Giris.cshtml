@* RAZOR KOD BLOĞU: Sunucu tarafında (C#) çalışan kodlar burada yer alır. *@
@{
    // Tarayıcının üst sekmesinde (Title bar) görünecek sayfa başlığını belirliyoruz.
    ViewData["Title"] = "Gazi Üniversitesi | EBYS Beyaz Giriş";
}

<div class="ebys-white-wrapper">
    <div class="main-wallpaper" style="background-image: url('/assets/gaziebys.jpg');"></div>
    <div class="auth-card-white animate__animated animate__fadeInUp">
        <div class="auth-card-content">

            <div class="text-center mb-5">

                <div class="logo-premium-wrapper mb-3">
                    <img src="/assets/gazilogo.jpg" alt="Gazi Logo" class="brand-img">
                </div>

                <h4 class="fw-800 text-navy mb-1">EBYS GİRİŞ</h4><p class="text-muted small mb-0">Elektronik Belge Yönetim Sistemi</p>

                <div class="ebys-badge-gold">SİSTEME GÜVENLİ ERİŞİM</div>
            </div>

            <form action="/EBYS/Login" method="post">
                <div class="input-modern mb-4">
                    <label class="premium-label-navy">KULLANICI İSMİ</label>

                    <div class="field-wrapper-white">
                        <i class="fas fa-id-card-alt text-navy-light"></i><input type="text" placeholder="Kullanıcı adınızı giriniz" required>
                    </div>
                </div>

                <div class="input-modern mb-4">
                    <label class="premium-label-navy">PAROLA</label>
                    <div class="field-wrapper-white">
                        <i class="fas fa-lock text-navy-light"></i><input type="password" placeholder="••••••••" required>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-5 px-1">

                    <div class="custom-checkbox-white">
                        <input type="checkbox" id="remember">
                        <label for="remember" class="text-navy small ms-1">Oturumu Açık Tut</label>
                    </div>

                    <div class="forgot-pass-link">
                        <a href="#" class="small fw-600 text-navy-light">Parola İşlemleri</a>
                    </div>
                </div>

                <button type="submit" class="btn-ebys-action-gold shadow-lg">
                    <span>SİSTEME GİRİŞ YAP</span>
                    <i class="fas fa-sign-in-alt"></i>
                </button>
            </form>

            <div class="footer-links-modern mt-5">
                <a href="#">Kullanım Kılavuzu</a> <span class="dot-sep-navy">•</span><a href="#">Destek Talebi</a>
            </div>
        </div>
    </div>
</div>


@* CSS BÖLÜMÜ: Sadece bu sayfada geçerli olacak stiller. 
   _Layout.cshtml içindeki '@RenderSection("Styles", required: false)' etiketinin olduğu yere otomatik olarak yerleşir.
*@
@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        /* CSS DEĞİŞKENLERİ: Kodun her yerinde aynı renk kodunu ezberlemek yerine isim verilir. Değiştirmek çok kolaydır */
        :root {
            --gazi-navy: #0f172a; /* Koyu lacivert: Başlıklar ve buton yazıları için */
            --gazi-navy-light: #475569; /* Açık lacivert/gri: İkonlar ve alt yazılar için */
            --gazi-gold-premium: #c5a059; /* Altın/Hardal: Rozet ve butonun ana rengi */
            --soft-gold: rgba(197, 160, 89, 0.4); /* Yarı saydam altın: Kartın etrafındaki parlama(glow) gölgesi için */
            --btn-gold-gr-1: #c5a059; /* Buton gradyanı (renk geçişi) başlangıç rengi */
            --btn-gold-gr-2: #e2c28d; /* Buton gradyanı bitiş rengi (daha açık ton) */
        }

        /* Sayfa Genel Ayarları */
        body {
            margin: 0;
            padding: 0; /* Tarayıcının varsayılan boşluklarını sıfırlar */
            font-family: 'Plus Jakarta Sans', sans-serif; /* Modern, okunabilir yazı fontu */
            overflow-x: hidden; /* Sayfanın sağa sola kaymasını (yatay scroll) engeller */
        }

        /* Tüm Ekranı Kaplayan Dış Div */
        .ebys-white-wrapper {
            min-height: 100vh; /* Ekranın yüzde 100'ünü dikey olarak kaplar (Görünür alan kadar) */
            display: flex; /* İçindeki elemanları (kartı) esnek yerleştirmeyi sağlar */
            align-items: center; /* Kartı dikey olarak tam ortaya (düşey merkez) hizalar */
            justify-content: center; /* Kartı yatay olarak tam ortaya hizalar */
            position: relative; /* Arka plan resmini absolute yapabilmek için gerekli */
            padding: 20px; /* Mobil ekranlarda kartın kenarlara yapışmaması için boşluk */
        }

        /* Arka Plan Görseli Özellikleri */
        .main-wallpaper {
            position: fixed;
            top: 0;
            left: 0; /* Ekranın sol üst köşesine kilitler, kaydırılsa da yerinde kalır */
            width: 100%;
            height: 100%; /* Ekranın tamamını doldurur */
            background-size: cover; /* Resmi sündürmeden, en-boy oranını koruyarak ekranı kaplatır */
            background-position: center; /* Resmin ortasını odaklar */
            z-index: -2; /* Sayfanın en arkasına (alt katmana) atar */
            filter: brightness(0.5) blur(3px); /* Resmi %50 karartır ve 3px bulanıklaştırır ki üzerindeki beyaz kart okunsun */
        }

        /* Beyaz Giriş Kartı Özellikleri */
        .auth-card-white {
            width: 100%;
            max-width: 440px; /* Kart esnektir ama genişliği 440px'i geçemez */
            background: #ffffff; /* Saf beyaz arka plan */
            border-radius: 40px; /* Kartın köşelerini yuvarlatır (Modern görünüm) */
            padding: 50px 45px; /* Kartın içindeki yazılarla kenarları arasında boşluk bırakır */
            /* Gölgelendirme: İlk değer koyu alt gölge, ikinci değer etrafındaki altın rengi (glow) yansıma */
            box-shadow: 0 40px 100px -15px rgba(0, 0, 0, 0.3), 0 0 10px var(--soft-gold);
            z-index: 1; /* Arka plan resminin (z-index:-2) üstünde görünmesini sağlar */
        }

        /* Logo Yuvası */
        .logo-premium-wrapper {
            width: 80px;
            height: 80px; /* Logonun oturduğu kutunun ebatları */
            background: #f8fafc; /* Logonun arkasına çok açık gri bir zemin */
            border-radius: 20px; /* Logonun kutusunu yuvarlatır */
            margin: 0 auto; /* Kutuyu yatayda tam ortaya hizalar */
            padding: 8px; /* Logonun kutu dışına taşmaması için iç boşluk */
            display: flex;
            align-items: center;
            justify-content: center; /* İçindeki logoyu tam merkeze oturtur */
            box-shadow: 0 5px 15px rgba(0,0,0,0.1); /* Logonun altına hafif derinlik (gölge) verir */
        }

        /* Logonun Kendisi */
        .brand-img {
            width: 100%;
            height: 100%; /* Kutunun içini tam doldurur */
            object-fit: contain; /* Logonun kenarlarından kesilmeden, orantılı sığmasını sağlar */
        }

        /* Altın Rozet Tasarımı */
        .ebys-badge-gold {
            display: inline-block;
            margin-top: 15px; /* Üstteki yazıdan biraz uzaklaştırır */
            font-size: 10px;
            font-weight: 800; /* Çok küçük ama kalın yazılır */
            letter-spacing: 2px; /* Harflerin arasını açarak premium görünüm katar */
            color: #fff; /* Rozet içi yazı rengi beyaz */
            background: var(--gazi-gold-premium); /* Değişkendeki altın rengini zemin yapar */
            border-radius: 50px; /* Rozetin uçlarını tam yuvarlak (hap şeklinde) yapar */
            padding: 6px 18px; /* Rozetin içi boşlukları */
        }

        /* Yazı Renklendirmeleri */
        .text-navy {
            color: var(--gazi-navy);
        }
        /* Koyu lacivert ataması */
        .text-navy-light {
            color: var(--gazi-navy-light);
            text-decoration: none;
        }
        /* Açık lacivert ve alt çizgisi olmayan link */
        .fw-800 {
            font-weight: 800;
        }
        /* Yazıyı ekstra kalınlaştırır */

        /* Inputların Üzerindeki Başlıklar (KULLANICI İSMİ vs.) */
        .premium-label-navy {
            font-size: 11px;
            font-weight: 800;
            color: var(--gazi-navy-light);
            margin-bottom: 8px;
            display: block; /* Etiketin altına inmesini (block) sağlar */
            letter-spacing: 1.5px; /* Harf aralığı */
        }

        /* Inputlar (Metin Kutuları) İçin Taşıyıcı */
        .field-wrapper-white {
            position: relative; /* İçindeki ikonun (absolute) konumlanabilmesi için referans noktası olur */
            display: flex;
            align-items: center;
        }

            /* Metin Kutularının İçindeki İkonlar */
            .field-wrapper-white i {
                position: absolute;
                left: 18px; /* İkonu kutunun en soluna yaslar */
                font-size: 1.1rem;
                opacity: 0.8; /* İkon boyutu ve %80 saydamlık */
            }

            /* Metin Kutuları (Input'ların kendisi) */
            .field-wrapper-white input {
                width: 100%;
                height: 58px; /* Kutunun genişliği ve yüksekliği */
                background: #f8fafc; /* İçi hafif açık gri */
                border: 1px solid #e2e8f0; /* Çok ince gri dış çizgi (border) */
                border-radius: 15px; /* Köşeleri yuvarlatılmış kutu */
                padding: 0 20px 0 55px; /* Soldan 55px boşluk bırakır, çünkü orada ikon duruyor. Yazı ikonun üstüne binmez */
                color: var(--gazi-navy);
                font-weight: 600; /* Girilen yazının rengi ve kalınlığı */
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); /* Focus efekti için yumuşak geçiş animasyonu süresi */
            }

                /* Kullanıcı Input'a Tıkladığında (Yazı Yazarken) Olanlar */
                .field-wrapper-white input:focus {
                    background: #ffffff; /* Kutunun içi tam beyaz olur */
                    border-color: var(--gazi-gold-premium); /* Dış çizgisi altın rengi olur */
                    box-shadow: 0 0 15px var(--soft-gold); /* Kutunun etrafına altın rengi bir parlama (glow) verir */
                    outline: none; /* Tarayıcının varsayılan mavi çizgisini yok eder */
                }

        /* Giriş Yap Butonu */
        .btn-ebys-action-gold {
            width: 100%;
            height: 60px;
            /* Arka plana linear-gradient (iki renkli geçiş) verir */
            background: linear-gradient(135deg, var(--btn-gold-gr-1) 0%, var(--btn-gold-gr-2) 100%);
            border: none;
            border-radius: 15px;
            color: var(--gazi-navy);
            font-weight: 800; /* Buton yazısı lacivert ve kalın */
            display: flex;
            align-items: center;
            justify-content: space-between; /* Yazı sola, ikon sağa yaslanır */
            padding: 0 25px;
            transition: all 0.5s ease; /* Hover(üzerine gelme) efekti süresi */
            letter-spacing: 1px;
        }

            /* Farenin İmleci Butonun Üzerine Geldiğinde (Hover) */
            .btn-ebys-action-gold:hover {
                transform: translateY(-3px); /* Butonu hafifçe 3 piksel yukarı kaldırır (Tıklanma hissi verir) */
                /* Renk geçişini tersine çevirip biraz daha açık hale getirir */
                background: linear-gradient(135deg, #e0bf81 0%, #c5a059 100%);
                color: #fff; /* Üstüne gelince yazı lacivertten beyaza döner */
                box-shadow: 0 15px 30px var(--soft-gold); /* Altındaki gölgeyi/parlamayı büyütür */
            }

        /* Linklere Tıklanma/Gelinme Efekti */
        .forgot-pass-link a:hover {
            color: var(--gazi-gold-premium);
        }
        /* "Parola işlemleri" linkinin üstüne gelince sararması */

        /* En Alttaki Footer Linkleri (Kullanım Kılavuzu vs.) */
        .footer-links-modern {
            text-align: center;
        }
            /* Linkleri ortalar */
            .footer-links-modern a {
                color: var(--gazi-navy-light);
                text-decoration: none; /* Alt çizgiyi kaldırır */
                font-size: 12px;
                font-weight: 700;
                transition: 0.3s;
            }

                .footer-links-modern a:hover {
                    color: var(--gazi-gold-premium);
                }

        .dot-sep-navy {
            color: #cbd5e1;
            margin: 0 10px;
        }
        /* Linkler arasındaki noktaların rengi ve boşluğu */

        /* MOBİL UYUM (Responsive Tasarım) */
        /* Ekran genişliği 576px'den (telefon ekranları) küçükse aşağıdaki kodlar devreye girer */
        @@media (max-width: 576px) {
            .auth-card-white

        {
            padding: 40px 25px; /* Telefon ekranında iç boşlukları daraltarak kartın ekrana sığmasını sağlar */
            border-radius: 30px; /* Ovaliği biraz azaltır */
            margin: 10px; /* Dışarıdan 10px pay bırakarak telefonun kenarlarına yapışmasını engeller */
        }

        }
    </style>
}