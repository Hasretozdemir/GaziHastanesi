@* RAZOR KOD BLOĐU: Sunucu tarafýnda (C#) çalýţan kodlar burada yer alýr.
*@
@{
    // Tarayýcýnýn üst sekmesinde (Title bar) görünecek sayfa baţlýđýný belirliyoruz.
    ViewData["Title"] = "Gazi Üniversitesi | EBYS Beyaz Giriţ";
}

<div class="ebys-white-wrapper">
    <!-- Tüm giriţ ekranýný sarmalayan ana kapsayýcý. Beyaz ađýrlýklý bir tema olduđunu iţaret ediyor.-->

    <div class="main-wallpaper" style="background-image: url('/assets/gaziebys.jpg');"></div>
	<!-- Sayfanýn arka planýnda tam ekran kaplayan bir görsel. CSS ile karartýlmýţ ve bulanýklaţtýrýlmýţ, böylece üzerindeki beyaz kart öne çýkar. -->'
    <div class="auth-card-white animate__animated animate__fadeInUp">
        <!--  Giriţ formunun içinde bulunduđu beyaz kutu. animate__fadeInUp sýnýfý, kutunun sayfa açýldýđýnda aţađýdan yukarýya dođru kayarak gelmesini (animasyon) sađlar.-->

        <div class="auth-card-content">

            <div class="text-center mb-5">

                <div class="logo-premium-wrapper mb-3">
                    <!--Logoyu estetik bir çerçeveye alan kýsým.-->
                    <img src="/assets/gazilogo.jpg" alt="Gazi Logo" class="brand-img"><!--Gazi Üniversitesi'nin logosunu ekrana basar.-->
                </div>

                <h4 class="fw-800 text-navy mb-1">EBYS GÝRÝŢ</h4><!--Kalýn puntolu (fw-800) ve lacivert renkli (text-navy) ana baţlýk.-->

                <p class="text-muted small mb-0">Elektronik Belge Yönetim Sistemi</p>
               
                <div class="ebys-badge-gold">SÝSTEME GÜVENLÝ ERÝŢÝM</div> <!--Altýn rengi temalý bir rozet/etiket; sistemin güvenli olduđunu vurgulayan görsel bir öge.-->

            </div>

            <form action="/EBYS/Login" method="post">
                <!--Formun kalbidir. Kullanýcý butona bastýđýnda veriler güvenli bir ţekilde (post) sunucudaki /EBYS/Login adresine gönderilir.
                -->

                <div class="input-modern mb-4">
                    <label class="premium-label-navy">KULLANICI ÝSMÝ</label>

                    <div class="field-wrapper-white">
                        <i class="fas fa-id-card-alt text-navy-light"></i><!-- FontAwesome kütüphanesinden bir kimlik kartý ikonu ekler.-->
                        <input type="text" placeholder="Kullanýcý adýnýzý giriniz" required><!--Kullanýcýnýn metin gireceđi alan. required boţ býrakýlmasýný engeller.-->
                    </div>
                </div>

                <div class="input-modern mb-4">
                    <label class="premium-label-navy">PAROLA</label>
                    <div class="field-wrapper-white">
                        <i class="fas fa-lock text-navy-light"></i><!--Kilit ikonu ekler.-->
                        <input type="password" placeholder="••••••••" required><!--Yazýlan karakterlerin gizli (nokta ţeklinde) görünmesini sađlar.-->
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-5 px-1">

                    <div class="custom-checkbox-white">
                        <input type="checkbox" id="remember">
                        <label for="remember" class="text-navy small ms-1">Oturumu Açýk Tut</label><!--"Oturumu Açýk Tut" seçeneđi için özelleţtirilmiţ onay kutusu.-->
                    </div>

                    <div class="forgot-pass-link">
                        <!--Ţifresini unutanlar için "Parola Ýţlemleri" bađlantýsý.-->
                        <a href="#" class="small fw-600 text-navy-light">Parola Ýţlemleri</a>
                    </div>
                </div>

                <button type="submit" class="btn-ebys-action-gold shadow-lg">
                    <!--Formu gönderen ana buton. Altýn rengi efektine ve üzerine gelindiđinde parlayan bir gölgeye (shadow-lg) sahiptir.-->
                    <span>SÝSTEME GÝRÝŢ YAP</span>
                    <i class="fas fa-sign-in-alt"></i><!-- Butonun yanýndaki "giriţ yap" ikonu.-->
                </button>
            </form>

            <div class="footer-links-modern mt-5">
                <!-- Kartýn en altýnda bulunan yardýmcý linkler alaný.-->
                <a href="#">Kullaným Kýlavuzu</a> <!--Kullanýcýya sistemle ilgili yardým alabileceđi yönlendirmeler sunar.-->
                <span class="dot-sep-navy">•</span><!-->: Ýki link arasýna lacivert bir nokta iţareti koyar.-->
                -->
                <a href="#">Destek Talebi</a>
            </div>
        </div>
    </div>
</div>


@* CSS BÖLÜMÜ: Sadece bu sayfada geçerli olacak stiller. 
  _Layout.cshtml içindeki '@RenderSection("Styles", required: false)' etiketinin olduđu yere otomatik olarak yerleţir.
*@
@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        /* CSS DEĐÝŢKENLERÝ: Kodun her yerinde ayný renk kodunu ezberlemek yerine isim verilir. Deđiţtirmek çok kolaydýr */
        :root {
            --gazi-navy: #0f172a; /* Koyu lacivert: Baţlýklar ve buton yazýlarý için */
            --gazi-navy-light: #475569; /* Açýk lacivert/gri: Ýkonlar ve alt yazýlar için */
            --gazi-gold-premium: #c5a059; /* Altýn/Hardal: Rozet ve butonun ana rengi */
            --soft-gold: rgba(197, 160, 89, 0.4); /* Yarý saydam altýn: Kartýn etrafýndaki parlama(glow) gölgesi için */
            --btn-gold-gr-1: #c5a059; /* Buton gradyaný (renk geçiţi) baţlangýç rengi */
            --btn-gold-gr-2: #e2c28d; /* Buton gradyaný bitiţ rengi (daha açýk ton) */
        }

        /* Sayfa Genel Ayarlarý */
        body {
            margin: 0;
            padding: 0; /* Tarayýcýnýn varsayýlan boţluklarýný sýfýrlar */
            font-family: 'Plus Jakarta Sans', sans-serif; /* Modern, okunabilir yazý fontu */
            overflow-x: hidden; /* Sayfanýn sađa sola kaymasýný (yatay scroll) engeller */
        }

        /* Tüm Ekraný Kaplayan Dýţ Div */
        .ebys-white-wrapper {
            min-height: 100vh; /* Ekranýn yüzde 100'ünü dikey olarak kaplar (Görünür alan kadar) */
            display: flex; /* Ýçindeki elemanlarý (kartý) esnek yerleţtirmeyi sađlar */
            align-items: center; /* Kartý dikey olarak tam ortaya (düţey merkez) hizalar */
            justify-content: center; /* Kartý yatay olarak tam ortaya hizalar */
            position: relative; /* Arka plan resmini absolute yapabilmek için gerekli */
            padding: 20px; /* Mobil ekranlarda kartýn kenarlara yapýţmamasý için boţluk */
        }

        /* Arka Plan Görseli Özellikleri */
        .main-wallpaper {
            position: fixed;
            top: 0;
            left: 0; /* Ekranýn sol üst köţesine kilitler, kaydýrýlsa da yerinde kalýr */
            width: 100%;
            height: 100%; /* Ekranýn tamamýný doldurur */
            background-size: cover; /* Resmi sündürmeden, en-boy oranýný koruyarak ekraný kaplatýr */
            background-position: center; /* Resmin ortasýný odaklar */
            z-index: -2; /* Sayfanýn en arkasýna (alt katmana) atar */
            filter: brightness(0.5) blur(3px); /* Resmi %50 karartýr ve 3px bulanýklaţtýrýr ki üzerindeki beyaz kart okunsun */
        }

        /* Beyaz Giriţ Kartý Özellikleri */
        .auth-card-white {
            width: 100%;
            max-width: 440px; /* Kart esnektir ama geniţliđi 440px'i geçemez */
            background: #ffffff; /* Saf beyaz arka plan */
            border-radius: 40px; /* Kartýn köţelerini yuvarlatýr (Modern görünüm) */
            padding: 50px 45px; /* Kartýn içindeki yazýlarla kenarlarý arasýnda boţluk býrakýr */
            /* Gölgelendirme: Ýlk deđer koyu alt gölge, ikinci deđer etrafýndaki altýn rengi (glow) yansýma */
            box-shadow: 0 40px 100px -15px rgba(0, 0, 0, 0.3), 0 0 10px var(--soft-gold);
            z-index: 1; /* Arka plan resminin (z-index:-2) üstünde görünmesini sađlar */
        }

        /* Logo Yuvasý */
        .logo-premium-wrapper {
            width: 80px;
            height: 80px; /* Logonun oturduđu kutunun ebatlarý */
            background: #f8fafc; /* Logonun arkasýna çok açýk gri bir zemin */
            border-radius: 20px; /* Logonun kutusunu yuvarlatýr */
            margin: 0 auto; /* Kutuyu yatayda tam ortaya hizalar */
            padding: 8px; /* Logonun kutu dýţýna taţmamasý için iç boţluk */
            display: flex;
            align-items: center;
            justify-content: center; /* Ýçindeki logoyu tam merkeze oturtur */
            box-shadow: 0 5px 15px rgba(0,0,0,0.1); /* Logonun altýna hafif derinlik (gölge) verir */
        }

        /* Logonun Kendisi */
        .brand-img {
            width: 100%;
            height: 100%; /* Kutunun içini tam doldurur */
            object-fit: contain; /* Logonun kenarlarýndan kesilmeden, orantýlý sýđmasýný sađlar */
        }

        /* Altýn Rozet Tasarýmý */
        .ebys-badge-gold {
            display: inline-block;
            margin-top: 15px; /* Üstteki yazýdan biraz uzaklaţtýrýr */
            font-size: 10px;
            font-weight: 800; /* Çok küçük ama kalýn yazýlýr */
            letter-spacing: 2px; /* Harflerin arasýný açarak premium görünüm katar */
            color: #fff; /* Rozet içi yazý rengi beyaz */
            background: var(--gazi-gold-premium); /* Deđiţkendeki altýn rengini zemin yapar */
            border-radius: 50px; /* Rozetin uçlarýný tam yuvarlak (hap ţeklinde) yapar */
            padding: 6px 18px; /* Rozetin içi boţluklarý */
        }

        /* Yazý Renklendirmeleri */
        .text-navy {
            color: var(--gazi-navy);
        }
        /* Koyu lacivert atamasý */
        .text-navy-light {
            color: var(--gazi-navy-light);
            text-decoration: none;
        }
        /* Açýk lacivert ve alt çizgisi olmayan link */
        .fw-800 {
            font-weight: 800;
        }
        /* Yazýyý ekstra kalýnlaţtýrýr */

        /* Inputlarýn Üzerindeki Baţlýklar (KULLANICI ÝSMÝ vs.) */
        .premium-label-navy {
            font-size: 11px;
            font-weight: 800;
            color: var(--gazi-navy-light);
            margin-bottom: 8px;
            display: block; /* Etiketin altýna inmesini (block) sađlar */
            letter-spacing: 1.5px; /* Harf aralýđý */
        }

        /* Inputlar (Metin Kutularý) Ýçin Taţýyýcý */
        .field-wrapper-white {
            position: relative; /* Ýçindeki ikonun (absolute) konumlanabilmesi için referans noktasý olur */
            display: flex;
            align-items: center;
        }

            /* Metin Kutularýnýn Ýçindeki Ýkonlar */
            .field-wrapper-white i {
                position: absolute;
                left: 18px; /* Ýkonu kutunun en soluna yaslar */
                font-size: 1.1rem;
                opacity: 0.8; /* Ýkon boyutu ve %80 saydamlýk */
            }

            /* Metin Kutularý (Input'larýn kendisi) */
            .field-wrapper-white input {
                width: 100%;
                height: 58px; /* Kutunun geniţliđi ve yüksekliđi */
                background: #f8fafc; /* Ýçi hafif açýk gri */
                border: 1px solid #e2e8f0; /* Çok ince gri dýţ çizgi (border) */
                border-radius: 15px; /* Köţeleri yuvarlatýlmýţ kutu */
                padding: 0 20px 0 55px; /* Soldan 55px boţluk býrakýr, çünkü orada ikon duruyor. Yazý ikonun üstüne binmez */
                color: var(--gazi-navy);
                font-weight: 600; /* Girilen yazýnýn rengi ve kalýnlýđý */
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); /* Focus efekti için yumuţak geçiţ animasyonu süresi */
            }

                /* Kullanýcý Input'a Týkladýđýnda (Yazý Yazarken) Olanlar */
                .field-wrapper-white input:focus {
                    background: #ffffff; /* Kutunun içi tam beyaz olur */
                    border-color: var(--gazi-gold-premium); /* Dýţ çizgisi altýn rengi olur */
                    box-shadow: 0 0 15px var(--soft-gold); /* Kutunun etrafýna altýn rengi bir parlama (glow) verir */
                    outline: none; /* Tarayýcýnýn varsayýlan mavi çizgisini yok eder */
                }

        /* Giriţ Yap Butonu */
        .btn-ebys-action-gold {
            width: 100%;
            height: 60px;
            /* Arka plana linear-gradient (iki renkli geçiţ) verir */
            background: linear-gradient(135deg, var(--btn-gold-gr-1) 0%, var(--btn-gold-gr-2) 100%);
            border: none;
            border-radius: 15px;
            color: var(--gazi-navy);
            font-weight: 800; /* Buton yazýsý lacivert ve kalýn */
            display: flex;
            align-items: center;
            justify-content: space-between; /* Yazý sola, ikon sađa yaslanýr */
            padding: 0 25px;
            transition: all 0.5s ease; /* Hover(üzerine gelme) efekti süresi */
            letter-spacing: 1px;
        }

            /* Farenin Ýmleci Butonun Üzerine Geldiđinde (Hover) */
            .btn-ebys-action-gold:hover {
                transform: translateY(-3px); /* Butonu hafifçe 3 piksel yukarý kaldýrýr (Týklanma hissi verir) */
                /* Renk geçiţini tersine çevirip biraz daha açýk hale getirir */
                background: linear-gradient(135deg, #e0bf81 0%, #c5a059 100%);
                color: #fff; /* Üstüne gelince yazý lacivertten beyaza döner */
                box-shadow: 0 15px 30px var(--soft-gold); /* Altýndaki gölgeyi/parlamayý büyütür */
            }

        /* Linklere Týklanma/Gelinme Efekti */
        .forgot-pass-link a:hover {
            color: var(--gazi-gold-premium);
        }
        /* "Parola iţlemleri" linkinin üstüne gelince sararmasý */

        /* En Alttaki Footer Linkleri (Kullaným Kýlavuzu vs.) */
        .footer-links-modern {
            text-align: center;
        }
            /* Linkleri ortalar */
            .footer-links-modern a {
                color: var(--gazi-navy-light);
                text-decoration: none; /* Alt çizgiyi kaldýrýr */
                font-size: 12px;
                font-weight: 700;
                transition: 0.3s;
            }

                .footer-links-modern a:hover {
                    color: var(--gazi-gold-premium);
                }

        .dot-sep-navy {
            color: #cbd5e1;
            margin: 0 10px;
        }
        /* Linkler arasýndaki noktalarýn rengi ve boţluđu */

        /* MOBÝL UYUM (Responsive Tasarým) */
        /* Ekran geniţliđi 576px'den (telefon ekranlarý) küçükse aţađýdaki kodlar devreye girer */
        @@media (max-width: 576px) {
            .auth-card-white {
                padding: 40px 25px; /* Telefon ekranýnda iç boţluklarý daraltarak kartýn ekrana sýđmasýný sađlar */
                border-radius: 30px; /* Ovaliđi biraz azaltýr */
                margin: 10px; /* Dýţarýdan 10px pay býrakarak telefonun kenarlarýna yapýţmasýný engeller */
            }
        }
    </style>
}

      