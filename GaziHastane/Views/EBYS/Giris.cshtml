@{
    ViewData["Title"] = "Gazi Üniversitesi | EBYS Beyaz Giriţ";
}

<div class="ebys-white-wrapper">
    <div class="main-wallpaper" style="background-image: url('/assets/gaziebys.jpg');"></div>

    <div class="auth-card-white animate__animated animate__fadeInUp">
        <div class="auth-card-content">

            <div class="text-center mb-5">
                <div class="logo-premium-wrapper mb-3">
                    <img src="/assets/gazilogo.jpg" alt="Gazi Logo" class="brand-img">
                </div>
                <h4 class="fw-800 text-navy mb-1">EBYS GÝRÝŢ</h4>
                <p class="text-muted small mb-0">Elektronik Belge Yönetim Sistemi</p>
                <div class="ebys-badge-gold">SÝSTEME GÜVENLÝ ERÝŢÝM</div>
            </div>

            <form action="/EBYS/Login" method="post">

                <div class="input-modern mb-4">
                    <label class="premium-label-navy">KULLANICI ÝSMÝ</label>
                    <div class="field-wrapper-white">
                        <i class="fas fa-id-card-alt text-navy-light"></i>
                        <input type="text" placeholder="Kullanýcý adýnýzý giriniz" required>
                    </div>
                </div>

                <div class="input-modern mb-4">
                    <label class="premium-label-navy">PAROLA</label>
                    <div class="field-wrapper-white">
                        <i class="fas fa-lock text-navy-light"></i>
                        <input type="password" placeholder="••••••••" required>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-5 px-1">
                    <div class="custom-checkbox-white">
                        <input type="checkbox" id="remember">
                        <label for="remember" class="text-navy small ms-1">Oturumu Açýk Tut</label>
                    </div>
                    <div class="forgot-pass-link">
                        <a href="#" class="small fw-600 text-navy-light">Parola Ýţlemleri</a>
                    </div>
                </div>

                <button type="submit" class="btn-ebys-action-gold shadow-lg">
                    <span>SÝSTEME GÝRÝŢ YAP</span>
                    <i class="fas fa-sign-in-alt"></i>
                </button>
            </form>

            <div class="footer-links-modern mt-5">
                <a href="#">Kullaným Kýlavuzu</a>
                <span class="dot-sep-navy">•</span>
                <a href="#">Destek Talebi</a>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <style>
        :root {
            --gazi-navy: #0f172a; /* Koyu Lacivert (Yazýlar için) */
            --gazi-navy-light: #475569; /* Daha açýk navy (Ýkonlar için) */
            --gazi-gold-premium: #c5a059;
            --soft-gold: rgba(197, 160, 89, 0.4);
            /* Turuncu/Gold Buton Gradyaný */
            --btn-gold-gr-1: #c5a059;
            --btn-gold-gr-2: #e2c28d;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Plus Jakarta Sans', sans-serif;
            overflow-x: hidden;
        }

        .ebys-white-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            padding: 20px;
        }

        /* Arka Plan Resmi ( gazimail.jpg ) ve Karartma */
        .main-wallpaper {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-size: cover;
            background-position: center;
            z-index: -2;
            /* Resim canlý kalsýn ama karartma ve blur olsun */
            filter: brightness(0.5) blur(3px);
        }

        /* Tamamen Beyaz, Premium Kart Tasarýmý */
        .auth-card-white {
            width: 100%;
            max-width: 440px;
            background: #ffffff; /* Beyaz Zemin */
            border-radius: 40px;
            padding: 50px 45px;
            /* Beyaz karta derinlik vermek için gölge ve glow */
            box-shadow: 0 40px 100px -15px rgba(0, 0, 0, 0.3), 0 0 10px var(--soft-gold);
            z-index: 1;
        }

        /* Logo */
        .logo-premium-wrapper {
            width: 80px;
            height: 80px;
            background: #f8fafc;
            border-radius: 20px;
            margin: 0 auto;
            padding: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .brand-img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        /* Gold Badge */
        .ebys-badge-gold {
            display: inline-block;
            margin-top: 15px;
            font-size: 10px;
            font-weight: 800;
            letter-spacing: 2px;
            color: #fff;
            background: var(--gazi-gold-premium); /* Tam Gold rozet */
            border-radius: 50px;
            padding: 6px 18px;
        }

        /* Yazý Renkleri (Navy Dengesi) */
        .text-navy {
            color: var(--gazi-navy);
        }

        .text-navy-light {
            color: var(--gazi-navy-light);
            text-decoration: none;
        }

        .fw-800 {
            font-weight: 800;
        }

        /* Inputlar (Beyaz Zemin Ýçin) */
        .premium-label-navy {
            font-size: 11px;
            font-weight: 800;
            color: var(--gazi-navy-light);
            margin-bottom: 8px;
            display: block;
            letter-spacing: 1.5px;
        }

        .field-wrapper-white {
            position: relative;
            display: flex;
            align-items: center;
        }

            .field-wrapper-white i {
                position: absolute;
                left: 18px;
                font-size: 1.1rem;
                opacity: 0.8;
            }

            .field-wrapper-white input {
                width: 100%;
                height: 58px;
                /* Beyaz karta uygun hafif gri input arka planý */
                background: #f8fafc;
                border: 1px solid #e2e8f0;
                border-radius: 15px;
                padding: 0 20px 0 55px;
                color: var(--gazi-navy);
                font-weight: 600;
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            }

                .field-wrapper-white input:focus {
                    background: #ffffff;
                    border-color: var(--gazi-gold-premium);
                    /* Focus olduđunda gold glow */
                    box-shadow: 0 0 15px var(--soft-gold);
                    outline: none;
                }

        /* Gold Buton Tasarýmý */
        .btn-ebys-action-gold {
            width: 100%;
            height: 60px;
            /* Tam turuncu/gold gradyan */
            background: linear-gradient(135deg, var(--btn-gold-gr-1) 0%, var(--btn-gold-gr-2) 100%);
            border: none;
            border-radius: 15px;
            color: var(--gazi-navy);
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 25px;
            transition: all 0.5s ease;
            letter-spacing: 1px;
        }

            .btn-ebys-action-gold:hover {
                transform: translateY(-3px);
                /* Hover'da turuncuyu biraz daha parlatýyoruz */
                background: linear-gradient(135deg, #e0bf81 0%, #c5a059 100%);
                color: #fff;
                box-shadow: 0 15px 30px var(--soft-gold);
            }

        /* Linkler */
        .forgot-pass-link a:hover {
            color: var(--gazi-gold-premium);
        }

        /* Footer */
        .footer-links-modern {
            text-align: center;
        }

            .footer-links-modern a {
                color: var(--gazi-navy-light);
                text-decoration: none;
                font-size: 12px;
                font-weight: 700;
                transition: 0.3s;
            }

                .footer-links-modern a:hover {
                    color: var(--gazi-gold-premium);
                }

        .dot-sep-navy {
            color: #cbd5e1;
            margin: 0 10px;
        }

        @@media (max-width: 576px) {
            .auth-card-white {
                padding: 40px 25px;
                border-radius: 30px;
                margin: 10px;
            }
        }
    </style>
}