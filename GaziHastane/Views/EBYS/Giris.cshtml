@* CSS Bïŋ―Lïŋ―Mïŋ―: Sadece bu sayfada geïŋ―erli olacak stiller. 
  _Layout.cshtml iïŋ―indeki '@RenderSection("Styles", required: false)' etiketinin olduïŋ―u yere otomatik olarak yerleïŋ―ir.
*@
@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        /* CSS DEïŋ―ïŋ―ïŋ―KENLERïŋ―: Kodun her yerinde aynïŋ― renk kodunu ezberlemek yerine isim verilir. Deïŋ―iïŋ―tirmek ïŋ―ok kolaydïŋ―r */
        :root {
            --gazi-navy: #0f172a; /* Koyu lacivert: Baïŋ―lïŋ―klar ve buton yazïŋ―larïŋ― iïŋ―in */
            --gazi-navy-light: #475569; /* Aïŋ―ïŋ―k lacivert/gri: ïŋ―konlar ve alt yazïŋ―lar iïŋ―in */
            --gazi-gold-premium: #c5a059; /* Altïŋ―n/Hardal: Rozet ve butonun ana rengi */
            --soft-gold: rgba(197, 160, 89, 0.4); /* Yarïŋ― saydam altïŋ―n: Kartïŋ―n etrafïŋ―ndaki parlama(glow) gïŋ―lgesi iïŋ―in */
            --btn-gold-gr-1: #c5a059; /* Buton gradyanïŋ― (renk geïŋ―iïŋ―i) baïŋ―langïŋ―ïŋ― rengi */
            --btn-gold-gr-2: #e2c28d; /* Buton gradyanïŋ― bitiïŋ― rengi (daha aïŋ―ïŋ―k ton) */
        }

        /* Sayfa Genel Ayarlarïŋ― */
        body {
            margin: 0;
            padding: 0; /* Tarayïŋ―cïŋ―nïŋ―n varsayïŋ―lan boïŋ―luklarïŋ―nïŋ― sïŋ―fïŋ―rlar */
            font-family: 'Plus Jakarta Sans', sans-serif; /* Modern, okunabilir yazïŋ― fontu */
            overflow-x: hidden; /* Sayfanïŋ―n saïŋ―a sola kaymasïŋ―nïŋ― (yatay scroll) engeller */
        }

        /* Tïŋ―m Ekranïŋ― Kaplayan Dïŋ―ïŋ― Div */
        .ebys-white-wrapper {
            min-height: 100vh; /* Ekranïŋ―n yïŋ―zde 100'ïŋ―nïŋ― dikey olarak kaplar (Gïŋ―rïŋ―nïŋ―r alan kadar) */
            display: flex; /* ïŋ―ïŋ―indeki elemanlarïŋ― (kartïŋ―) esnek yerleïŋ―tirmeyi saïŋ―lar */
            align-items: center; /* Kartïŋ― dikey olarak tam ortaya (dïŋ―ïŋ―ey merkez) hizalar */
            justify-content: center; /* Kartïŋ― yatay olarak tam ortaya hizalar */
            position: relative; /* Arka plan resmini absolute yapabilmek iïŋ―in gerekli */
            padding: 20px; /* Mobil ekranlarda kartïŋ―n kenarlara yapïŋ―ïŋ―mamasïŋ― iïŋ―in boïŋ―luk */
        }

        /* Arka Plan Gïŋ―rseli ïŋ―zellikleri */
        .main-wallpaper {
            position: fixed;
            top: 0;
            left: 0; /* Ekranïŋ―n sol ïŋ―st kïŋ―ïŋ―esine kilitler, kaydïŋ―rïŋ―lsa da yerinde kalïŋ―r */
            width: 100%;
            height: 100%; /* Ekranïŋ―n tamamïŋ―nïŋ― doldurur */
            background-size: cover; /* Resmi sïŋ―ndïŋ―rmeden, en-boy oranïŋ―nïŋ― koruyarak ekranïŋ― kaplatïŋ―r */
            background-position: center; /* Resmin ortasïŋ―nïŋ― odaklar */
            z-index: -2; /* Sayfanïŋ―n en arkasïŋ―na (alt katmana) atar */
            filter: brightness(0.5) blur(3px); /* Resmi %50 karartïŋ―r ve 3px bulanïŋ―klaïŋ―tïŋ―rïŋ―r ki ïŋ―zerindeki beyaz kart okunsun */
        }

        /* Beyaz Giriïŋ― Kartïŋ― ïŋ―zellikleri */
        .auth-card-white {
            width: 100%;
            max-width: 440px; /* Kart esnektir ama geniïŋ―liïŋ―i 440px'i geïŋ―emez */
            background: #ffffff; /* Saf beyaz arka plan */
            border-radius: 40px; /* Kartïŋ―n kïŋ―ïŋ―elerini yuvarlatïŋ―r (Modern gïŋ―rïŋ―nïŋ―m) */
            padding: 50px 45px; /* Kartïŋ―n iïŋ―indeki yazïŋ―larla kenarlarïŋ― arasïŋ―nda boïŋ―luk bïŋ―rakïŋ―r */
            /* Gïŋ―lgelendirme: ïŋ―lk deïŋ―er koyu alt gïŋ―lge, ikinci deïŋ―er etrafïŋ―ndaki altïŋ―n rengi (glow) yansïŋ―ma */
            box-shadow: 0 40px 100px -15px rgba(0, 0, 0, 0.3), 0 0 10px var(--soft-gold);
            z-index: 1; /* Arka plan resminin (z-index:-2) ïŋ―stïŋ―nde gïŋ―rïŋ―nmesini saïŋ―lar */
        }

        /* Logo Yuvasïŋ― */
        .logo-premium-wrapper {
            width: 80px;
            height: 80px; /* Logonun oturduïŋ―u kutunun ebatlarïŋ― */
            background: #f8fafc; /* Logonun arkasïŋ―na ïŋ―ok aïŋ―ïŋ―k gri bir zemin */
            border-radius: 20px; /* Logonun kutusunu yuvarlatïŋ―r */
            margin: 0 auto; /* Kutuyu yatayda tam ortaya hizalar */
            padding: 8px; /* Logonun kutu dïŋ―ïŋ―ïŋ―na taïŋ―mamasïŋ― iïŋ―in iïŋ― boïŋ―luk */
            display: flex;
            align-items: center;
            justify-content: center; /* ïŋ―ïŋ―indeki logoyu tam merkeze oturtur */
            box-shadow: 0 5px 15px rgba(0,0,0,0.1); /* Logonun altïŋ―na hafif derinlik (gïŋ―lge) verir */
        }

        /* Logonun Kendisi */
        .brand-img {
            width: 100%;
            height: 100%; /* Kutunun iïŋ―ini tam doldurur */
            object-fit: contain; /* Logonun kenarlarïŋ―ndan kesilmeden, orantïŋ―lïŋ― sïŋ―ïŋ―masïŋ―nïŋ― saïŋ―lar */
        }

        /* Altïŋ―n Rozet Tasarïŋ―mïŋ― */
        .ebys-badge-gold {
            display: inline-block;
            margin-top: 15px; /* ïŋ―stteki yazïŋ―dan biraz uzaklaïŋ―tïŋ―rïŋ―r */
            font-size: 10px;
            font-weight: 800; /* ïŋ―ok kïŋ―ïŋ―ïŋ―k ama kalïŋ―n yazïŋ―lïŋ―r */
            letter-spacing: 2px; /* Harflerin arasïŋ―nïŋ― aïŋ―arak premium gïŋ―rïŋ―nïŋ―m katar */
            color: #fff; /* Rozet iïŋ―i yazïŋ― rengi beyaz */
            background: var(--gazi-gold-premium); /* Deïŋ―iïŋ―kendeki altïŋ―n rengini zemin yapar */
            border-radius: 50px; /* Rozetin uïŋ―larïŋ―nïŋ― tam yuvarlak (hap ïŋ―eklinde) yapar */
            padding: 6px 18px; /* Rozetin iïŋ―i boïŋ―luklarïŋ― */
        }

        /* Yazïŋ― Renklendirmeleri */
        .text-navy {
            color: var(--gazi-navy);
        }
        /* Koyu lacivert atamasïŋ― */
        .text-navy-light {
            color: var(--gazi-navy-light);
            text-decoration: none;
        }
        /* Aïŋ―ïŋ―k lacivert ve alt ïŋ―izgisi olmayan link */
        .fw-800 {
            font-weight: 800;
        }
        /* Yazïŋ―yïŋ― ekstra kalïŋ―nlaïŋ―tïŋ―rïŋ―r */

        /* Inputlarïŋ―n ïŋ―zerindeki Baïŋ―lïŋ―klar (KULLANICI ïŋ―SMïŋ― vs.) */
        .premium-label-navy {
            font-size: 11px;
            font-weight: 800;
            color: var(--gazi-navy-light);
            margin-bottom: 8px;
            display: block; /* Etiketin altïŋ―na inmesini (block) saïŋ―lar */
            letter-spacing: 1.5px; /* Harf aralïŋ―ïŋ―ïŋ― */
        }

        /* Inputlar (Metin Kutularïŋ―) ïŋ―ïŋ―in Taïŋ―ïŋ―yïŋ―cïŋ― */
        .field-wrapper-white {
            position: relative; /* ïŋ―ïŋ―indeki ikonun (absolute) konumlanabilmesi iïŋ―in referans noktasïŋ― olur */
            display: flex;
            align-items: center;
        }

            /* Metin Kutularïŋ―nïŋ―n ïŋ―ïŋ―indeki ïŋ―konlar */
            .field-wrapper-white i {
                position: absolute;
                left: 18px; /* ïŋ―konu kutunun en soluna yaslar */
                font-size: 1.1rem;
                opacity: 0.8; /* ïŋ―kon boyutu ve %80 saydamlïŋ―k */
            }

            /* Metin Kutularïŋ― (Input'larïŋ―n kendisi) */
            .field-wrapper-white input {
                width: 100%;
                height: 58px; /* Kutunun geniïŋ―liïŋ―i ve yïŋ―ksekliïŋ―i */
                background: #f8fafc; /* ïŋ―ïŋ―i hafif aïŋ―ïŋ―k gri */
                border: 1px solid #e2e8f0; /* ïŋ―ok ince gri dïŋ―ïŋ― ïŋ―izgi (border) */
                border-radius: 15px; /* Kïŋ―ïŋ―eleri yuvarlatïŋ―lmïŋ―ïŋ― kutu */
                padding: 0 20px 0 55px; /* Soldan 55px boïŋ―luk bïŋ―rakïŋ―r, ïŋ―ïŋ―nkïŋ― orada ikon duruyor. Yazïŋ― ikonun ïŋ―stïŋ―ne binmez */
                color: var(--gazi-navy);
                font-weight: 600; /* Girilen yazïŋ―nïŋ―n rengi ve kalïŋ―nlïŋ―ïŋ―ïŋ― */
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); /* Focus efekti iïŋ―in yumuïŋ―ak geïŋ―iïŋ― animasyonu sïŋ―resi */
            }

                /* Kullanïŋ―cïŋ― Input'a Tïŋ―kladïŋ―ïŋ―ïŋ―nda (Yazïŋ― Yazarken) Olanlar */
                .field-wrapper-white input:focus {
                    background: #ffffff; /* Kutunun iïŋ―i tam beyaz olur */
                    border-color: var(--gazi-gold-premium); /* Dïŋ―ïŋ― ïŋ―izgisi altïŋ―n rengi olur */
                    box-shadow: 0 0 15px var(--soft-gold); /* Kutunun etrafïŋ―na altïŋ―n rengi bir parlama (glow) verir */
                    outline: none; /* Tarayïŋ―cïŋ―nïŋ―n varsayïŋ―lan mavi ïŋ―izgisini yok eder */
                }

        /* Giriïŋ― Yap Butonu */
        .btn-ebys-action-gold {
            width: 100%;
            height: 60px;
            /* Arka plana linear-gradient (iki renkli geïŋ―iïŋ―) verir */
            background: linear-gradient(135deg, var(--btn-gold-gr-1) 0%, var(--btn-gold-gr-2) 100%);
            border: none;
            border-radius: 15px;
            color: var(--gazi-navy);
            font-weight: 800; /* Buton yazïŋ―sïŋ― lacivert ve kalïŋ―n */
            display: flex;
            align-items: center;
            justify-content: space-between; /* Yazïŋ― sola, ikon saïŋ―a yaslanïŋ―r */
            padding: 0 25px;
            transition: all 0.5s ease; /* Hover(ïŋ―zerine gelme) efekti sïŋ―resi */
            letter-spacing: 1px;
        }

            /* Farenin ïŋ―mleci Butonun ïŋ―zerine Geldiïŋ―inde (Hover) */
            .btn-ebys-action-gold:hover {
                transform: translateY(-3px); /* Butonu hafifïŋ―e 3 piksel yukarïŋ― kaldïŋ―rïŋ―r (Tïŋ―klanma hissi verir) */
                /* Renk geïŋ―iïŋ―ini tersine ïŋ―evirip biraz daha aïŋ―ïŋ―k hale getirir */
                background: linear-gradient(135deg, #e0bf81 0%, #c5a059 100%);
                color: #fff; /* ïŋ―stïŋ―ne gelince yazïŋ― lacivertten beyaza dïŋ―ner */
                box-shadow: 0 15px 30px var(--soft-gold); /* Altïŋ―ndaki gïŋ―lgeyi/parlamayïŋ― bïŋ―yïŋ―tïŋ―r */
            }

        /* Linklere Tïŋ―klanma/Gelinme Efekti */
        .forgot-pass-link a:hover {
            color: var(--gazi-gold-premium);
        }
        /* "Parola iïŋ―lemleri" linkinin ïŋ―stïŋ―ne gelince sararmasïŋ― */

        /* En Alttaki Footer Linkleri (Kullanïŋ―m Kïŋ―lavuzu vs.) */
        .footer-links-modern {
            text-align: center;
        }
            /* Linkleri ortalar */
            .footer-links-modern a {
                color: var(--gazi-navy-light);
                text-decoration: none; /* Alt ïŋ―izgiyi kaldïŋ―rïŋ―r */
                font-size: 12px;
                font-weight: 700;
                transition: 0.3s;
            }

                .footer-links-modern a:hover {
                    color: var(--gazi-gold-premium);
                }

        .dot-sep-navy {
            color: #cbd5e1;
            margin: 0 10px;
        }
        /* Linkler arasïŋ―ndaki noktalarïŋ―n rengi ve boïŋ―luïŋ―u */

        /* MOBïŋ―L UYUM (Responsive Tasarïŋ―m) */
        /* Ekran geniïŋ―liïŋ―i 576px'den (telefon ekranlarïŋ―) kïŋ―ïŋ―ïŋ―kse aïŋ―aïŋ―ïŋ―daki kodlar devreye girer */
        @@media (max-width: 576px) {
            .auth-card-white {
                padding: 40px 25px; /* Telefon ekranïŋ―nda iïŋ― boïŋ―luklarïŋ― daraltarak kartïŋ―n ekrana sïŋ―ïŋ―masïŋ―nïŋ― saïŋ―lar */
                border-radius: 30px; /* Ovaliïŋ―i biraz azaltïŋ―r */
