@* RAZOR BLOĐU: Sunucu tarafýnda (C#) çalýţacak kodlar burada baţlar. *@
@{
    @* Tarayýcýnýn üst sekmesinde yazacak olan baţlýđý belirler. Arama motorlarý ve kullanýcýlar için önemlidir. *@
    ViewData["Title"] = "Gazi Sađlýk | Kalite Yönetimi";
}

<!-- SAYFA YAPISI BAŢLANGICI -->
<!-- 'quality-page-viewport': Tüm içeriđi kapsayan ana dýţ div. Sayfa ortalamasý ve genel yapý burada kurulur. -->
<div class="quality-page-viewport">

    <!-- ARKA PLAN EFEKTLERÝ -->
    <!-- 'bg-visuals': Sayfanýn arkasýndaki bulanýk renkli lekeleri (blob) tutan katman. -->
    <div class="bg-visuals">
        <!-- Sađ üst taraftaki mavi leke efekti -->
        <div class="blob blob-1"></div>
        <!-- Sol alt taraftaki lacivert leke efekti -->
        <div class="blob blob-2"></div>
    </div>

    <!-- MERKEZÝ ÝÇERÝK ALANI -->
    <!-- 'container': Ýçeriđi ekranýn ortasýnda tutar ve kenarlardan boţluk býrakýr. 
         'position-relative' ve 'style="z-index: 2;"': Ýçeriđin arka plan efektlerinin (lekelerin) üstünde kalmasýný sađlar. -->
    <div class="container py-5 position-relative" style="z-index: 2;">

        <!-- BAŢLIK BÖLÜMÜ -->
        <!-- 'animate__animated animate__fadeIn': Sayfa açýldýđýnda bu bölümün yumuţakça belirmesini sađlayan animasyon. -->
        <div class="header-section text-center mb-5 animate__animated animate__fadeIn">

            <!-- ÝKON ALANI -->
            <!-- 'quality-icon-circle': Baţlýđýn üzerindeki ikonun içinde durduđu yuvarlak. -->
            <div class="quality-icon-circle mx-auto mb-3">
                <!-- 'fa-award': FontAwesome ödül ikonu. 'fa-2x': Ýkonu büyütme. 'text-primary': Mavi renk. -->
                <i class="fas fa-award fa-2x text-primary"></i>
            </div>

            <!-- SAYFA BAŢLIĐI -->
            <!-- 'h1': Sayfanýn ana baţlýđý. 'text-navy': Lacivert renk. 'fw-900': Çok kalýn font. -->
            <h1 class="fw-900 text-navy display-5 mb-2">Kalite Yönetimi</h1>

            <!-- ALT BAŢLIK / SLOGAN -->
            <!-- 'text-muted': Gri renkli metin. -->
            <p class="text-muted fw-bold">Sürekli Ýyileţtirme ve Mükemmeliyet Odaklý Hizmet Anlayýţý</p>

            <!-- GÜNCELLEME BÝLGÝSÝ -->
            <div class="mt-2">
                <!-- 'badge': Rozet görünümü. 'rounded-pill': Hap ţeklinde kenarlar. -->
                <span class="badge rounded-pill bg-white text-muted border shadow-sm px-3 py-2" style="font-size: 0.75rem;">
                    <i class="far fa-clock me-1"></i> Son Güncelleme: 13.08.2025
                </span>
            </div>
        </div>

        <!-- MENÜ BUTONLARI (KARTLAR) -->
        <!-- 'row': Kartlarýn dizileceđi satýr yapýsý. 
             'justify-content-center': Kartlarý ortalar. 
             'animate__fadeInUp': Kartlarýn aţađýdan yukarý dođru kayarak gelme animasyonu. -->
        <div class="row g-3 justify-content-center animate__animated animate__fadeInUp">

            @* C# DÝZÝSÝ (VERÝ KAYNAĐI):
               Sayfadaki 14 butonu tek tek HTML ile yazmak yerine, C# tarafýnda bir dizi (array) tanýmlýyoruz.
               Bu yöntem kod tekrarýný önler (DRY - Don't Repeat Yourself) ve yönetimi kolaylaţtýrýr. *@
            @{
                var kaliteMaddeleri = new[] {
                        new { Icon = "fa-sitemap", Title = "Organizasyon Ţemasý", Color = "blue" },
                        new { Icon = "fa-route", Title = "Kalite Yolculuđu", Color = "purple" },
                        new { Icon = "fa-cogs", Title = "Kalite Yönetim Sistemi", Color = "orange" },
                        new { Icon = "fa-user-check", Title = "Görev, Yetki ve Sorumluluklar", Color = "green" },
                        new { Icon = "fa-users-cog", Title = "Kalite Ekibi", Color = "blue" },
                        new { Icon = "fa-external-link-alt", Title = "Faydalý Bađlantýlar ve Yayýnlar", Color = "purple" },
                        new { Icon = "fa-tasks", Title = "Faaliyetler", Color = "orange" },
                        new { Icon = "fa-users", Title = "Kalite Komiteleri", Color = "green" },
                        new { Icon = "fa-project-diagram", Title = "Akýţ Ţemasý", Color = "blue" },
                        new { Icon = "fa-envelope-open-text", Title = "Ýletiţim", Color = "purple" },
                        new { Icon = "fa-clipboard-list", Title = "Görev Tanýmlarý", Color = "orange" },
                        new { Icon = "fa-user-tie", Title = "Kalite Komisyonu", Color = "green" },
                        new { Icon = "fa-hand-holding-heart", Title = "Toplumsal Katký", Color = "blue" },
                        new { Icon = "fa-file-medical-alt", Title = "Raporlar", Color = "purple" }
                        };
            }

            @* DÖNGÜ (FOREACH):
               Yukarýda tanýmlanan 'kaliteMaddeleri' dizisindeki her bir eleman için aţađýdaki HTML blođunu oluţturur.
               Böylece her kart için tekrar kod yazmaya gerek kalmaz. *@
            @foreach (var madde in kaliteMaddeleri)
            {
                <!-- SÜTUN AYARLARI (RESPONSIVE) -->
                <!-- col-xl-3: Geniţ masaüstünde yan yana 4 tane.
                     col-lg-4: Laptopta yan yana 3 tane.
                     col-md-6: Tablette yan yana 2 tane.
                     col-sm-12: Telefonda alt alta tek sütun. -->
                <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12">

                    <!-- KART LÝNKÝ -->
                    <!-- 'quality-link-card': Kartýn tasarýmýný belirleyen özel CSS sýnýfý. -->
                    <a href="#" class="quality-link-card h-100 shadow-sm">

                        <!-- ÝKON KUTUSU -->
                        <!-- @madde.Color: Diziden gelen renk verisini (blue, purple vb.) buraya class olarak ekler. -->
                        <div class="card-icon @madde.Color">
                            <!-- @madde.Icon: Diziden gelen ikon adýný (fa-sitemap vb.) buraya ekler. -->
                            <i class="fas @madde.Icon"></i>
                        </div>

                        <!-- KART BÝLGÝ ALANI (BAŢLIK ve OK) -->
                        <div class="card-info">
                            <!-- @madde.Title: Diziden gelen baţlýk metnini yazar. -->
                            <span class="card-title">@madde.Title</span>
                            <!-- Sađdaki küçük ok ikonu -->
                            <i class="fas fa-chevron-right arrow-icon"></i>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@* ================= CSS BÖLÜMÜ (ÖZEL TASARIM KODLARI) ================= *@
@section Styles {
    <!-- Animasyon kütüphanesi (Animate.css) çađrýlýyor. -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        /* CSS DEĐÝŢKENLERÝ (ROOT):
           Renklerin tek bir yerden yönetilmesini sađlar. Temayý deđiţtirmek kolaylaţýr. */
        :root {
            --navy: #0f172a; /* Koyu lacivert (Metinler için) */
            --primary: #2563eb; /* Marka mavisi */
            --bg-gray: #f4f7fa; /* Sayfanýn arka plan gri/mavi rengi */
        }

        /* SAYFA GENELÝ */
        body, html {
            margin: 0;
            padding: 0; /* Sayfa kenarlarýndaki beyaz boţluklarý sýfýrlar */
            background-color: var(--bg-gray); /* Arka plan rengini atar */
            font-family: 'Plus Jakarta Sans', sans-serif; /* Okunabilir, modern font */
            min-height: 100vh; /* Sayfanýn en az ekran yüksekliđi kadar olmasýný sađlar */
        }

        /* ANA KAPSAYICI (VIEWPORT) */
        .quality-page-viewport {
            min-height: 100vh; /* Tam ekran yüksekliđi */
            display: flex;
            align-items: center; /* Dikey ortalama */
            justify-content: center; /* Yatay ortalama */
            position: relative; /* Bloblarýn (lekelerin) buna göre konumlanmasýný sađlar */
            overflow-x: hidden; /* Taţmalarý gizler */
        }

        /* ARKA PLAN LEKELERÝ (BLOB) */
        .bg-visuals .blob {
            position: fixed; /* Sayfa kaydýrýlsa bile ekrandaki yeri sabit kalýr */
            width: 500px;
            height: 500px; /* Lekelerin boyutlarý */
            filter: blur(100px); /* 100 piksel bulanýklaţtýrarak bulut görünümü verir */
            z-index: 1; /* Diđer içeriklerin arkasýnda kalmasýný sađlar */
            opacity: 0.5; /* Yarý saydam */
            border-radius: 50%; /* Tam yuvarlak */
        }

        /* 1. Lekenin Konumu ve Rengi (Mavi - Sađ Üst) */
        .blob-1 {
            top: -100px;
            right: -50px;
            background: rgba(37, 99, 235, 0.08);
        }

        /* 2. Lekenin Konumu ve Rengi (Lacivert - Sol Alt) */
        .blob-2 {
            bottom: -100px;
            left: -50px;
            background: rgba(15, 23, 42, 0.04);
        }

        /* BAŢLIKTAKÝ ÝKON YUVASI (Beyaz Kutu) */
        .quality-icon-circle {
            width: 80px;
            height: 80px;
            background: #fff;
            border-radius: 25px; /* Köţeleri yuvarlatýr */
            display: flex;
            align-items: center;
            justify-content: center; /* Ýkonu ortalar */
            box-shadow: 0 10px 25px rgba(0,0,0,0.05); /* Altýna hafif gölge verir */
        }

        /* LÝNK KARTLARI TASARIMI */
        .quality-link-card {
            background: #fff; /* Beyaz kart */
            border-radius: 20px;
            padding: 20px;
            display: flex;
            align-items: center; /* Ýkonu ve yazýyý dikeyde ortalar */
            text-decoration: none; /* Link alt çizgisini kaldýrýr */
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); /* Hover animasyonunun yaylanma efekti */
            border: 1px solid rgba(255,255,255,0.8); /* Ýnce beyaz çerçeve */
        }

            /* HAREKET EFEKTÝ (HOVER): Mouse üzerine gelince çalýţýr */
            .quality-link-card:hover {
                transform: translateY(-5px); /* Kartý 5 piksel yukarý kaldýrýr */
                background: #fff;
                box-shadow: 0 15px 30px rgba(0,0,0,0.08) !important; /* Gölgeyi büyütür */
                border-color: var(--primary); /* Kenar rengini mavi yapar */
            }

                /* OK ÝKONU HAREKETÝ (Kart üzerine gelince) */
                .quality-link-card:hover .arrow-icon {
                    transform: translateX(5px); /* Oku sađa dođru kaydýrýr */
                    color: var(--primary); /* Ok rengini mavi yapar */
                }

        /* ÝKON KUTUCUKLARI (Kart içindeki renkli kareler) */
        .card-icon {
            width: 45px;
            height: 45px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            margin-right: 15px; /* Yazý ile ikon arasýna boţluk koyar */
            flex-shrink: 0; /* Alan daralsa bile ikonun ezilmesini engeller */
        }

            /* RENK TEMALARI (Döngüden gelen renklere göre) */
            .card-icon.blue {
                background: #eff6ff;
                color: #2563eb;
            }
            /* Mavi Tema */
            .card-icon.purple {
                background: #faf5ff;
                color: #9333ea;
            }
            /* Mor Tema */
            .card-icon.orange {
                background: #fff7ed;
                color: #ea580c;
            }
            /* Turuncu Tema */
            .card-icon.green {
                background: #f0fdf4;
                color: #16a34a;
            }
        /* Yeţil Tema */

        /* KART ÝÇÝ YERLEŢÝM */
        .card-info {
            display: flex;
            justify-content: space-between; /* Yazýyý sola, oku sađa yaslar */
            align-items: center;
            width: 100%;
        }

        /* KART BAŢLIĐI */
        .card-title {
            color: var(--navy);
            font-weight: 700;
            font-size: 0.95rem;
            line-height: 1.2;
        }

        /* YÖNLENDÝRME OKU */
        .arrow-icon {
            color: #cbd5e1; /* Pasif gri renk */
            font-size: 0.8rem;
            transition: 0.3s;
        }

        /* YARDIMCI SINIFLAR */
        .fw-900 {
            font-weight: 900;
        }

        .text-navy {
            color: var(--navy);
        }

        /* MOBÝL UYUMLULUK (RESPONSIVE) */
        /* Ekran geniţliđi 768px ve altýndaysa (Tablet ve Telefonlar) */
        @@media (max-width: 768px) {
            .quality-page-viewport

        {
            align-items: flex-start; /* Ortalamayý iptal edip üstten baţlatýr */
            padding-top: 40px; /* Üstten boţluk býrakýr */
        }

        .header-section h1 {
            font-size: 2rem; /* Baţlýk fontunu küçültür */
        }

        }
    </style>
}