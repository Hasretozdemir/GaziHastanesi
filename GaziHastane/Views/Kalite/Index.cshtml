@{
    Layout = null;
    ViewData["Title"] = "Gazi Sađlýk | Kalite Yönetimi";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        body {
            background-color: #f0f4f8; /* Sitenin ana arka plan rengi */
            font-family: 'Plus Jakarta Sans', sans-serif;
            overflow-x: hidden;
        }

        .color-navy {
            color: #0f172a;
        }

        /* Ortalanmýţ Beyaz Portal Kutusu */
        .portal-master-card {
            background: rgba(255, 255, 255, 0.98);
            border: 1px solid #e2e8f0;
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.04);
            max-width: 1100px;
            width: 100%;
            margin: 0 auto;
            position: relative;
            z-index: 2;
        }

        /* Arka Plan Lekeleri (Blob Efektleri) */
        .bg-visuals {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            z-index: 0;
            pointer-events: none;
            overflow: hidden;
        }

        .blob {
            position: absolute;
            width: 500px;
            height: 500px;
            filter: blur(100px);
            opacity: 0.5;
            border-radius: 50%;
        }

        .blob-1 {
            top: -100px;
            right: -50px;
            background: rgba(37, 99, 235, 0.08); /* Mavi leke */
        }

        .blob-2 {
            bottom: -100px;
            left: -50px;
            background: rgba(15, 23, 42, 0.04); /* Lacivert leke */
        }

        /* Kart Tasarýmlarý */
        .committee-action-card {
            background: white;
            border: 1px solid #f1f5f9;
            border-radius: 16px;
            padding: 16px;
            display: flex;
            align-items: center;
            gap: 15px;
            text-decoration: none !important;
            transition: all 0.3s ease;
        }

            .committee-action-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 12px 25px rgba(0,0,0,0.05);
                border-color: #cbd5e1;
            }

                .committee-action-card:hover .arrow-icon {
                    transform: translateX(4px);
                    color: #2563eb !important;
                }

        .card-icon-wrapper {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            flex-shrink: 0;
        }

        .card-info h5 {
            font-size: 0.95rem;
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 0;
        }

        .arrow-icon {
            transition: transform 0.3s ease, color 0.3s ease;
        }

        /* Ýkon Renk Paletleri */
        .bg-soft-blue {
            background: #eff6ff;
            color: #3b82f6;
        }

        .bg-soft-purple {
            background: #f5f3ff;
            color: #8b5cf6;
        }

        .bg-soft-orange {
            background: #fff7ed;
            color: #ea580c;
        }

        .bg-soft-green {
            background: #f0fdf4;
            color: #16a34a;
        }
    </style>
</head>

<body class="pt-20 pb-10 min-vh-100 d-flex flex-column align-items-center justify-content-center">

    <div class="bg-visuals">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
    </div>

    <header class="fixed top-0 left-0 right-0 bg-white/95 backdrop-blur-md shadow-sm border-b border-slate-200 z-[100]">
        <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
            <a href="/Home/Index" class="flex items-center gap-3 text-decoration-none">
                <img src="~/assets/gazilogo.jpg" alt="Gazi Logo" class="h-9 w-auto rounded-lg border border-slate-100 shadow-sm" />
                <div class="leading-none">
                    <p class="text-sm font-extrabold tracking-tight uppercase text-slate-900 mb-0">Gazi Üniversitesi</p>
                    <p class="text-[10px] font-bold text-blue-600 tracking-widest uppercase mb-0 mt-0.5">Hastanesi</p>
                </div>
            </a>
            <div class="flex items-center gap-2 sm:gap-3">
                <a href="tel:4440911" class="flex items-center gap-2 border border-red-200 text-red-600 text-[10px] font-black px-3 py-2 rounded-xl hover:bg-red-50 transition text-decoration-none">
                    <i class="fa-solid fa-phone animate-pulse"></i> <span class="hidden sm:inline">ARA: 444 0 911</span>
                </a>
                <a href="/Randevu/Giris" class="bg-blue-600 text-white px-3 sm:px-4 py-2 rounded-xl text-[10px] font-black tracking-widest hover:bg-blue-700 transition shadow-md shadow-blue-200 text-decoration-none">RANDEVU AL</a>
                <a href="/Home/Index" title="Ana Sayfaya Dön" class="w-9 h-9 flex items-center justify-center bg-slate-100 text-slate-600 rounded-xl hover:bg-slate-200 transition text-decoration-none">
                    <i class="fa-solid fa-house text-sm"></i>
                </a>
            </div>
        </div>
    </header>

    <div class="container px-3 mt-4">
        <div class="portal-master-card animate__animated animate__fadeInUp">

            <div class="text-center mb-5 pb-4 border-bottom">
                <div class="d-inline-flex align-items-center justify-content-center bg-soft-blue rounded-circle mb-3" style="width:64px; height:64px; font-size:1.75rem;">
                    <i class="fas fa-award"></i>
                </div>
                <h2 class="fw-900 color-navy mb-1" style="font-size: 1.8rem;">Kalite Yönetimi</h2>
                <p class="text-muted fw-bold mb-3">Sürekli Ýyileţtirme ve Mükemmeliyet Odaklý Hizmet Anlayýţý</p>

                <span class="badge rounded-pill bg-light text-muted border shadow-sm px-3 py-2" style="font-size: 0.75rem;">
                    <i class="far fa-clock me-1"></i> Son Güncelleme: 13.08.2025
                </span>
            </div>

            <div class="row g-3 justify-content-center">

                @* C# DÝZÝSÝ (VERÝ KAYNAĐI) 
                   Renk sýnýflarý yeni CSS yapýsýna uyumlu hale getirildi (bg-soft-...) *@
                @{
                    var kaliteMaddeleri = new[] {
                                new { Icon = "fa-sitemap", Title = "Organizasyon Ţemasý", ColorClass = "bg-soft-blue" },
                                new { Icon = "fa-route", Title = "Kalite Yolculuđu", ColorClass = "bg-soft-purple" },
                                new { Icon = "fa-cogs", Title = "Kalite Yönetim Sistemi", ColorClass = "bg-soft-orange" },
                                new { Icon = "fa-user-check", Title = "Görev, Yetki ve Sorumluluklar", ColorClass = "bg-soft-green" },
                                new { Icon = "fa-users-cog", Title = "Kalite Ekibi", ColorClass = "bg-soft-blue" },
                                new { Icon = "fa-external-link-alt", Title = "Faydalý Bađlantýlar ve Yayýnlar", ColorClass = "bg-soft-purple" },
                                new { Icon = "fa-tasks", Title = "Faaliyetler", ColorClass = "bg-soft-orange" },
                                new { Icon = "fa-users", Title = "Kalite Komiteleri", ColorClass = "bg-soft-green" },
                                new { Icon = "fa-project-diagram", Title = "Akýţ Ţemasý", ColorClass = "bg-soft-blue" },
                                new { Icon = "fa-envelope-open-text", Title = "Ýletiţim", ColorClass = "bg-soft-purple" },
                                new { Icon = "fa-clipboard-list", Title = "Görev Tanýmlarý", ColorClass = "bg-soft-orange" },
                                new { Icon = "fa-user-tie", Title = "Kalite Komisyonu", ColorClass = "bg-soft-green" },
                                new { Icon = "fa-hand-holding-heart", Title = "Toplumsal Katký", ColorClass = "bg-soft-blue" },
                                new { Icon = "fa-file-medical-alt", Title = "Raporlar", ColorClass = "bg-soft-purple" }
                                };
                }

                @foreach (var madde in kaliteMaddeleri)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <a href="#" class="committee-action-card h-100">
                            <div class="card-icon-wrapper @madde.ColorClass">
                                <i class="fas @madde.Icon"></i>
                            </div>

                            <div class="card-info d-flex justify-content-between align-items-center w-100">
                                <h5 class="text-truncate pe-2">@madde.Title</h5>
                                <i class="fas fa-chevron-right text-muted opacity-50 arrow-icon"></i>
                            </div>
                        </a>
                    </div>
                }

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>