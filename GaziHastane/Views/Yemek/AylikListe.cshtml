@* RAZOR KOD BLOĞU: Sunucu tarafında (C#) çalışan kodlar. *@
@{
    // Sayfanın başlığını belirtiyoruz. Tarayıcı sekmesinde "Mart 2026 | Aylık Yemek Listesi" olarak görünecek.
    ViewData["Title"] = "Mart 2026 | Aylık Yemek Listesi";
}

<!-- Ana Kapsayıcı: Tüm aylık yemek listesi sayfasını saran yapı. -->
<div class="monthly-page-viewport">
    <!-- Arka plan görsel efektleri (bulanık daireler/blob'lar). -->
    <div class="bg-visuals">
        <!-- Birinci bulanık daire (Mavi tonlarında) -->
        <div class="blob blob-1"></div>
        <!-- İkinci bulanık daire (Daha koyu tonlarda) -->
        <div class="blob blob-2"></div>
    </div>

    <!-- İçerik Kapsayıcısı: Ortalanmış ve dikey dolgusu (padding) olan alan. -->
    <div class="container py-5 position-relative" style="z-index: 2;">

        <!-- Üst Başlık Bölümü: Geri dön butonu ve sayfa başlığını içerir. -->
        <div class="page-header-wrapper mb-5 animate__animated animate__fadeIn">
            <!-- Geri Dön Butonu -->
            <div class="d-flex align-items-center mb-3">
                <!-- Tarayıcının geçmişine (bir önceki sayfaya) döndüren javascript bağlantısı. -->
                <a href="javascript:history.back()" class="btn-back-modern">
                    <i class="fas fa-chevron-left"></i>
                    <span>GERİ DÖN</span>
                </a>
            </div>
            
            <!-- Sayfa Başlığı ve Alt Metin -->
            <div class="header-text">
                <h2 class="fw-900 text-navy m-0">MART 2026 <span class="text-primary">YEMEK MENÜSÜ</span></h2>
                <p class="text-muted m-0 fw-600">Gazi Üniversitesi Hastanesi Aylık Çizelgesi</p>
            </div>
        </div>

        <!-- Aylık Listeleme Grid Yapısı: Aşağıdan yukarı animasyonlu giriş. -->
        <div class="row g-4 justify-content-center animate__animated animate__fadeInUp">
            
            @* Döngü Örneği: Mart ayının 3. gününden 6. gününe kadar olan verileri basar. 
               Gerçek projede burası veritabanından gelen bir liste üzerinde dönecektir. *@
            @for (int day = 3; day <= 6; day++)
            {
                <div class="col-12 col-xl-11">
                    @* Tekil Gün Kartı: Her bir günü temsil eden yatay kart yapısı. *@
                    <div class="monthly-row-card shadow-sm">
                        
                        <!-- Sol Taraf: Tarih ve Gün Bilgisi (Koyu arka plan) -->
                        <div class="row-date-side">
                            <!-- Günün rakamı (Örn: 03, 04) -->
                            <span class="day-number">@day.ToString("00")</span>
                            <!-- Ay İsmi -->
                            <span class="month-name">MART</span>
                            <!-- Ramazan Günü Göstergesi (Hesaplamalı örnek) -->
                            <div class="ramazan-tag">RAMAZAN @(day + 10)</div>
                        </div>

                        <!-- Orta Kısım: Yemek İçerikleri (Kahvaltı, Öğle, Akşam) -->
                        <div class="row-content-side">
                            <!-- Kahvaltı Bölümü -->
                            <div class="meal-group">
                                <label><i class="fas fa-coffee text-orange"></i> KAHVALTI</label>
                                <p>Çay, Yumurta, Bal, Tereyağ, Siyah Zeytin</p>
                            </div>

                            <!-- Öğle Yemeği Bölümü -->
                            <div class="meal-group middle">
                                <label><i class="fas fa-sun text-green"></i> ÖĞLE YEMEĞİ</label>
                                <p>Kıymalı Ispanak (Yoğurt), Soslu Makarna, Güllaç</p>
                            </div>

                            <!-- Akşam Yemeği Bölümü -->
                            <div class="meal-group">
                                <label><i class="fas fa-moon text-blue"></i> AKŞAM YEMEĞİ</label>
                                <p>Et Kavurma (Pirinç Pilavı), Hanımağa Çorba, Portakal</p>
                            </div>
                        </div>

                        <!-- Sağ Taraf: Ek Bilgiler (Kalori vb.) - Sadece masaüstünde görünür (d-none d-lg-flex) -->
                        <div class="row-info-side d-none d-lg-flex">
                            <div class="kcal-pill">2100 kcal</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <!-- Sayfaya Özel CSS Stilleri -->
    <style>
        /* CSS Değişkenleri */
        :root {
            --navy: #0f172a; /* Temel lacivert renk */
            --primary: #2563eb; /* Ana mavi renk */
            --bg-page: #f8fafc; /* Sayfa arka plan rengi */
        }

        /* Ekranı ortalayan ve dikey hizalayan ana kısıtlayıcı */
        .monthly-page-viewport {
            min-height: 100vh; /* Ekran boyu kadar yükseklik */
            background: var(--bg-page);
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center; /* Yatayda tam merkezleme */
        }

        /* Başlık Alanı Düzeni: Çizgi ile ayrılmış alt kısım */
        .page-header-wrapper {
            width: 100%;
            border-bottom: 2px solid rgba(0,0,0,0.03); /* Çok hafif alt çizgi */
            padding-bottom: 20px;
        }

        /* Geri Dön Butonu Tasarımı */
        .btn-back-modern {
            background: white;
            color: var(--navy);
            padding: 8px 20px;
            border-radius: 12px;
            text-decoration: none; /* Alt çizgiyi kaldır */
            font-weight: 800; /* Kalın yazı */
            font-size: 0.85rem;
            display: inline-flex;
            align-items: center;
            gap: 10px; /* İkon ve yazı arası boşluk */
            box-shadow: 0 4px 10px rgba(0,0,0,0.05); /* Hafif gölge */
            transition: all 0.3s;
            border: 1px solid #e2e8f0;
        }

            /* Buton Hover Efekti */
            .btn-back-modern:hover {
                background: var(--navy); /* Zemin rengi değişimi */
                color: white; /* Yazı rengi değişimi */
                transform: translateX(-5px); /* Hafif sola kayma */
            }

        /* Aylık Liste Kartı Tasarımı (Glassmorphism) */
        .monthly-row-card {
            background: rgba(255, 255, 255, 0.9); /* Yarı saydam beyaz */
            backdrop-filter: blur(10px); /* Arka planı bulanıklaştır */
            border-radius: 20px; /* Yuvarlak köşeler */
            display: flex; /* İçerikleri yan yana diz */
            overflow: hidden; /* Taşmayı engelle */
            border: 1px solid rgba(255,255,255,0.6);
            min-height: 120px;
        }

        /* Sol Taraf: Tarih Kutusu */
        .row-date-side {
            background: var(--navy); /* Koyu arka plan */
            color: white;
            padding: 20px;
            min-width: 130px; /* Sabit genişlik */
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        /* Gün Numarası (Büyük Font) */
        .day-number {
            font-size: 2.2rem;
            font-weight: 900;
            line-height: 1;
        }

        /* Ay İsmi */
        .month-name {
            font-size: 0.8rem;
            font-weight: 700;
            opacity: 0.7; /* Hafif saydamlık */
        }

        /* Yemek İçerik Alanı (Orta Kısım) */
        .row-content-side {
            flex-grow: 1; /* Kalan boşluğu doldur */
            padding: 20px 30px;
            display: grid;
            grid-template-columns: repeat(3, 1fr); /* 3 eşit kolona böl */
            align-items: center;
            gap: 15px; /* Kolonlar arası boşluk */
        }

        /* Yemek Grubu Başlığı (Kahvaltı, Öğle...) */
        .meal-group label {
            display: block;
            font-size: 0.7rem;
            font-weight: 800;
            color: #94a3b8;
            margin-bottom: 4px;
        }

        /* Yemek İçeriği Metni */
        .meal-group p {
            font-size: 0.95rem;
            font-weight: 700;
            color: var(--navy);
            margin: 0;
        }

        /* Sağ Taraf: Bilgi Kutusu */
        .row-info-side {
            padding: 20px;
            display: flex;
            align-items: center;
            border-left: 1px solid #f1f5f9; /* Sol kenar çizgisi */
        }

        /* Kalori Hapı (Pill Badge) */
        .kcal-pill {
            background: #f1f5f9;
            color: #64748b;
            padding: 6px 12px;
            border-radius: 50px;
            font-weight: 800;
            font-size: 0.8rem;
        }

        /* Arka Plan Görsel Efektleri (Blob'lar) */
        .bg-visuals .blob {
            position: fixed; /* Sayfa kaydığında sabit kalır */
            width: 500px;
            height: 500px;
            filter: blur(100px); /* Bulanıklık efekti */
            z-index: 1; /* İçeriğin arkasında */
        }

        /* Birinci Blob Konumu */
        .blob-1 {
            top: -100px;
            right: -50px;
            background: rgba(37, 99, 235, 0.08);
        }

        /* İkinci Blob Konumu */
        .blob-2 {
            bottom: -100px;
            left: -50px;
            background: rgba(15, 23, 42, 0.04);
        }

        /* MOBİL UYUMLULUK (Responsive Ayarlar) */
        /* Ekran genişliği 991px (Tablet/Mobil) altındaysa devreye girer */
        @@media (max-width: 991px) {
            
            /* Yemek içeriklerini tek sütuna düşür */
            .row-content-side {
                grid-template-columns: 1fr;
                padding: 20px;
            }

            /* Kartı dikey yerleşime çevir */
            .monthly-row-card {
                flex-direction: column;
            }

            /* Tarih kutusunu yatay yap ve genişlet */
            .row-date-side {
                flex-direction: row;
                min-width: 100%;
                gap: 15px;
                padding: 10px;
            }

            /* Gün numarasını küçült */
            .day-number {
                font-size: 1.5rem;
            }

            /* Bilgi kutusunun kenarlığını değiştir ve ortala */
            .row-info-side {
                border-left: none;
                border-top: 1px solid #f1f5f9;
                justify-content: center;
            }
        }
    </style>
}