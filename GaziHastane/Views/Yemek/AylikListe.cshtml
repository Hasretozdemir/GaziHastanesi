@model IEnumerable<GaziHastane.Models.YemekListesi>

@{
    ViewData["Title"] = "Mart 2026 | Aylık Yemek Listesi";

    // Verileri tarihe göre grupluyoruz ki her güne bir satır/kart basalım
    var gruplanmisListe = Model.GroupBy(x => x.Tarih.Date).OrderBy(g => g.Key);
}

<div class="monthly-page-viewport">
    <div class="bg-visuals">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
    </div>

    <div class="container py-5 position-relative" style="z-index: 2;">

        <div class="page-header-wrapper mb-5 animate__animated animate__fadeIn">
            <div class="d-flex align-items-center mb-3">
                <a href="javascript:history.back()" class="btn-back-modern">
                    <i class="fas fa-chevron-left"></i>
                    <span>GERİ DÖN</span>
                </a>
            </div>

            <div class="header-text">
                <h2 class="fw-900 text-navy m-0">MART 2026 <span class="text-primary">YEMEK MENÜSÜ</span></h2>
                <p class="text-muted m-0 fw-600">Gazi Üniversitesi Hastanesi Aylık Çizelgesi</p>
            </div>
        </div>

        <div class="row g-4 justify-content-center animate__animated animate__fadeInUp">

            @foreach (var gun in gruplanmisListe)
            {
                // O güne ait öğünleri değişkenlere atıyoruz
                var kahvalti = gun.FirstOrDefault(x => x.Ogun == 1);
                var ogle = gun.FirstOrDefault(x => x.Ogun == 2);
                var aksam = gun.FirstOrDefault(x => x.Ogun == 3);

                <div class="col-12 col-xl-11">
                    <div class="monthly-row-card shadow-sm">

                        <div class="row-date-side">
                            <span class="day-number">@gun.Key.Day.ToString("00")</span>
                            <span class="month-name">@gun.Key.ToString("MMMM").ToUpper()</span>
                            @* Hafta sonu ise belirtmek için ek bilgi eklenebilir *@
                            <small style="opacity:0.6; font-size:10px;">@gun.Key.ToString("dddd").ToUpper()</small>
                        </div>

                        <div class="row-content-side">
                            <div class="meal-group">
                                <label><i class="fas fa-coffee text-orange"></i> KAHVALTI</label>
                                <p>@(kahvalti != null ? $"{kahvalti.AnaYemek}, {kahvalti.YardimciYemek}" : "Kayıt Yok")</p>
                            </div>

                            <div class="meal-group middle">
                                <label><i class="fas fa-sun text-green"></i> ÖĞLE YEMEĞİ</label>
                                <p>@(ogle != null ? $"{ogle.Corba}, {ogle.AnaYemek}, {ogle.YardimciYemek}, {ogle.TatliMeyve}" : "Kayıt Yok")</p>
                            </div>

                            <div class="meal-group">
                                <label><i class="fas fa-moon text-blue"></i> AKŞAM YEMEĞİ</label>
                                <p>@(aksam != null ? $"{aksam.Corba}, {aksam.AnaYemek}, {aksam.YardimciYemek}, {aksam.TatliMeyve}" : "Kayıt Yok")</p>
                            </div>
                        </div>

                        <div class="row-info-side d-none d-lg-flex">
                            @{
                                var toplamKcal = gun.Sum(x => x.ToplamKalori ?? 0);
                            }
                            <div class="kcal-pill">@toplamKcal kcal</div>
                        </div>
                    </div>
                </div>
            }

            @if (!gruplanmisListe.Any())
            {
                <div class="alert alert-info text-center">Henüz bu aya ait yemek listesi girilmemiştir.</div>
            }
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* CSS kısmınız aynı kalabilir, yukarıdaki yapıya tam uyumludur */
        :root {
            --navy: #0f172a;
            --primary: #2563eb;
            --bg-page: #f8fafc;
        }

        .monthly-page-viewport {
            min-height: 100vh;
            background: var(--bg-page);
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .monthly-row-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            display: flex;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.6);
            min-height: 120px;
            margin-bottom: 10px;
        }

        .row-date-side {
            background: var(--navy);
            color: white;
            padding: 20px;
            min-width: 130px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        .day-number {
            font-size: 2.2rem;
            font-weight: 900;
            line-height: 1;
        }

        .month-name {
            font-size: 0.8rem;
            font-weight: 700;
            opacity: 0.7;
        }

        .row-content-side {
            flex-grow: 1;
            padding: 20px 30px;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            align-items: center;
            gap: 15px;
        }

        .meal-group label {
            display: block;
            font-size: 0.7rem;
            font-weight: 800;
            color: #94a3b8;
            margin-bottom: 4px;
        }

        .meal-group p {
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--navy);
            margin: 0;
            line-height: 1.4;
        }

        .row-info-side {
            padding: 20px;
            display: flex;
            align-items: center;
            border-left: 1px solid #f1f5f9;
        }

        .kcal-pill {
            background: #f1f5f9;
            color: #64748b;
            padding: 6px 12px;
            border-radius: 50px;
            font-weight: 800;
            font-size: 0.8rem;
            white-space: nowrap;
        }

        @@media (max-width: 991px) {
            .row-content-side {
                grid-template-columns: 1fr;
                padding: 20px;
            }

            .monthly-row-card {
                flex-direction: column;
            }

            .row-date-side {
                flex-direction: row;
                min-width: 100%;
                gap: 15px;
                padding: 10px;
            }

            .day-number {
                font-size: 1.5rem;
            }

            .row-info-side {
                border-left: none;
                border-top: 1px solid #f1f5f9;
                justify-content: center;
            }
        }
    </style>
}