ïŧŋ@* RAZOR KOD BLOïŋ―U: Sunucu tarafïŋ―nda (C#) ïŋ―alïŋ―ïŋ―an kodlar. *@
@{
    // Sayfanïŋ―n baïŋ―lïŋ―ïŋ―ïŋ―nïŋ― belirtiyoruz. Tarayïŋ―cïŋ― sekmesinde "Mart 2026 | Aylïŋ―k Yemek Listesi" olarak gïŋ―rïŋ―necek.
    ViewData["Title"] = "Mart 2026 | Aylïŋ―k Yemek Listesi";
}

<!-- Ana Kapsayïŋ―cïŋ―: Tïŋ―m aylïŋ―k yemek listesi sayfasïŋ―nïŋ― saran yapïŋ―. -->
<div class="monthly-page-viewport">
    <!-- Arka plan gïŋ―rsel efektleri (bulanïŋ―k daireler/blob'lar). -->
    <div class="bg-visuals">
        <!-- Birinci bulanïŋ―k daire (Mavi tonlarïŋ―nda) -->
        <div class="blob blob-1"></div>
        <!-- ïŋ―kinci bulanïŋ―k daire (Daha koyu tonlarda) -->
        <div class="blob blob-2"></div>
    </div>

    <!-- ïŋ―ïŋ―erik Kapsayïŋ―cïŋ―sïŋ―: Ortalanmïŋ―ïŋ― ve dikey dolgusu (padding) olan alan. -->
    <div class="container py-5 position-relative" style="z-index: 2;">

        <!-- ïŋ―st Baïŋ―lïŋ―k Bïŋ―lïŋ―mïŋ―: Geri dïŋ―n butonu ve sayfa baïŋ―lïŋ―ïŋ―ïŋ―nïŋ― iïŋ―erir. -->
        <div class="page-header-wrapper mb-5 animate__animated animate__fadeIn">
            <!-- Geri Dïŋ―n Butonu -->
            <div class="d-flex align-items-center mb-3">
                <!-- Tarayïŋ―cïŋ―nïŋ―n geïŋ―miïŋ―ine (bir ïŋ―nceki sayfaya) dïŋ―ndïŋ―ren javascript baïŋ―lantïŋ―sïŋ―. -->
                <a href="javascript:history.back()" class="btn-back-modern">
                    <i class="fas fa-chevron-left"></i>
                    <span>GERïŋ― Dïŋ―N</span>
                </a>
            </div>

            <!-- Sayfa Baïŋ―lïŋ―ïŋ―ïŋ― ve Alt Metin -->
            <div class="header-text">
                <h2 class="fw-900 text-navy m-0">MART 2026 <span class="text-primary">YEMEK MENïŋ―Sïŋ―</span></h2>
                <p class="text-muted m-0 fw-600">Gazi ïŋ―niversitesi Hastanesi Aylïŋ―k ïŋ―izelgesi</p>
            </div>
        </div>

        <!-- Aylïŋ―k Listeleme Grid Yapïŋ―sïŋ―: Aïŋ―aïŋ―ïŋ―dan yukarïŋ― animasyonlu giriïŋ―. -->
        <div class="row g-4 justify-content-center animate__animated animate__fadeInUp">

            @* Dïŋ―ngïŋ― ïŋ―rneïŋ―i: Mart ayïŋ―nïŋ―n 3. gïŋ―nïŋ―nden 6. gïŋ―nïŋ―ne kadar olan verileri basar. 
               Gerïŋ―ek projede burasïŋ― veritabanïŋ―ndan gelen bir liste ïŋ―zerinde dïŋ―necektir. *@
            @for (int day = 3; day <= 6; day++)
            {
                <div class="col-12 col-xl-11">
                    @* Tekil Gïŋ―n Kartïŋ―: Her bir gïŋ―nïŋ― temsil eden yatay kart yapïŋ―sïŋ―. *@
                    <div class="monthly-row-card shadow-sm">

                        <!-- Sol Taraf: Tarih ve Gïŋ―n Bilgisi (Koyu arka plan) -->
                        <div class="row-date-side">
                            <!-- Gïŋ―nïŋ―n rakamïŋ― (ïŋ―rn: 03, 04) -->
                            <span class="day-number">@day.ToString("00")</span>
                            <!-- Ay ïŋ―smi -->
                            <span class="month-name">MART</span>
                            <!-- Ramazan Gïŋ―nïŋ― Gïŋ―stergesi (Hesaplamalïŋ― ïŋ―rnek) -->
                            <div class="ramazan-tag">RAMAZAN @(day + 10)</div>
                        </div>

                        <!-- Orta Kïŋ―sïŋ―m: Yemek ïŋ―ïŋ―erikleri (Kahvaltïŋ―, ïŋ―ïŋ―le, Akïŋ―am) -->
                        <div class="row-content-side">
                            <!-- Kahvaltïŋ― Bïŋ―lïŋ―mïŋ― -->
                            <div class="meal-group">
                                <label><i class="fas fa-coffee text-orange"></i> KAHVALTI</label>
                                <p>ïŋ―ay, Yumurta, Bal, Tereyaïŋ―, Siyah Zeytin</p>
                            </div>

                            <!-- ïŋ―ïŋ―le Yemeïŋ―i Bïŋ―lïŋ―mïŋ― -->
                            <div class="meal-group middle">
                                <label><i class="fas fa-sun text-green"></i> ïŋ―ïŋ―LE YEMEïŋ―ïŋ―</label>
                                <p>Kïŋ―ymalïŋ― Ispanak (Yoïŋ―urt), Soslu Makarna, Gïŋ―llaïŋ―</p>
                            </div>

                            <!-- Akïŋ―am Yemeïŋ―i Bïŋ―lïŋ―mïŋ― -->
                            <div class="meal-group">
                                <label><i class="fas fa-moon text-blue"></i> AKïŋ―AM YEMEïŋ―ïŋ―</label>
                                <p>Et Kavurma (Pirinïŋ― Pilavïŋ―), Hanïŋ―maïŋ―a ïŋ―orba, Portakal</p>
                            </div>
                        </div>

                        <!-- Saïŋ― Taraf: Ek Bilgiler (Kalori vb.) - Sadece masaïŋ―stïŋ―nde gïŋ―rïŋ―nïŋ―r (d-none d-lg-flex) -->
                        <div class="row-info-side d-none d-lg-flex">
                            <div class="kcal-pill">2100 kcal</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <!-- Sayfaya ïŋ―zel CSS Stilleri -->
    <style>
        /* CSS Deïŋ―iïŋ―kenleri */
        :root {
            --navy: #0f172a; /* Temel lacivert renk */
            --primary: #2563eb; /* Ana mavi renk */
            --bg-page: #f8fafc; /* Sayfa arka plan rengi */
        }

        /* Ekranïŋ― ortalayan ve dikey hizalayan ana kïŋ―sïŋ―tlayïŋ―cïŋ― */
        .monthly-page-viewport {
            min-height: 100vh; /* Ekran boyu kadar yïŋ―kseklik */
            background: var(--bg-page);
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center; /* Yatayda tam merkezleme */
        }

        /* Baïŋ―lïŋ―k Alanïŋ― Dïŋ―zeni: ïŋ―izgi ile ayrïŋ―lmïŋ―ïŋ― alt kïŋ―sïŋ―m */
        .page-header-wrapper {
            width: 100%;
            border-bottom: 2px solid rgba(0,0,0,0.03); /* ïŋ―ok hafif alt ïŋ―izgi */
            padding-bottom: 20px;
        }

        /* Geri Dïŋ―n Butonu Tasarïŋ―mïŋ― */
        .btn-back-modern {
            background: white;
            color: var(--navy);
            padding: 8px 20px;
            border-radius: 12px;
            text-decoration: none; /* Alt ïŋ―izgiyi kaldïŋ―r */
            font-weight: 800; /* Kalïŋ―n yazïŋ― */
            font-size: 0.85rem;
            display: inline-flex;
            align-items: center;
            gap: 10px; /* ïŋ―kon ve yazïŋ― arasïŋ― boïŋ―luk */
            box-shadow: 0 4px 10px rgba(0,0,0,0.05); /* Hafif gïŋ―lge */
            transition: all 0.3s;
            border: 1px solid #e2e8f0;
        }

            /* Buton Hover Efekti */
            .btn-back-modern:hover {
                background: var(--navy); /* Zemin rengi deïŋ―iïŋ―imi */
                color: white; /* Yazïŋ― rengi deïŋ―iïŋ―imi */
                transform: translateX(-5px); /* Hafif sola kayma */
            }

        /* Aylïŋ―k Liste Kartïŋ― Tasarïŋ―mïŋ― (Glassmorphism) */
        .monthly-row-card {
            background: rgba(255, 255, 255, 0.9); /* Yarïŋ― saydam beyaz */
            backdrop-filter: blur(10px); /* Arka planïŋ― bulanïŋ―klaïŋ―tïŋ―r */
            border-radius: 20px; /* Yuvarlak kïŋ―ïŋ―eler */
            display: flex; /* ïŋ―ïŋ―erikleri yan yana diz */
            overflow: hidden; /* Taïŋ―mayïŋ― engelle */
            border: 1px solid rgba(255,255,255,0.6);
            min-height: 120px;
        }

        /* Sol Taraf: Tarih Kutusu */
        .row-date-side {
            background: var(--navy); /* Koyu arka plan */
            color: white;
            padding: 20px;
            min-width: 130px; /* Sabit geniïŋ―lik */
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        /* Gïŋ―n Numarasïŋ― (Bïŋ―yïŋ―k Font) */
        .day-number {
            font-size: 2.2rem;
            font-weight: 900;
            line-height: 1;
        }

        /* Ay ïŋ―smi */
        .month-name {
            font-size: 0.8rem;
            font-weight: 700;
            opacity: 0.7; /* Hafif saydamlïŋ―k */
        }

        /* Yemek ïŋ―ïŋ―erik Alanïŋ― (Orta Kïŋ―sïŋ―m) */
        .row-content-side {
            flex-grow: 1; /* Kalan boïŋ―luïŋ―u doldur */
            padding: 20px 30px;
            display: grid;
            grid-template-columns: repeat(3, 1fr); /* 3 eïŋ―it kolona bïŋ―l */
            align-items: center;
            gap: 15px; /* Kolonlar arasïŋ― boïŋ―luk */
        }

        /* Yemek Grubu Baïŋ―lïŋ―ïŋ―ïŋ― (Kahvaltïŋ―, ïŋ―ïŋ―le...) */
        .meal-group label {
            display: block;
            font-size: 0.7rem;
            font-weight: 800;
            color: #94a3b8;
            margin-bottom: 4px;
        }

        /* Yemek ïŋ―ïŋ―eriïŋ―i Metni */
        .meal-group p {
            font-size: 0.95rem;
            font-weight: 700;
            color: var(--navy);
            margin: 0;
        }

        /* Saïŋ― Taraf: Bilgi Kutusu */
        .row-info-side {
            padding: 20px;
            display: flex;
            align-items: center;
            border-left: 1px solid #f1f5f9; /* Sol kenar ïŋ―izgisi */
        }

        /* Kalori Hapïŋ― (Pill Badge) */
        .kcal-pill {
            background: #f1f5f9;
            color: #64748b;
            padding: 6px 12px;
            border-radius: 50px;
            font-weight: 800;
            font-size: 0.8rem;
        }

        /* Arka Plan Gïŋ―rsel Efektleri (Blob'lar) */
        .bg-visuals .blob {
            position: fixed; /* Sayfa kaydïŋ―ïŋ―ïŋ―nda sabit kalïŋ―r */
            width: 500px;
            height: 500px;
            filter: blur(100px); /* Bulanïŋ―klïŋ―k efekti */
            z-index: 1; /* ïŋ―ïŋ―eriïŋ―in arkasïŋ―nda */
        }

        /* Birinci Blob Konumu */
        .blob-1 {
            top: -100px;
            right: -50px;
            background: rgba(37, 99, 235, 0.08);
        }

        /* ïŋ―kinci Blob Konumu */
        .blob-2 {
            bottom: -100px;
            left: -50px;
            background: rgba(15, 23, 42, 0.04);
        }

        /* MOBïŋ―L UYUMLULUK (Responsive Ayarlar) */
        /* Ekran geniïŋ―liïŋ―i 991px (Tablet/Mobil) altïŋ―ndaysa devreye girer */
        @@media (max-width: 991px) {
            /* Yemek iïŋ―eriklerini tek sïŋ―tuna dïŋ―ïŋ―ïŋ―r */
            .row-content-side {
                grid-template-columns: 1fr;
                padding: 20px;
            }
            /* Kartïŋ― dikey yerleïŋ―ime ïŋ―evir */
            .monthly-row-card {
                flex-direction: column;
            }
            /* Tarih kutusunu yatay yap ve geniïŋ―let */
            .row-date-side {
                flex-direction: row;
                min-width: 100%;
                gap: 15px;
                padding: 10px;
            }
            /* Gïŋ―n numarasïŋ―nïŋ― kïŋ―ïŋ―ïŋ―lt */
            .day-number {
                font-size: 1.5rem;
            }
            /* Bilgi kutusunun kenarlïŋ―ïŋ―ïŋ―nïŋ― deïŋ―iïŋ―tir ve ortala */
            .row-info-side {
                border-left: none;
                border-top: 1px solid #f1f5f9;
                justify-content: center;
            }
        }
    </style>
}